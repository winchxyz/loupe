      "$value": "#ffd363",
      "$type": "color",
      "$description": "Prism Yellow — Accent stroke and warning/state highlight"
    },
    "prism-green": {
      "$value": "#5ab040",
      "$type": "color",
      "$description": "Prism Green — Accent stroke and success state highlight"
    },
    "cream-wash": {
