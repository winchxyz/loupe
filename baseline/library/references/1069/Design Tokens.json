{
  "color": {
    "midnight-ink": {
      "$value": "#090a1e",
      "$type": "color",
      "$description": "Midnight Ink — Primary text, primary CTA fill, strong borders — the dominant brand dark; a slightly blue-tinted near-black that reads warmer than pure black on white"
    },
    "paper-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper White — Page canvas, card surfaces, button text on dark fills"
    },
    "ash-border": {
      "$value": "#e0e0e0",
      "$type": "color",
      "$description": "Ash Border — Default hairline borders, button outlines, icon strokes"
    },
    "carbon-nav": {
      "$value": "#222222",
      "$type": "color",
      "$description": "Carbon Nav — Navigation text and thin nav borders — sits one step lighter than Midnight Ink"
    },
    "mist-blue": {
      "$value": "#c3dae3",
      "$type": "color",
      "$description": "Mist Blue — Cool-tinted card borders and subtle section dividers"
    },
    "pure-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Pure Black — SVG fills, icon glyphs, and high-contrast decorative shapes only — not used for UI text or backgrounds"
    },
    "prism-blue": {
      "$value": "#2969ff",
      "$type": "color",
      "$description": "Prism Blue — Brand accent and logo mark — the cool anchor of the rainbow; also acts as info/state accent on badges and borders; Signature iridescent gradient — the through-line of the brand, sweeping pink → blue → yellow → green like light through a prism"
    },
    "prism-pink": {
      "$value": "#f75cc3",
      "$type": "color",
      "$description": "Prism Pink — Accent stroke and badge accent — warm half of the prism spectrum"
    },
