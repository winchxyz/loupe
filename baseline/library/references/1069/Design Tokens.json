  "font": {
    "noto-serif": {
      "$value": "Noto Serif",
      "$type": "fontFamily",
      "$description": "All editorial headlines and section titles — the serif against a sans UI gives the brand an editorial, almost magazine-like voice. Used at 77px for hero display, scaling down through 63/49/42/35/26px for h1→h5."
    },
    "manrope": {
      "$value": "Manrope",
      "$type": "fontFamily",
      "$description": "Body copy, UI controls, navigation, button labels, badges, and large numeric display. 18–19px for body, 14–16px for compact UI, 11px with +0.06em tracking for eyebrow labels like 'TRUSTED BY' and section kickers. The geometric construction balances the serif headlines."
    }
  },
