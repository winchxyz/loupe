{
  "color": {
    "paper-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper White — Page canvas, card surfaces, body text inversion, button labels. The dominant background; everything else sits on top of it"
    },
    "ink-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Ink Black — Primary text, icon strokes, hairline borders, the logo wordmark. Used for most dividers and structural lines (border frequency 1,156)"
    },
    "charcoal": {
      "$value": "#2c2222",
      "$type": "color",
      "$description": "Charcoal — Secondary text and the heaviest border color in the system (freq 3,104). A warm-toned near-black that softens harsh contrast on long reads"
    },
    "fossil": {
      "$value": "#b2b4b1",
      "$type": "color",
      "$description": "Fossil — Muted link color, inactive nav items, tertiary text. Desaturated green-gray that recedes against both paper white and ink black"
    },
    "slate-iris": {
      "$value": "#495472",
      "$type": "color",
      "$description": "Slate Iris — Filled button background and select card surfaces — the only chromatic voice in the system. A muted violet-slate that reads as architectural blue-grey rather than brand color, so it never shouts over the photography"
    }
  },
  "font": {
    "helveticaneue": {
      "$value": "HelveticaNeue",
      "$type": "fontFamily",
      "$description": "The sole typeface. Used for everything from the lowercase 'spacelab_' logo to 62px display headlines, 19–21px section headings, 17px body, and 15px captions."
    },
    "helveticaneue-light": {
      "$value": "HelveticaNeue-Light",
      "$type": "fontFamily",
      "$description": "Body copy and supporting paragraphs where a quieter voice is needed. The light cut creates typographic variety without changing families — a single-typeface system that breathes through weight, not variety."
    }
  },
