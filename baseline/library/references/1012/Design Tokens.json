{
  "color": {
    "void-plum": {
      "$value": "#0f0217",
      "$type": "color",
      "$description": "Void Plum — Page canvas and primary dark surface — the near-black violet base that absorbs the whole immersive hero and footer bands"
    },
    "eclipse-black": {
      "$value": "#0b0211",
      "$type": "color",
      "$description": "Eclipse Black — Elevated card and panel surface — one shade deeper than the canvas, used for floating UI elements against the dark backdrop"
    },
    "carbon-ink": {
      "$value": "#111111",
      "$type": "color",
      "$description": "Carbon Ink — Badge fills, icon stroke accents, and dark section surfaces on lighter contexts"
    },
    "lavender-mist": {
      "$value": "#44374a",
