{
  "color": {
    "void-black": {
      "$value": "#0c0c0b",
      "$type": "color",
      "$description": "Void Black — Page canvas, input fills, icon backgrounds — the base layer everything floats on"
    },
    "graphite": {
      "$value": "#1f2228",
      "$type": "color",
      "$description": "Graphite — Hairline borders across all containers, cards, nav separators, and input outlines — defines structural edges without contrast"
    },
    "charcoal": {
      "$value": "#141619",
      "$type": "color",
      "$description": "Charcoal — Secondary border tone for deeper structural edges"
    },
    "smoke": {
      "$value": "#474747",
      "$type": "color",
      "$description": "Smoke — Dark borders and separators for elevated surfaces and inverted UI. Do not promote it to the primary CTA color"
    },
    "ash": {
      "$value": "#7d8187",
      "$type": "color",
      "$description": "Ash — Muted helper text, badge labels, secondary nav links — the voice that whispers rather than speaks"
    },
    "bone": {
      "$value": "#71717a",
      "$type": "color",
      "$description": "Bone — Input focus ring shadow at 0px 0px 0px 2px — the only ambient glow in the system"
    },
    "stellar-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Stellar White — Primary text, icon strokes, ghost-pill borders, and the hero wordmark — everything that should feel like emitted light"
    },
    "signal-blue": {
      "$value": "#2563eb",
      "$type": "color",
      "$description": "Signal Blue — Input focus border — the single chromatic accent, used exclusively to signal active state in text fields"
    },
    "horizon-amber": {
      "$value": "#ff6308",
      "$type": "color",
      "$description": "Horizon Amber — Footer atmospheric wash — warm light bleeding from the bottom edge, transitioning through to cool blue at the horizon line"
    }
  },
  "font": {
    "universalsans": {
      "$value": "universalSans",
