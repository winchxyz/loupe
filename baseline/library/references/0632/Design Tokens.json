{
  "color": {
    "signal-blue": {
      "$value": "#3ba6f1",
      "$type": "color",
      "$description": "Signal Blue — Blue action color for filled buttons, selected navigation states, and focused conversion moments."
    },
    "highlight-wash": {
      "$value": "#c1e1f7",
      "$type": "color",
      "$description": "Highlight Wash — Gray wash for highlight backgrounds, decorative bands, and soft emphasis behind content. Do not promote it to the primary CTA color"
    },
    "canvas-cream": {
      "$value": "#fafaf9",
      "$type": "color",
      "$description": "Canvas Cream — Page background, body of the document — warm off-white stone-50 that keeps the system from feeling clinical"
    },
    "pure-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Pure White — Card surfaces, elevated panels, button text on dark, dashboard preview background"
    },
    "stone-ink": {
      "$value": "#0c0a09",
      "$type": "color",
      "$description": "Stone Ink — Primary headings and body text — near-black with a warm undertone, never pure #000"
    },
    "stone-charcoal": {
      "$value": "#1c1917",
      "$type": "color",
      "$description": "Stone Charcoal — Secondary button fill, dark accent surfaces — one step warmer/lighter than Stone Ink for dark UI moments"
    },
    "warm-slate": {
      "$value": "#78716c",
      "$type": "color",
      "$description": "Warm Slate — Secondary body text, helper text, subtle labels — the working gray of the system"
    },
    "soft-slate": {
      "$value": "#a8a29e",
      "$type": "color",
      "$description": "Soft Slate — Tertiary text, muted captions, low-emphasis labels"
    },
    "mist-gray": {
      "$value": "#afafae",
      "$type": "color",
      "$description": "Mist Gray — Decorative icon fills, placeholder strokes, low-emphasis graphic elements"
    },
    "pearl-border": {
      "$value": "#e5e7eb",
      "$type": "color",
      "$description": "Pearl Border — Primary 1px hairlines — card borders, dividers, input borders, button outlines; the dominant border color by frequency"
    },
    "warm-border": {
      "$value": "#d6d3d1",
      "$type": "color",
      "$description": "Warm Border — Secondary borders — input fields, section dividers, subtly warmer hairlines for contained UI"
    },
    "fog-border": {
      "$value": "#e1dfdd",
      "$type": "color",
      "$description": "Fog Border — Navigation borders, subtle dividers between header items — the lightest structural line"
    },
    "heading-mute": {
      "$value": "#c9c5c2",
      "$type": "color",
      "$description": "Heading Mute — Placeholder headlines, disabled heading text — the only gray that can substitute for Stone Ink at display sizes"
    }
  },
  "font": {
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "Body text, UI controls, navigation, buttons, form labels, footer — the workhorse family; weight 400 for paragraphs, 500 for buttons and emphasized labels, 600 for strong inline emphasis"
    },
    "roobert": {
      "$value": "Roobert",
      "$type": "fontFamily",
      "$description": "Display and large headings — the 52px hero, 32px subheadings, and 20px lead paragraphs; tighter tracking at size creates compact confident statements"
    }
  },
