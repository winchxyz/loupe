  "font": {
    "satoshi": {
      "$value": "Satoshi",
      "$type": "fontFamily",
      "$description": "Display headings — hero, section titles. Medium weight only (no bold), tight line-height, and a geometric construction give headlines a calm, technical confidence rather than SaaS shout. Substitute with 'Inter' at 600 or 'General Sans'."
    },
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "Body, UI, navigation, subheadings, buttons — the workhorse. Compact 1.4-1.5 line-heights create density without crowding. 600 is reserved for button labels and small-caps-feel emphasis; 500 carries nav and labels; 400 is the body default."
    },
    "geistmono": {
      "$value": "GeistMono",
      "$type": "fontFamily",
      "$description": "Monospace UI — URL slugs, API keys, tag chips, code-like inline data. Tightly confined to functional text where variable-width would break alignment."
    }
  },
