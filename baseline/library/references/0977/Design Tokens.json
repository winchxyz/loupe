{
  "color": {
    "aurora-magenta": {
      "$value": "#995bb9",
      "$type": "color",
      "$description": "Aurora Magenta — Headline gradient start, icon fills, decorative brand strokes — the single chromatic voice of the system, used as gradient text on display headings and as fill on small icon badges"
    },
    "deep-iris": {
      "$value": "#5b638c",
      "$type": "color",
      "$description": "Deep Iris — Muted violet used for decorative SVG strokes and secondary graphic outlines — sits behind the magenta as the system-wide line color"
    },
    "midnight-ink": {
      "$value": "#1d2630",
      "$type": "color",
      "$description": "Midnight Ink — Primary body and heading text on light surfaces — slightly warmer than pure black, reads softer at large sizes while keeping AAA contrast"
    },
    "obsidian": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Obsidian — Highest-weight text and the densest border color — used where maximum contrast is required against the near-white canvas"
    },
    "lavender-mist": {
      "$value": "#e0dde2",
      "$type": "color",
      "$description": "Lavender Mist — Page canvas and subtle surface tint — the entire site reads on this near-white, giving the aurora gradient something warm to land on"
    },
    "paper-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper White — Card and elevated surface fill — floats above Lavender Mist as the base for product cards, phone screen, and feature panels"
    },
    "frost-shadow": {
      "$value": "#f0f0f0",
      "$type": "color",
      "$description": "Frost Shadow — Shadow tone used in the multi-layer card elevation — too light to be a border, present only as the ambient outer blur"
    },
    "pebble": {
      "$value": "#9aa1b2",
      "$type": "color",
      "$description": "Pebble — Mid-neutral for muted body text and link borders — the default text color for descriptions and the border for inline link affordances"
    },
    "silver-lining": {
      "$value": "#a5afcb",
      "$type": "color",
      "$description": "Silver Lining — Light hairline border and secondary muted text — used on card edges and quiet metadata rows"
    },
    "cloud-veil": {
      "$value": "#abbdcf",
      "$type": "color",
      "$description": "Cloud Veil — Softest neutral for decorative SVG fills and ambient accents — supports the aurora without competing with the magenta"
    },
    "tidewater-navy": {
      "$value": "#3a4766",
      "$type": "color",
      "$description": "Tidewater Navy — Violet accent for outlined action borders, linked labels, and lightweight interactive emphasis. Do not promote it to the primary CTA color"
    },
    "aurora-green": {
      "$value": "#69c966",
      "$type": "color",
      "$description": "Aurora Green — Gradient stop in the page-level aurora and accent on positive chart lines inside the phone mockup"
    }
  },
