{
  "color": {
    "void": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Void — Page canvas, primary surface — the only background; every other color reads as light emitted from this base"
    },
    "pure-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Pure White — All text, dividers, list markers, and outline borders — 21:1 contrast against Void means type is the loudest element on the page by far"
    },
    "dark-graphite": {
      "$value": "#333333",
      "$type": "color",
      "$description": "Dark Graphite — Hairline borders, secondary dividers, and structural rules — sits just above the void to define edges without lifting weight"
    },
    "mid-gray": {
      "$value": "#666666",
      "$type": "color",
      "$description": "Mid Gray — Muted helper text and inactive label borders — 3.7:1 against black intentionally fails contrast, signaling de-emphasis rather than legibility"
    },
    "signal-green": {
      "$value": "#1eff66",
      "$type": "color",
      "$description": "Signal Green — Green wash for highlight backgrounds, decorative bands, and soft emphasis behind content"
    }
  },
  "font": {
    "helvetica-now": {
      "$value": "Helvetica Now",
      "$type": "fontFamily",
      "$description": "Primary UI and display face — geometric grotesque set tight (0.93 on the 56px display creates an almost single-line block of text)"
    },
    "ballinger-mono": {
      "$value": "ballinger-mono",
      "$type": "fontFamily",
      "$description": "Micro-copy, taglines, and trademark marks (the ® in 'PHANTOM STUDIOS® TECHNOLOGY CREATIVE'); 11px monospaced at 1.10 is intentionally difficult — it reads as metadata, not prose"
    }
  },
