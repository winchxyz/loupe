{
  "color": {
    "soft-pebble": {
      "$value": "#e5e7eb",
      "$type": "color",
      "$description": "Soft Pebble — Page canvas, card surfaces, and the dominant background tone — a warm-leaning gray that reads as handmade paper rather than digital white"
    },
    "carbon-ink": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Carbon Ink — Primary text, nav labels, icons, and the default state of unselected interactive controls. Carries all typographic and chrome weight in the system"
    },
    "ash": {
      "$value": "#bbbab7",
      "$type": "color",
      "$description": "Ash — Hairline borders and dividers on buttons and structural elements — just visible enough to define edges without ever competing with text"
    },
    "stone": {
      "$value": "#8d8c8a",
      "$type": "color",
      "$description": "Stone — Muted helper text — product prices, secondary metadata, and any label that should recede behind the primary content"
    },
    "sunlit-marigold": {
      "$value": "#ecca53",
      "$type": "color",
      "$description": "Sunlit Marigold — The sole chromatic accent — active filter pills, selected nav states, and the only place a UI element may be filled with color. The warmth against Soft Pebble creates an almost-handmade yellow, not a digital primary"
    }
  },
  "font": {
