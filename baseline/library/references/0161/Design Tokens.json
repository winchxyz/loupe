{
  "color": {
    "coral-flame": {
      "$value": "#f73b20",
      "$type": "color",
      "$description": "Coral Flame — Outlined action borders, hero headlines, active links, key icon strokes — the dominant brand mark; its intensity against pure white creates urgency without aggression; Full-bleed hero background gradient — a warm wash from pink through coral to peach, the visual identity of the brand's first impression"
    },
    "brandwood": {
      "$value": "#360802",
      "$type": "color",
      "$description": "Brandwood — Deep accent for bold display type, input borders, high-contrast text — a near-black with warm brown undertone that pairs naturally with the coral"
    },
    "sunset-fade": {
      "$value": "#fef5f3",
      "$type": "color",
      "$description": "Sunset Fade — Warm tinted surface for subtle layering above the white canvas — barely warmer than the page"
    },
    "blush-mist": {
      "$value": "#fbdfd9",
      "$type": "color",
      "$description": "Blush Mist — Secondary warm tint surface, used behind the hero gradient base and soft section washes"
    },
    "pure-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Pure White — Hairline borders, dividers, input outlines, and card edges on light surfaces. Do not promote it to the primary CTA color"
    },
    "carbon": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Carbon — Icon strokes and minimal accent borders where absolute contrast is required"
    },
    "mint-action": {
      "$value": "#34c771",
      "$type": "color",
