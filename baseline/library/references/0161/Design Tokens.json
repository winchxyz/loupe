  "font": {
    "sequel-sans": {
      "$value": "Sequel Sans",
      "$type": "fontFamily",
      "$description": "Sole typeface across the system — display, body, nav, buttons. Sequel Sans is a geometric humanist sans with wide apertures and generous x-height, giving it warmth uncommon in geometric faces. Weight 450 (a medium-light step between regular and medium) appears to be the workhorse, used for both display and body — a non-conventional choice that keeps the page from feeling heavy."
    }
  },
