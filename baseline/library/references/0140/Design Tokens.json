    },
    "circular-bold": {
      "$value": "Circular Bold",
      "$type": "fontFamily",
      "$description": "Display and hero headlines — Circular Bold at 96px with -0.042em letter-spacing carries the 'Fund your creative work' headline; the extreme size and tight tracking make the wordmark feel monumental. Also used for button labels and emphasized short-form copy."
    },
    "circular-medium": {
      "$value": "Circular Medium",
      "$type": "fontFamily",
