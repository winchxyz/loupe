{
  "color": {
    "cream-paper": {
      "$value": "#faf8f0",
      "$type": "color",
      "$description": "Cream Paper — Page canvas, section backgrounds — the warm off-white ground that softens every interface layer and gives the whole product its café-on-paper atmosphere"
    },
    "card-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Card White — Card surfaces, modal backgrounds, raised panels — pure white floats above the cream canvas to create depth through luminance contrast rather than color"
    },
    "hairline-gray": {
      "$value": "#e5e7eb",
      "$type": "color",
      "$description": "Hairline Gray — Borders, dividers, icon outlines, badge outlines — used at 1146+ occurrences as the universal hairline separator across cards, buttons, and inputs"
    },
    "ink-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Ink Black — Primary text, filled icon strokes, high-contrast UI elements — the dominant text and icon color across the entire product"
    },
    "charcoal": {
      "$value": "#222222",
      "$type": "color",
      "$description": "Charcoal — Body and heading text, filled SVG strokes — slightly softer than pure black for sustained reading in longer copy blocks"
    },
    "fog-gray": {
      "$value": "#717171",
      "$type": "color",
      "$description": "Fog Gray — Muted helper text, secondary metadata, small caps labels — the quietest text voice for timestamps, supporter counts, and contextual hints"
    },
    "marigold": {
      "$value": "#ffdd00",
      "$type": "color",
      "$description": "Marigold — Yellow wash for highlight backgrounds, decorative bands, and soft emphasis behind content. Do not promote it to the primary CTA color"
    },
    "buttercup": {
      "$value": "#f7d046",
      "$type": "color",
      "$description": "Buttercup — Yellow wash for highlight backgrounds, decorative bands, and soft emphasis behind content. Do not promote it to the primary CTA color"
    },
    "terracotta": {
      "$value": "#d8573f",
      "$type": "color",
      "$description": "Terracotta — Orange outline accent for tags, dividers, and focused UI edges. Do not promote it to the primary CTA color"
    },
    "blush-border": {
      "$value": "#f5d5cf",
      "$type": "color",
      "$description": "Blush Border — Soft warm border accent for notification cards and supporter activity popovers — bridges Terracotta's intensity into a gentle outline"
    }
  },
  "font": {
    "ui-sans-serif": {
