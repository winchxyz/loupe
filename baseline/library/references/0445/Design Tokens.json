    },
    "pure-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Pure White — Card surfaces, button text, elevated panels — the layer above the warm canvas"
    },
    "mint-wash": {
      "$value": "#eaf7f0",
