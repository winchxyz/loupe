{
  "color": {
    "ink-black": {
      "$value": "#1a1a19",
      "$type": "color",
      "$description": "Ink Black — Primary text, pill CTA background, logo mark, icon strokes — near-black rather than pure black gives a softer, warmer feel than #000000"
    },
    "pure-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Pure Black — Occasional hard-black fills for high-contrast accents and announcement bar"
    },
    "charcoal": {
      "$value": "#333331",
      "$type": "color",
      "$description": "Charcoal — Body text, link color, secondary headings — warmer than Ink Black, used when pure black feels too heavy"
    },
    "slate-gray": {
      "$value": "#808080",
      "$type": "color",
      "$description": "Slate Gray — Muted helper text, placeholder content, disabled states"
    },
    "hairline": {
      "$value": "#e5e7eb",
      "$type": "color",
      "$description": "Hairline — Default border for cards, inputs, icons, nav separators, and table dividers — the most-used color in the entire system"
    },
    "cloud": {
      "$value": "#f0f0f0",
      "$type": "color",
      "$description": "Cloud — Secondary card borders, subtle structural outlines"
    },
    "warm-canvas": {
