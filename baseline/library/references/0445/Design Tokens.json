    "bean-orange": {
      "$value": "#ff5310",
      "$type": "color",
      "$description": "Bean Orange — Decorative squiggle strokes, inline icon accent, brand heartbeat — warm vivid orange that defines the playful personality"
    },
    "bean-green": {
      "$value": "#44c67f",
