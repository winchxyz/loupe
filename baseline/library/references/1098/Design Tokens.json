{
  "color": {
    "cream-paper": {
      "$value": "#fafaf8",
      "$type": "color",
      "$description": "Cream Paper — Page canvas and primary surface — warm off-white that softens the otherwise stark black/orange system"
    },
    "card-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Card White — Elevated card surfaces and input backgrounds — sits one step above the cream canvas"
    },
    "pebble-gray": {
      "$value": "#f0f0ef",
      "$type": "color",
      "$description": "Pebble Gray — Secondary surface for section bands, subtle backgrounds behind grouped content"
    },
    "linen-border": {
      "$value": "#e4e5e1",
      "$type": "color",
      "$description": "Linen Border — Hairline dividers, card borders, and table separators — the dominant structural line color"
    },
    "ash": {
      "$value": "#d9d9d9",
      "$type": "color",
      "$description": "Ash — Disabled controls, placeholder shapes, and de-emphasized borders"
    },
    "ink": {
      "$value": "#141415",
      "$type": "color",
      "$description": "Ink — Primary headings, body text, and the near-black terminal panel background"
    },
    "graphite": {
      "$value": "#2e2e2c",
      "$type": "color",
      "$description": "Graphite — Dark elevated surfaces for code blocks and terminal mockups"
    },
    "carbon": {
      "$value": "#454542",
      "$type": "color",
      "$description": "Carbon — Secondary text, button text on light backgrounds, icon strokes"
    },
    "slate": {
      "$value": "#6e6f6c",
      "$type": "color",
      "$description": "Slate — Muted helper text and meta-information"
    },
    "stone": {
      "$value": "#8c8c89",
      "$type": "color",
      "$description": "Stone — Tertiary captions, timestamps, inactive nav items"
    },
    "fog": {
      "$value": "#b7b7b4",
      "$type": "color",
      "$description": "Fog — Light placeholder text, icon tints on muted backgrounds"
    },
    "signal-orange": {
      "$value": "#f35b22",
      "$type": "color",
      "$description": "Signal Orange — Orange supporting accent for decorative details and low-frequency emphasis. Do not promote it to the primary CTA color"
    },
    "ember": {
      "$value": "#ff5e24",
      "$type": "color",
      "$description": "Ember — Hover state for Signal Orange, secondary highlight orange for icons and micro-emphasis"
    },
    "apricot": {
      "$value": "#f77c55",
      "$type": "color",
      "$description": "Apricot — Lighter orange for inline links, secondary text accents, and warm icon strokes"
    },
    "burnt-orange": {
      "$value": "#be400f",
      "$type": "color",
      "$description": "Burnt Orange — Deep orange for borders on featured elements, hover borders, and dark-mode accent strokes"
    },
    "persimmon": {
      "$value": "#d14200",
      "$type": "color",
      "$description": "Persimmon — Darkest orange for high-contrast text accents on light surfaces and breadcrumb separators"
    },
    "peach-blush": {
      "$value": "#ffcab5",
      "$type": "color",
      "$description": "Peach Blush — Pale orange wash for decorative borders and soft highlight backgrounds"
    },
    "teal-token": {
      "$value": "#88d2c3",
      "$type": "color",
      "$description": "Teal Token — IDE syntax-highlight color for strings and identifiers in code blocks — repeated at scale gives the page its terminal texture"
    },
    "sky-token": {
      "$value": "#8bc5f3",
      "$type": "color",
      "$description": "Sky Token — IDE syntax-highlight for keys, booleans, and object properties in code blocks"
    },
    "orchid-token": {
      "$value": "#c678dd",
      "$type": "color",
      "$description": "Orchid Token — IDE syntax-highlight for keywords and function names in code blocks"
    },
    "forest": {
      "$value": "#165424",
      "$type": "color",
      "$description": "Forest — Green supporting accent for decorative details and low-frequency emphasis. Use as a supporting accent, not as a status color"
    },
    "success-green": {
      "$value": "#62b06d",
      "$type": "color",
      "$description": "Success Green — Green supporting accent for decorative details and low-frequency emphasis. Use as a supporting accent, not as a status color"
    },
    "coral-alert": {
      "$value": "#f67976",
      "$type": "color",
      "$description": "Coral Alert — Red supporting accent for decorative details and low-frequency emphasis. Use as a supporting accent, not as a status color"
    },
    "rose-blush": {
      "$value": "#f9aea9",
      "$type": "color",
      "$description": "Rose Blush — Red supporting accent for decorative details and low-frequency emphasis. Use as a supporting accent, not as a status color"
    }
  },
  "font": {
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "Primary UI and editorial typeface — handles all headings, body text, buttons, and navigation. Weight 600 is the default for headlines, weight 400 for body, weight 500 for labels. Calt and liga features are disabled, giving the type a more uniform, 'engineered' feel rather than the swashy alternates Inter ships with."
    },
    "jetbrains-mono": {
      "$value": "JetBrains Mono",
      "$type": "fontFamily",
      "$description": "Developer-language typeface — owns the eyebrow labels ('I'M A DEVELOPER'), code blocks, terminal output, API URLs, and visitor IDs. Acts as a visual signature: whenever the page shifts from prose to technical content, JetBrains Mono takes over. Weight 470 is the distinctive 'regular' weight that sits between 400 and 500."
    }
  },
