      "$value": "#f8d4d4",
      "$type": "color",
      "$description": "Blush Field — Hero section background, full-bleed section dividers, decorative border washes — the warm pastel that sets the emotional temperature for the whole site"
    },
    "vermilion-mark": {
      "$value": "#eb4726",
      "$type": "color",
      "$description": "Vermilion Mark — Sole chromatic accent — brand wordmark, link underlines, arrow icons, scroll indicator. One warm note against all the near-monochrome"
    },
    "mint-accent": {
      "$value": "#d2fdd1",
      "$type": "color",
      "$description": "Mint Accent — Rare card or section background — the only cool note permitted, used sparingly for tonal variety"
    },
    "charcoal-ink": {
      "$value": "#282828",
      "$type": "color",
      "$description": "Charcoal Ink — Primary body text, heading text, default borders, icon strokes — the workhorse warm-black neutral"
    },
    "pure-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Pure White — Card surfaces, content section backgrounds, floating pill nav fill"
    },
    "jet-black": {
