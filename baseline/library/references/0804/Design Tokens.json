{
  "color": {
    "void-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Void Black — Page canvas, hero backgrounds, section bands, image mattes — the absolute black that swallows the viewport and lets the product photography and peach accent feel lit"
    },
    "graphite": {
      "$value": "#191919",
      "$type": "color",
      "$description": "Graphite — Supporting neutral for secondary UI, dividers, and muted labels."
    },
    "charcoal": {
      "$value": "#3d3d3d",
      "$type": "color",
      "$description": "Charcoal — Secondary surface tone for button hover states, tertiary card layers, and the borders that separate a card from canvas"
    },
    "warm-smoke": {
      "$value": "#61635d",
      "$type": "color",
      "$description": "Warm Smoke — Desaturated warm-gray for divider lines, muted metadata, and the border tone that gives the dark UI a slight olive cast rather than going cold blue"
    },
    "shadow": {
      "$value": "#292929",
      "$type": "color",
      "$description": "Shadow — Inset fills, shadow tones beneath floating elements, and the inner depth on product showcase cards"
    },
    "paper-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper White — Light supporting surface for subtle backgrounds and section separation. Do not promote it to the primary CTA color"
    },
    "fog": {
      "$value": "#cccccc",
      "$type": "color",
      "$description": "Fog — Secondary text, subheadings under large titles, and icon strokes that need to recede from primary content"
    },
    "ash": {
      "$value": "#9e9e9e",
      "$type": "color",
      "$description": "Ash — Tertiary helper text, caption metadata, and placeholder labels in inputs"
    },
    "steel-lilac": {
      "$value": "#797985",
      "$type": "color",
      "$description": "Steel Lilac — Muted body copy and the cool-tinted gray used for sub-labels and pricing context — the only neutra with a cool cast, used sparingly"
    },
    "ember-peach": {
      "$value": "#e3a081",
      "$type": "color",
      "$description": "Ember Peach — Orange supporting accent for decorative details and low-frequency emphasis."
    },
    "twilight-violet": {
      "$value": "#5351f3",
      "$type": "color",
      "$description": "Twilight Violet — Violet supporting accent for decorative details and low-frequency emphasis. Do not promote it to the primary CTA color"
    },
    "app-store-blue-gold": {
      "$value": "#c28e01",
      "$type": "color",
      "$description": "App Store — Blue Gold — Terminal stop of the blue-to-gold linear gradient on app-store and feature cards"
    },
    "app-store-violet-ember": {
      "$value": "#fe7900",
      "$type": "color",
      "$description": "App Store — Violet Ember — Terminal stop of the violet-to-orange linear gradient on rotating feature tiles"
    },
    "app-store-crimson": {
      "$value": "#ff3b3b",
      "$type": "color",
      "$description": "App Store — Crimson — Terminal stop of the deep-red feature tile gradient used on the OpenClaw card"
    },
    "deep-space": {
      "$value": "#051e22",
      "$type": "color",
      "$description": "Deep Space — Atmospheric radial gradient base for the closing app-store section — a near-black blue-violet that signals the transition into the app ecosystem"
    }
  },
  "font": {
    "sans-serif": {
      "$value": "sans-serif",
      "$type": "fontFamily",
      "$description": "sans-serif — detected in extracted data but not described by AI"
    },
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "The whole voice of the interface — headings, body, buttons, nav. Tight negative tracking at every size (-0.01em at 14px scaling to -0.03em at 48px) is a signature move that makes Inter feel custom-cut rather than system. The alt glyphs 'blwf', 'cv03', 'cv04', 'cv09', 'cv11' are explicitly set, choosing the single-storey 'a' and the curly 'l' that give the brand its distinct letterforms."
    },
    "inter-display": {
      "$value": "Inter Display",
      "$type": "fontFamily",
      "$description": "Hero product-name headings like 'Umbrel Pro' — a heavier cut at 43px with -0.02em tracking that lands the name as a logo-mark rather than a sentence. Use only for the largest product titles on dark backgrounds."
    },
    "inter-tight": {
      "$value": "Inter Tight",
      "$type": "fontFamily",
      "$description": "Tighter-metrics variant for compact nav links and small labels where Inter's default width feels too airy at 12px"
    },
    "system-sans": {
      "$value": "System Sans",
      "$type": "fontFamily",
      "$description": "Unstyled fallback stack for the dense body of legacy or dynamic content where loading the webfont is unnecessary — do not use for headings or branded surfaces"
    },
    "manrope": {
      "$value": "Manrope",
      "$type": "fontFamily",
      "$description": "Manrope — detected in extracted data but not described by AI"
    },
    "inter-regular": {
      "$value": "Inter Regular",
      "$type": "fontFamily",
      "$description": "Inter Regular — detected in extracted data but not described by AI"
    },
    "roboto-condensed": {
      "$value": "Roboto Condensed",
      "$type": "fontFamily",
      "$description": "Roboto Condensed — detected in extracted data but not described by AI"
    },
    "inter-variable": {
      "$value": "Inter Variable",
