      "$description": "Fog — Page background, section fills — the dominant surface of the entire site"
    },
    "snow": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Snow — Card surfaces, nav background, button fill for ghost variant"
    },
    "peach-whisper": {
      "$value": "#fad7c1",
      "$type": "color",
      "$description": "Peach Whisper — Decorative SVG fills, illustration accent highlights"
    },
    "dusty-rose": {
      "$value": "#c97b84",
      "$type": "color",
      "$description": "Dusty Rose — Semantic accent — appears in hover or highlight states on certain interactive elements"
    }
  },
  "font": {
    "pp-radio-grotesk-light": {
      "$value": "PP Radio Grotesk Light",
      "$type": "fontFamily",
      "$description": "All hero and section headings. Weight 400 in this geometric grotesque renders visually as 'light' — at 70px the type feels pencil-drawn rather than set, giving large-format headlines an editorial quality no system font can replicate. The signature typographic move of this site."
    },
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "Navigation labels, body copy, input fields, UI labels, subheadings. Weight 400 for body, 500 for nav links and emphasis. The negative letter-spacing is tighter than Inter's default, compressing the text block slightly without feeling cramped."
    },
    "inter-variable": {
      "$value": "Inter Variable",
      "$type": "fontFamily",
      "$description": "Tightly set inline body snippets, single-line descriptors. Line-height 1.00 means no leading — used for compact label-style text only."
    },
    "inter-display": {
      "$value": "Inter Display",
      "$type": "fontFamily",
      "$description": "Occasional heading contexts at small display sizes, card titles in feature sections."
    },
    "sans-serif-system-fallback": {
      "$value": "sans-serif (system fallback)",
      "$type": "fontFamily",
      "$description": "Icon labels, tooltip text, browser-level UI elements — not a designed choice."
    }
  },
