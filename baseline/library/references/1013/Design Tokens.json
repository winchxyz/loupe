{
  "color": {
    "tangerine-tag": {
      "$value": "#f69251",
      "$type": "color",
      "$description": "Tangerine Tag — Primary CTA buttons, 'Book a demo' pill — warm orange against near-white backgrounds signals action without urgency, echoing the palette of premium retail labels"
    },
    "midnight-ink": {
      "$value": "#181825",
      "$type": "color",
      "$description": "Midnight Ink — Body text, borders — near-black with a barely perceptible blue undertone, softer than pure black for long-form reading"
    },
    "graphite": {
      "$value": "#484758",
      "$type": "color",
      "$description": "Graphite — Secondary body text, descriptive copy, meta information"
    },
    "deep-slate": {
      "$value": "#242433",
      "$type": "color",
      "$description": "Deep Slate — Dark surface backgrounds, card overlays in dark sections"
    },
    "carbon": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Carbon — Headings, icon fills, primary text — used at full weight for maximum legibility"
    },
    "stone": {
      "$value": "#636363",
      "$type": "color",
      "$description": "Stone — Supporting body text, nav labels, secondary labels"
    },
    "pebble": {
      "$value": "#949494",
      "$type": "color",
      "$description": "Pebble — Placeholder text, muted links, disabled states"
    },
    "ash": {
      "$value": "#8b8b8b",
      "$type": "color",
      "$description": "Ash — Tertiary text, icon strokes, faint borders"
    },
    "fog": {
      "$value": "#f7f7f7",
