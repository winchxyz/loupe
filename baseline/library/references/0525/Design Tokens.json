  "font": {
    "helvetica-now-display-cn-bold": {
      "$value": "Helvetica Now Display Cn Bold",
      "$type": "fontFamily",
      "$description": "Display and headline voice — compressed, ultra-bold, negative tracking (-0.033em at 85–164px). Carries the page's identity: shouty statements like 164px section openers. Substitute with 'Helvetica Neue Condensed Bold' or 'Roboto Condensed 900'."
    },
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "Body, UI, navigation, and small headings. Weight 400 for body, 500 for emphasis, 700 for subheadings. Letter-spacing -0.02em tightens the UI text. Free Google Font."
    },
    "miss-fajardose": {
      "$value": "Miss Fajardose",
      "$type": "fontFamily",
      "$description": "Hand-lettered display accent — used sparingly (one observation) for a personal signature on a card. Substitute with 'Caveat Brush' or 'Permanent Marker' for the same marker-on-paper feel."
    },
    "system-sans-serif": {
      "$value": "System sans-serif",
      "$type": "fontFamily",
      "$description": "Fallback body fallback; appears in 357 instances as the default rendering surface for generic UI chrome and inline text nodes."
    }
  },
