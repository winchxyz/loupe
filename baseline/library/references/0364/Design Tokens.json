    "cool-stone": {
      "$value": "#b7b7b5",
      "$type": "color",
      "$description": "Cool Stone — Supporting neutral for secondary UI, dividers, and muted labels. Do not promote it to the primary CTA color"
    },
    "dust-blue": {
      "$value": "#ccdbe8",
      "$type": "color",
      "$description": "Dust Blue — Sole chromatic accent — link states, decorative highlights, subtle wash backgrounds, icon tints. The only color in an otherwise monochrome system"
    }
  },
  "font": {
    "anthropic-serif": {
      "$value": "Anthropic Serif",
      "$type": "fontFamily",
      "$description": "Editorial display and heading type. Used for hero headlines (56px weight 330), section headings (30px), plan tier names, and price figures. The low weight 330 for large display sizes is anti-convention — most tech brands use 700+ for hero text, but this whisper-weight serif creates authority through literary restraint rather than visual volume. Liga features enabled for refined ligatures."
    },
    "anthropic-sans": {
      "$value": "Anthropic Sans",
      "$type": "fontFamily",
      "$description": "Interface and body type. Weight 430 (between regular and medium) is the workhorse for body text and buttons — 400 for body, 430 for buttons and emphasis, 500 for subheadings, 600 for strong UI labels. Size 24px sans serves as a mid-scale heading or prominent label. The 430 weight is distinctive — it provides more presence than 400 without jumping to the heaviness of 500, giving the UI a slightly warmer, less clinical feel than standard system fonts."
    }
  },
