  "font": {
    "onest-variable": {
      "$value": "Onest Variable",
      "$type": "fontFamily",
      "$description": "All interface text — display headlines at weight 300 create a technical-confident tone; body at 16–18px weight 400; labels and micro UI at 11–13px weight 500. Weight 300 headlines are a signature anti-convention choice that makes the system feel like an instrument panel rather than a marketing page"
    },
    "monospace-system": {
      "$value": "monospace (system)",
      "$type": "fontFamily",
      "$description": "Telemetry values, code snippets, configuration keys, metric labels in the product UI. Used at 10–12px weight 500 for data density; 0.057em tracking gives a technical, terminal-like read"
    }
  },
