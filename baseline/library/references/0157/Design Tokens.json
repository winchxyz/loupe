{
  "color": {
    "harvest-flame": {
      "$value": "#fa5d00",
      "$type": "color",
      "$description": "Harvest Flame — Primary CTA fill, active nav indicator, brand link color, heading underlines — warm vermilion that reads as energetic but not aggressive, the single chromatic decision in an otherwise achromatic system"
    },
    "marigold-glow": {
      "$value": "#fee3b5",
      "$type": "color",
      "$description": "Marigold Glow — Soft warm highlight wash on cards, decorative glow tint behind product UI — never functional, only atmospheric"
    },
    "parchment-shadow": {
      "$value": "#e3d6c5",
      "$type": "color",
      "$description": "Parchment Shadow — Warm-tinted card shadow color, subtle image shadow — the shadow hue is not neutral gray but matches the cream base"
    },
    "ink-black": {
      "$value": "#1d1e1c",
      "$type": "color",
      "$description": "Ink Black — Primary text, icon strokes, nav borders, card headings — warm near-black rather than pure #000, preserves the system warmth"
    },
    "paper-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper White — Card surfaces, input fields, elevated panels, button text on orange fill"
    },
    "cream-canvas": {
      "$value": "#fff8f1",
      "$type": "color",
      "$description": "Cream Canvas — Page background, hero section base, nav backdrop — the signature warm cream that replaces standard SaaS white"
    },
    "mist-gray": {
      "$value": "#d9d9d9",
      "$type": "color",
      "$description": "Mist Gray — Hairline dividers, subtle borders on neutral surfaces"
    },
    "warm-stone": {
      "$value": "#615f5c",
      "$type": "color",
      "$description": "Warm Stone — Secondary body text, list items, muted icon strokes"
    },
    "driftwood": {
      "$value": "#8e8b87",
      "$type": "color",
      "$description": "Driftwood — Tertiary body text, decorative strokes, subtle metadata"
    },
    "ironwood": {
      "$value": "#4a4a47",
      "$type": "color",
      "$description": "Ironwood — Strong secondary text, emphasized muted labels"
    },
    "ash": {
      "$value": "#777571",
      "$type": "color",
      "$description": "Ash — Helper text, placeholder-adjacent copy, low-priority borders"
    },
    "bone": {
      "$value": "#c0bbb6",
      "$type": "color",
      "$description": "Bone — Input borders, form field outlines at rest"
    },
    "smoke": {
      "$value": "#a5a19c",
      "$type": "color",
      "$description": "Smoke — Disabled text, decorative borders, very low-priority separators"
    },
    "graphite": {
      "$value": "#999999",
      "$type": "color",
      "$description": "Graphite — List borders, tertiary structural lines"
    }
  },
  "font": {
    "muotoweb": {
      "$value": "MuotoWeb",
      "$type": "fontFamily",
      "$description": "Primary UI and body typeface — geometric sans covering navigation, buttons, body copy, subheadings, and most headings up to 50px. Custom-drawn letterforms give it warmth that generic Inter or Helvetica cannot: slightly humanist terminals and open apertures that read friendly rather than cold."
    },
    "monarch": {
      "$value": "Monarch",
      "$type": "fontFamily",
      "$description": "Hero display serif — used only for the largest emotional headline (72px) where editorial weight is needed. The serif is the signature contrast against MuotoWeb's sans body: the page whispers functional in sans, then ROARS one moment in serif. Reserve for hero/page-title moments only."
    }
  },
