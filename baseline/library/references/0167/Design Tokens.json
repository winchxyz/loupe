      "$type": "color",
      "$description": "Ice Border — Badge borders, light blue-tinted separator lines."
    },
    "mist": {
      "$value": "#bdc5d2",
      "$type": "color",
      "$description": "Mist — Subtle borders, dividers, input outlines in resting state."
    },
    "near-white": {
      "$value": "#fefefe",
      "$type": "color",
      "$description": "Near White — Card surface background — one step off pure white to reduce glare on elevated surfaces."
    }
  },
  "font": {
    "segoe-ui-variable-text": {
      "$value": "Segoe UI Variable Text",
      "$type": "fontFamily",
      "$description": "The primary workhorse: all headings, body text, nav labels, buttons, badges. Microsoft's own variable font whose optical sizing axis auto-adjusts letterform construction at different sizes — tighter tracking at display scale (48px at −0.01em to −0.025em) is baked into the font's design intent, not added post hoc."
    },
    "segoe-ui-variable-display": {
      "$value": "Segoe UI Variable Display",
      "$type": "fontFamily",
      "$description": "Hero and section headings at large scale — the Display optical axis activates wider, more open letterforms than the Text axis at the same point size, making headlines feel more authoritative at 48px and above."
    },
    "segoe-ui-variable-small": {
      "$value": "Segoe UI Variable Small",
      "$type": "fontFamily",
      "$description": "Tight-tracked small labels and fine-print contexts."
    },
    "segoe-ui": {
      "$value": "Segoe UI",
      "$type": "fontFamily",
      "$description": "System fallback used in footer, some nav utility links, and browser-rendered UI chrome. No tracking adjustments — falls back to OS default rendering."
    }
  },
