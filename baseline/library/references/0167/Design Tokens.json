{
  "color": {
    "teams-violet": {
      "$value": "#5d5bd4",
      "$type": "color",
      "$description": "Teams Violet — Primary CTA buttons, active nav underlines, badge backgrounds — the single saturated signal on an otherwise achromatic page. Vivid violet-purple stands apart from Microsoft blue (#0067b8) to brand Teams distinctly within the Microsoft ecosystem."
    },
    "teams-midnight": {
      "$value": "#333275",
      "$type": "color",
      "$description": "Teams Midnight — Hover and pressed states for Teams Violet buttons, nav link active text — darker violet that deepens without shifting hue."
    },
    "teams-deep": {
      "$value": "#424197",
      "$type": "color",
      "$description": "Teams Deep — Button pressed/focus states — intermediate violet between Teams Violet and Teams Midnight."
    },
    "microsoft-blue": {
      "$value": "#0067b8",
      "$type": "color",
      "$description": "Microsoft Blue — Link text, icon fills, navigation affordances — the legacy Microsoft hyperlink blue used on informational elements, never on CTA buttons."
    },
    "ink-navy": {
      "$value": "#17253d",
      "$type": "color",
      "$description": "Ink Navy — Primary text, headings, body copy, icons — near-black with a distinct blue cast that avoids pure black harshness."
    },
    "abyss-navy": {
      "$value": "#0e1726",
      "$type": "color",
      "$description": "Abyss Navy — Darkest heading weight, button text on transparent dark-background variants."
    },
    "steel": {
      "$value": "#616161",
      "$type": "color",
      "$description": "Steel — Secondary body text, captions, placeholder text, icon color for inactive states."
    },
    "graphite": {
      "$value": "#262626",
      "$type": "color",
      "$description": "Graphite — Nav link text, body text at medium emphasis."
    },
    "cloud": {
