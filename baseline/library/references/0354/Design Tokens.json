{
  "color": {
    "parchment": {
      "$value": "#fef9ed",
      "$type": "color",
      "$description": "Parchment — Page canvas, card surface, light text on dark — the foundational warm cream that carries 80% of the interface"
    },
    "bone": {
      "$value": "#f5f0e4",
      "$type": "color",
      "$description": "Bone — Secondary surface, muted panels, badge backgrounds, tab track — one shade deeper than the canvas for subtle layering without shadow"
    },
    "walnut": {
      "$value": "#5d524b",
      "$type": "color",
      "$description": "Walnut — Primary text, body copy, nav links, icons, borders — warm dark brown replaces black, keeping the system on the earth-tone spectrum"
    },
    "cedar": {
      "$value": "#72675b",
      "$type": "color",
      "$description": "Cedar — Muted secondary text, helper copy, inactive nav — mid-tone brown for de-emphasis within the warm scale"
    },
    "linen": {
      "$value": "#cec7bc",
      "$type": "color",
      "$description": "Linen — Hairline borders, input outlines, dividers — warm light gray that reads as thread on the cream canvas"
    },
    "library-ink": {
      "$value": "#2e4d4d",
      "$type": "color",
      "$description": "Library Ink — Hero background, dark section fill — deep desaturated teal-green, the only cool note in the system; creates the dramatic contrast with the warm display type"
    },
    "apricot-wash": {
      "$value": "#fbd3be",
      "$type": "color",
      "$description": "Apricot Wash — Gradient accent, warm highlight band, peachy atmosphere — the only chromatic warmth, used as a wash rather than a fill"
    },
    "faded-rose": {
      "$value": "#8c5462",
      "$type": "color",
      "$description": "Faded Rose — Accent text, italic emphasis, decorative label — muted burgundy that recedes into the warm palette without shouting"
    },
    "slate-lilac": {
      "$value": "#666583",
      "$type": "color",
      "$description": "Slate Lilac — Cool secondary accent for sparse cross-palette moments — muted blue-gray, used sparingly to break the warm monotony"
    }
  },
  "font": {
    "bradford-ll": {
      "$value": "Bradford LL",
      "$type": "fontFamily",
      "$description": "Primary serif for body, headings, and all display. Custom transitional serif with warm proportions; the italic cut carries the hero word 'Humanist' and functions as the system's expressive voice. Aggressive negative tracking at display sizes (up to -5px at 125px) tightens the wordmark into a sculpted slab. Single weight axis (400-450) keeps the system restrained — hierarchy comes from size and italic, never from bold."
    },
    "red-hat-mono": {
      "$value": "Red Hat Mono",
      "$type": "fontFamily",
      "$description": "Monospace for UI chrome — search input, tab labels, badge text, navigation links, the accessibility mode toggle, footer micro-copy. Its mechanical character provides the only structural counterpoint to the flowing serif. Use with positive tracking (0.05-0.10em) for uppercase tag labels to create a printed-typesetter effect."
    },
    "mwf-mdl2": {
      "$value": "MWF-MDL2",
      "$type": "fontFamily",
      "$description": "MWF-MDL2 — detected in extracted data but not described by AI"
    }
  },
