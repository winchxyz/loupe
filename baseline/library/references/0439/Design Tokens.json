{
  "color": {
    "lime-spark": {
      "$value": "#d2e823",
      "$type": "color",
      "$description": "Lime Spark — Primary action buttons, active nav fills, highlight card surfaces — the single loud CTA accent that punches through every colored band"
    },
    "lavender-mist": {
      "$value": "#e9c0e9",
      "$type": "color",
      "$description": "Lavender Mist — Decorative borders, icon outlines, soft card edges, and subtle highlight washes — a pastel companion that desaturates without disappearing"
    },
    "cobalt-band": {
      "$value": "#2665d6",
      "$type": "color",
      "$description": "Cobalt Band — Violet outline accent for tags, dividers, and focused UI edges. Do not promote it to the primary CTA color"
    },
    "maroon-plate": {
      "$value": "#780016",
      "$type": "color",
      "$description": "Maroon Plate — Deep section backgrounds, card fills — anchors the lower page with a wine-colored tray that makes white type glow"
    },
    "cobalt-deep": {
      "$value": "#061492",
      "$type": "color",
      "$description": "Cobalt Deep — Card surface fills for product mockups and feature blocks — a denser, more intense blue than Cobalt Band"
    },
    "forest-ink": {
      "$value": "#254f1a",
      "$type": "color",
      "$description": "Forest Ink — Card surface fills, body accent text — the dark green that grounds warm-toned card compositions"
    },
    "mustard-pop": {
      "$value": "#d6a337",
      "$type": "color",
      "$description": "Mustard Pop — Card surface fills, decorative tile colors — a warm gold that adds variety to bento grid compositions"
    },
    "linen-canvas": {
      "$value": "#f3f3f1",
      "$type": "color",
      "$description": "Linen Canvas — Page background, neutral button fills, soft section breaks — the warm off-white base that lets colored bands float"
    },
    "white-plate": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "White Plate — Card surfaces, form inputs, icon fills, and inverted text on dark/colored backgrounds"
    },
    "ink-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Ink Black — Primary text, dominant borders (all cards/buttons/icons carry a black stroke), and illustration outlines — the structural ink that defines every shape"
    },
    "midnight-ink": {
      "$value": "#1e2330",
      "$type": "color",
      "$description": "Midnight Ink — Secondary dark text and borders, heading strokes on light surfaces, icon outlines — a near-black with a cool cast that softens the harshness of pure black"
    },
    "sage-mute": {
      "$value": "#676b5f",
      "$type": "color",
      "$description": "Sage Mute — Muted helper text, secondary link borders, low-emphasis captions — a desaturated olive-gray that recedes without disappearing"
    },
    "silver-border": {
      "$value": "#c7c8cb",
      "$type": "color",
      "$description": "Silver Border — Subtle button borders, disabled states, low-emphasis dividers"
    },
    "charcoal-pill": {
      "$value": "#222222",
      "$type": "color",
      "$description": "Charcoal Pill — Dark mode button borders, hover state outlines on inverted components"
    },
    "concrete-tile": {
      "$value": "#adadad",
      "$type": "color",
      "$description": "Concrete Tile — Placeholder card backgrounds, skeleton states, and muted tile fills"
    },
    "leaf-wash": {
      "$value": "#ebffc5",
      "$type": "color",
      "$description": "Leaf Wash — Soft section backgrounds and highlight washes — a very pale lime that echoes Lime Spark without competing"
    },
    "moss-tint": {
      "$value": "#e8efd6",
      "$type": "color",
      "$description": "Moss Tint — Alternate pale surface for section banding — a desaturated green-gray that adds another neutral layer"
    }
  },
  "font": {
    "arial": {
      "$value": "Arial",
      "$type": "fontFamily",
      "$description": "System fallback only — present in small quantities, likely from a legacy or utility context. Do not use as a primary face."
    },
    "linksans": {
      "$value": "Linksans",
      "$type": "fontFamily",
      "$description": "Primary type system for all UI, body, headings, and display. Used at 400 for body, 500 for emphasis, 700 for subheadings/buttons, 800 for the densest display headlines. The 800-weight display at 80px with -0.043em tracking is the signature: type that reads as a single shape, not a sentence. Substitute with Inter or General Sans for close geometric proportions."
    },
    "linksans-linksansvf": {
      "$value": "Linksans Linksansvf",
      "$type": "fontFamily",
      "$description": "Linksans Linksansvf — detected in extracted data but not described by AI"
    },
