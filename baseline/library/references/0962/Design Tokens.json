{
  "color": {
    "ink": {
      "$value": "#1e242c",
      "$type": "color",
      "$description": "Ink — Primary text, nav borders, icon strokes, card borders — near-black with a barely-there cool tint reads as a refined alternative to pure black"
    },
    "steel": {
      "$value": "#576579",
      "$type": "color",
      "$description": "Steel — Secondary text, muted nav links, subtle borders — the workhorse mid-gray for everything that must be quieter than body copy"
    },
    "paper": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper — Page canvas, card surfaces, button text on filled controls — the dominant surface"
    },
    "mist": {
      "$value": "#e7eaee",
      "$type": "color",
      "$description": "Mist — Nav dividers, subtle section separators — the lightest functional border"
    },
    "fog": {
      "$value": "#dbdfe5",
      "$type": "color",
      "$description": "Fog — Card borders, content block outlines — slightly darker than Mist for card-level separation"
    },
    "ash": {
      "$value": "#cfd5dd",
      "$type": "color",
      "$description": "Ash — Button focus shadow, input hover rings — the mid-neutral for interaction feedback"
    },
    "signal-blue": {
      "$value": "#1a73e8",
      "$type": "color",
      "$description": "Signal Blue — Blue action color for filled buttons, selected navigation states, and focused conversion moments."
    },
    "coal": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Coal — Icon fills, SVG strokes — true black reserved for graphic assets only, not text"
    }
