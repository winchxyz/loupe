{
  "color": {
    "blueprint-blue": {
      "$value": "#1d52de",
      "$type": "color",
      "$description": "Blueprint Blue — Violet supporting accent for decorative details and low-frequency emphasis. Do not promote it to the primary CTA color"
    },
    "ink-black": {
      "$value": "#16191c",
      "$type": "color",
      "$description": "Ink Black — Primary body text, headings, icon strokes — the dominant ink"
    },
    "carbon": {
      "$value": "#1c2024",
      "$type": "color",
      "$description": "Carbon — Secondary heading text and high-emphasis icon fills where a subtle warmth is desired over pure ink"
    },
    "slate": {
      "$value": "#7b8187",
      "$type": "color",
      "$description": "Slate — Muted metadata, helper text, placeholder text, secondary icons, timestamps, vote/comment counts"
    },
    "fog": {
      "$value": "#d1d4d9",
      "$type": "color",
      "$description": "Fog — Hairline borders, card outlines, dividers, subtle separator strokes — the structural gray that defines every card edge"
    },
    "paper": {
      "$value": "#f4f5f7",
      "$type": "color",
      "$description": "Paper — Subtle surface tint behind nested elements, hover states, and tag/chip backgrounds"
    },
    "stone": {
      "$value": "#e6e8eb",
      "$type": "color",
      "$description": "Stone — Mid-surface layer for inset panels and elevated cards between Paper and Fog"
    },
    "canvas": {
      "$value": "#f9fafb",
      "$type": "color",
      "$description": "Canvas — Page background, primary card surface — the base on which everything sits"
    },
    "mint": {
      "$value": "#00bc7d",
      "$type": "color",
      "$description": "Mint — Green supporting accent for decorative details and low-frequency emphasis"
    }
  },
  "font": {
    "suisseintl": {
      "$value": "suisseIntl",
      "$type": "fontFamily",
      "$description": "suisseIntl — detected in extracted data but not described by AI"
    },
    "suisse-intl": {
      "$value": "Suisse Int'l",
      "$type": "fontFamily",
      "$description": "Sole text family for everything: body, headings, nav, buttons, links. Tight -0.025em tracking on larger sizes creates a confident editorial feel; the 0.05em and 0.10em tracking on smaller sizes mark small caps and category labels. Weight 500–600 is the workhorse range; 700 is reserved for the largest hero headline (30px). The 'ss01' stylistic set is active and shapes the typeface's distinctive flavor — a designer should never opt out of it."
    },
    "font-awesome-7-jelly-pro": {
      "$value": "Font Awesome 7 Jelly / Pro",
      "$type": "fontFamily",
      "$description": "Icon system — Jelly for soft-filled illustrated icons, Pro for sharp utility icons. Icons align to text-baseline and inherit color from the surrounding text level (Ink for primary, Slate for secondary)."
    },
    "suisse-mono": {
      "$value": "Suisse Mono",
      "$type": "fontFamily",
      "$description": "Tiny uppercase monospace for micro-labels and badge pills where monospaced character spacing signals 'system/metadata' — extremely rare, used as a typographic accent only"
    },
    "font-awesome-7-pro": {
      "$value": "Font Awesome 7 Pro",
      "$type": "fontFamily",
      "$description": "Font Awesome 7 Pro — detected in extracted data but not described by AI"
    }
  },
