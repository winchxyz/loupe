{
  "color": {
    "ink-black": {
      "$value": "#111111",
      "$type": "color",
      "$description": "Ink Black — Primary text, hairline borders, icon strokes, filled button background — the dominant structural neutral at ~5000 occurrences, always reading as near-black with no warm or cool cast"
    },
    "paper-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper White — Primary page and card surfaces, inverse text on dark buttons and dark sections"
    },
    "obsidian-warm": {
      "$value": "#272625",
      "$type": "color",
      "$description": "Obsidian Warm — Dark section background (CTAs, feature blocks), dark surface for cards inside dark contexts — subtly warmer than pure black so the violet text on top still feels in the same family"
    },
    "graphite-mid": {
      "$value": "#6d6c6b",
      "$type": "color",
      "$description": "Graphite Mid — Secondary body text, muted labels, caption helper copy, decorative image borders"
    },
    "cream-paper": {
      "$value": "#f4f3ef",
      "$type": "color",
      "$description": "Cream Paper — Soft warm off-white for subtle surface lifts, link/chip backgrounds — the only non-pure-white surface tint in the system"
    },
    "stone-border": {
      "$value": "#b1b1af",
      "$type": "color",
      "$description": "Stone Border — Light hairline borders on nav and link components, low-contrast dividers"
    },
    "pearl-mist": {
      "$value": "#ecebea",
      "$type": "color",
      "$description": "Pearl Mist — Subtle disabled or secondary button surface, barely-there hover states"
    },
    "deep-violet": {
      "$value": "#10054d",
      "$type": "color",
      "$description": "Deep Violet — Brand purple — appears on dark surfaces, emphasis cards, and the bold accent; concentrated and used sparingly so it reads as a power color, not a wash"
    },
    "violet-shade": {
      "$value": "#2e2460",
      "$type": "color",
      "$description": "Violet Shade — Input field background on dark sections, slightly lifted violet that keeps form controls readable against the obsidian surface"
    },
    "ember-orange": {
      "$value": "#e8400d",
      "$type": "color",
      "$description": "Ember Orange — Orange wash for highlight backgrounds, decorative bands, and soft emphasis behind content. Do not promote it to the primary CTA color"
    },
    "blush-pink": {
      "$value": "#ffd7f0",
      "$type": "color",
      "$description": "Blush Pink — Soft pastel card surface — used on feature or category tiles to break the monochrome rhythm with a gentle chromatic note"
    },
    "mint-green": {
      "$value": "#b7efb2",
      "$type": "color",
      "$description": "Mint Green — Soft pastel card surface — secondary chromatic card variant in the same family as Blush Pink and Pale Yellow"
    },
    "pale-yellow": {
      "$value": "#ffef99",
      "$type": "color",
      "$description": "Pale Yellow — Soft pastel card surface — warm accent tile, reads warm against the cool violets"
    },
    "lilac-wash": {
      "$value": "#e2ddfd",
      "$type": "color",
      "$description": "Lilac Wash — Near-gray lavender card surface — the quietest chromatic tile, used when a hint of color is needed without breaking the neutral rhythm"
    }
  },
  "font": {
    "labil-grotesk-variable": {
      "$value": "Labil Grotesk Variable",
      "$type": "fontFamily",
      "$description": "Single-family system — Labil Grotesk carries every voice from 8px micro-labels to the 84px hero display. Variable weight axis spans Regular through Black. The custom stylistic sets ss01 and ss02 are enabled across the board, activating alternate letterforms (notably the single-story 'a' and a distinctive 'g') that give the brand its quiet distinctive voice. The signature typographic move is aggressive negative tracking at display sizes: -0.05em at 84px and -0.04em at 56px compresses the headline into a dense block that reads as confident rather than airy. Small sizes sit in positive tracking (+0.025em, +0.030em) for label and eyebrow legibility."
    }
  },
