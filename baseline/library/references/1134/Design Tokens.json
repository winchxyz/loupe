{
  "color": {
    "warm-canvas": {
      "$value": "#ebeadf",
      "$type": "color",
      "$description": "Warm Canvas — Page background — the foundational warm off-white that gives the whole interface its sunlit, lived-in feel"
    },
    "pristine-surface": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Pristine Surface — Elevated card surfaces, navigation bar, product card backgrounds, pill button fills"
    },
    "sand-beige": {
      "$value": "#d5cec0",
      "$type": "color",
      "$description": "Sand Beige — Secondary card surfaces and warm-toned background panels for product grouping and featured sections"
    },
    "ink-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Ink Black — Primary text, icon strokes, hairline borders, and the brand wordmark — defines the entire typographic system"
    },
    "coral-pulse": {
      "$value": "#f04923",
      "$type": "color",
      "$description": "Coral Pulse — Bestseller badges, promotional card backgrounds, price callouts, and active accents — the singular warm energy that breaks the cream monochrome"
    }
  },
  "font": {
    "supreme-ll-tt": {
      "$value": "Supreme LL TT",
      "$type": "fontFamily",
      "$description": "Primary brand typeface used for all UI text, headings, navigation, buttons, and product labels — geometric sans with uniformly tight -0.05em tracking gives the type a compact, modern rhythm; weight 400 handles body and most labels while weight 700 drives headings and product names"
    },
    "times": {
      "$value": "Times",
      "$type": "fontFamily",
      "$description": "Fallback or system-rendered text where Supreme LL TT is unavailable"
    }
  },
