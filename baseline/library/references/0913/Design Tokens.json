  "font": {
    "pp-neue-montreal": {
      "$value": "PP Neue Montreal",
      "$type": "fontFamily",
      "$description": "Primary face across body, navigation, subheadings, and display. The custom geometric grotesque carries the entire brand voice: tight tracking at display sizes (up to -4.8px at 120px) compresses headlines into editorial-poster blocks, while relaxed tracking at body keeps 16px reading clean. Single weight 400 used throughout — weight does not differentiate hierarchy; size and color do."
    },
    "pp-neue-montreal-medium": {
      "$value": "PP Neue Montreal Medium",
      "$type": "fontFamily",
      "$description": "Navigation and select body emphasis at the 16px size — the only place a medium weight appears, used to give nav links a subtle lift over body text without breaking the single-weight visual rhythm"
    },
    "abc-monument-grotesk": {
      "$value": "ABC Monument Grotesk",
      "$type": "fontFamily",
      "$description": "Alternate display face for the largest hero statement — a wider, more architectural grotesque that provides a second editorial voice at maximum scale without competing with PP Neue Montreal elsewhere"
    },
    "system-sans-serif": {
      "$value": "System Sans-Serif",
      "$type": "fontFamily",
      "$description": "Micro labels, copyright, legal footnotes — the only size at which the system stack appears, keeping fine print neutral and invisible"
    }
  },
