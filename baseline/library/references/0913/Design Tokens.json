    "pale-lemon": {
      "$value": "#ffffa7",
      "$type": "color",
      "$description": "Pale Lemon — Primary action fill, brand accent, hero section wash, badge labels — the single chromatic voice of the entire system"
    },
    "electric-yellow": {
      "$value": "#fddd05",
      "$type": "color",
      "$description": "Electric Yellow — Yellow outline accent for tags, dividers, and focused UI edges. Do not promote it to the primary CTA color"
    },
    "obsidian": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Obsidian — Page canvas, card surfaces, text on light fills, hairline dividers, image borders — the base everything floats on"
    },
    "paper": {
      "$value": "#ffffff",
