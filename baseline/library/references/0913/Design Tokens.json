    "mist": {
      "$value": "#999999",
      "$type": "color",
      "$description": "Mist — Body subtext, link idle state, tertiary metadata — the only neutral that softens body copy without going silver"
    },
    "steel": {
      "$value": "#808080",
      "$type": "color",
      "$description": "Steel — Captions, helper text, dense metadata rows, low-emphasis body"
    }
