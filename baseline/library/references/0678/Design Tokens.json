{
  "color": {
    "linen-canvas": {
      "$value": "#fcf9f7",
      "$type": "color",
      "$description": "Linen Canvas — Page background, hero gradient origin — warm cream base that absorbs the entire site into a unified off-white"
    },
    "bone-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Bone White — Card surfaces, section backgrounds, raised panels against the linen canvas"
    },
    "graphite-ink": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Graphite Ink — Primary text, dominant border color across cards and sections — the system's typographic anchor"
    },
    "nightshade-black": {
      "$value": "#05060b",
      "$type": "color",
      "$description": "Nightshade Black — Primary action button fill, footer background — near-black with a faint cool undertone"
    },
    "deep-harbor": {
      "$value": "#030f1c",
      "$type": "color",
      "$description": "Deep Harbor — Alternate dark surface, nav background — indistinguishable from Nightshade but carries a subtle navy tilt"
    },
    "charcoal-slate": {
      "$value": "#1d1d1d",
      "$type": "color",
      "$description": "Charcoal Slate — Body borders, secondary surfaces, image card borders — slightly softer than pure black"
    },
    "iron-grey": {
      "$value": "#262628",
      "$type": "color",
      "$description": "Iron Grey — Icon strokes, heading borders, secondary fills — mid-dark neutral for iconography"
    },
    "obsidian": {
      "$value": "#111112",
      "$type": "color",
      "$description": "Obsidian — Nav text, body borders — the darkest readable neutral after Nightshade"
    },
    "stone-grey": {
      "$value": "#575757",
      "$type": "color",
      "$description": "Stone Grey — Muted body text, default body border — the primary mid-grey for paragraph copy and dividers"
    },
    "ash": {
      "$value": "#717171",
      "$type": "color",
      "$description": "Ash — Helper text, icon strokes, link borders — lighter mid-grey for secondary metadata"
    },
    "pebble": {
      "$value": "#989695",
      "$type": "color",
      "$description": "Pebble — Subtle body borders, low-emphasis copy — barely-there dividers"
    },
    "concrete": {
      "$value": "#a5a5a5",
      "$type": "color",
      "$description": "Concrete — Faint body text and dividers — used sparingly for ultra-low emphasis"
    },
    "dove": {
      "$value": "#bababa",
      "$type": "color",
      "$description": "Dove — Button border, icon fill, disabled-state borders — the lightest mid-tone"
    },
    "clay-shadow": {
      "$value": "#d1cfcd",
      "$type": "color",
      "$description": "Clay Shadow — Soft shadow color, card box-shadows, subtle background fills — warm-tinted shadow grey that matches the canvas"
    },
    "haze": {
      "$value": "#ecedef",
      "$type": "color",
      "$description": "Haze — Subtle card borders, low-contrast dividers — the cool counterpoint to Clay Shadow"
    },
    "spotlight-gradient": {
      "$value": "#a89c8a",
      "$type": "color",
      "$description": "Spotlight Gradient — Hero radial gradient terminus — warm clay tone that pools beneath the product like stage light fading into a linen floor"
    }
  },
  "font": {
    "sans-serif": {
      "$value": "sans-serif",
      "$type": "fontFamily",
      "$description": "sans-serif — detected in extracted data but not described by AI"
    },
    "hanken-grotesk": {
      "$value": "Hanken Grotesk",
      "$type": "fontFamily",
      "$description": "Primary brand typeface for all navigation, body, headings, and lists. Weight 400 carries body and long-form copy; 500–600 lifts subheadings and buttons; 700 anchors the largest display sizes. Carries custom OpenType features (blwf, cv03, cv04, cv09, cv11) that shape the letterforms into their editorial geometry — not a system stack."
    },
    "system-sans": {
      "$value": "System Sans",
      "$type": "fontFamily",
      "$description": "Utility and icon font. Used at micro sizes (10–12px) for eyebrow labels, meta tags, and icon-adjacent text, where the unusually wide 0.4440em tracking creates the spaced-out all-caps aesthetic typical of premium wellness branding."
    },
    "sf-mono": {
      "$value": "SF Mono",
      "$type": "fontFamily",
      "$description": "Micro-verification labels (e.g. 'Verified by BrandPush.co'). Tight 0.02em tracking, monospaced at 9px — the smallest typographic element on the site, sitting beneath press logos."
    },
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "Occasional fallback body copy. Lowest frequency of all fonts — appears sparingly in body contexts."
    },
    "apple-system": {
      "$value": "-apple-system",
      "$type": "fontFamily",
      "$description": "-apple-system — detected in extracted data but not described by AI"
    }
  },
