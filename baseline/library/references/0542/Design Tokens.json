{
  "color": {
    "parchment": {
      "$value": "#e5e4e0",
      "$type": "color",
      "$description": "Parchment — Page canvas, section backgrounds — warm off-white that replaces pure white, making the page feel like printed stock rather than a screen"
    },
    "ink": {
      "$value": "#1d1d1d",
      "$type": "color",
      "$description": "Ink — Primary text, heading strokes, link borders, all dark UI elements — near-black with zero blue cast, reading as editorial print"
    },
    "paper": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper — Elevated card surfaces, logo container backgrounds, project card canvases — pure white to lift content above the warm parchment"
    },
    "ash": {
      "$value": "#bfbebe",
      "$type": "color",
      "$description": "Ash — Hairline borders, subtle dividers, structural outlines that need to recede against the parchment"
    },
    "stone": {
      "$value": "#cdcdc9",
      "$type": "color",
      "$description": "Stone — Mid-tone surface between parchment and white — secondary panel background when a layer needs quiet separation"
    },
    "iridescent-sphere": {
      "$value": "#facb00",
      "$type": "color",
      "$description": "Iridescent Sphere — Signature gradient object in the hero — the only chromatic element, flowing from saturated yellow through hot pink to cool blue before dissolving to white. Functions as a brand beacon, not a UI color"
    }
  },
  "font": {
    "ataero-retina-ob-edition": {
      "$value": "Ataero Retina OB Edition",
      "$type": "fontFamily",
      "$description": "Sole typeface across the entire system. A custom geometric sans-serif with tall x-height and generous counters. Weight 400 serves body and display alike; weight 700 is reserved for small labels and navigation. Display sizes (70–103px) use 0.80 line-height to stack headline lines into a single typographic block. The font's distinctive openness and slight humanist warmth is the brand's primary identity signal — no fallback font family should appear on a production page"
    }
  },
