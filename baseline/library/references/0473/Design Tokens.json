{
  "color": {
    "microsoft-blue": {
      "$value": "#0067b8",
      "$type": "color",
      "$description": "Microsoft Blue — All interactive elements — links, primary buttons, icon accents. A single saturated hue against a near-grayscale UI creates maximum clickability signal without a second accent color."
    },
    "deep-azure": {
      "$value": "#004a7f",
      "$type": "color",
      "$description": "Deep Azure — Hover and active states for links and card link colors — darkened variant of Microsoft Blue creating depth without hue shift."
    },
    "fluent-icon-blue": {
      "$value": "#0078d4",
      "$type": "color",
      "$description": "Fluent Icon Blue — Card image icon color per CSS token; slightly lighter than Microsoft Blue, used in Fluent UI icon contexts."
    },
    "amber-badge": {
      "$value": "#ffb900",
      "$type": "color",
      "$description": "Amber Badge — Badge background (CSS token sc-badge-bg-yellow) with black text — the only warm accent in the system, reserved for promotional or notification badges."
    },
    "void": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Void — Primary text, borders, SVG fills across heading, body, nav, footer."
    },
    "graphite": {
      "$value": "#171717",
      "$type": "color",
      "$description": "Graphite — Ghost button text and border color; near-black for secondary interactive labels."
    },
    "charcoal": {
      "$value": "#262626",
      "$type": "color",
      "$description": "Charcoal — Body copy, nav text, secondary button labels."
    },
    "iron": {
      "$value": "#333333",
      "$type": "color",
      "$description": "Iron — Tertiary text contexts, muted body copy."
    },
    "slate": {
      "$value": "#616161",
      "$type": "color",
      "$description": "Slate — Secondary nav links, icon strokes, footer body text, caption-level text."
    },
    "fog": {
      "$value": "#f2f2f2",
      "$type": "color",
      "$description": "Fog — Footer background, alternate section backgrounds."
    },
    "white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "White — Page background, card surfaces, button text on filled blue buttons."
    }
  },
  "font": {
    "segoe-ui": {
      "$value": "Segoe UI",
      "$type": "fontFamily",
      "$description": "Single typeface for all text — nav at 13-15px/400, body at 15-16px/400, card headings at 29px/600, hero headlines at 37px/600. No decorative cuts, no variable-weight axes. The absence of a separate display face makes even 37px headlines feel utilitarian — authority through recurrence, not grandeur."
    }
  },
