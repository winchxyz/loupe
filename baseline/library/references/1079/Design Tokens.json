      "$type": "color",
      "$description": "Midnight Ink — Primary heading and body text — near-black with the faintest warm undertone that keeps it from feeling harsh"
    },
    "deep-charcoal": {
      "$value": "#292929",
      "$type": "color",
      "$description": "Deep Charcoal — Nav text, footer text, secondary headings, filled icon fills; Decorative gradient on AI-enhanced copy indicators — transitions from dark charcoal through amber, pink, lavender, sky, chartreuse, then fades transparent"
    },
