{
  "color": {
    "espresso-bark": {
      "$value": "#3c261c",
      "$type": "color",
      "$description": "Espresso Bark — Primary text, navigation background, structural borders — a warm near-black that anchors every screen without the harshness of pure #000000"
    },
    "terracotta-ember": {
      "$value": "#e97451",
      "$type": "color",
      "$description": "Terracotta Ember — Primary action borders, active nav state, decorative accents — rationed to moments of intent, never used as a large surface fill"
    },
    "iris-ink": {
      "$value": "#4a43dd",
      "$type": "color",
      "$description": "Iris Ink — Decorative display headings, logo monogram stroke — a vivid violet that breaks the warm palette for brand-voice headlines only"
    },
    "honey-parchment": {
      "$value": "#f7efc5",
      "$type": "color",
      "$description": "Honey Parchment — Subtle highlight washes, eyebrow label backgrounds, warm text tint — a muted yellow that warms the cream canvas without competing with terracotta"
    },
    "warm-linen": {
      "$value": "#f9f8f0",
      "$type": "color",
      "$description": "Warm Linen — Page canvas, content section backgrounds — the dominant surface, never pure white, always slightly cream"
    },
    "ash-mist": {
      "$value": "#dddedf",
      "$type": "color",
      "$description": "Ash Mist — Hairline borders, dividers, card edges — the most-used color on the site (1,300+ occurrences), creates the cool rule-lines that structure every layout"
    },
    "blush-cream": {
      "$value": "#fcede8",
      "$type": "color",
      "$description": "Blush Cream — Warm tinted surface for hover states and soft callout blocks — a peach wash that warms the cream canvas"
    },
    "lilac-mist": {
      "$value": "#e4e3f2",
      "$type": "color",
      "$description": "Lilac Mist — Cool surface accent for secondary panels — a lavender-tinted gray that introduces gentle contrast against the warm cream"
    },
    "carbon": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Carbon — True black used sparingly for image fills and footer text — Espresso Bark handles all structural dark needs"
    }
  },
  "font": {
    "monasans": {
      "$value": "MonaSans",
      "$type": "fontFamily",
      "$description": "Body text, navigation, buttons, section headings, UI labels — the workhorse sans-serif. Uppercase instances at 0.07-0.1em tracking are signature; the wide tracking on 12-14px labels reads like a museum placard, not a UI label."
    },
    "paradigm-pro": {
      "$value": "paradigm-pro",
      "$type": "fontFamily",
      "$description": "Display headings and hero text only — a whisper-thin custom serif at weight 300. The ultra-light weight is anti-convention: most editorial sites use 400-500 serifs for headlines, but this 300 creates authority through restraint. Tight line-height (0.95) lets the letters interlock like a logotype."
    }
  },
