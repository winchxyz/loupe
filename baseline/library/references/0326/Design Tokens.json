    "polysans-bulky": {
      "$value": "PolySans Bulky",
      "$type": "fontFamily",
      "$description": "Hero display headlines — the signature compressed ultra-bold weight; tight line-height (1.0) lets the letters stack like a logo mark rather than reading as paragraphs"
    },
    "polysans-median": {
      "$value": "PolySans Median",
      "$type": "fontFamily",
      "$description": "Primary workhorse — nav links, section headings, the 86px display for page-openers, all-caps micro-labels with 0.05em tracking. The compressed line-heights (0.85–1.0) at large sizes are what give Wizz its editorial-magazine density"
    },
    "polysans-neutral": {
      "$value": "PolySans Neutral",
      "$type": "fontFamily",
      "$description": "Body copy, paragraph text, descriptive content — generous line-height (1.5) creates reading rhythm distinct from the tight display set"
    },
    "polysans-slim": {
      "$value": "PolySans Slim",
      "$type": "fontFamily",
