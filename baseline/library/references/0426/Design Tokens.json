  "font": {
    "dropmarkrealhead": {
      "$value": "DropmarkRealHead",
      "$type": "fontFamily",
      "$description": "Display and section headings only — used at 60px for hero, 40px for section titles, 24px for sub-section headings. Medium weight is deliberate; avoids the heavy 700 convention to keep headlines calm and editorial rather than assertive."
    },
    "dropmarkrealtext": {
      "$value": "DropmarkRealText",
      "$type": "fontFamily",
      "$description": "Body, buttons, nav, list, footer, supporting UI. 400 for body and links, 600 for emphasized sub-labels and button text, 700 reserved for occasional inline emphasis. Functions as the working sans — every non-heading element uses it."
    }
  },
