    },
    "smoke": {
      "$value": "#818181",
      "$type": "color",
      "$description": "Smoke — Disabled button text and inactive state labels"
    },
    "charcoal": {
      "$value": "#333333",
      "$type": "color",
      "$description": "Charcoal — Long-form body text in editorial blocks where the slightly lighter tone than Ink reduces visual weight over long reads"
    },
    "pure-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Pure Black — SVG icon fills, logo lockup, strict black-tone elements where maximum contrast is required"
    }
  },
  "font": {
    "margiela-sans": {
      "$value": "Margiela Sans",
      "$type": "fontFamily",
      "$description": "All UI text, navigation, buttons, labels, captions. The custom sans is the structural voice of the system. Weights 375-500 handle body and nav; 600-700 appear in micro-labels at the upper edge. The extreme letter-spacing (0.067-0.125em) applied to the smaller sizes is a signature choice — uppercase micro-text at 8-12px breathes like engraved metalwork rather than digital UI. The narrow weight range (no display-weight condensation) means type never yells; hierarchy comes from tracking and size, not boldness."
    },
    "margiela-serif": {
      "$value": "Margiela Serif",
      "$type": "fontFamily",
      "$description": "The wordmark 'Maison Margiela Paris', editorial pull-quotes, product name captions, and serif body in select sections. Single weight (400) only, with hairline negative tracking (-0.004 to -0.002em) that makes the serif feel drawn rather than typeset. It appears sparingly — when it does, it signals a shift from UI to editorial register."
    }
  },
