{
  "color": {
    "ink": {
      "$value": "#121212",
      "$type": "color",
      "$description": "Ink — Primary text, nav links, button labels, footer copy — the near-black (not pure) gives the page a slightly warmer, printed feel rather than a screen feel"
    },
    "paper": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper — Page canvas, input fills, button text on dark — the clean base against which warm off-white sections layer"
    },
    "atelier-white": {
      "$value": "#f7f7f2",
      "$type": "color",
      "$description": "Atelier White — Light supporting surface for subtle backgrounds and section separation."
    },
    "linen": {
      "$value": "#eaeae6",
      "$type": "color",
      "$description": "Linen — Deeper warm neutral for tertiary sections, input borders, subtle dividers — sits one step below Atelier White in the surface stack"
    },
    "stone": {
      "$value": "#898989",
      "$type": "color",
      "$description": "Stone — Supporting neutral for secondary UI, dividers, and muted labels."
    },
    "graphite": {
