  "font": {
    "sf-pro-display": {
      "$value": "SF Pro Display",
      "$type": "fontFamily",
      "$description": "All display and heading text from 21px upward. Hero headlines at 80px weight 600 with -0.015em tracking create Apple's signature confident, condensed voice. Subheadings drop to 48–56px. Weights stay 400 or 600 — no decorative bold."
    },
    "sf-pro-text": {
      "$value": "SF Pro Text",
      "$type": "fontFamily",
      "$description": "Body copy at 17–21px weight 400, fine print at 12–14px weight 400, large subhead accents at 40–44px weight 300. Weight 300 is used selectively on large subdued subheads to create quiet authority."
    }
  },
