{
  "color": {
    "aubergine": {
      "$value": "#240029",
      "$type": "color",
      "$description": "Aubergine — Primary text, icon strokes, hairline borders, and the dark-section fill — the structural ink of the system; every functional border carries this tint rather than neutral gray"
    },
    "fuchsia-signal": {
      "$value": "#df37a7",
      "$type": "color",
      "$description": "Fuchsia Signal — Primary action fill (Sign up CTA, active states) — the only hot chromatic in the system, reserved exclusively for the conversion moment"
    },
    "heather": {
      "$value": "#6d526d",
      "$type": "color",
      "$description": "Heather — Pink accent for outlined action borders, linked labels, and lightweight interactive emphasis."
    },
    "glowstick": {
      "$value": "#ffcc11",
      "$type": "color",
      "$description": "Glowstick — Hero gradient terminal color and decorative accent — a single warm yellow used only for celebration moments and the sunset gradient"
    },
    "plum-tinted": {
      "$value": "#d4ccd4",
      "$type": "color",
      "$description": "Plum Tinted — Mauve-tinted light border, the default hairline — always carries a hint of the brand purple rather than being pure gray"
    },
    "ink": {
      "$value": "#222222",
      "$type": "color",
      "$description": "Ink — Icon strokes and link text where the brand purple is too saturated; the near-neutral companion to Aubergine"
    },
    "smoke": {
      "$value": "#bbadbb",
      "$type": "color",
      "$description": "Smoke — Soft border and muted heading accent — a lighter companion to Plum Tinted for secondary dividers"
    },
    "charcoal": {
      "$value": "#333333",
      "$type": "color",
      "$description": "Charcoal — Body text fallback and image-level deep fills"
    },
    "frost": {
      "$value": "#767676",
      "$type": "color",
      "$description": "Frost — Input border, form field resting state"
    },
    "forest": {
      "$value": "#15803d",
      "$type": "color",
      "$description": "Forest — Success badge text and inline success state — a true forest green for confirmations and positive feedback"
    },
    "mint": {
      "$value": "#bbf7d0",
      "$type": "color",
      "$description": "Mint — Green outline accent for tags, dividers, and focused UI edges. Use as a supporting accent, not as a status color"
    },
    "honeydew": {
      "$value": "#dcfce7",
      "$type": "color",
      "$description": "Honeydew — Success badge background — the soft mint wash behind positive status pills"
    },
    "strawberry": {
      "$value": "#ef4444",
      "$type": "color",
      "$description": "Strawberry — Red outline accent for tags, dividers, and focused UI edges. Use as a supporting accent, not as a status color"
    },
    "mango": {
      "$value": "#22c55e",
      "$type": "color",
      "$description": "Mango — Green outline accent for tags, dividers, and focused UI edges. Use as a supporting accent, not as a status color"
    },
    "canvas": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Canvas — Page background, card surface, button text on dark fills"
    },
    "hero-glow": {
      "$value": "#ffbdd3",
      "$type": "color",
      "$description": "Hero Glow — Terminal stop of the hero gradient — a soft rose that opens the sunset wash"
    }
  },
  "font": {
    "inter-var": {
      "$value": "Inter Var",
      "$type": "fontFamily",
      "$description": "Workhorse UI and body font — the single axis variable cuts tracking at every size (-0.02em at 10px through -0.004em at 36px), so body text and headings share one family with no jarring weight jumps."
    },
    "kaio": {
      "$value": "Kaio",
      "$type": "fontFamily",
      "$description": "Display headlines — bold, ultra-condensed sans with strong character, used at 56-80px for hero statements. The choice of a single bold weight with tight tracking is anti-convention; most SaaS sites pair weight 300 whispers with 700 shouts. Kaio commits fully to one volume."
    },
    "jetbrains-mono": {
      "$value": "JetBrains Mono",
      "$type": "fontFamily",
      "$description": "Section eyebrows and technical labels (e.g. 'STRIPE VERIFIED PARTNER', 'ALL-IN-ONE MEMBERSHIP STACK') — the wide tracking (0.04-0.10em) turns mono into a humanist label voice, not code."
    },
    "permanent-marker": {
      "$value": "Permanent Marker",
      "$type": "fontFamily",
      "$description": "Handwritten annotations layered over the hero gradient ('SEE WHAT OUR CUSTOMERS ARE BUILDING', 'HOOK IN THE FIRST 90 MINUTES') — these are not body text, they are a personality layer; use sparingly to mark sections, not to carry meaning."
    },
    "phosphor": {
      "$value": "Phosphor",
      "$type": "fontFamily",
      "$description": "Icon system — single weight, single color (Aubergine #240029), 1px-equivalent stroke, used inline with body copy and as standalone glyphs."
    },
    "font-awesome-6-brands": {
      "$value": "Font Awesome 6 Brands",
      "$type": "fontFamily",
      "$description": "Third-party brand glyphs (integration logos, social icons) — kept distinct from Phosphor so the system can mix its own line icons with customer brand marks without visual collision."
    },
    "phosphor-bold": {
      "$value": "Phosphor-Bold",
      "$type": "fontFamily",
      "$description": "Phosphor-Bold — detected in extracted data but not described by AI"
    },
    "phosphor-fill": {
