{
  "color": {
    "pure-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Pure Black — Page canvas, hero backgrounds, full-bleed sections — the void that makes all imagery and accent color read as luminous"
    },
    "surface-one": {
      "$value": "#212121",
      "$type": "color",
      "$description": "Surface One — Primary card surface, elevated panels, and section backgrounds one level above the canvas"
    },
    "surface-two": {
      "$value": "#292929",
      "$type": "color",
      "$description": "Surface Two — Secondary button background (ghost/outlined), nested cards, and hover surfaces one step lighter than Surface One"
    },
    "surface-three": {
      "$value": "#333333",
      "$type": "color",
      "$description": "Surface Three — Tertiary button background, highest elevation layer, and active-state surface tints"
    },
    "paper-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper White — Primary headings, button text, logo, and high-emphasis copy on dark surfaces"
    },
    "fog": {
      "$value": "#e5e7eb",
      "$type": "color",
      "$description": "Fog — Hairline borders and dividers — applied at very low opacity so cards have edge definition without visual weight"
    },
    "mist": {
      "$value": "#f5f5f5",
      "$type": "color",
      "$description": "Mist — Soft highlight washes, secondary text on light surfaces, and subtle icon fills"
    },
    "mid-gray": {
      "$value": "#999999",
      "$type": "color",
      "$description": "Mid Gray — Muted body text, inactive labels, and disabled-state copy"
    },
    "steel": {
      "$value": "#737373",
      "$type": "color",
      "$description": "Steel — Link text in resting state, secondary annotations, and icon strokes at low contrast"
    },
    "graphite": {
      "$value": "#666666",
      "$type": "color",
      "$description": "Graphite — Tertiary headings, caption text, and supporting metadata"
    },
    "slate": {
      "$value": "#525252",
      "$type": "color",
      "$description": "Slate — Lowest-emphasis body text, helper copy, and subdued annotations"
    },
    "charcoal": {
      "$value": "#404040",
      "$type": "color",
      "$description": "Charcoal — Icon strokes and outlines at medium contrast, secondary borders"
    },
    "electric-blue": {
      "$value": "#0075ff",
      "$type": "color",
      "$description": "Electric Blue — Blue action color for filled buttons, selected navigation states, and focused conversion moments."
    }
  },
  "font": {
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "Sole typeface across all UI, headings, and body. The complete weight range (400-700) allows a single family to carry the full hierarchy: 700 for display headlines, 600 for section headers, 500 for buttons and nav, 400 for body and captions. Inter's geometric neutrality and tall x-height make it ideal for a dark canvas where character width and spacing carry more visual weight than personality."
    }
  },
