{
  "color": {
    "corten": {
      "$value": "#b84b30",
      "$type": "color",
      "$description": "Corten — Primary brand color — hero field, headline text, icon strokes, pill button borders, link accents. The defining rust-orange that makes every page read as Monte"
    },
    "bordeaux": {
      "$value": "#5f1d1a",
      "$type": "color",
      "$description": "Bordeaux — Deep brand accent for SVG illustration fills and occasional link hover. Used sparingly as a deeper register of Corten"
    },
    "sandstone": {
      "$value": "#f8f4e9",
      "$type": "color",
      "$description": "Sandstone — Primary canvas — body section backgrounds, card surfaces, text on terracotta fields. The warm cream that carries every page after the hero"
    },
    "driftwood": {
      "$value": "#e5e7eb",
      "$type": "color",
      "$description": "Driftwood — Hairline borders, dividers, and card outlines. A barely-there neutral that separates without shouting"
    },
    "charcoal": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Charcoal — Line-art illustration strokes, icon fills, inline pictograms. Pure black for hand-drawn elements on the cream canvas"
    },
    "bone": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Bone — Pure white for text on terracotta fields, button text, image overlays. Also appears as subtle borders"
    },
    "smoke": {
      "$value": "#666666",
      "$type": "color",
      "$description": "Smoke — Muted helper text, secondary metadata, quiet body copy. Reads as a soft gray against Sandstone"
    },
    "ash": {
      "$value": "#999999",
      "$type": "color",
      "$description": "Ash — Lowest-priority neutral — image metadata, placeholder tones. Sits behind Smoke in the hierarchy"
    },
    "espresso": {
      "$value": "#3e3d3a",
      "$type": "color",
      "$description": "Espresso — Dark surface for badge backgrounds, occasional deep contrast blocks. A near-black warm brown"
    }
  },
  "font": {
    "riposte": {
      "$value": "Riposte",
      "$type": "fontFamily",
      "$description": "Primary serif face — all headlines, display text, navigation, buttons, body copy. Riposte carries the entire brand voice with its warm geometric serif character. Weight 400 for body and most text, weight 600 reserved for display headlines. The wide tracking at 0.10em on uppercase labels (HELLO & GOOD MORNING) is a signature move — the serif breathes in all-caps, unlike most modern sans-serif systems that tighten."
    },
    "apercu-mono": {
      "$value": "Apercu Mono",
      "$type": "fontFamily",
      "$description": "Monospace secondary face — timestamps (TOMORROW FROM 6:30AM), temperature readouts (NEWCASTLE 22°C), input fields, and quiet data labels. Slight negative tracking tightens the mono for functional data display. Creates a typographic counterpoint to the serif — the serif speaks, the mono measures."
    }
  },
