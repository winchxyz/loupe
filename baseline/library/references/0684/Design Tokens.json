{
  "color": {
    "obsidian": {
      "$value": "#0e1311",
      "$type": "color",
      "$description": "Obsidian — Primary canvas — page backgrounds, hero sections, card surfaces. The near-black with a faint green undertone makes white type glow without feeling sterile"
    },
    "pure-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Pure Black — Deepest surface, borders, and type. Used for maximum-contrast outlines, product box photography backgrounds, and the darkest UI strokes"
    },
    "ash-charcoal": {
      "$value": "#1a1a1a",
      "$type": "color",
      "$description": "Ash Charcoal — Secondary surface and border tone — slightly lifted from black for subtle layering on nav, dividers, and outlined button edges"
    },
    "graphite": {
      "$value": "#333333",
      "$type": "color",
      "$description": "Graphite — Mid-neutral for secondary text, input borders, and card outlines where pure black is too heavy"
    },
    "stone-gray": {
      "$value": "#808080",
      "$type": "color",
      "$description": "Stone Gray — Image placeholder and muted background tone — holds space where product photography is loading or absent"
    },
    "silver": {
      "$value": "#b3b3b3",
      "$type": "color",
      "$description": "Silver — De-emphasized borders and helper text on light surfaces"
    },
    "bone": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Bone — Primary text on dark canvases, price-chip fills, inverted button surfaces. The brightest accent in an otherwise low-key palette"
    },
    "linen": {
      "$value": "#f6f7f2",
      "$type": "color",
      "$description": "Linen — Warm off-white surface for inverted sections, price pill backgrounds, and soft button fills. Sits between bone and the khaki family"
    },
    "sand-khaki": {
      "$value": "#dfdbca",
      "$type": "color",
      "$description": "Sand Khaki — Hairline borders, dividers, input outlines, and card edges on light surfaces."
    },
    "lichen-green": {
      "$value": "#cadcac",
      "$type": "color",
      "$description": "Lichen Green — Green state accent for badges, validation surfaces, and short status labels."
    },
    "citron": {
      "$value": "#faf080",
      "$type": "color",
      "$description": "Citron — Yellow state accent for badges, validation surfaces, and short status labels."
    },
    "antique-gold": {
      "$value": "#cfa53b",
      "$type": "color",
      "$description": "Antique Gold — Accent stroke and border for promotional or limited-availability badges. Reads as aged brass — never neon"
    },
    "olive-bark": {
      "$value": "#4d4a31",
      "$type": "color",
      "$description": "Olive Bark — Dark olive link/announcement background — the deep green-brown of the top bar, grounded and earthy"
    }
  },
  "font": {
    "gt-america-standard": {
      "$value": "GT America Standard",
      "$type": "fontFamily",
      "$description": "The UI workhorse: navigation labels, body copy, button text, metadata, footer text, cart count, form fields. Weight 400 for body, 500 for nav items, 600 sparingly for tiny uppercase labels like 'FEATURED'. At 11–14px it carries the entire structural layer."
    },
    "id00-serif": {
      "$value": "ID00 Serif",
      "$type": "fontFamily",
      "$description": "The editorial voice: product names, section headings, the 'Shop Now' and 'Limited Time Offer' labels in the hero, the 'Independent specialty coffee roaster…' manifesto copy. Almost always set in italic — this is the signature move. The italic serif against a black canvas is what makes the site read as a curated coffee journal rather than a store."
    },
    "helvetica": {
      "$value": "Helvetica",
      "$type": "fontFamily",
      "$description": "Fallback / system substitute for small tertiary text and icons where GT America is not loaded."
    },
    "reviewsio-font": {
      "$value": "reviewsio-font",
      "$type": "fontFamily",
      "$description": "reviewsio-font — detected in extracted data but not described by AI"
    }
  },
