{
  "color": {
    "butter-paper": {
      "$value": "#fff3b8",
      "$type": "color",
      "$description": "Butter Paper — Dominant page canvas for entire sections, emphasis text on dark photographic backgrounds, hairline link borders, and the third band in the surface stack — a warm cream that replaces white as the design's atmospheric ground"
    },
    "ink-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Ink Black — Primary text color across all surfaces, hairlines and structural borders, the footer and dark-band background — every word, rule, and icon reads as solid ink on the cream or white ground"
    },
    "paper-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper White — White section backgrounds and card surfaces that separate the yellow bands, inverse text on the black footer, and the language modal surface"
    },
    "wheat": {
      "$value": "#f1e4a4",
      "$type": "color",
      "$description": "Wheat — Muted input-field fill used on the yellow canvas — a slightly darker cream that lets form fields recede into the warm ground without losing the surface hierarchy"
    },
    "signal-red": {
      "$value": "#ff0000",
      "$type": "color",
      "$description": "Signal Red — Active-state and current-section indicator in the hamburger nav menu — a single red dash marks the present position in the menu, the only chromatic departure from the black-on-cream system"
    }
  },
  "font": {
    "ot-neue-montreal": {
      "$value": "OT Neue Montreal",
      "$type": "fontFamily",
      "$description": "Primary workhorse covering display headlines, navigation, buttons, and labels — the 58px weight-700 lockup with 0.90 leading is the signature editorial poster voice; uppercase treatment is consistent across all sizes."
    },
    "abc-diatype": {
      "$value": "ABC Diatype",
      "$type": "fontFamily",
      "$description": "Secondary humanist sans for body copy, footer details, input fields, and the modal message — slightly warmer and more legible than the geometric Montreal, used where long-form reading or quieter hierarchy is required."
    }
  },
