{
  "color": {
    "ember-orange": {
      "$value": "#ff4d00",
      "$type": "color",
      "$description": "Ember Orange — Orange accent for outlined action borders, linked labels, and lightweight interactive emphasis. Do not promote it to the primary CTA color"
    },
    "foundry-black": {
      "$value": "#121212",
      "$type": "color",
      "$description": "Foundry Black — Page background, section canvas, main surface — the dominant ground that lets white type and orange accents read as luminous"
    },
    "chalk-white": {
      "$value": "#e2e8f0",
      "$type": "color",
      "$description": "Chalk White — Hairline borders, nav rules, link underlines, tag outlines — the wireframe color that constructs the entire UI scaffold"
    },
    "bone-white": {
      "$value": "#efefef",
      "$type": "color",
      "$description": "Bone White — Primary body and UI text, icon strokes, button text, secondary surface fills — the readable text color and the inverse fill used for emphasized controls"
    },
    "soot": {
      "$value": "#3a3a3a",
      "$type": "color",
      "$description": "Soot — Low-contrast structural borders, subtle dividers between stacked sections — the quietest rule line, only visible against the bone-white inverted surfaces"
    },
    "ash": {
      "$value": "#747474",
      "$type": "color",
      "$description": "Ash — Muted helper text, inactive labels, secondary metadata — recedes so the monospace chrome can carry hierarchy without competing with display type"
    }
  },
  "font": {
    "jetbrains-mono": {
      "$value": "JetBrains Mono",
      "$type": "fontFamily",
      "$description": "The operating-system font: drives the sidebar navigation, font-spec labels, button text, metadata strips, and body copy. Treated as a UI element itself — uppercase, tracked-out (0.04–0.06em) for labels, tight (-0.02em) for body. Its monospaced geometry is the visual signature of every chrome component."
    },
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "Secondary text voice for longer-form copy blocks and supporting paragraphs that need a less technical rhythm than the monospace. Appears sparingly so the monospace remains the dominant signal."
    },
    "basement-grotesque-ffflauta-b-mecha-bunker-caniche-carpenter-curia-adhesion-trovador-xer0-blob": {
      "$value": "Basement Grotesque, FFFLAUTA, B-Mecha, Bunker, Caniche, Carpenter, Curia, Adhesion, Trovador, XER0, Blob",
      "$type": "fontFamily",
      "$description": "Display specimens — the products. Each fills a full-width section at monumental size, set tight (0.95–1.10 leading) with a hair of positive tracking. An AI agent should treat these as content blocks to be authored, not as system fonts to be re-created; substitute with the user's own display typefaces at proportional sizes."
    },
    "ffflauta-400": {
