    "mint": {
      "$value": "#0f9972",
      "$type": "color",
      "$description": "Mint — Green supporting accent for decorative details and low-frequency emphasis. Use as a supporting accent, not as a status color"
    },
    "lilac-wash": {
      "$value": "#9357f4",
      "$type": "color",
      "$description": "Lilac Wash — Gradient origin for the hero radial glow and card overlays — never used as a flat fill"
    }
  },
  "font": {
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "Sole workhorse — body at 16px/400, section headings at 24–30px/700, and display at 48–64px/900. The 900 weight at 60–64px is the signature: headlines are not politely bold, they are geometric slabs that anchor every section"
