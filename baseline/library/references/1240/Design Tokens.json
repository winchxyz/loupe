{
  "color": {
    "lavender-paper": {
      "$value": "#ece0ff",
      "$type": "color",
      "$description": "Lavender Paper — Page canvas, soft card surfaces, hero wash — near-gray violet that reads as neutral paper across the entire site"
    },
    "pure-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Pure White — Card surface above canvas, icon strokes, inverse text on violet buttons, nav background"
    },
    "ash-gray": {
      "$value": "#cfcfcf",
      "$type": "color",
      "$description": "Ash Gray — Hairline dividers, card borders, input borders, separator rules — the dominant border tone at 2484 occurrences"
    },
    "onyx": {
      "$value": "#121212",
      "$type": "color",
      "$description": "Onyx — Primary text, heading fill, dark icon strokes — the only body-color the UI commits to"
    },
    "graphite": {
      "$value": "#616161",
      "$type": "color",
      "$description": "Graphite — Secondary body text, muted helper copy, nav subtext"
    },
    "fog": {
      "$value": "#8c8c8c",
      "$type": "color",
      "$description": "Fog — Tertiary text, disabled nav items, low-priority borders"
    },
    "ethereum-violet": {
      "$value": "#6c24e0",
      "$type": "color",
      "$description": "Ethereum Violet — Violet supporting accent for decorative details and low-frequency emphasis. Do not promote it to the primary CTA color"
    },
    "deep-iris": {
      "$value": "#41128c",
      "$type": "color",
      "$description": "Deep Iris — Hover state on violet, dark accent surface, gradient origin — the violet pushed to its shadow end"
    },
    "hot-magenta": {
      "$value": "#f60e9d",
      "$type": "color",
      "$description": "Hot Magenta — Secondary accent for inline links inside feature cards, tag pills, illustration accent"
