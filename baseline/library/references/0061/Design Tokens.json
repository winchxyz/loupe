  "font": {
    "denim-ink": {
      "$value": "Denim Ink",
      "$type": "fontFamily",
      "$description": "All interface text — from tiny labels to massive display headlines. The custom geometric face is the voice of the brand; weight 400 covers body and body-large, 600 for subheadings and emphasized inline, 700 reserved for the largest display moments. Extreme size jumps (40→64→86→94) create a poster-like hierarchy where the largest text dwarfs everything else on the page."
    },
    "courier-new": {
      "$value": "Courier New",
      "$type": "fontFamily",
      "$description": "Tiny monospaced labels (8px) for micro-annotations, likely near icons or status indicators. Ultra-tight tracking (-0.14em) at this size reads as a decorative tech-glitch element rather than readable text."
    }
  },
