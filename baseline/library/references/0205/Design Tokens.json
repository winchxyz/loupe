{
  "color": {
    "electric-indigo": {
      "$value": "#0000ff",
      "$type": "color",
      "$description": "Electric Indigo — Primary CTA fill, brand text, decorative ASCII pattern — the signal color that makes actions switched on against the dark canvas"
    },
    "cobalt-pulse": {
      "$value": "#4141fc",
      "$type": "color",
      "$description": "Cobalt Pulse — Button borders, secondary accent — slightly lighter than Electric Indigo for outlined controls and hover states"
    },
    "periwinkle-veil": {
      "$value": "#8b8bfe",
      "$type": "color",
      "$description": "Periwinkle Veil — Outlined action border, light violet accent — ghost button outlines and muted decorative strokes"
    },
    "lime-beacon": {
      "$value": "#7fd579",
      "$type": "color",
      "$description": "Lime Beacon — Rare chromatic punctuation — cursor marker, outlined button variant, location indicator on the data map"
    },
    "orchid-whisper": {
      "$value": "#d896ff",
      "$type": "color",
      "$description": "Orchid Whisper — Rare chromatic punctuation — outlined button variant, decorative icon accent"
    },
    "midnight-void": {
      "$value": "#0d0d0d",
      "$type": "color",
      "$description": "Midnight Void — Page background — the base canvas everything floats on"
    },
    "carbon-panel": {
      "$value": "#161616",
      "$type": "color",
      "$description": "Carbon Panel — Card and panel surfaces — one step above the canvas for contained content blocks"
    },
    "graphite-lift": {
      "$value": "#252525",
      "$type": "color",
      "$description": "Graphite Lift — Dark elevated surface for cards, headers, and contained panels. Do not promote it to the primary CTA color"
    },
    "steel-hover": {
      "$value": "#3b3b3b",
      "$type": "color",
      "$description": "Steel Hover — Highest surface elevation, filled neutral button background — the brightest the neutrals get"
    },
    "pure-signal": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Pure Signal — Primary headings, button text, high-contrast text — the loudest text voice"
    },
    "soft-mist": {
      "$value": "#eaeaea",
      "$type": "color",
      "$description": "Soft Mist — Body text, secondary copy, subtle fill — quieter than Pure Signal for paragraphs and descriptions"
    },
    "charcoal": {
      "$value": "#333333",
      "$type": "color",
      "$description": "Charcoal — Borders in light sections, link underlines — visible only against the white band"
    },
    "warm-filament": {
      "$value": "#b8ad97",
      "$type": "color",
      "$description": "Warm Filament — Decorative SVG stroke and fill — warm-toned accent for abstract graphics and illustration details"
    }
  },
  "font": {
    "cofo-sans": {
      "$value": "Cofo Sans",
      "$type": "fontFamily",
      "$description": "Primary typeface across all UI — headings at 64px weight 700, body at 14–16px weight 400, nav links at 13–14px. The tight -0.02em tracking at 64px creates a compressed, technical headline feel; most crypto/data brands use looser tracking at this size."
    },
    "cofo-sans-pixel": {
      "$value": "Cofo Sans Pixel",
      "$type": "fontFamily",
      "$description": "Technical metadata labels — nav dot-prefixed links (BUILD, ABOUT, COMMUNITY, TOOLS), small uppercase tags, and machine-precise annotations. The pixel variant creates a monospace-adjacent rhythm that signals 'system metadata' vs 'human prose'."
    }
  },
