{
  "color": {
    "yellix-yellow": {
      "$value": "#fff65d",
      "$type": "color",
      "$description": "Yellix Yellow — Primary action buttons, section accent blocks, highlight tags, decorative fills — the sole chromatic color, used sparingly to make a single element pop per view"
    },
    "bone-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Bone White — Page canvas, inverted text on dark blocks, filled button text"
    },
    "warm-parchment": {
