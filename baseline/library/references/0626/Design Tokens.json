{
  "color": {
    "white-canvas": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "White Canvas — Page background, product photography backdrop, hero base layer"
    },
    "mist": {
      "$value": "#f2f5f8",
      "$type": "color",
      "$description": "Mist — Primary light surface for cards, product tiles, section bands, input fills, hairline borders — the most-used non-white color"
    },
    "soft-mist": {
      "$value": "#e6ebee",
      "$type": "color",
      "$description": "Soft Mist — Elevated surface layer one step above Mist for nested cards or secondary content blocks"
    },
    "pale-slate": {
      "$value": "#cfdce7",
      "$type": "color",
      "$description": "Pale Slate — Button and navigation borders, subtle dividers, outlined-control stroke"
    },
    "steel": {
      "$value": "#58737e",
      "$type": "color",
      "$description": "Steel — Secondary text, muted helper labels, subdued body copy where Deep Slate would feel too heavy"
    },
    "deep-slate": {
      "$value": "#3b505a",
      "$type": "color",
      "$description": "Deep Slate — The signature brand color — primary text, all hairline borders (536 nav + 304 misc border uses), nav link color, footer text, and the single dark surface tone that anchors the otherwise pale system"
    },
    "deep-ink": {
      "$value": "#202f3b",
      "$type": "color",
      "$description": "Deep Ink — Heaviest heading text where maximum contrast against white is needed"
    },
    "carbon": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Carbon — Icon strokes, strict-contrast text, and occasional fill — used sparingly only when absolute black is required"
    }
  },
  "font": {
    "libre-caslon-condensed": {
      "$value": "Libre Caslon Condensed",
      "$type": "fontFamily",
      "$description": "Editorial display — the wordmark, section headings, and any text that needs to feel like a magazine title. Used at only three sizes, all dramatic, all in a single weight 400. The condensed proportions and negative tracking make the brand name feel architectural and permanent rather than decorative."
    },
    "circular-pro": {
      "$value": "Circular Pro",
      "$type": "fontFamily",
      "$description": "The single workhorse sans for all navigation, body copy, buttons, links, inputs, icons, and utility UI. The geometric neutrality and slightly wide letterforms give the system a calm, clinical tone appropriate to a biology-driven skincare brand. Never goes above 16px, never goes bold — the 400 weight at small sizes is the only voice UI text gets."
    }
  },
