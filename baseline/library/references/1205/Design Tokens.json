    "boathouse": {
      "$value": "Boathouse",
      "$type": "fontFamily",
      "$description": "Sole typeface across all UI, headings, body, nav, and footer. The weight contrast is deliberately binary — 400 for almost everything, 600 reserved for the wordmark, headings, and CTA labels. Tight line-heights (1.0 on display) give headings a compressed, assertive posture rather than the airy SaaS default."
    }
  },
