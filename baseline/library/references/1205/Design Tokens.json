{
  "color": {
    "strava-orange": {
      "$value": "#fc5200",
      "$type": "color",
      "$description": "Strava Orange — Orange supporting accent for decorative details and low-frequency emphasis. Do not promote it to the primary CTA color"
    },
    "link-blue": {
      "$value": "#0060d0",
      "$type": "color",
      "$description": "Link Blue — Inline text links and policy references; the only secondary chromatic color and reserved strictly for navigational links"
    },
    "paper-white": {
      "$value": "#ffffff",
      "$type": "color",
