    "ink-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Ink Black — Primary text, iconography, hairline rules, table borders — the only high-contrast element on the page"
    },
    "paper-warm-gray": {
      "$value": "#dbdad9",
      "$type": "color",
      "$description": "Paper Warm Gray — Card surfaces, soft fills, the single chromatic departure from pure white, gentle gradient origin"
    },
    "graphite-border": {
      "$value": "#808080",
