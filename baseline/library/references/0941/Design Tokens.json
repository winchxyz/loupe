{
  "color": {
    "void-canvas": {
      "$value": "#0e0e13",
      "$type": "color",
      "$description": "Void Canvas — Page background, primary canvas — near-black with a cool ink tint that lets the cream text feel hand-set rather than digital"
    },
    "carbon-surface": {
      "$value": "#09090b",
      "$type": "color",
      "$description": "Carbon Surface — Card backgrounds, inset panels, and list items — one shade deeper than the canvas to create surface depth without elevation"
    },
    "slab-elevated": {
      "$value": "#18181b",
      "$type": "color",
      "$description": "Slab Elevated — Elevated surface layer, rarely visible — used only for small chips and modal-like overlays that need to sit above cards"
    },
    "iron-border": {
      "$value": "#27272a",
      "$type": "color",
      "$description": "Iron Border — Primary hairline border across lists, dividers, and card edges — appears 490+ times, it is the structural skeleton of the system"
    },
    "steel-border": {
      "$value": "#3f3f46",
      "$type": "color",
      "$description": "Steel Border — Dark borders and separators for elevated surfaces and inverted UI. Do not promote it to the primary CTA color"
    },
    "zinc-mute": {
      "$value": "#71717a",
      "$type": "color",
      "$description": "Zinc Mute — Muted body text, icon strokes, and disabled labels — the voice of secondary information"
    },
    "pearl-border": {
      "$value": "#d8d7d4",
      "$type": "color",
      "$description": "Pearl Border — Light hairline border used inside nav bars and inverted surfaces — a near-white wire for dark containers"
    },
    "ice-border": {
      "$value": "#d9e6ef",
      "$type": "color",
      "$description": "Ice Border — Cool-tinted light border for icons, links, and glassy outlined elements — adds a faint blue whisper to contrast with the warm Cream text"
    },
    "cream-text": {
      "$value": "#fffaea",
      "$type": "color",
      "$description": "Cream Text — Primary heading and body text — warm off-white (not pure #fff) that reads softer on dark and unifies with the orange accent's warmth"
    },
    "bone-text": {
      "$value": "#f4f4f5",
      "$type": "color",
      "$description": "Bone Text — Secondary text and button labels — the cool counterpart to Cream, used when a label needs to feel more clinical than editorial"
    },
    "mercury-text": {
      "$value": "#a1a1aa",
      "$type": "color",
      "$description": "Mercury Text — Tertiary text and meta-information — the lightest reading level above Zinc Mute"
    },
    "ember-orange": {
      "$value": "#e96b34",
      "$type": "color",
      "$description": "Ember Orange — Primary filled CTA (Request a Demo) — warm burnt orange against cool dark creates urgency without the aggression of pure red"
    },
    "mint-pulse": {
      "$value": "#62f6b5",
      "$type": "color",
      "$description": "Mint Pulse — Secondary filled CTA (Sign Up / Login) — bright mint green pairs against Ember Orange as a complementary pair, the two action colors share the same pill geometry but never co-occupy the same surface"
    },
    "spectrogram-blue": {
      "$value": "#4dcafa",
      "$type": "color",
      "$description": "Spectrogram Blue — Decorative waveform accent — appears only inside the hero audio visualization, never on UI elements"
    },
    "spectrogram-pink": {
      "$value": "#de94e2",
      "$type": "color",
      "$description": "Spectrogram Pink — Decorative waveform accent — part of the six-color spectrogram palette in the hero"
    },
    "spectrogram-yellow": {
      "$value": "#ffdd03",
      "$type": "color",
      "$description": "Spectrogram Yellow — Decorative waveform accent — bright lemon dot in the hero waveform graphic"
    },
    "spectrogram-violet": {
      "$value": "#9977ff",
      "$type": "color",
      "$description": "Spectrogram Violet — Decorative waveform accent — soft purple dot in the hero waveform graphic"
    }
  },
  "font": {
    "seasonsans": {
      "$value": "seasonSans",
      "$type": "fontFamily",
      "$description": "All UI text, headings, body, and button labels — a custom neo-grotesque with an unusually wide weight range (300→650) that lets headlines whisper at 300 while labels speak at 650"
    },
    "geist-mono": {
      "$value": "Geist Mono",
      "$type": "fontFamily",
      "$description": "Developer-facing micro-copy: nav links, section labels, 'TALK TO VAPI' callouts, and any monospaced interface element — tracked wide (+0.05em to +0.08em) to read as a console label rather than code"
    }
  },
