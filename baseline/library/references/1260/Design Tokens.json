{
  "color": {
    "hot-magenta": {
      "$value": "#ff2e95",
      "$type": "color",
      "$description": "Hot Magenta — Primary CTA fill, logo mark, link color, accent strokes — the only chromatic voice in the system, used sparingly to signal action"
    },
    "ink-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Ink Black — Primary heading text, button text, heavy borders, navigation bar background"
    },
    "oat-canvas": {
      "$value": "#f6f2ee",
      "$type": "color",
      "$description": "Oat Canvas — Page background, large surface fills — the warm cream that replaces cold white throughout"
    },
    "soft-ink": {
      "$value": "#111111",
      "$type": "color",
      "$description": "Soft Ink — Body text and headings on light surfaces, card surface background for dark elements"
    },
    "slate": {
      "$value": "#0f172a",
      "$type": "color",
      "$description": "Slate — Secondary text, subtle body copy — a cool near-black used for non-headline text"
    },
    "charcoal": {
      "$value": "#414040",
      "$type": "color",
      "$description": "Charcoal — Neutral form states, badge text, and quiet UI feedback where color should stay understated. Do not promote it to the primary CTA color"
    },
    "stone": {
      "$value": "#848383",
      "$type": "color",
      "$description": "Stone — Icon strokes, muted helper text, subtle UI dividers"
    },
    "paper-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper White — Card surfaces, elevated panels, contrast surface against oat canvas"
    },
    "warm-mist": {
      "$value": "#e8e5e0",
      "$type": "color",
      "$description": "Warm Mist — Hairline borders, dividers, subtle container outlines — warm-toned to match canvas"
    },
