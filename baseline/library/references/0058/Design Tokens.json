{
  "color": {
    "stone-charcoal": {
      "$value": "#444242",
      "$type": "color",
      "$description": "Stone Charcoal — Primary text, navigation links, hairline borders, footer anchors — dark warm gray carries the same temperature as the cream surfaces it sits on, never pure black"
    },
    "linen-cream": {
      "$value": "#efe3dc",
      "$type": "color",
      "$description": "Linen Cream — Heading text, footer surface, and the lighter plane in the surface stack — sits one step above the canvas"
    },
    "warm-sand": {
      "$value": "#dacabf",
      "$type": "color",
      "$description": "Warm Sand — Page canvas — the dominant field every section and hero lives on"
    },
    "dust": {
      "$value": "#938a83",
      "$type": "color",
      "$description": "Dust — Secondary borders and dividers when Stone Charcoal would be too heavy"
    },
    "mortar": {
      "$value": "#595552",
      "$type": "color",
      "$description": "Mortar — Muted body text and subdued borders — the quietest readable neutral"
    }
  },
  "font": {
    "basis": {
      "$value": "Basis",
      "$type": "fontFamily",
      "$description": "Body, nav, labels, captions — the only text family used for everything below display. The 0.066–0.099em tracking on 10–14px is the signature: it makes small text feel like a printed catalogue label rather than screen UI."
    },
    "favorit": {
      "$value": "Favorit",
      "$type": "fontFamily",
      "$description": "Display and heading — set at a single 30px size, weight 400 only. The narrow, slightly quirky character shapes (open apertures, subtle inktraps) carry all the personality the system allows. No bold weight exists."
    }
  },
