  "font": {
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "Single-family system: Inter carries everything from 10px eyebrow labels to 64px display headlines. The aggressive negative tracking at display sizes (-3.2px at 64px) makes headlines feel dense and architectural rather than airy, which suits the cosmic-dark page. Positive 0.5px tracking only appears on 10px uppercase eyebrows, creating a tight micro-label style. Weight 500 is the default for UI; 600 for button labels; 700 sparingly for hero emphasis."
    }
  },
