{
  "color": {
    "canvas-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Canvas White — Page background, sidebar background, card surfaces, input fills"
    },
    "youtube-ink": {
      "$value": "#0f0f0f",
      "$type": "color",
      "$description": "YouTube Ink — Primary text, icon strokes, logo wordmark, button text — the near-black that defines the entire interface"
    },
    "graphite": {
      "$value": "#606060",
      "$type": "color",
      "$description": "Graphite — Secondary text, metadata, timestamps, muted descriptions, nav secondary labels"
    },
    "ash": {
      "$value": "#909090",
      "$type": "color",
      "$description": "Ash — Tertiary text, disabled states, inactive icon strokes, micro-copy"
    },
    "mist": {
      "$value": "#c6c6c6",
      "$type": "color",
      "$description": "Mist — Hairline borders, inactive toggle tracks, subtle dividers"
    },
    "silver": {
      "$value": "#d3d3d3",
      "$type": "color",
      "$description": "Silver — Button borders, input field outlines, card outlines — the structural divider"
    },
    "signal-blue": {
      "$value": "#065fd4",
      "$type": "color",
      "$description": "Signal Blue — Blue supporting accent for decorative details and low-frequency emphasis. Do not promote it to the primary CTA color"
    },
    "play-red": {
      "$value": "#ff0000",
      "$type": "color",
      "$description": "Play Red — Logo play triangle exclusively — the locked brand mark, never used as a functional UI color"
    }
  },
  "font": {
    "roboto": {
      "$value": "Roboto",
      "$type": "fontFamily",
      "$description": "Primary interface font — nav labels, body copy, links, button text, metadata, timestamps. The 2.57 line-height on small sizes creates generous vertical breathing room for sidebar items."
    },
    "youtube-sans": {
      "$value": "YouTube Sans",
      "$type": "fontFamily",
      "$description": "Wordmark only — the logo's custom typeface that makes 'YouTube' instantly recognizable. Never used for headings, body, or nav."
    },
    "arial": {
      "$value": "Arial",
      "$type": "fontFamily",
      "$description": "System fallback for legacy components and button labels in older UI fragments"
    }
  },
