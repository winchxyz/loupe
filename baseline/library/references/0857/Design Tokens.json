    "geist": {
      "$value": "Geist",
      "$type": "fontFamily",
      "$description": "Primary typeface across the entire system. Geist Bold (weight 600) carries all display and heading sizes from 36-88px with aggressive -0.04em tracking; Geist SemiBold handles subheadings and card titles at 14-36px; Geist Regular flows body and caption text at 10-24px. The geometric precision of Geist pairs with the deep indigo to create a research-terminal feel — the letterforms feel measured and exact, which suits an AI research product. The extreme size range (10px to 88px) is a signature: display headlines at 88px are nearly 9x the smallest text, creating dramatic scale contrast."
    },
    "geist-regular": {
      "$value": "Geist Regular",
      "$type": "fontFamily",
      "$description": "Geist Regular — detected in extracted data but not described by AI"
    },
