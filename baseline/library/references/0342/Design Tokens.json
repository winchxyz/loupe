{
  "color": {
    "parchment": {
      "$value": "#fdf6ee",
      "$type": "color",
      "$description": "Parchment — Page canvas, hero background, card surfaces on light sections — sets the warm literary tone that distinguishes this from the cool-white default of most SaaS"
    },
    "soft-cream": {
      "$value": "#f0e6dc",
      "$type": "color",
      "$description": "Soft Cream — Navigation background, secondary surface layer, subtle hover/elevated zones"
    },
    "pure-card": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Pure Card — Foreground card surface for content blocks, feature panels, and the floating chat testimonials in the hero"
    },
    "ink-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Ink Black — Primary text, icon strokes, and border lines — used at the highest prominence to anchor every paragraph and heading"
    },
    "charcoal-bark": {
      "$value": "#21201c",
      "$type": "color",
      "$description": "Charcoal Bark — Body text on light surfaces where pure black reads too cold against the cream"
    },
    "sepia": {
      "$value": "#2b180a",
      "$type": "color",
      "$description": "Sepia — Headings, button text, emphasized inline elements — dark brown instead of black gives headlines a printed-ink quality"
    },
    "bronze": {
      "$value": "#7f6e60",
      "$type": "color",
      "$description": "Bronze — Muted secondary body text, descriptive captions beneath headings"
    },
    "driftwood": {
      "$value": "#94877c",
      "$type": "color",
      "$description": "Driftwood — Tertiary text, nav links, low-emphasis labels, and warm-toned dividers"
    },
    "stone": {
      "$value": "#a99d93",
      "$type": "color",
      "$description": "Stone — Disabled or lowest-emphasis text, ghost iconography"
    },
    "pebble": {
      "$value": "#d9cfc3",
      "$type": "color",
      "$description": "Pebble — Hairline borders, card edges, and subtle dividers on cream surfaces"
    },
    "chestnut": {
      "$value": "#3e2407",
      "$type": "color",
      "$description": "Chestnut — Orange supporting accent for decorative details and low-frequency emphasis. Do not promote it to the primary CTA color"
    },
    "ember-orange": {
      "$value": "#f65726",
      "$type": "color",
      "$description": "Ember Orange — Accent text, in-card highlights, conversational emphasis — warm vivid orange that ignites against the parchment"
    },
    "saffron-pulse": {
      "$value": "#ff5c00",
      "$type": "color",
      "$description": "Saffron Pulse — Orange supporting accent for decorative details and low-frequency emphasis."
    },
    "peach-glow": {
      "$value": "#fed0b3",
      "$type": "color",
      "$description": "Peach Glow — Orange supporting accent for decorative details and low-frequency emphasis. Do not promote it to the primary CTA color"
    }
