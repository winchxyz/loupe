{
  "color": {
    "page-mist": {
      "$value": "#f0efef",
      "$type": "color",
      "$description": "Page Mist — Page canvas — the warm off-white that holds the entire site. Cards and content float on top of this"
    },
    "card-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Card White — Card surfaces, input fields, elevated panels — the brighter layer stacked above Page Mist"
    },
    "ink": {
      "$value": "#2b2b2b",
      "$type": "color",
      "$description": "Ink — Primary text, body copy, headings, icons, link defaults. Slightly softer than pure black, warming the type against the off-white canvas"
    },
    "graphite": {
      "$value": "#676767",
      "$type": "color",
      "$description": "Graphite — Secondary text, metadata (dates, bylines), footer labels, muted descriptions"
    },
    "slate": {
      "$value": "#555555",
      "$type": "color",
      "$description": "Slate — Tertiary text, image captions, disabled-adjacent labels"
    },
    "faint-line": {
      "$value": "#c2c2c2",
      "$type": "color",
      "$description": "Faint Line — Hairline dividers, subtle borders between feed items and card edges"
    },
    "ash": {
      "$value": "#929292",
      "$type": "color",
      "$description": "Ash — Placeholder text, low-emphasis labels, very muted helper copy"
    },
    "banner-cream": {
      "$value": "#faead9",
      "$type": "color",
      "$description": "Banner Cream — Top promotional bar background, soft warm callouts. The only non-violet warmth in the system"
    },
    "signal-violet": {
      "$value": "#8147ff",
      "$type": "color",
      "$description": "Signal Violet — Violet supporting accent for decorative details and low-frequency emphasis. Do not promote it to the primary CTA color"
    },
    "deep-iris": {
      "$value": "#6219ff",
      "$type": "color",
      "$description": "Deep Iris — Pressed/hover state of Signal Violet, chromatic text emphasis, link text in article contexts. Sits one step darker on the same hue"
    },
    "hi-vis-yellow": {
      "$value": "#ffd519",
      "$type": "color",
      "$description": "Hi-Vis Yellow — Yellow supporting accent for decorative details and low-frequency emphasis. Do not promote it to the primary CTA color"
    }
  },
  "font": {
    "labilvariable": {
      "$value": "LabilVariable",
      "$type": "fontFamily",
      "$description": "Display and heading face. Set at 40px for article hero titles and 25px for section headings, with aggressively wide tracking (up to 0.091em at display size). The wide letter-spacing is the single most recognizable typographic signal of the brand — it forces whitespace between letters, giving headlines a printed-poster cadence. Also used for navigation labels, tags, and the floating nav bar."
    },
    "bradford": {
      "$value": "Bradford",
      "$type": "fontFamily",
      "$description": "Body and UI face. Tight tracking (0.005–0.027em) at 15–17px for article descriptions, card metadata, button labels, and dense UI chrome. The contrast with LabilVariable's wide tracking is deliberate: LabilVariable announces, Bradford explains. Weight 500 appears for emphasis in metadata and button labels."
    },
    "labil": {
      "$value": "Labil",
      "$type": "fontFamily",
      "$description": "Masthead and logo lockup, plus secondary UI labels. A static companion to LabilVariable — same family, different cuts — used where the variable axis isn't needed (wordmark, fixed-size badges)."
    }
  },
