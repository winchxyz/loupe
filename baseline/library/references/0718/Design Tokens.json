  "font": {
    "mona-sans": {
      "$value": "Mona Sans",
      "$type": "fontFamily",
      "$description": "All display and section headings. The custom GitHub-adjacent variable font at weight 700 with -0.04em tracking at large sizes compresses headlines into dense data labels — they read as precision output rather than marketing copy. Weight 500 at 24-32px handles subheadings."
    },
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "All body copy, UI labels, badges, nav links, button text, card metadata. The wide weight range (400 body, 600 stat labels, 700 metric numerals) creates internal hierarchy within data-dense components without switching families."
    },
    "sans-serif": {
      "$value": "sans-serif",
      "$type": "fontFamily",
      "$description": "System fallback for non-critical UI chrome. Not a designed choice — browser default in edge cases."
    }
  },
