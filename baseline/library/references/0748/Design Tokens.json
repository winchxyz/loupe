      "$description": "Snow — Primary text, primary icons, high-contrast UI elements — near-white but not pure"
    },
    "acid-lime": {
      "$value": "#e4f222",
      "$type": "color",
      "$description": "Acid Lime — Green action color for filled buttons, selected navigation states, and focused conversion moments"
    },
    "indigo": {
      "$value": "#5e6ad2",
      "$type": "color",
      "$description": "Indigo — Icon accent, link emphasis, brand surface washes, decorative indigo that signals Linear identity in secondary contexts"
    },
    "emerald": {
      "$value": "#27a644",
      "$type": "color",
      "$description": "Emerald — Green outline accent for tags, dividers, and focused UI edges. Use as a supporting accent, not as a status color"
    },
    "crimson": {
      "$value": "#eb5757",
      "$type": "color",
      "$description": "Crimson — Red outline accent for tags, dividers, and focused UI edges. Use as a supporting accent, not as a status color"
    },
    "cyan": {
      "$value": "#02b8cc",
      "$type": "color",
      "$description": "Cyan — Teal wash for highlight backgrounds, decorative bands, and soft emphasis behind content. Use as a supporting accent, not as a status color"
    }
  },
  "font": {
    "inter-variable": {
      "$value": "Inter Variable",
      "$type": "fontFamily",
      "$description": "All UI text — navigation, headings, body, buttons, badges, inputs. The custom weight 510 sits between Regular and Medium for that signature Linear \"precise but not bold\" voice; weight 590 is used sparingly for emphasis. Weight 300 on display sizes is an anti-loud choice: the headlines whisper authority through restraint rather than shout with 700+."
    },
    "berkeley-mono": {
      "$value": "Berkeley Mono",
      "$type": "fontFamily",
      "$description": "Code, IDs, keyboard shortcuts, technical metadata (issue IDs like ENG-2703, code references in agent prompts). Its presence signals \"this is a tool, not a marketing site\" — the monospace voice only speaks where precision matters."
    }
  },
