    },
    "slate": {
      "$value": "#62666d",
      "$type": "color",
      "$description": "Slate — Muted text, placeholder text, inactive nav, low-emphasis borders — the workhorse gray"
    },
    "fog": {
      "$value": "#8a8f98",
      "$type": "color",
