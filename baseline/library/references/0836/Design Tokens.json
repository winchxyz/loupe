{
  "color": {
    "pure-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Pure White — Primary text, logotype fill, border strokes, and the dominant foreground on the dark canvas — carries 92% of all color instances"
    },
    "carbon-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Carbon Black — Base canvas and primary background — the default surface for every page"
    },
    "charcoal-shale": {
      "$value": "#101010",
      "$type": "color",
      "$description": "Charcoal Shale — Secondary surface for icon wells, sub-panels, and slight tonal lift above the pure-black canvas"
    },
    "signal-red": {
      "$value": "#ff2936",
      "$type": "color",
      "$description": "Signal Red — Sparingly-applied accent for active states, marquee highlights, and high-emphasis punctuation — used as a single saturated note against the monochrome system"
    }
  },
  "font": {
    "editorial-new": {
      "$value": "Editorial New",
      "$type": "fontFamily",
      "$description": "Hero and headline display — the ultralight weight 200 is anti-convention; combined with the 20px breakpoint it reads as editorial print rather than web UI"
    },
    "tt-firs-neue": {
      "$value": "TT Firs Neue",
      "$type": "fontFamily",
      "$description": "Workhorse UI and body sans — the only geometric grotesque in the system, anchors the project ticker labels, menu trigger, and utility text"
    },
    "altform": {
      "$value": "Altform",
      "$type": "fontFamily",
      "$description": "Compact meta and condensed labels — tight 0.86–0.88 line-height and -0.03em tracking make it read like a festival credit roll"
    },
    "wasted-year": {
      "$value": "Wasted Year",
      "$type": "fontFamily",
      "$description": "Signature editorial flourishes — bracket-wrapped taglines and small accent phrases; its hand-set quality is used for personality, not information density"
    }
  },
