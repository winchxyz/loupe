{
  "color": {
    "celluloid-cream": {
      "$value": "#ece4b4",
      "$type": "color",
      "$description": "Celluloid Cream — Primary text, all icon strokes, 1px hairline borders, and the only outlined-link action border in the system — a warm off-white that reads as aged film stock against black"
    },
    "darkroom-shadow": {
      "$value": "#4f4d3c",
      "$type": "color",
      "$description": "Darkroom Shadow — Atmospheric mid-surface visible around and between film stills — a desaturated warm olive-black that softens the page from pure void into projection-room dimness"
    },
    "projection-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Projection Black — Deep canvas void used for the darkest recesses of the page and behind embedded media; the floor beneath everything"
    }
  },
  "font": {
    "changeling-neo": {
      "$value": "changeling-neo",
      "$type": "fontFamily",
      "$description": "Sole typeface — used for both the smallest nav label and the 280px display numerals. Weight 400 across every role is a deliberate anti-convention: no bold ever appears, so hierarchy is built purely through scale and tracking. The very tight -4% letter-spacing at 230-280px is what makes the giant wordmark feel carved rather than typeset."
    }
  },
