{
  "color": {
    "iris-glow": {
      "$value": "#6366f1",
      "$type": "color",
      "$description": "Iris Glow — Violet accent for outlined action borders, linked labels, and lightweight interactive emphasis."
    },
    "signal-blue": {
      "$value": "#1685c7",
      "$type": "color",
      "$description": "Signal Blue — Blue accent for outlined action borders, linked labels, and lightweight interactive emphasis. Do not promote it to the primary CTA color"
    },
    "ember-red": {
      "$value": "#e92f48",
      "$type": "color",
      "$description": "Ember Red — Red wash for highlight backgrounds, decorative bands, and soft emphasis behind content"
    },
    "coral-pulse": {
      "$value": "#ff4141",
      "$type": "color",
      "$description": "Coral Pulse — Gradient start and secondary accent — used sparingly on warm cards and the pink-orange wash"
    },
    "sunset-amber": {
      "$value": "#ff8040",
      "$type": "color",
      "$description": "Sunset Amber — Gradient end — the warm terminal of the coral-to-orange wash used on featured cards"
    },
    "ink": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Ink — Headings, strong borders, icon fills — the heaviest text weight and the sharpest structural lines"
    },
    "graphite": {
      "$value": "#333333",
      "$type": "color",
      "$description": "Graphite — Primary body text and the workhorse border color — appears more than any other color, forming the connective tissue of the layout"
    },
    "slate": {
      "$value": "#707070",
      "$type": "color",
      "$description": "Slate — Secondary headings and muted borders"
    },
    "cool-gray": {
      "$value": "#6b7280",
      "$type": "color",
      "$description": "Cool Gray — Body and helper text where lower contrast is acceptable"
    },
    "steel": {
      "$value": "#7e8389",
      "$type": "color",
      "$description": "Steel — Subtle text and quiet borders"
    },
    "fog": {
      "$value": "#949494",
      "$type": "color",
      "$description": "Fog — Tertiary text and disabled-leaning borders"
    },
    "pearl": {
      "$value": "#dedee0",
      "$type": "color",
      "$description": "Pearl — Hairline borders, icon containers, and link outlines that need to recede"
    },
    "mist": {
      "$value": "#cccccf",
      "$type": "color",
      "$description": "Mist — Soft surface tints and the lightest structural dividers"
    },
    "paper": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper — Card surfaces and elevated content — sits one step above the page canvas"
    },
    "linen": {
      "$value": "#f7f7f9",
      "$type": "color",
      "$description": "Linen — Page canvas and the base of the surface stack"
    },
    "ash": {
      "$value": "#f2f2f2",
      "$type": "color",
      "$description": "Ash — Secondary surface for nested elements and subtle backgrounds"
    },
    "cream": {
      "$value": "#fff9ed",
      "$type": "color",
      "$description": "Cream — Warm accent card surface — the only place the system breaks from cool neutrals"
    },
    "lavender-mist": {
      "$value": "#eff0ff",
      "$type": "color",
      "$description": "Lavender Mist — Active and hover wash — the soft halo behind selected links and cards"
    },
    "rose-glow": {
      "$value": "#f8c1c8",
      "$type": "color",
      "$description": "Rose Glow — Tinted shadow color for warm cards — a blush offset shadow that ties to the coral accent"
    }
  },
  "font": {
    "maison-neue": {
      "$value": "Maison Neue",
      "$type": "fontFamily",
      "$description": "Primary body and UI text. Weight 400 for running copy, 600 for emphasis. The 40px size anchors the manifesto headlines. Substitutes: Inter, Söhne, General Sans"
    },
    "graphik": {
      "$value": "Graphik",
      "$type": "fontFamily",
      "$description": "Links, buttons, card titles, and section headings. The workhorse for anything interactive or navigational. Substitutes: Inter, Untitled Sans, Söhne"
    },
    "neue-montreal": {
      "$value": "Neue Montreal",
      "$type": "fontFamily",
      "$description": "Micro-labels, tags, metadata, and tracked-out captions. The wide tracking at small sizes is the signature move — it makes 8–12px text feel like printed stationery, not UI chrome. Substitutes: Neue Haas Grotesk, Inter Tight, Monument Grotesk"
    },
    "sf-pro-display": {
      "$value": "SF Pro Display",
      "$type": "fontFamily",
      "$description": "System font fallback for native-feeling status bar text and a few embedded contexts. Rarely the primary face."
    },
    "chirp": {
      "$value": "Chirp",
      "$type": "fontFamily",
      "$description": "Twitter embed text — appears only inside embedded tweet widgets, never used for first-party content"
    },
    "bluu-suuperstar": {
      "$value": "Bluu suuperstar",
      "$type": "fontFamily",
      "$description": "Display/decorative accent — used at most three times on the page for a single moment of personality. The 38px size is the signature flourish."
    }
  },
