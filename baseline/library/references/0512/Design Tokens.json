{
  "color": {
    "signal-blue": {
      "$value": "#0063e1",
      "$type": "color",
      "$description": "Signal Blue — Primary CTA fill, active nav indicator, brand accent dots, link highlights — the single chromatic voice in an otherwise silent monochrome system"
    },
    "obsidian": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Obsidian — Page canvas, dominant background, hairline divider color, icon fill — the floor of the entire system"
    },
    "carbon": {
      "$value": "#040910",
      "$type": "color",
      "$description": "Carbon — Card surface base, deep panel backgrounds — first step above the page canvas"
    },
    "graphite": {
      "$value": "#0d0d0d",
      "$type": "color",
      "$description": "Graphite — Elevated card surfaces, section backgrounds, border fills — the mid-surface layer"
    },
    "iron": {
      "$value": "#1f1f1f",
      "$type": "color",
      "$description": "Iron — Input field backgrounds, form controls, tertiary surfaces"
    },
    "steel": {
      "$value": "#2b2c2e",
      "$type": "color",
      "$description": "Steel — Highest card elevation, modal surfaces, hover-state surfaces — the ceiling of the surface stack"
    },
    "ash": {
      "$value": "#858585",
      "$type": "color",
      "$description": "Ash — Body text, muted labels, secondary borders, link underlines — the workhorse neutral for non-heading text"
    },
    "smoke": {
      "$value": "#979797",
      "$type": "color",
      "$description": "Smoke — Icon strokes, tertiary button borders, low-priority text"
    },
    "fog": {
      "$value": "#8c8c8c",
      "$type": "color",
      "$description": "Fog — Link text, subdued navigation labels"
    },
    "paper": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper — Light neutral action fill for buttons on dark surfaces."
    }
  },
  "font": {
    "sans-serif": {
      "$value": "sans-serif",
      "$type": "fontFamily",
      "$description": "sans-serif — detected in extracted data but not described by AI"
    },
    "diatype-rekki": {
      "$value": "Diatype REKKI",
      "$type": "fontFamily",
      "$description": "Primary brand typeface — body text at 16-20px weight 400, large headlines at 56-86px weight 400 with aggressive negative tracking (as tight as -0.064em at 86px). The whisper-weight headlines are signature: no bold shouting, just precise geometric calm. Subheadings/nav at 16-20px weight 400-600."
    },
    "diatype-rekki-bolder-rounded": {
      "$value": "Diatype REKKI Bolder Rounded",
      "$type": "fontFamily",
      "$description": "Display variant for the most prominent brand moments — heavier geometric terminals, used sparingly at 72px for hero declarations and at 12-20px weight 700 for emphasis labels in nav/inputs."
    },
    "ocd-garri": {
      "$value": "OCD-GARRI",
      "$type": "fontFamily",
      "$description": "Secondary utility face — likely for product UI labels, status indicators, or monospaced-feeling tabular data within the embedded product screenshots. Carries slight positive letter-spacing (0.033-0.038em) giving it a structured, instrument-label quality."
    },
    "diatype-rekki-regular": {
      "$value": "Diatype REKKI Regular",
      "$type": "fontFamily",
      "$description": "Diatype REKKI Regular — detected in extracted data but not described by AI"
    },
