  "color": {
    "atlassian-blue": {
      "$value": "#1868db",
      "$type": "color",
      "$description": "Atlassian Blue — Primary action buttons, active links, focus states, icon accents — the single chromatic action color across the entire system, providing directional clarity against monochrome surfaces"
    },
    "midnight-navy": {
      "$value": "#101214",
      "$type": "color",
      "$description": "Midnight Navy — Primary text, heading fills on light surfaces, dark hero panel backgrounds, link text — the dominant ink color"
    },
    "carbon-edge": {
      "$value": "#292a2e",
      "$type": "color",
      "$description": "Carbon Edge — Card borders on light surfaces, body text, input borders, secondary heading text"
    },
    "slate-current": {
      "$value": "#1c2b42",
      "$type": "color",
