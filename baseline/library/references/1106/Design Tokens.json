{
  "color": {
    "void": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Void — Primary text, nav labels, filled CTA button background, icon fills — the singular chromatic anchor of the entire system"
    },
    "fog-border": {
      "$value": "#e5e7eb",
      "$type": "color",
      "$description": "Fog Border — All dividing lines, card outlines, input borders, nav underlines — the lightest possible mark that still reads as a separator on white"
    },
    "chalk": {
      "$value": "#f1f1f1",
      "$type": "color",
      "$description": "Chalk — Hover-state button backgrounds, subtle surface fills — one step off pure white without introducing warmth"
    },
    "graphite": {
      "$value": "#666666",
      "$type": "color",
      "$description": "Graphite — Supporting body text, icon strokes, secondary labels — muted but still readable"
    },
    "ash": {
      "$value": "#8f8f8f",
      "$type": "color",
      "$description": "Ash — Tertiary labels, disabled states, fine-grain icon strokes"
    },
    "canvas": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Canvas — Page background, card surfaces, all primary surfaces — absolute white with no warm or cool tint"
    }
  },
  "font": {
    "openai-sans": {
      "$value": "OpenAI Sans",
      "$type": "fontFamily",
      "$description": "The single typeface for the entire site across every context — nav, body, headlines, buttons, inputs. At 48px display it runs at roughly -0.03em letter-spacing, making large text feel compressed and precise rather than airy. Weight 600 for headlines, 500 for UI labels, 400 for body. The custom cuts provide 'calt' and 'liga' features for text composition."
    }
  },
