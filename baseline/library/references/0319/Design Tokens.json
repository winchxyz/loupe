{
  "color": {
    "parchment": {
      "$value": "#e2dedb",
      "$type": "color",
      "$description": "Parchment — Page background, image matte areas — the warm stock everything else is printed on"
    },
    "bone-cream": {
      "$value": "#cdc6be",
      "$type": "color",
      "$description": "Bone Cream — Card surfaces, secondary panels, subtle inset backgrounds slightly darker than parchment"
    },
    "ink-black": {
      "$value": "#1d1d1b",
      "$type": "color",
      "$description": "Ink Black — Body text, nav links, borders, large display banner fills, icon strokes — the near-black that carries every contrast-critical role"
    },
    "charcoal": {
      "$value": "#69645f",
      "$type": "color",
      "$description": "Charcoal — Muted secondary text, subdued borders, quiet typographic accents"
    },
    "pure-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Pure Black — Card outline emphasis, deepest fills, highest-contrast border work on cream surfaces"
    },
    "ember-orange": {
      "$value": "#c03f13",
      "$type": "color",
      "$description": "Ember Orange — Stamp illustrations, star icon accent, occasional seal/sticker color — the single chromatic punctuation in an otherwise monochrome system"
    }
  },
  "font": {
    "editorial-new": {
      "$value": "Editorial New",
      "$type": "fontFamily",
      "$description": "Body text, nav, links, card descriptions, smaller headings — the workhorse serif"
    },
    "canopee": {
      "$value": "Canopee",
      "$type": "fontFamily",
      "$description": "Display headlines and section titles — the signature font for oversize banners (MIRANDA, WEBSITE, INTERACTIVE ARTIST!)"
    },
    "domaine-display": {
      "$value": "Domaine Display",
      "$type": "fontFamily",
      "$description": "Mid-weight display headings, body emphasis, secondary hero text — bridges Editorial New's restraint and Canopee's drama"
    },
    "germgoth": {
      "$value": "Germgoth",
      "$type": "fontFamily",
      "$description": "Rare gothic/blackletter accent — used for occasional impact moments that need medieval or poster-poster weight"
    }
  },
