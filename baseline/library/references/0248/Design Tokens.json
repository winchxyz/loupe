{
  "color": {
    "linen-canvas": {
      "$value": "#fcfcfc",
      "$type": "color",
      "$description": "Linen Canvas — Primary page background and default card surface — the near-white that reads as paper rather than pure white, reducing harshness on body-length reading"
    },
    "sky-wash": {
      "$value": "#f0f4fe",
      "$type": "color",
      "$description": "Sky Wash — Subtle blue-tinted section backgrounds, secondary card fills, and hero gradient endpoint — the one step between canvas and pure white that creates soft depth"
    },
    "midnight-ink": {
      "$value": "#020520",
      "$type": "color",
      "$description": "Midnight Ink — Primary hero and display headline color — the deepest text tone on light backgrounds, with a slight violet shift that prevents flat-black harshness"
    },
    "graphite": {
      "$value": "#14141e",
      "$type": "color",
      "$description": "Graphite — Secondary headline and body text at high prominence — slightly lighter than Midnight Ink, used for section headings and strong body content"
    },
    "slate": {
      "$value": "#374151",
      "$type": "color",
      "$description": "Slate — Product UI labels, sidebar navigation text, and medium-emphasis body content inside app screenshots"
    },
    "ash": {
      "$value": "#696a72",
      "$type": "color",
      "$description": "Ash — Secondary body text, subheadings, and caption-level content that needs to recede behind primary text"
    },
    "fog": {
      "$value": "#95959b",
      "$type": "color",
      "$description": "Fog — Placeholder text, disabled states, timestamp labels, and tertiary metadata"
    },
    "steel": {
      "$value": "#6b7280",
      "$type": "color",
      "$description": "Steel — Muted helper text inside product cards and customer company descriptions"
    },
    "signal-blue": {
      "$value": "#145aff",
      "$type": "color",
      "$description": "Signal Blue — Violet outline accent for tags, dividers, and focused UI edges. Do not promote it to the primary CTA color"
    },
    "periwinkle-glow": {
      "$value": "#b6cbfd",
      "$type": "color",
      "$description": "Periwinkle Glow — Hero background wash and decorative shadow bloom — the diffused halo that gives the hero section its soft blue atmosphere"
    },
    "hero-blue-fade": {
      "$value": "#3b82f6",
      "$type": "color",
      "$description": "Hero Blue Fade — Blue outline accent for tags, dividers, and focused UI edges"
    },
    "emerald-status": {
      "$value": "#16ca2e",
      "$type": "color",
      "$description": "Emerald Status — Green outline accent for tags, dividers, and focused UI edges. Use as a supporting accent, not as a status color"
    },
    "coral-alert": {
      "$value": "#f26052",
      "$type": "color",
      "$description": "Coral Alert — Red outline accent for tags, dividers, and focused UI edges. Use as a supporting accent, not as a status color"
    },
    "azure-info": {
      "$value": "#0099ff",
      "$type": "color",
      "$description": "Azure Info — Blue supporting accent for decorative details and low-frequency emphasis. Use as a supporting accent, not as a status color"
    },
    "amber-tag": {
      "$value": "#ffa64d",
      "$type": "color",
      "$description": "Amber Tag — Orange outline accent for tags, dividers, and focused UI edges. Use as a supporting accent, not as a status color"
    },
    "primary-action-accent": {
      "$value": "#0f1f3d",
      "$type": "color",
      "$description": "Primary Action Accent — Violet accent for outlined action borders, linked labels, and lightweight interactive emphasis. Use as the primary outlined action border and text"
    }
  },
  "font": {
    "sans-serif": {
      "$value": "sans-serif",
      "$type": "fontFamily",
      "$description": "sans-serif — detected in extracted data but not described by AI"
    },
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "Primary typeface for all headings, body, navigation, and buttons. The signature move is aggressive negative letter-spacing at display sizes: -2.96px at 80px, -1.51px at 56px, -0.76px at 40px — headlines compress toward the left edge while body text runs at normal or slightly positive tracking. This creates two distinct visual registers: dense display and airy body."
    },
    "pretendard": {
      "$value": "Pretendard",
      "$type": "fontFamily",
      "$description": "Korean-language body and UI text used in the product screenshots and localized content. Slightly positive tracking (0.019–0.03em) to compensate for CJK glyph density. Present in the product UI cards, not the marketing copy."
    },
    "roboto-mono": {
      "$value": "Roboto Mono",
      "$type": "fontFamily",
      "$description": "Monospaced accent font for deal values, pipeline counts, and data labels — the tight -0.054em tracking at 22px keeps numeric displays compact."
    },
    "font-awesome-6-pro": {
      "$value": "Font Awesome 6 Pro",
      "$type": "fontFamily",
      "$description": "Icon system used throughout product UI and navigation. Light variant at 8–12px for dense UI rows, Solid variant for emphasis. Monochromatic, matching surrounding text color."
    },
    "font-awesome-6-pro-solid": {
      "$value": "Font Awesome 6 Pro Solid",
      "$type": "fontFamily",
      "$description": "Font Awesome 6 Pro Solid — detected in extracted data but not described by AI"
    },
    "font-awesome-6-pro-regular": {
