{
  "color": {
    "signal-blue": {
      "$value": "#3c83f6",
      "$type": "color",
      "$description": "Signal Blue — Blue action color for filled buttons, selected navigation states, and focused conversion moments."
    },
    "deep-dusk": {
      "$value": "#022c70",
      "$type": "color",
      "$description": "Deep Dusk — Gradient terminal stop, button shadow depth — dark indigo that anchors the primary blue toward night"
    },
    "azure-crest": {
      "$value": "#0544a5",
      "$type": "color",
      "$description": "Azure Crest — Supporting palette color for small decorative accents when the core palette needs contrast. Do not promote it to the primary CTA color"
    },
    "hover-glow": {
      "$value": "#81b6ff",
      "$type": "color",
      "$description": "Hover Glow — Blue supporting accent for decorative details and low-frequency emphasis. Do not promote it to the primary CTA color"
    },
    "ink-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Ink Black — Maximum-emphasis text, logo wordmark, icon fills — true black for highest hierarchy"
    },
    "carbon": {
      "$value": "#18181b",
      "$type": "color",
      "$description": "Carbon — Primary body and heading text — near-black with slight warmth, softer than pure black for long reading"
    },
    "slate": {
      "$value": "#2e3038",
      "$type": "color",
      "$description": "Slate — Navigation text, icon strokes, secondary headings — dark cool gray for nav and structural elements"
    },
    "steel": {
      "$value": "#5e616e",
      "$type": "color",
      "$description": "Steel — Muted body text, helper text — medium gray for supporting copy"
    },
    "fog": {
      "$value": "#777a88",
      "$type": "color",
      "$description": "Fog — Tertiary text, captions, disabled states — lighter gray for de-emphasized content"
    },
    "mist": {
      "$value": "#afb3c4",
      "$type": "color",
      "$description": "Mist — Icon strokes (most frequent use at 56 stroke instances), placeholder icons, secondary strokes — the workhorse cool-gray for line work"
    },
    "vapor": {
      "$value": "#edeef2",
      "$type": "color",
      "$description": "Vapor — Card surface tint, body background alternates, subtle elevation base — cool off-white for layered surfaces"
    },
    "frost": {
      "$value": "#f3f8ff",
      "$type": "color",
      "$description": "Frost — Tinted card background, hero-adjacent surfaces — barely-blue white that whispers atmospheric color"
    },
    "chalk": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Chalk — Primary card surface, page background, button text — pure white for max-brightness layers"
    },
    "bone": {
      "$value": "#e4e4e7",
      "$type": "color",
      "$description": "Bone — Hairline borders (2500+ instances), dividers, input borders, icon borders — the dominant structural line color"
    },
    "ash": {
      "$value": "#d7d7d7",
      "$type": "color",
      "$description": "Ash — Secondary borders, separator lines — slightly darker than Bone for tiered dividers"
    },
    "neon": {
      "$value": "#00ff26",
      "$type": "color",
      "$description": "Neon — Green outline accent for tags, dividers, and focused UI edges"
    },
    "cyan-veil": {
      "$value": "#7df0f8",
      "$type": "color",
      "$description": "Cyan Veil — Subtle highlight wash, code-block tints, decorative gradient stop — cool cyan as atmospheric detail"
    }
  },
  "font": {
    "eb-garamond": {
      "$value": "EB Garamond",
      "$type": "fontFamily",
      "$description": "Display headline — serif at 80px with -0.012em tracking is the signature move; only used for the hero '#1 Undetectable AI for Meetings' title, creating editorial gravitas against the sans-serif body. This anti-tech choice distinguishes Cluely from generic SaaS."
    },
    "geist": {
      "$value": "Geist",
      "$type": "fontFamily",
      "$description": "All UI text — body copy, headings, buttons, nav, labels. Geist's tight letter-spacing at large sizes (-0.04em at 48px+) creates compact, engineered headlines. Weight 300 available for whisper-quiet secondary text, weight 500-600 for active states. The wide size range (9-56px) supports everything from micro-labels to section headings."
    },
    "ui-monospace": {
      "$value": "ui-monospace",
      "$type": "fontFamily",
      "$description": "Code snippets, technical labels — system monospace at 10px, never decorative, only functional in product-mockup contexts"
    }
  },
