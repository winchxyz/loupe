{
  "color": {
    "ink": {
      "$value": "#1a1a1a",
      "$type": "color",
      "$description": "Ink — Supporting neutral for secondary UI, dividers, and muted labels. Do not promote it to the primary CTA color"
    },
    "paper": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper — Page canvas, card surfaces, button text on dark fills"
    },
    "mist": {
      "$value": "#f7f7f7",
      "$type": "color",
      "$description": "Mist — Subtle surface lift for inset panels, hover states, secondary card backgrounds"
    },
    "ash": {
      "$value": "#eaeaea",
      "$type": "color",
      "$description": "Ash — Hairline borders, dividers, tag outlines, input default border"
    },
    "smoke": {
      "$value": "#e1e1e1",
      "$type": "color",
      "$description": "Smoke — Table row dividers, secondary borders, icon outlines in inactive state"
    },
    "graphite": {
      "$value": "#838383",
      "$type": "color",
      "$description": "Graphite — Tertiary text, placeholder copy, disabled icon color"
    },
    "steel": {
      "$value": "#989898",
      "$type": "color",
      "$description": "Steel — Secondary text, helper labels, subdued metadata"
    },
    "slate": {
      "$value": "#6f6f6f",
      "$type": "color",
      "$description": "Slate — Body text secondary, link text in resting state, breadcrumb text"
    },
    "marigold": {
      "$value": "#ffb84d",
      "$type": "color",
      "$description": "Marigold — Accent stroke on the primary input — a single warm spark that signals focus, never fills a surface"
    },
    "buttercream": {
      "$value": "#ffe480",
      "$type": "color",
      "$description": "Buttercream — Yellow supporting accent for decorative details and low-frequency emphasis. Do not promote it to the primary CTA color"
    },
    "cream": {
      "$value": "#fff6d4",
      "$type": "color",
      "$description": "Cream — Very pale accent wash for soft highlight backgrounds behind marigold borders"
    }
  },
  "font": {
    "output-sans": {
      "$value": "Output Sans",
      "$type": "fontFamily",
      "$description": "Single-family type system: 24px/700 for the page heading, 18px/400 for the hero greeting and primary links, 14px/400–700 for body, controls, and template labels, 10px/400 for micro-labels and column headers. The tight negative tracking at 18–24px (-0.043em) tightens the headline and greeting into a compact, spreadsheet-like block, while positive tracking on 10–14px caps and labels adds quiet authority to tiny type."
    }
  },
