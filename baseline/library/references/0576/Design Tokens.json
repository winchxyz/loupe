{
  "color": {
    "violet-pulse": {
      "$value": "#a565ff",
      "$type": "color",
      "$description": "Violet Pulse — Primary CTAs, active icons, brand glow accents — the single chromatic accent in the system; everything else defers to it"
    },
    "indigo-ink": {
      "$value": "#5e5cff",
      "$type": "color",
      "$description": "Indigo Ink — Link text, secondary text emphasis, and accent strokes where violet would be too loud"
    },
    "lavender-wash": {
      "$value": "#ebebff",
      "$type": "color",
      "$description": "Lavender Wash — Soft tinted backgrounds for highlighted callouts and subtle surface differentiation"
    },
    "iris-glow": {
      "$value": "#e0c9ff",
      "$type": "color",
      "$description": "Iris Glow — Violet supporting accent for decorative details and low-frequency emphasis. Do not promote it to the primary CTA color"
    },
    "ledger-green": {
      "$value": "#2e7317",
      "$type": "color",
      "$description": "Ledger Green — Green text accent for links, tags, and emphasized short phrases. Use as a supporting accent, not as a status color"
    },
    "paper-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper White — Primary canvas, card surfaces, button fills, and elevated surface layer"
    },
    "bone": {
      "$value": "#f7f7f7",
      "$type": "color",
      "$description": "Bone — Recessed card surfaces and subtle panel backgrounds one step off white"
    },
    "fog": {
      "$value": "#f1f1f1",
      "$type": "color",
      "$description": "Fog — Disabled surface fills, table row alternates, and recessed UI regions"
    },
    "silver": {
      "$value": "#efefef",
      "$type": "color",
      "$description": "Silver — Inset borders, button outlines, and shadow-stack fills for elevation"
    },
    "marble": {
      "$value": "#fff6df",
      "$type": "color",
      "$description": "Marble — Warm cream accent for announcement bars and subtle highlight bands"
    },
    "graphite": {
      "$value": "#1d1d20",
      "$type": "color",
      "$description": "Graphite — Primary heading and body text — near-black with a barely-warm tint"
    },
    "slate": {
      "$value": "#42424a",
      "$type": "color",
      "$description": "Slate — Secondary headings, emphasized body text, and list accents"
    },
    "iron": {
      "$value": "#505050",
      "$type": "color",
      "$description": "Iron — Default body text and the most-used text color across the system"
    },
    "steel": {
      "$value": "#757575",
      "$type": "color",
      "$description": "Steel — Muted helper text, navigation labels, and secondary table text"
    },
    "smoke": {
      "$value": "#92939e",
      "$type": "color",
      "$description": "Smoke — Placeholder text, disabled labels, and tertiary table cells"
    },
    "ash": {
      "$value": "#e5e7eb",
      "$type": "color",
      "$description": "Ash — Default hairline border — the structural backbone of the entire UI; the most-used color in the system"
    },
    "mist": {
      "$value": "#d1d9e4",
      "$type": "color",
      "$description": "Mist — Cooler border for inputs, dividers, and sections needing visual separation from Ash"
    },
    "olive-gray": {
      "$value": "#808076",
      "$type": "color",
      "$description": "Olive Gray — SVG illustration stroke and fill — the default for vector graphics in content"
    },
    "noir": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Noir — Icon fills and contrast anchors where pure black is required"
    }
  },
  "font": {
    "twk-lausanne": {
      "$value": "TWK Lausanne",
      "$type": "fontFamily",
      "$description": "Primary UI typeface — all body text, navigation, buttons, labels, and most headings from 8px to 24px. A humanist sans with open apertures that stays legible at 10–12px in dense tables and form chrome."
    },
    "moderat-serif": {
      "$value": "Moderat Serif",
      "$type": "fontFamily",
      "$description": "Editorial display serif used only on the largest marketing headlines (h1). Light weight at 40–46px with aggressive -0.025em tracking — the contrast against the humanist sans signals premium editorial tone and breaks the product-UI pattern."
    },
    "sf-mono": {
      "$value": "SF Mono",
      "$type": "fontFamily",
      "$description": "Monospaced micro-text for API references, code snippets, and technical annotations at 10px. Rare and deliberate — appears only where machine-readable content is shown."
    }
  },
