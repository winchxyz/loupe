{
  "color": {
    "forest-ink": {
      "$value": "#022c22",
      "$type": "color",
      "$description": "Forest Ink — All text, headings, and icon strokes — deep desaturated green replaces black throughout the entire interface, giving the system its organic technical warmth"
    },
    "emerald-pulse": {
      "$value": "#00bc7d",
      "$type": "color",
      "$description": "Emerald Pulse — Green supporting accent for decorative details and low-frequency emphasis. Do not promote it to the primary CTA color; Hero headline gradient flowing from forest green through emerald to amber — makes the display wordmark feel alive"
    },
    "pine": {
      "$value": "#007a55",
      "$type": "color",
      "$description": "Pine — Secondary brand green for darker button states, link text, and icon outlines when a heavier weight than Forest Ink is needed"
    },
    "mint-glow": {
      "$value": "#34d399",
      "$type": "color",
      "$description": "Mint Glow — Light accent green for secondary icons, decorative highlights, and hover state washes"
    },
    "jade-wash": {
      "$value": "#10b981",
      "$type": "color",
      "$description": "Jade Wash — Mid-green for outlined button borders, checkbox accents, and form focus rings"
    },
    "spearmint": {
      "$value": "#6ee7b7",
      "$type": "color",
      "$description": "Spearmint — Lightest green for link hover states and subtle decorative washes"
    },
    "signal-red": {
      "$value": "#dc2626",
      "$type": "color",
      "$description": "Signal Red — Red supporting accent for decorative details and low-frequency emphasis. Use as a supporting accent, not as a status color"
    },
    "lilac-whisper": {
      "$value": "#e9d5ff",
      "$type": "color",
      "$description": "Lilac Whisper — Soft violet accent for the QStash product icon and category tags that need chromatic separation from the green family"
    },
    "snow": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Snow — Page canvas, card surfaces, and inverse text on dark code blocks"
    },
    "paper": {
      "$value": "#f5f5f5",
      "$type": "color",
      "$description": "Paper — Subtle alternating section backgrounds and disabled control fills"
    },
    "pale-sage": {
      "$value": "#c9dbd6",
      "$type": "color",
      "$description": "Pale Sage — Soft green-tinted surface for hero background washes and the gradient tail stop on decorative backgrounds"
    },
    "mint-mist": {
      "$value": "#d2f2e7",
      "$type": "color",
      "$description": "Mint Mist — Lightest green-tinted background for announcement bars, tag pills, and the hero's left-edge gradient wash"
    },
    "hairline": {
      "$value": "#e5e7eb",
      "$type": "color",
      "$description": "Hairline — Universal 1px border color for cards, inputs, dividers, and table rules — the most used color in the system"
    },
    "graphite": {
      "$value": "#71717a",
      "$type": "color",
      "$description": "Graphite — Muted secondary text, nav items, placeholder text, and subdued icon strokes"
    },
    "carbon": {
      "$value": "#3d3d3f",
      "$type": "color",
      "$description": "Carbon — Darkest neutral for code block backgrounds and high-contrast borders where #000 feels too harsh"
    },
    "obsidian": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Obsidian — Code block background only — the single hard-black surface in the system"
    }
  },
  "font": {
    "inter": {
      "$value": "Inter",
