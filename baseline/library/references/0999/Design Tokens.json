{
  "color": {
    "canvas-white": {
      "$value": "#f8f9fa",
      "$type": "color",
      "$description": "Canvas White — Page background, card surfaces, section bands — the off-white ground that prevents harshness against pure white product screenshots"
    },
    "charcoal-ink": {
      "$value": "#202124",
      "$type": "color",
      "$description": "Charcoal Ink — Primary text, display headlines, active icon strokes — the deepest readable black-blue for maximum hierarchy"
    },
    "graphite": {
      "$value": "#3c4043",
      "$type": "color",
      "$description": "Graphite — Secondary headings, nav text, strong body — one step lighter than charcoal for sub-headings and navigation labels"
    },
    "slate": {
      "$value": "#5f6368",
      "$type": "color",
      "$description": "Slate — Muted body text, helper copy, icon glyphs, breadcrumb separators, footer micro-copy"
    },
    "mist": {
      "$value": "#dadce0",
      "$type": "color",
      "$description": "Mist — Hairline borders, card outlines, input strokes, dividers between sections — the only structural separator in the system"
    },
    "cloud-shadow": {
      "$value": "#c4c6c7",
      "$type": "color",
      "$description": "Cloud Shadow — Soft elevation on focused inputs and floating chips"
    },
    "google-blue": {
      "$value": "#1a73e8",
      "$type": "color",
      "$description": "Google Blue — Blue supporting accent for decorative details and low-frequency emphasis. Do not promote it to the primary CTA color"
    },
    "google-blue-deep": {
      "$value": "#1967d2",
      "$type": "color",
      "$description": "Google Blue Deep — Blue supporting accent for decorative details and low-frequency emphasis. Do not promote it to the primary CTA color"
    },
    "classroom-green": {
      "$value": "#188038",
      "$type": "color",
      "$description": "Classroom Green — Green supporting accent for decorative details and low-frequency emphasis"
    }
  },
  "font": {
    "google-sans-display": {
      "$value": "Google Sans Display",
      "$type": "fontFamily",
      "$description": "Display headlines and section titles. The 80px display weight is the page's signature — tightly tracked and stacked to two lines in the hero. At 48px and below, tracking relaxes toward 0. Substituting with Inter (closest free analog) or Product Sans preserves the geometric warmth; system sans-serif will feel colder."
    },
    "google-sans-text": {
      "$value": "Google Sans Text",
      "$type": "fontFamily",
      "$description": "Body copy, navigation, buttons, form inputs, helper text, breadcrumbs. Weight 400 is the default; 500 marks emphasis and nav-active states. The positive tracking at small sizes (0.036em at 12px) is anti-convention — it adds air to prevent the dense, gray-on-gray feel that typical SaaS body copy produces."
    }
  },
