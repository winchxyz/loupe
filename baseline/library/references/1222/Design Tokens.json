{
  "color": {
    "signal-orange": {
      "$value": "#ff4f00",
      "$type": "color",
      "$description": "Signal Orange — Hero blocks, brand statement panels, full-bleed feature sections — the single chromatic commitment, used in large committed areas rather than small accents"
    },
    "ink-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Ink Black — Primary text, logo, hairline borders, dark UI elements, and display type on light surfaces"
    },
    "paper-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper White — Display headings overlaid on photography and colored panels, input fields, light surface level, inverse text on dark hero blocks"
    },
    "raw-linen": {
      "$value": "#ebe9e3",
      "$type": "color",
      "$description": "Raw Linen — Page canvas, footer background, secondary surface — warm off-white that softens the contrast between stark white and pure black"
    },
    "faint-stone": {
      "$value": "#767676",
      "$type": "color",
      "$description": "Faint Stone — Input field borders, low-emphasis form chrome — the only mid-tone in the system"
    }
  },
