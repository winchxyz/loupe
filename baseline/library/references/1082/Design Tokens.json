{
  "color": {
    "carbon-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Carbon Black — Primary text, logo plate, pill-button fills, hairline borders, icon strokes — the dominant ink that carries every label, heading, and outline"
    },
    "paper-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper White — Page canvas, card surfaces, product image backdrops, button text on dark fills, inverted text on category overlays"
    },
    "concrete-gray": {
      "$value": "#cacaca",
      "$type": "color",
      "$description": "Concrete Gray — Card borders, thumbnail dividers, secondary dividers between product cells — the structural neutral that frames the grid"
    },
    "mist-gray": {
      "$value": "#f1f1f1",
      "$type": "color",
      "$description": "Mist Gray — Subtle surface tint for inactive button states and soft fill washes, never a page background"
    },
    "iron-gray": {
      "$value": "#404040",
      "$type": "color",
      "$description": "Iron Gray — Deep shadow tone and heavier border treatment for elevated containers and section breaks"
    },
    "ash-gray": {
      "$value": "#616161",
      "$type": "color",
      "$description": "Ash Gray — Muted secondary text, body helpers, tertiary borders — the gray that whispers beneath the ink"
    },
    "ink": {
      "$value": "#1a1b1e",
      "$type": "color",
      "$description": "Ink — Rare near-black accent for solid button fills that need a touch of warmth without drifting to pure carbon"
    },
    "caution-yellow": {
      "$value": "#ffdd00",
      "$type": "color",
      "$description": "Caution Yellow — Yellow wash for highlight backgrounds, decorative bands, and soft emphasis behind content."
    }
  },
  "font": {
    "ui-sans-serif": {
      "$value": "ui-sans-serif",
      "$type": "fontFamily",
      "$description": "ui-sans-serif — detected in extracted data but not described by AI"
    },
    "akkstdrg-akkurat-standard": {
      "$value": "AkkStdRg (Akkurat Standard)",
      "$type": "fontFamily",
      "$description": "Sole brand typeface. The neo-grotesque Swiss workhorse used for everything from display headlines down to 8px eyebrow labels. Weight stays at 400 — no bold weight exists in the system; emphasis is achieved through size, uppercase, and tracking. The 0.74 line-height on display sizes is anti-conventional and creates a compressed, industrial poster effect. Wide tracking on small sizes (0.04–0.05em) gives labels the spacing of machine-stamped serial numbers."
    },
    "frg-freitag-regular": {
      "$value": "FRg (Freitag Regular)",
      "$type": "fontFamily",
      "$description": "Reserved for product model codes (F141 CLARK, F531 ARCHER) — a secondary condensed-mark treatment that makes the SKU read as a stamped part number on a shipping crate"
    },
    "arial": {
      "$value": "Arial",
      "$type": "fontFamily",
      "$description": "Arial — detected in extracted data but not described by AI"
