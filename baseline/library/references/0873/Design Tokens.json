  "font": {
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "All UI, body, button, link, and supporting text. Negative letter-spacing across the scale tightens Inter into an editorial companion to Heldane — at 16px body the tracking reads noticeably tighter than default. Weights 400 for body, 500 for labels/buttons, 600–700 reserved for emphasis."
    },
    "heldane-display": {
      "$value": "Heldane Display",
      "$type": "fontFamily",
      "$description": "Editorial display headlines at 48–80px. Near-regular weight (400) with tight tracking and compressed line-heights creates a literary, magazine-cover feel — the headline is the hero, not a shout. The 22–26px usage at weight 500 handles mid-size editorial subtitles."
    },
    "aktiv-grotesk": {
      "$value": "Aktiv Grotesk",
      "$type": "fontFamily",
      "$description": "Aktiv Grotesk — detected in extracted data but not described by AI"
    }
  },
