{
  "color": {
    "lime-spark": {
      "$value": "#96ff1a",
      "$type": "color",
      "$description": "Lime Spark — Primary CTA fills, active toggle states, the AI creation prompt accent — an electric green that functions as the brand's ignition switch, impossible to miss on the white canvas"
    },
    "spring-wash": {
      "$value": "#d6ffa6",
      "$type": "color",
      "$description": "Spring Wash — Green wash for highlight backgrounds, decorative bands, and soft emphasis behind content. Do not promote it to the primary CTA color"
    },
    "forest-ink": {
      "$value": "#083300",
      "$type": "color",
      "$description": "Forest Ink — Deep brand green used for borders, icon strokes, and text on light green washes — the anchor tone that gives the lime palette a grounded counterweight"
    },
    "mint-mist": {
      "$value": "#e6ffc8",
      "$type": "color",
      "$description": "Mint Mist — Subtle tint for secondary button hovers and soft highlight zones — the palest breath of the green family"
    },
    "carbon": {
      "$value": "#0c0a09",
      "$type": "color",
      "$description": "Carbon — Primary heading and body text — a warm near-black with a whisper of brown that pairs with the lime accent without reading as dead-black"
    },
    "charcoal": {
      "$value": "#323232",
      "$type": "color",
      "$description": "Charcoal — Workhorse text, secondary borders, link undertones — the most-used neutral across borders and structural lines"
    },
    "graphite": {
      "$value": "#292a2e",
      "$type": "color",
      "$description": "Graphite — Dark surface fills, button text on light backgrounds, icon strokes — the primary dark tone for elevated dark sections"
    },
    "onyx": {
      "$value": "#121212",
      "$type": "color",
      "$description": "Onyx — Dark section backgrounds, heading text on light surfaces — the deepest neutral for full-bleed dark bands"
    },
    "slate": {
      "$value": "#4d4d51",
      "$type": "color",
      "$description": "Slate — Icon borders, secondary structural lines — a mid-gray for non-content boundaries"
    },
    "smoke": {
      "$value": "#71737a",
      "$type": "color",
      "$description": "Smoke — Muted helper text, link borders, placeholder text — the voice of secondary information"
    },
    "ash": {
      "$value": "#444446",
      "$type": "color",
      "$description": "Ash — Tertiary borders, icon detail strokes — a bridge tone between slate and charcoal"
    },
    "mist": {
      "$value": "#f2f1f0",
      "$type": "color",
      "$description": "Mist — Secondary surface fills, button backgrounds on hero areas, subtle tonal dividers"
    },
    "fog": {
      "$value": "#e6e6e7",
      "$type": "color",
      "$description": "Fog — Hairline borders on light surfaces, divider lines"
    },
    "paper": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper — Page canvas, card surfaces, button fills — the dominant light surface"
    }
  },
  "font": {
    "swissnow": {
      "$value": "SwissNow",
      "$type": "fontFamily",
      "$description": "The universal workhorse — handles all UI, body, navigation, button labels, inputs, footer, and most headings. A neo-grotesque with tight geometry and very tight tracking at large sizes (-0.05em at display, easing to near-normal at body). Its neutrality lets the lime accent and editorial serif carry the personality."
    },
    "ppeditorialnew": {
      "$value": "PPEditorialNew",
      "$type": "fontFamily",
      "$description": "The editorial display serif reserved exclusively for top-tier section headings. A high-contrast didone-influenced face with extremely tight tracking (-0.05em at 54px) and near-zero leading (0.88–1.0) — it whispers luxury into a tool that could otherwise feel utilitarian. The contrast between SwissNow and PPEditorialNew is the brand's typographic signature."
    }
  },
