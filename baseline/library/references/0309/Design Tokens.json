{
  "color": {
    "ink-violet": {
      "$value": "#01011b",
      "$type": "color",
      "$description": "Ink Violet — Primary text, body copy, heavy borders, data labels — the near-black ink with a violet undertone that makes charts and code blocks feel in-brand even at full contrast"
    },
    "plum-charcoal": {
      "$value": "#31263b",
      "$type": "color",
      "$description": "Plum Charcoal — Heavy borders, icon strokes, secondary text — a warm dark that softens harsh black and gives outlines a violet cast"
    },
    "storm-mauve": {
      "$value": "#43394c",
      "$type": "color",
      "$description": "Storm Mauve — Nav borders, tertiary text, muted headings — sits between Ink Violet and Plum Charcoal for intermediate contrast"
    },
    "slate-iris": {
      "$value": "#717a94",
      "$type": "color",
      "$description": "Slate Iris — Muted body text, icon fills, table borders — cool blue-gray for de-emphasized UI elements"
    },
    "ash-lavender": {
      "$value": "#89828d",
      "$type": "color",
      "$description": "Ash Lavender — Placeholder text, disabled labels, subtle icon tints"
    },
    "parchment": {
      "$value": "#fffcfc",
      "$type": "color",
      "$description": "Parchment — Page background, card surfaces, input fills — the warm near-white canvas, never pure #fff"
    },
    "bone-mist": {
      "$value": "#ecedf2",
      "$type": "color",
      "$description": "Bone Mist — Subtle dividers, zebra-striped table rows, hairline section separators"
    },
    "fog-border": {
      "$value": "#dbd7da",
      "$type": "color",
      "$description": "Fog Border — Default 1px border, card outlines, nav separators"
    },
    "twilight-plum": {
      "$value": "#473982",
      "$type": "color",
      "$description": "Twilight Plum — Brand-violet accent for focus rings (4px halo at 15% opacity), inset borders on elevated cards, decorative brand tints"
    },
    "amethyst": {
      "$value": "#6f63b7",
      "$type": "color",
      "$description": "Amethyst — Mid-tone violet for chart series, illustration fills, and data visualization highlights"
    },
    "wisteria": {
      "$value": "#9e91d6",
      "$type": "color",
      "$description": "Wisteria — Light violet for chart backgrounds, soft brand washes, and paired data fills"
    },
    "indigo-plum": {
      "$value": "#544692",
      "$type": "color",
      "$description": "Indigo Plum — Deep accent violet for dark-mode callouts, gradient endpoints, and badge fills; Gradient start"
    }
  },
  "font": {
    "pp-editorial-new": {
      "$value": "PP Editorial New",
      "$type": "fontFamily",
      "$description": "Hero display headline — ultra-light italic serif floats above the page, an anti-convention whisper-voice where competitors use bold sans. The 200 weight at 78px with -0.024em tracking gives the italic terminals room to breathe. Substitute: Cormorant Garamond Italic 200, or Playfair Display Italic 300 as fallback."
    },
    "pp-formula-semiextended": {
      "$value": "PP Formula SemiExtended",
      "$type": "fontFamily",
      "$description": "Section display headings — semi-condensed industrial sans at 60px balances the editorial hero. Tight -0.031em tracking makes the letterforms lock together for a compressed, engineered read."
    },
    "pp-formula": {
      "$value": "PP Formula",
      "$type": "fontFamily",
      "$description": "Mid-weight display subheadings — condensed 800 weight for tight, headline-grade labels"
    },
    "ibm-plex-sans": {
      "$value": "IBM Plex Sans",
      "$type": "fontFamily",
      "$description": "Primary UI and body — the workhorse. 400 for body, 500/600 for nav and subheadings, 700 for emphasized labels. Tracking tightens with size: -0.70px at 20px, -0.65px at 26px. Letterforms stay technical and neutral so the violet ink color does the brand work."
    },
    "cinetype": {
      "$value": "Cinetype",
      "$type": "fontFamily",
      "$description": "Secondary UI — nav links, button text, badges, inline labels. A geometric companion to Plex Sans, used when slightly more character is needed in controls."
    },
    "ibm-plex-mono": {
      "$value": "IBM Plex Mono",
      "$type": "fontFamily",
      "$description": "Code snippets, query cells, technical annotations — confined to 11px in product screenshots and embedded code blocks"
    },
    "lato": {
      "$value": "Lato",
      "$type": "fontFamily",
      "$description": "Tertiary small text — footers, fine print, logo-grid captions"
    }
  },
