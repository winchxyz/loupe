  "font": {
    "unica77": {
      "$value": "Unica77",
      "$type": "fontFamily",
      "$description": "Primary UI and body typeface — weight 400 for body, captions, buttons, and nav; weight 700 for subheadings and card titles. The custom geometric-humanist forms give Cohere a distinctive editorial warmth that system sans-serifs cannot replicate. Letter-spacing -0.0100em across all sizes tightens the rhythm and keeps the display sizes from feeling airy."
    },
    "coheretext": {
      "$value": "CohereText",
      "$type": "fontFamily",
      "$description": "Display-only face for the hero headline. Line-height locked at 1.00 and tracking at -0.0200em create a monumental, tightly-stacked wordmark presence — the first thing a visitor reads sits at this scale. Reserved exclusively for the largest statement on each page; never used below 48px."
    },
    "coheremono": {
      "$value": "CohereMono",
      "$type": "fontFamily",
      "$description": "Monospaced accent for version tags, code-like metadata, and micro-labels in the nav. The 8px size with 0.0200em tracking gives a technical, almost stamped quality that contrasts the editorial serif-adjacent primary face."
    }
  },
