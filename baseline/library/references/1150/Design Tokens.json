    "gopher-medium": {
      "$value": "Gopher Medium",
      "$type": "fontFamily",
      "$description": "Display and heading typeface. The signature choice — a geometric sans with editorial weight, set tight at line-height 1.0 so headlines stack into dense blocks. The 56px size is reserved for hero statements; 32px for section headings; 24px for sub-section headings. Substitute: 'Manrope' or 'Plus Jakarta Sans' (Google) for open-source parity, or 'GT America' for closer brand match."
    },
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "Small uppercase/tracked labels (eyebrows, badge text) at 12px with 0.083em letter-spacing — the only letter-spaced tier in the system, reserved for categorical tags above headings."
    },
