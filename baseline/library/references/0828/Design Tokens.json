{
  "color": {
    "apple-blue": {
      "$value": "#2997ff",
      "$type": "color",
      "$description": "Apple Blue — Link color, active states, accent icons — the sole chromatic element in the system; appears wherever a text element invites interaction"
    },
    "deep-link-blue": {
      "$value": "#0066cc",
      "$type": "color",
      "$description": "Deep Link Blue — Visited and hover state for links; deeper saturation signals state change without introducing a new hue family"
    },
    "button-blue": {
      "$value": "#0071e3",
      "$type": "color",
      "$description": "Button Blue — Blue supporting accent for decorative details and low-frequency emphasis. Do not promote it to the primary CTA color"
    },
    "graphite": {
      "$value": "#1d1d1f",
      "$type": "color",
      "$description": "Graphite — Primary text, headings, product names — the near-black of editorial print rather than pure #000, with a subtle warmth that feels premium on retina displays"
    },
    "slate": {
      "$value": "#333333",
      "$type": "color",
      "$description": "Slate — Secondary body text, descriptions under headlines, icon strokes — one step lighter than Graphite for reading rhythm"
    },
    "steel": {
      "$value": "#474747",
      "$type": "color",
      "$description": "Steel — Supporting neutral for secondary UI, dividers, and muted labels. Do not promote it to the primary CTA color"
    },
    "fog": {
      "$value": "#707070",
      "$type": "color",
      "$description": "Fog — Helper text, legal copy, sub-labels — quiet enough to disappear into the page when not needed"
    },
    "ash": {
      "$value": "#858585",
      "$type": "color",
      "$description": "Ash — Disabled button text, tertiary metadata — the lightest functional gray still legible at 12px"
    },
    "cloud": {
      "$value": "#f5f5f7",
      "$type": "color",
      "$description": "Cloud — Page canvas, alternating section backgrounds — not pure white, slightly cool-tinted to feel like a paper substrate"
    },
    "bone": {
      "$value": "#e2e2e5",
      "$type": "color",
      "$description": "Bone — Subtle button hover surfaces, card backgrounds, disabled states — the first perceptible step off the canvas"
    },
    "paper": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper — Card surfaces, nav bar, modal overlays — pure white reserved for elements that need to sit ON the canvas"
    },
    "ink": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Ink — Apple logo, high-contrast icons, dark-section text — used only where maximum punch is needed"
    }
  },
  "font": {
    "sf-pro-text": {
      "$value": "SF Pro Text",
      "$type": "fontFamily",
      "$description": "Body copy, navigation, buttons, footer, captions. The workhorse family: handles 90% of all text on the site. Weight 300 is used selectively for product subtitles ('Now supercharged by M4') to create a whisper-tone beneath the bold display headline."
    },
    "sf-pro-display": {
      "$value": "SF Pro Display",
      "$type": "fontFamily",
      "$description": "Display headlines, product names (iPhone, iPad air, MacBook Neo), hero section titles. The optical-size variant designed for 20px+ rendering with tighter apertures and higher contrast strokes."
    }
  },
