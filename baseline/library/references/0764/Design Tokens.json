{
  "color": {
    "obsidian": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Obsidian — Neutral form states, badge text, and quiet UI feedback where color should stay understated. Do not promote it to the primary CTA color"
    },
    "paper-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper White — Page canvas, card surfaces, filled-button text — the bright stage everything sits on"
    },
    "deep-ink": {
      "$value": "#121211",
      "$type": "color",
      "$description": "Deep Ink — Secondary text and input field treatment — a near-black that softens long-form body copy without losing contrast"
    },
    "graphite": {
      "$value": "#575551",
      "$type": "color",
      "$description": "Graphite — Muted helper text and secondary descriptions — a mid-gray that recedes behind Obsidian labels"
    },
    "warm-stone": {
      "$value": "#958d7e",
      "$type": "color",
      "$description": "Warm Stone — Tertiary text, subdued link and border accents — a desaturated taupe that warms the otherwise cold grayscale"
    },
    "ember-tag": {
      "$value": "#e8552b",
      "$type": "color",
      "$description": "Ember Tag — Product-UI accent visible in feature mockups (agent tags, handoff markers) — the only chromatic punctuation, kept small and functional"
    }
  },
  "font": {
    "geigy-ll-duplex-var": {
      "$value": "Geigy LL Duplex Var",
      "$type": "fontFamily",
      "$description": "Display and editorial headings — a custom neo-grotesque variable face that sets the entire tone; aggressive negative tracking at 48–113px pulls letters tight for a compressed, architectural headline"
    },
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "UI, body copy, form fields, button labels — the workhorse at 14–16px, with 10px reserved for uppercase eyebrow labels at expanded tracking"
    },
    "system-sans-serif": {
      "$value": "system sans-serif",
      "$type": "fontFamily",
      "$description": "Fallback and small utility rendering at 12px — appears in decorative or rendering contexts where Inter is not loaded"
    }
  },
