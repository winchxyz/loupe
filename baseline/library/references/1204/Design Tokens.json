{
  "color": {
    "glossier-yellow": {
      "$value": "#fff116",
      "$type": "color",
      "$description": "Glossier Yellow — Yellow supporting accent for decorative details and low-frequency emphasis. Do not promote it to the primary CTA color"
    },
    "ink": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Ink — Primary text, nav links, body copy, footer text, icon strokes, hairline borders; the dominant typographic and structural color"
    },
    "paper": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper — Product card surfaces, input fills, elevated panels; the brightest surface level in the stack"
    },
    "fog": {
      "$value": "#f7f7f7",
      "$type": "color",
      "$description": "Fog — Page canvas, section backgrounds, image-to-page transitions; the base surface the entire site sits on"
    },
    "blush": {
      "$value": "#faf2f4",
      "$type": "color",
      "$description": "Blush — Footer background, soft warm section breaks; a barely-perceptible pink-tinted off-white that adds warmth to the bottom of pages"
    },
    "mist": {
      "$value": "#f0f0f0",
      "$type": "color",
