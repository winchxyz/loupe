  "font": {
    "apercu": {
      "$value": "Apercu",
      "$type": "fontFamily",
      "$description": "Primary typeface across all UI — body at 16px/400, navigation and labels at 12–14px/500, subheadings at 20px/500, editorial headlines at 32px/700. Apercu's geometric humanist construction gives the brand its compressed, contemporary voice; the near-zero letter-spacing (0.002–0.003em) keeps type tight and magazine-like rather than airy or friendly. Weight 700 is reserved for editorial display moments, not UI chrome."
    },
    "apercu-mono": {
      "$value": "Apercu Mono",
      "$type": "fontFamily",
      "$description": "Micro-utility typography for order metadata, tracking numbers, and code-adjacent labels; the monospaced cousin creates technical texture against the proportional body face"
    },
    "gtstandard-m": {
      "$value": "GTStandard-M",
      "$type": "fontFamily",
      "$description": "GTStandard-M — detected in extracted data but not described by AI"
    }
  },
