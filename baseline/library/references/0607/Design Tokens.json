    },
    "amber": {
      "$value": "#f1a900",
      "$type": "color",
      "$description": "Amber — Yellow supporting accent for decorative details and low-frequency emphasis. Do not promote it to the primary CTA color"
    },
    "goldenrod": {
      "$value": "#ffbc3c",
      "$type": "color",
      "$description": "Goldenrod — Lighter amber variant for hover states, secondary accent surfaces — same hue family, one step lighter"
    }
  },
  "font": {
    "vsco-gothic": {
      "$value": "VSCO Gothic",
      "$type": "fontFamily",
      "$description": "Single custom family used at every size — nav items at 13px tracked to 0.08-0.10em, body at 15-16px, product card titles at 24px, section headings at 36-54px, and hero display at 89-98px with -0.05em tracking. The narrow geometric letterforms with ligatures disabled give every text element a distinctive editorial-gallery feel, even at body sizes."
    }
  },
