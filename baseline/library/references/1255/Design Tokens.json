{
  "color": {
    "wellfound-ink": {
      "$value": "#051316",
      "$type": "color",
      "$description": "Wellfound Ink — High-contrast neutral action fill for primary buttons on light surfaces."
    },
    "paper-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper White — Canvas, card surface, button fill, nav surface — the dominant background across nearly every screen"
    },
    "blush-mist": {
      "$value": "#fff4f6",
      "$type": "color",
      "$description": "Blush Mist — Soft warm card surface for feature blocks, gentle wash on two-column benefit sections"
    },
    "ash-gray": {
      "$value": "#d8d8d8",
      "$type": "color",
      "$description": "Ash Gray — Ghost-button borders, hairline dividers, muted tag outlines — present without demanding attention"
    },
    "charcoal": {
      "$value": "#333333",
      "$type": "color",
      "$description": "Charcoal — Secondary text on images, subdued link color — slightly lighter than Ink for hierarchy"
    },
    "slate-depth": {
      "$value": "#222222",
      "$type": "color",
      "$description": "Slate Depth — Nav text in dark sections, alternative ink tone for darker surface contexts"
    },
    "signal-red": {
      "$value": "#ec2e3a",
      "$type": "color",
      "$description": "Signal Red — Brand accent — the colon in the wordmark, dot ornaments beside display headlines, card highlight borders, feature icon strokes. Carries the entire chromatic identity of the system"
    },
    "aubergine-depth": {
      "$value": "#210d25",
      "$type": "color",
      "$description": "Aubergine Depth — Dark hero/stat-band background, inverse-mode surface — turns the stats counter into a velvet authority moment against the otherwise light page"
    },
    "plum-shadow": {
      "$value": "#541142",
      "$type": "color",
      "$description": "Plum Shadow — Deeper purple link background, secondary dark accent for hover or emphasis on the aubergine family"
    },
    "ember-red": {
      "$value": "#e32e19",
      "$type": "color",
      "$description": "Ember Red — Warmer secondary red for text and border accents where Signal Red reads too cool"
    }
  },
  "font": {
    "graphik": {
      "$value": "Graphik",
      "$type": "fontFamily",
      "$description": "Primary workhorse — used for everything from 14px nav links to 100px hero stats. Weight 400 for body and tags, 500 for buttons and medium emphasis, 600 for headlines and display. Negative letter-spacing (-0.013em to -0.020em) tightens display sizes into compact, confident shapes that read more like editorial typography than UI text. The very tight leading on 72px+ (0.82–1.0) is signature — display numbers feel sculpted rather than typeset."
    },
    "aeonik-fono": {
      "$value": "Aeonik Fono",
      "$type": "fontFamily",
      "$description": "Secondary typeface used sparingly for small-caps-style labels and select 40px display moments. Brings a slightly geometric counter-form to Graphik's humanist shapes, creating contrast when both fonts appear on the same surface."
    },
    "aeonikfono": {
      "$value": "Aeonikfono",
      "$type": "fontFamily",
      "$description": "Aeonikfono — detected in extracted data but not described by AI"
    }
  },
