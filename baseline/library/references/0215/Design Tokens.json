  "font": {
    "notion-inter": {
      "$value": "Notion Inter",
      "$type": "fontFamily",
      "$description": "Primary interface and heading family — the only sans used across the entire product surface, from 12px helper text to 64px hero headlines. Tabular lining numerals and localized forms are always on. Weight 600–700 carries headings and button labels; weight 400 carries body and descriptions."
    },
    "lyon-text": {
      "$value": "Lyon Text",
      "$type": "fontFamily",
      "$description": "Sparingly used editorial serif at 32px for moments that need a magazine-cover feel — never repeated in dense UI. Its appearance is a deliberate counterpoint to the otherwise all-sans system."
    }
  },
