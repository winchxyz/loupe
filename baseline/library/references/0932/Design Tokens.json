{
  "color": {
    "ink-violet": {
      "$value": "#0d0129",
      "$type": "color",
      "$description": "Ink Violet — Violet accent for outlined action borders, linked labels, and lightweight interactive emphasis. Do not promote it to the primary CTA color"
    },
    "butter-yellow": {
      "$value": "#fae59b",
      "$type": "color",
      "$description": "Butter Yellow — Yellow wash for highlight backgrounds, decorative bands, and soft emphasis behind content. Do not promote it to the primary CTA color"
    },
    "deep-teal": {
      "$value": "#19615c",
      "$type": "color",
      "$description": "Deep Teal — Dark section backgrounds for contrasting content blocks and nav text. Used as a full-bleed band color when a section needs to shift away from the cream canvas into a more saturated, grounded tone"
    },
    "cream-paper": {
      "$value": "#fffcf7",
      "$type": "color",
      "$description": "Cream Paper — Primary page canvas and card surface — replaces the default pure white. The slight warm tint is the most distinctive choice in the system; it makes the violet ink and yellow accent feel intentional rather than stark"
    },
    "pure-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Pure White — Inset card surfaces and elevated panels layered over the cream canvas. Used when a component needs to feel lifted off the paper without introducing a tint"
    },
    "shadow-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Shadow Black — Hard-offset button shadow color and SVG illustration fills. Never used as text or large surface — only as the 1–3px offset shadow behind Butter Yellow buttons and as fill on line-art elements that need maximum contrast"
    }
  },
  "font": {
    "roobert": {
      "$value": "Roobert",
      "$type": "fontFamily",
      "$description": "The sole typeface across the system. Weight 700 reserved for display headlines and button labels; weight 400 for body, nav, and subheadings. The custom geometric forms give the cream-paper palette its modern editorial backbone — a system font would flatten the identity."
    },
    "supply": {
      "$value": "Supply",
      "$type": "fontFamily",
      "$description": "Secondary use at 20px body size for supporting paragraphs in illustration-adjacent contexts. The monospace-adjacent quality suggests a technical or data-oriented voice; treat it as a sparing accent, not a co-equal voice."
    }
  },
