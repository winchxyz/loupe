  "font": {
    "degular": {
      "$value": "Degular",
      "$type": "fontFamily",
      "$description": "UI and body sans — navigation, buttons, body copy, metadata, links, tags, resumé dates. Carries all functional text. Weights step from 400 body to 700 for emphasis in headings and dates."
    },
    "blanco": {
      "$value": "Blanco",
      "$type": "fontFamily",
      "$description": "Editorial serif — hero headline, resumé role titles, section headings, and any text that should read as 'published' rather than 'navigational'. Single weight 400, letting size and the serif's own authority carry hierarchy."
    }
  },
