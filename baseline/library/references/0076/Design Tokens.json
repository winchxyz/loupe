{
  "color": {
    "abyss-navy": {
      "$value": "#17202e",
      "$type": "color",
      "$description": "Abyss Navy — Page canvas and card surfaces — the foundational darkness every other element floats on"
    },
    "tide-card": {
      "$value": "#202a3e",
      "$type": "color",
      "$description": "Tide Card — Elevated surface for nested cards, button backgrounds, and section containers — one step lighter than the canvas to imply depth without shadow"
    },
    "spectral-cyan": {
      "$value": "#6ae4ff",
      "$type": "color",
      "$description": "Spectral Cyan — Hero highlight word, outlined action borders, icon strokes, link borders — the single electric signal that draws the eye through the dark interface"
    },
    "bone-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Bone White — Primary text, filled action buttons, and high-contrast labels — the only fully white tone, reserved for reading and final calls-to-action"
    },
    "carbon-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Carbon Black — Hairline borders on dark surfaces and fine dividers — invisible structural lines that define cards without lifting them off the page"
    },
    "fog-gray": {
      "$value": "#cdd0d6",
      "$type": "color",
      "$description": "Fog Gray — Secondary body copy and muted helper text — lowered brightness to create a clear reading hierarchy beneath Bone White"
    },
    "horizon-glow": {
      "$value": "#298acb",
      "$type": "color",
      "$description": "Horizon Glow — Gradient atmosphere — the midtone of the radial background bloom that makes the page feel lit from behind"
    },
    "yield-gradient": {
      "$value": "#00d1ff",
      "$type": "color",
      "$description": "Yield Gradient — Accent gradient for highlights and yield indicators — teal-to-cyan sweep signaling positive performance"
    }
  },
  "font": {
    "open-sans": {
      "$value": "Open Sans",
      "$type": "fontFamily",
      "$description": "Primary typeface across the entire system. Weight 700 carries headings and the hero statement; weight 400 handles body copy and metadata; weight 600 sits on emphasized inline labels. The negative letter-spacing of -0.0360em tightens large display sizes so headlines read as solid blocks rather than airy typography. Hero sizes reach 100px — a deliberate terminal-instrument scale that makes the page feel like a financial readout."
    },
    "source-sans-pro": {
      "$value": "Source Sans Pro",
      "$type": "fontFamily",
      "$description": "Secondary typeface for tabular data, small labels, and inline micro-copy. Its tighter glyph widths complement Open Sans for data-dense rows like TVL figures and percentage chips without competing with display headlines."
    },
    "arial": {
      "$value": "Arial",
      "$type": "fontFamily",
      "$description": "Arial — detected in extracted data but not described by AI"
    }
  },
