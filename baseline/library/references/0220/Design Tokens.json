  "font": {
    "nng": {
      "$value": "Nng",
      "$type": "fontFamily",
      "$description": "Primary typeface across all contexts: display headlines (44–69px, weight 300–400), headings (22–29px, weight 500), body (14–18px, weight 400), captions and micro-labels (12–13px, weight 500, uppercase). Custom geometric sans with tight tracking on large sizes (-0.021em at 69px) — the slight negative tracking makes the large display headlines feel dense and poster-like rather than airy."
    },
    "roboto": {
      "$value": "Roboto",
      "$type": "fontFamily",
      "$description": "Secondary system font used sparingly — likely for rendered user content (descriptions, quotes) where a neutral fallback is needed. Weight 400 only, tight tracking (-0.103em) gives it a condensed feel."
    },
    "apercu-pro-mono": {
      "$value": "Apercu pro mono",
      "$type": "fontFamily",
      "$description": "Monospaced accent — used for code-like or identifier text (project IDs, timestamps). Normal letter-spacing distinguishes it from the proportional Nng."
    },
    "moderat": {
      "$value": "Moderat",
      "$type": "fontFamily",
      "$description": "Moderat — detected in extracted data but not described by AI"
    }
  },
