      "$value": "Suisse",
      "$type": "fontFamily",
      "$description": "Neo-grotesque sans for body copy, navigation, button labels, tags, and utility UI — 400 reads body, 500 carries button labels and nav, 600 anchors subheadings; the wide weight range lets this one family run the entire interface without switching faces"
    }
