{
  "color": {
    "cerulean-surge": {
      "$value": "#60CDFF",
      "$type": "color",
      "$description": "Cerulean Surge — Hero backgrounds, section backgrounds, badge borders — the dominant attention color that establishes PayPal's sky-blue identity across the first viewport and accent panels"
    },
    "cobalt-vault": {
      "$value": "#002991",
      "$type": "color",
      "$description": "Cobalt Vault — Deep-section backgrounds, card fills, navy sections — counterpoint to Cerulean Surge, appearing in feature sections to create the hot/cold alternating rhythm"
    },
    "ice-mist": {
      "$value": "#B8E9FF",
      "$type": "color",
      "$description": "Ice Mist — Subtle background tints in transitional or secondary panels within the blue range"
    },
    "cobalt-fade": {
      "$value": "#002991",
      "$type": "color",
      "$description": "Cobalt Fade — Gradient overlay used to bleed navy into transparent sections — see linear-gradient underline/band effect on interactive elements"
    },
    "midnight": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Midnight — Page text, button borders (black variant), nav items, headings on light/sky backgrounds"
    },
    "snow": {
      "$value": "#FFFFFF",
      "$type": "color",
      "$description": "Snow — Page backgrounds, card surfaces, button borders (white variant on dark/colored fields), body text on dark sections"
    },
    "parchment": {
      "$value": "#F1EFEA",
      "$type": "color",
      "$description": "Parchment — Warm off-white panel backgrounds — appears in transitional content sections"
    },
    "ash": {
      "$value": "#B3B3B3",
      "$type": "color",
      "$description": "Ash — Inactive/ghost card backgrounds, dimmed UI state fills"
    },
    "fog": {
      "$value": "#CCCCCC",
      "$type": "color",
      "$description": "Fog — Dividers, subdued body text on light backgrounds"
    }
  },
  "font": {
    "plain": {
      "$value": "Plain",
      "$type": "fontFamily",
      "$description": "All UI text: nav labels, body copy, footer, links, button labels, captions. At 16-18px with weight 400 it handles running text; at 22-26px weight 500 it becomes section subheadings. The -0.02em tracking is applied universally, tightening all sizes slightly against system defaults."
    },
    "paypal-pro": {
      "$value": "PayPal Pro",
      "$type": "fontFamily",
      "$description": "Display headlines and hero text. Weight 900 at 67–181px is the signature move — at these sizes with -0.03em tracking, individual letters fill nearly the full viewport width, functioning as graphic architecture not just type. Weight 400 handles nav and smaller headings. The extreme scale range (16px to 181px) within one family indicates it carries ALL heading duties across the page."
    }
  },
