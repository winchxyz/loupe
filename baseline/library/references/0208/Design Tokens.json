      "$description": "Source Sans Pro — detected in extracted data but not described by AI"
    },
    "figma-sans-display": {
      "$value": "Figma Sans Display",
      "$type": "fontFamily",
      "$description": "Headlines and display copy — used at 56–86px for hero ('Schema by Figma', 'Meet our speakers!') with tight leading (0.90–1.10) and -0.02em tracking that makes type feel carved from a block. Weight 400 carries the design; 700 is reserved for emphasis."
    },
    "figma-sans-text": {
      "$value": "Figma Sans Text",
      "$type": "fontFamily",
      "$description": "Body, nav, button labels, supporting text. The companion text face at modest sizes (13–18px) with weight 400 as default and 600 for buttons/labels. -0.02em at 13px prevents the small type from feeling loose; 0.03em at 18px gives labels air."
    },
    "figma-mono": {
      "$value": "Figma Mono",
      "$type": "fontFamily",
      "$description": "Code or metadata snippets — used sparingly at 16px with 0.03em tracking for an architectural, monospaced accent in a world of proportional text"
    },
