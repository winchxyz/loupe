{
  "color": {
    "cobalt-signal": {
      "$value": "#002fff",
      "$type": "color",
      "$description": "Cobalt Signal — Violet action color for filled buttons, selected navigation states, and focused conversion moments."
    },
    "pure-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Pure White — Page canvas, card surfaces, button text on cobalt fill, heading text on dark sections"
    },
    "graphite": {
      "$value": "#171717",
      "$type": "color",
      "$description": "Graphite — Primary body text, heading text, hairline borders, icon strokes — the workhorse near-black that carries UI structure"
    },
    "carbon": {
      "$value": "#070707",
      "$type": "color",
      "$description": "Carbon — Deepest text, dark gradient anchor points, near-black accents where maximum contrast is needed"
    },
    "ink": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Ink — Absolute black for borders, icons, and the film-strip frame effect — appears most in structural borders rather than type"
    },
    "fog": {
      "$value": "#ededed",
      "$type": "color",
      "$description": "Fog — Soft card surface lift, input fields, subtle background differentiation from pure white canvas"
    },
    "mist": {
      "$value": "#b9b9b9",
      "$type": "color",
      "$description": "Mist — Light surface wash, disabled or decorative backgrounds"
    },
    "dove": {
