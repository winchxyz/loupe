      "$value": "#fa8669",
      "$type": "color",
      "$description": "Coral Signal — Orange supporting accent for decorative details and low-frequency emphasis. Do not promote it to the primary CTA color"
    },
    "ink-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Ink Black — Primary text, button strokes, dark mode contrast pairs, icon outlines"
    },
    "carbon": {
      "$value": "#222222",
