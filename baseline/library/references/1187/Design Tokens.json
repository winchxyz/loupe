{
  "color": {
    "carbon-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Carbon Black — Primary text, filled action buttons, icons — the only assertive color in the system carries all interactive and typographic weight"
    },
    "paper-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper White — Card surfaces, product screenshot backgrounds, button labels on filled buttons"
    },
    "drafting-gray": {
      "$value": "#f7f7f7",
      "$type": "color",
      "$description": "Drafting Gray — Page canvas, the base surface every component sits on; sets the off-white tone that makes cards read as elevated without shadow"
    },
    "graphite": {
      "$value": "#313131",
      "$type": "color",
      "$description": "Graphite — Secondary headings and body emphasis, slightly softer than pure black for hierarchical depth"
    },
    "pencil-gray": {
      "$value": "#686868",
      "$type": "color",
      "$description": "Pencil Gray — Muted helper text, inactive metadata, subtle icon fills, soft borders on secondary surfaces"
    },
    "faint-gray": {
      "$value": "#bbbbbb",
      "$type": "color",
      "$description": "Faint Gray — Disabled state surfaces, ultra-quiet dividers, placeholder card backgrounds"
    },
    "charcoal-trace": {
      "$value": "#7c7c7c",
      "$type": "color",
      "$description": "Charcoal Trace — Tertiary caption text, very subtle annotation labels"
    },
    "highlighter-amber": {
      "$value": "#ffb700",
      "$type": "color",
      "$description": "Highlighter Amber — Annotation callout cards, highlight washes, tag pills — the single chromatic accent that mimics yellow highlighter on paper, used sparingly as functional punctuation not decoration"
    },
    "indigo-ink": {
      "$value": "#914db2",
      "$type": "color",
      "$description": "Indigo Ink — Pink outline accent for tags, dividers, and focused UI edges."
    },
    "link-navy": {
      "$value": "#003399",
      "$type": "color",
      "$description": "Link Navy — Outlined link borders and underlined text links — a classic editorial link blue, used only for inline hyperlink elements"
    }
  },
  "font": {
    "sans-serif": {
      "$value": "sans-serif",
      "$type": "fontFamily",
      "$description": "sans-serif — detected in extracted data but not described by AI"
    },
    "van-condensed-pro-bold": {
      "$value": "Van Condensed Pro Bold",
      "$type": "fontFamily",
      "$description": "Hero display headlines, section titles — the signature voice. Used uppercase at tight tracking to create compressed, industrial-scale authority that contrasts against the soft canvas. The only place the system shouts."
    },
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "Primary UI and body typeface. Carries 90% of the interface: navigation, buttons, body copy, list items, small headings. The 500/600 weights step in for UI emphasis; 700 is reserved for short label headings. Light negative tracking (-0.01em) at all sizes gives it a slightly tightened, modern feel without becoming display-level."
    },
    "roboto-mono": {
      "$value": "Roboto Mono",
      "$type": "fontFamily",
      "$description": "Code-style labels, keyboard shortcuts, technical metadata, monospaced micro-text within product chrome"
    },
