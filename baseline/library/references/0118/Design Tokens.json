  "font": {
    "dm-sans": {
      "$value": "DM Sans",
      "$type": "fontFamily",
      "$description": "Single-family system — display headlines at 69–116px weight 500–600 with tight tracking create the editorial feel; body at 16–18px weight 400; UI at 14–16px weight 500–600. The same font handles 12px captions through 116px display, which is the signature: one voice, enormous dynamic range. The ss03 stylistic set is enabled site-wide."
    }
  },
