{
  "color": {
    "obsidian": {
      "$value": "#0c0a09",
      "$type": "color",
      "$description": "Obsidian — Page background, hero canvas, base surface — carries a warm umber undertone rather than neutral black so the page reads as lit, not void"
    },
    "graphite": {
      "$value": "#1c1917",
      "$type": "color",
      "$description": "Graphite — Card surface, elevated panels, nav bar, footer — one step lighter than canvas to create depth without color shift"
    },
    "charcoal": {
      "$value": "#292524",
      "$type": "color",
      "$description": "Charcoal — Higher elevation surfaces, input fields, nested cards — second step in the surface stack"
    },
    "slate": {
      "$value": "#44403c",
      "$type": "color",
      "$description": "Slate — Tertiary surface, hover states on dark panels, subtle dividers in dense contexts"
    },
    "stone": {
      "$value": "#57534e",
      "$type": "color",
      "$description": "Stone — Supporting neutral for secondary UI, dividers, and muted labels. Do not promote it to the primary CTA color"
    },
    "ash": {
      "$value": "#78716c",
      "$type": "color",
      "$description": "Ash — Muted icon color, secondary metadata text, inactive stroke"
    },
    "pebble": {
      "$value": "#a8a29e",
      "$type": "color",
      "$description": "Pebble — Tertiary text, captions, supporting metadata"
    },
    "mist": {
      "$value": "#d6d3d1",
      "$type": "color",
      "$description": "Mist — Secondary text, link hover, subtle icon stroke"
    },
    "fog": {
      "$value": "#e5e7eb",
      "$type": "color",
      "$description": "Fog — Primary text, headings, nav links — the dominant text color across the interface"
    },
    "bone": {
      "$value": "#f6f6f6",
      "$type": "color",
      "$description": "Bone — High-emphasis text, button labels on dark fills, hero headline accent"
    },
    "pure": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Pure — Maximum contrast text, logo wordmark, high-priority callouts"
    },
    "pilot-gold": {
      "$value": "#cab16a",
      "$type": "color",
      "$description": "Pilot Gold — Yellow supporting accent for decorative details and low-frequency emphasis"
    },
    "circuit-green": {
      "$value": "#89b482",
      "$type": "color",
      "$description": "Circuit Green — Decorative geometry only — floating triangle/quarter-circle accents in hero and section backgrounds; never used on buttons or states"
    },
    "signal-red": {
      "$value": "#ea6962",
      "$type": "color",
      "$description": "Signal Red — Red supporting accent for decorative details and low-frequency emphasis"
    }
  },
  "font": {
    "circularxx": {
      "$value": "CircularXX",
      "$type": "fontFamily",
      "$description": "Workhorse sans for body, nav, buttons, cards, and form labels. Weight 400 is the UI default; 500 for button text and emphasized labels; 300 appears in the logotype wordmark. The slight negative tracking (-0.019em) tightens the humanist forms into a more instrumented feel."
    },
    "whyte": {
      "$value": "Whyte",
      "$type": "fontFamily",
      "$description": "Display face for hero headlines and section titles. Weight 300 at 72px with -0.056em tracking is the signature move: anti-convention for a dev tool, where most competitors use 700-800. The whisper-weight display creates authority through restraint — the type breathes instead of pushing."
    },
    "whyte-inktrap": {
      "$value": "Whyte Inktrap",
      "$type": "fontFamily",
      "$description": "Mid-size headings (30-60px) where the inktrap terminals prevent thin strokes from closing up at smaller display sizes. Bridges the gap between the light display weight and readable mid-size headings."
    },
    "circularxxmono": {
      "$value": "CircularXXMono",
      "$type": "fontFamily",
      "$description": "Code snippets, monospaced labels, technical metadata, version strings. Limited to 12-18px — always auxiliary, never structural."
    }
  },
