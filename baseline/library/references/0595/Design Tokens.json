{
  "color": {
    "ember-orange": {
      "$value": "#ffa16c",
      "$type": "color",
      "$description": "Ember Orange — Orange supporting accent for decorative details and low-frequency emphasis."
    },
    "signal-blue": {
      "$value": "#479ffa",
      "$type": "color",
      "$description": "Signal Blue — Blue supporting accent for decorative details and low-frequency emphasis. Do not promote it to the primary CTA color"
    },
    "tape-green": {
      "$value": "#4ebe96",
      "$type": "color",
      "$description": "Tape Green — Green supporting accent for decorative details and low-frequency emphasis. Use as a supporting accent, not as a status color"
    },
    "snow": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Snow — Primary text and foreground icons — the dominant interface voice against the dark canvas"
    },
    "fog": {
      "$value": "#868f97",
      "$type": "color",
      "$description": "Fog — Secondary/muted body text, helper copy, inactive labels — carries the load when white would shout"
    },
    "ash": {
      "$value": "#cccccc",
      "$type": "color",
      "$description": "Ash — Tertiary text, disabled icons, low-emphasis captions"
    },
    "smoke": {
      "$value": "#999999",
      "$type": "color",
      "$description": "Smoke — Muted body and metadata text — sits between Fog and the canvas for non-essential information"
    },
    "iron": {
      "$value": "#828282",
      "$type": "color",
      "$description": "Iron — Secondary headings and chart axis labels"
    },
    "platinum": {
      "$value": "#e6e6e6",
      "$type": "color",
      "$description": "Platinum — Hairline borders, divider lines, ghost button outlines — the thinnest readable separator on dark"
    },
    "slate": {
      "$value": "#525252",
      "$type": "color",
      "$description": "Slate — Dim borders, inactive chart gridlines, low-contrast dividers where Platinum would be too bright"
    },
    "void": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Void — Deepest surface and shadow core — used inside elevated elements and behind the heaviest drop-shadows"
    },
    "obsidian": {
      "$value": "#0b0b0b",
      "$type": "color",
      "$description": "Obsidian — Primary page canvas — the near-black the entire UI floats on"
    },
    "graphite": {
      "$value": "#131313",
      "$type": "color",
      "$description": "Graphite — First-level card surface — visible separation from canvas without brightness"
    }
  },
  "font": {
    "calibre": {
      "$value": "calibre",
      "$type": "fontFamily",
      "$description": "Sole typeface for the entire system — UI, display, body, nav, and footer. The aggressive negative letter-spacing at large sizes (-0.08em at 48–54px) tightens display copy into something architectural and modern; 400 is the workhorse, 600–700 for emphasis. Calibre's slightly compressed geometry and tall x-height make it read as a financial-grade instrument typeface, closer to a Bloomberg label than a friendly app."
    }
  },
