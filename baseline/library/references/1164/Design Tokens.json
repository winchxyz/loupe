{
  "color": {
    "void": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Void — Page background, section backgrounds — the dominant canvas; everything else floats on this"
    },
    "bone": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Bone — Primary headings, body text, nav items, icon strokes, button labels"
    },
    "ash": {
      "$value": "#a1a1a1",
      "$type": "color",
      "$description": "Ash — Muted secondary text, inactive nav, subdued labels, hairline borders on dark"
    },
    "frost": {
      "$value": "#e5e5e5",
      "$type": "color",
      "$description": "Frost — Icon strokes, subtle dividers, light foreground accents"
    },
    "graphite": {
      "$value": "#262626",
      "$type": "color",
      "$description": "Graphite — Subtle card borders and dividers on the black canvas"
    },
    "lilac-haze": {
      "$value": "#f4f0ff",
      "$type": "color",
      "$description": "Lilac Haze — Link text and near-white secondary copy — a barely-violet tint that warms the pure white without breaking the monochrome rule"
    },
    "iridescent-pink": {
      "$value": "#d1aad7",
      "$type": "color",
      "$description": "Iridescent Pink — Decorative gradient stop — appears inside the hero 3D shape and gradient washes; not used as a UI accent; Iridescent gradient field applied to hero 3D objects and accent surfaces"
    },
    "iridescent-blue": {
      "$value": "#bbdef2",
      "$type": "color",
      "$description": "Iridescent Blue — Decorative gradient stop — the cool counterweight to Lilac Pink inside holographic assets; not used in interface chrome"
    }
  },
  "font": {
    "aeonik": {
      "$value": "Aeonik",
      "$type": "fontFamily",
      "$description": "Display and heading face — used at 48–89px for hero and section titles, always at weight 300. The ultra-light weight on a humanist geometric is the signature: enterprise AI copy rendered like an editorial magazine."
    },
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "Body, UI, navigation, and button text. 16px / 1.65 is the canonical body. Medium 500 is reserved for emphasis inside otherwise-regular runs and for primary button labels."
    },
    "geist": {
      "$value": "Geist",
      "$type": "fontFamily",
      "$description": "Eyebrow labels rendered as small caps with wide tracking (0.071em–0.083em). Used for section pre-titles above headings."
    }
  },
