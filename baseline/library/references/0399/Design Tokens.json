{
  "color": {
    "surfshark-teal": {
      "$value": "#1ebfbf",
      "$type": "color",
      "$description": "Surfshark Teal — Brand mark icon, accent highlights, inline link emphasis — the signature chromatic thread that ties logo, headings, and accent text together"
    },
    "coral-pulse": {
      "$value": "#fa3556",
      "$type": "color",
      "$description": "Coral Pulse — Primary action buttons, high-urgency CTAs — warm pink-red against the cool palette creates immediate conversion pull"
    },
    "promo-gold": {
      "$value": "#ffc200",
      "$type": "color",
      "$description": "Promo Gold — Promotional banner background, limited-time deal strips — golden yellow reserved exclusively for urgency framing"
    },
    "charcoal-ink": {
      "$value": "#16191c",
      "$type": "color",
      "$description": "Charcoal Ink — Primary text, dark hero backgrounds, footer surfaces, button text on coral — near-black with a hint of cool depth"
    },
    "pure-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Pure White — Page canvas, card surfaces, button text on dark fills, text on coral CTAs"
    },
    "fog-white": {
      "$value": "#f9f9f9",
      "$type": "color",
      "$description": "Fog White — Alternate canvas surface, subtle card backgrounds, soft section differentiation from pure white"
    },
    "tide-tint": {
      "$value": "#e8f7f8",
      "$type": "color",
      "$description": "Tide Tint — Faint teal-tinted surface wash — barely-perceptible background variant for feature blocks"
    },
    "ash-gray": {
      "$value": "#dadadd",
      "$type": "color",
      "$description": "Ash Gray — Light borders, dividers, subtle separation lines — cooler-toned hairline color"
    },
    "mist-gray": {
      "$value": "#bfbfc0",
      "$type": "color",
      "$description": "Mist Gray — Secondary borders, disabled states, heavy-use divider color (highest neutral frequency after black)"
    },
    "slate": {
      "$value": "#5b6065",
      "$type": "color",
      "$description": "Slate — Muted body text, secondary copy, icon strokes in resting state"
    },
    "graphite": {
      "$value": "#393e41",
      "$type": "color",
      "$description": "Graphite — Navigation borders, tertiary UI elements, slightly lighter than Charcoal for layered depth"
    },
    "carbon": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Carbon — Maximum-contrast borders, SVG icon fills, structural strokes — used heavily for crisp 1px rules"
    },
    "deep-abyss": {
      "$value": "#1e2327",
      "$type": "color",
      "$description": "Deep Abyss — Alternate dark surface — slightly bluer than Charcoal, used in distinct dark panels"
    }
