{
  "color": {
    "midnight-navy": {
      "$value": "#011c42",
      "$type": "color",
      "$description": "Midnight Navy — Page background, section canvas, footer — the dominant surface that gives the entire site its terminal-like confidence"
    },
    "canvas-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Canvas White — Primary text on dark surfaces, icon strokes, card text in light contexts"
    },
    "obsidian": {
      "$value": "#0b100f",
      "$type": "color",
      "$description": "Obsidian — Near-black text for light-context sections, logo mark, high-contrast headings"
    },
    "warm-sand": {
      "$value": "#f8f1e5",
      "$type": "color",
      "$description": "Warm Sand — Secondary text on dark surfaces, warm accent surface, card borders in light contexts — adds cream warmth that prevents the dark UI from feeling sterile"
    },
    "silver-mist": {
      "$value": "#c0c1c6",
      "$type": "color",
      "$description": "Silver Mist — Hairline borders, dividers, subtle separator strokes — the dominant neutral structural line (5200+ occurrences)"
    },
    "pewter": {
      "$value": "#c5beb2",
      "$type": "color",
      "$description": "Pewter — Box-shadow tone, muted accents on cream surfaces"
    },
    "bioluminescent-teal": {
      "$value": "#34e8bb",
      "$type": "color",
      "$description": "Bioluminescent Teal — Primary action — filled CTA buttons (Download), in-text links, nav accent, active states. The single chromatic color permitted to carry interactive meaning; glows against midnight navy"
    },
    "deep-teal": {
      "$value": "#003326",
      "$type": "color",
      "$description": "Deep Teal — Text on teal surfaces, dark-mode button color variant"
    },
    "lavender-mist": {
      "$value": "#a95af8",
      "$type": "color",
      "$description": "Lavender Mist — Card backgrounds, feature card fills, decorative chip backgrounds — provides purple dimension in card grids"
    },
    "bubblegum": {
      "$value": "#fb9ce5",
      "$type": "color",
      "$description": "Bubblegum — Outlined/ghost action borders, accent text, icon fills, pill button outlines — the secondary accent that complements teal in interactive components"
    },
    "plum-wine": {
      "$value": "#43045e",
      "$type": "color",
      "$description": "Plum Wine — Deep purple card surface variant, layered card backgrounds"
    },
    "soft-blush": {
      "$value": "#ffccf3",
      "$type": "color",
      "$description": "Soft Blush — Light pink card backgrounds, soft accent surface"
    },
    "cosmic-blue": {
      "$value": "#006aff",
      "$type": "color",
      "$description": "Cosmic Blue — Card accent fills, decorative stroke accent"
    },
    "plum-statement": {
      "$value": "#5c0047",
      "$type": "color",
      "$description": "Plum Statement — Magenta text and headings in accent contexts, feature highlight copy"
    }
  },
  "font": {
    "tomatogrotesk": {
      "$value": "tomatoGrotesk",
      "$type": "fontFamily",
      "$description": "Display headlines only. The weight 300 at 64-96px is the signature choice — most marketing sites use 600-700 for display; this system lets size carry authority and keeps weight whisper-thin. Used for hero ('Where developers are doing their best work'), section titles ('Cascade', 'Devin'), and feature headings."
    },
    "dm-sans": {
      "$value": "DM Sans",
      "$type": "fontFamily",
      "$description": "Body text, subheadings, navigation, buttons, list items, card content. The workhorse font — comfortable geometric sans with moderate negative tracking that tightens the feel without sacrificing readability."
    },
    "dm-mono": {
      "$value": "DM Mono",
      "$type": "fontFamily",
      "$description": "Code-adjacent labels, BETA badges, nav micro-text, technical annotations. The monospace signals 'developer tool' — its 0.05em positive tracking on caps reads as technical/precise, a deliberate contrast to the whisper-thin display weight."
    },
    "ui-sans-serif": {
      "$value": "ui-sans-serif",
      "$type": "fontFamily",
      "$description": "System fallback for browser-default rendering and any text not covered by the primary fonts. Sparse usage — the custom fonts carry the brand."
    }
  },
