    "forest-ink": {
      "$value": "#07503f",
      "$type": "color",
      "$description": "Forest Ink — Primary brand color, header background, nav bar fill, section dividers, footer — deep teal-green against warm cream creates agricultural gravitas"
    },
    "vivid-lime": {
      "$value": "#e8fe85",
      "$type": "color",
      "$description": "Vivid Lime — Promotional marquee strip, highlight announcement bars, occasional link hover wash — the only high-energy accent in the palette"
    },
