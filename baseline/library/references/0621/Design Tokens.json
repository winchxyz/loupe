{
  "color": {
    "iris-glow": {
      "$value": "#9985ff",
      "$type": "color",
      "$description": "Iris Glow — Primary brand accent — headline words, diagram group borders, and the violet offset shadow that makes hero cards pop off the canvas"
    },
    "pale-lavender": {
      "$value": "#ddccff",
      "$type": "color",
      "$description": "Pale Lavender — Softened brand accent — used where Iris Glow would be too saturated, particularly in headline strokes and lighter decorative borders"
    },
    "violet-deep": {
      "$value": "#363054",
      "$type": "color",
      "$description": "Violet Deep — Accent shadow tone — paired with the 6px solid-offset shadow recipe to make Iris Glow feel grounded on the dark canvas"
    },
    "sky-pulse": {
      "$value": "#94dbff",
      "$type": "color",
      "$description": "Sky Pulse — Cool accent — second headline color and decorative border accent; the blue counterpart to the violet brand system"
    },
    "saffron-whisper": {
      "$value": "#d6ca6f",
      "$type": "color",
      "$description": "Saffron Whisper — Warm accent — third headline color, brings the gold/amber note into the multi-word display treatment"
    },
    "rose-quartz": {
      "$value": "#ffa3c2",
      "$type": "color",
      "$description": "Rose Quartz — Warm accent — fourth headline color, the pink note that completes the four-color headline palette"
    },
    "bone": {
      "$value": "#e3e3e3",
      "$type": "color",
      "$description": "Bone — Primary text and dominant border color across the interface — the single most-used color in the system"
    },
    "obsidian": {
      "$value": "#181818",
      "$type": "color",
      "$description": "Obsidian — Page canvas and card fill background — the dark base everything sits on"
    },
    "charcoal": {
      "$value": "#4b4b4b",
      "$type": "color",
      "$description": "Charcoal — Muted borders and dividers, secondary structural lines on dark surfaces"
    },
    "ink-black": {
      "$value": "#080808",
      "$type": "color",
      "$description": "Ink Black — Deepest shadow tone — used in the 6px 6px 0 hard-offset shadow under standard cards"
    },
    "pure-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Pure White — Primary action fill — the only CTA button background; also used for high-emphasis text on dark surfaces"
    },
    "pearl": {
      "$value": "#f6f6f6",
      "$type": "color",
      "$description": "Pearl — Secondary text color and heading borders where Bone is too cool"
    },
    "slate": {
      "$value": "#2a2b2b",
      "$type": "color",
      "$description": "Slate — Subtle borders — the barely-there divider for low-emphasis separation"
    },
    "graphite": {
      "$value": "#878787",
      "$type": "color",
      "$description": "Graphite — Muted text and link borders — body copy de-emphasized, nav text in resting state"
    },
    "ash": {
      "$value": "#666666",
      "$type": "color",
      "$description": "Ash — Subtle link borders for de-emphasized text links"
    }
  },
  "font": {
    "national-2-condensed": {
      "$value": "National 2 Condensed",
      "$type": "fontFamily",
      "$description": "Display and hero headlines only — used for the brand's biggest typographic statement. The 0.85 line-height is unusually tight and makes multi-line headlines stack like a poster, not flow like prose. Combined with -0.007em tracking and condensed proportions, this face carries authority without weight."
    },
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "All UI text — body, nav, buttons, labels, subheadings, and card titles. The 400 weight is the workhorse; 600 is reserved for emphasis. The slight -0.019em tracking tightens UI text on the dark canvas, giving it the same technical-drawing precision as the display face. No 300 weight — restraint here means condensed, not thin."
    },
    "jetbrains-mono": {
      "$value": "JetBrains Mono",
      "$type": "fontFamily",
      "$description": "Code and technical tokens — used for diagram node labels, code snippets, and any monospaced context. The 1.00 line-height variant is for inline monospaced glyphs."
    }
  },
