      "$type": "color",
      "$description": "Fog — Page canvas and section background — the dominant pale-gray that separates content bands from pure white card surfaces"
    },
    "pure-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Pure White — Card surfaces, button text on dark fills, nav backgrounds, and badge interiors"
