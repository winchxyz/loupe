{
  "color": {
    "apple-blue": {
      "$value": "#0071e3",
      "$type": "color",
      "$description": "Apple Blue — Primary CTA fill — the single saturated button on the page (Comprar, Learn more). Vivid mid-blue that reads as a switch-on moment against matte neutrals"
    },
    "link-blue": {
      "$value": "#0066cc",
      "$type": "color",
      "$description": "Link Blue — Inline text links, footnote references, and underlined link borders. Slightly deeper and cooler than the CTA blue so links and buttons read as distinct actions"
    },
    "signal-green": {
      "$value": "#03aa49",
      "$type": "color",
      "$description": "Signal Green — Accent stroke for positive health/sleep metric visualizations and decorative data highlights on product UI"
    },
    "ember-orange": {
      "$value": "#ed6300",
      "$type": "color",
      "$description": "Ember Orange — Orange outline accent for tags, dividers, and focused UI edges"
    },
    "iris-violet": {
      "$value": "#8668ff",
      "$type": "color",
      "$description": "Iris Violet — Tertiary accent for multicolor data rings, decorative product UI, and illustration strokes"
    },
    "deep-teal": {
      "$value": "#00a1b3",
      "$type": "color",
      "$description": "Deep Teal — Quaternary accent completing the Apple Watch activity ring palette"
    },
    "space-black": {
      "$value": "#1d1d1f",
      "$type": "color",
      "$description": "Space Black — Primary text, heading fills, icon strokes, and card borders. Apple's near-black — softer than #000, reads warm against white"
    },
    "sterling": {
      "$value": "#707070",
      "$type": "color",
      "$description": "Sterling — Secondary/muted text, nav borders, list dividers, and subdued UI labels"
    },
    "graphite": {
