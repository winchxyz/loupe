{
  "color": {
    "espresso-ink": {
      "$value": "#26251e",
      "$type": "color",
      "$description": "Espresso Ink — Primary text, dark filled buttons (Download CTA), nav, icon strokes — warm near-black instead of pure #000, gives the interface a printed-ink quality"
    },
    "page-parchment": {
      "$value": "#f7f7f4",
      "$type": "color",
      "$description": "Page Parchment — Page canvas, card surfaces, button text on dark fills — the base warm white that everything sits on"
    },
    "card-stone": {
      "$value": "#e6e5e0",
      "$type": "color",
      "$description": "Card Stone — Elevated card surfaces, secondary button backgrounds, subtle section banding — one step warmer/darker than the page"
    },
    "border-sand": {
      "$value": "#d9d5cf",
      "$type": "color",
      "$description": "Border Sand — Hairline dividers, card borders, input borders — barely-visible warm gray for structure"
    },
    "muted-clay": {
      "$value": "#7a7974",
      "$type": "color",
      "$description": "Muted Clay — Muted body text, secondary icons, placeholder text — mid-warm-gray for non-primary reading"
    },
    "edge-ash": {
      "$value": "#8f8e89",
      "$type": "color",
      "$description": "Edge Ash — Borders on subtle UI elements, tertiary text — slightly lighter than muted clay for de-emphasized structure"
    },
    "trace-smoke": {
      "$value": "#a1a19f",
      "$type": "color",
      "$description": "Trace Smoke — Faintest borders, disabled states, ghost-button outlines — the lightest visible neutral"
    },
    "deep-charcoal": {
      "$value": "#141414",
      "$type": "color",
      "$description": "Deep Charcoal — Pure dark accent for high-emphasis text and critical UI elements — used sparingly when absolute black is needed"
    },
    "ember-orange": {
      "$value": "#f54e00",
      "$type": "color",
      "$description": "Ember Orange — Link underlines, link text on hover, chromatic interactive accents — the single vivid brand accent, rationed to interactive moments only"
    },
    "signal-green": {
      "$value": "#4ade80",
      "$type": "color",
      "$description": "Signal Green — Green outline accent for tags, dividers, and focused UI edges. Use as a supporting accent, not as a status color"
    },
    "brass-gold": {
      "$value": "#c08532",
      "$type": "color",
      "$description": "Brass Gold — Decorative icon strokes, tag accents, warm illustrative fills — secondary warm accent for product-screenshot chrome"
    },
    "deep-moss": {
      "$value": "#34785c",
      "$type": "color",
      "$description": "Deep Moss — Secondary button states, outlined action borders on warm surfaces — a desaturated forest green for alternative CTAs"
    }
  },
  "font": {
    "cursorgothic": {
      "$value": "CursorGothic",
      "$type": "fontFamily",
      "$description": "Primary brand typeface — used for everything from body copy to 72px display headlines. Single weight 400 with tight negative tracking at larger sizes creates editorial authority without bold. The custom face has monospace DNA (tabular numerals via 'tnum', stylistic alternates ss08/ss09) making it feel like a humanist sans designed for code-adjacent UI."
    },
    "berkeleymono": {
      "$value": "berkeleyMono",
      "$type": "fontFamily",
      "$description": "Monospace companion for code snippets, CLI commands, file paths, and terminal text — appears in product screenshots and inline code contexts. Weight 500 for emphasis within code blocks."
    },
    "eb-garamond": {
      "$value": "EB Garamond",
      "$type": "fontFamily",
      "$description": "Surprise serif accent used sparingly — breaks the sans-serif rhythm for editorial pull-quotes or italicized flourishes, creating a literary counterpoint to the technical CursorGothic."
    },
    "lato": {
      "$value": "Lato",
      "$type": "fontFamily",
      "$description": "Secondary sans for utility text, small labels, and supplementary UI — appears where CursorGothic isn't loaded or for sub-12px micro-copy."
    },
    "apple-system": {
      "$value": "-apple-system",
      "$type": "fontFamily",
      "$description": "-apple-system — detected in extracted data but not described by AI"
    }
  },
