{
  "color": {
    "ice-signal": {
      "$value": "#83c3ff",
      "$type": "color",
      "$description": "Ice Signal — Verified badges, link text, outlined button borders, focus rings, and filter pills — the only chromatic accent on a monochrome canvas, cool enough to read as informational rather than promotional"
    },
    "paper-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper White — Primary text, icon strokes, hairline borders, and checkbox fills — the dominant surface signal against the near-black canvas"
    },
    "fog": {
      "$value": "#acadae",
      "$type": "color",
      "$description": "Fog — Muted secondary text, placeholder copy, and subtle borders — the bridge tone between paper white and the dark surfaces"
    },
    "iron": {
      "$value": "#34353c",
      "$type": "color",
      "$description": "Iron — Outlined button borders and tertiary dividers on the main canvas — the lightest neutral that still reads as a structural edge"
    },
    "slate": {
      "$value": "#3c3d40",
      "$type": "color",
      "$description": "Slate — Hover-state surface wash on icons and small controls, lightest elevated background in the stack"
    },
    "graphite": {
      "$value": "#26272d",
      "$type": "color",
      "$description": "Graphite — Navigation rail, footer, and elevated panel backgrounds — one step above the page surface"
    },
    "charcoal": {
      "$value": "#1b1d1f",
      "$type": "color",
      "$description": "Charcoal — Page canvas and card surface — the dominant background under all content"
    },
    "obsidian": {
      "$value": "#141415",
      "$type": "color",
      "$description": "Obsidian — Top navigation bar and footer base — the deepest layer of the surface stack"
    },
    "void": {
      "$value": "#080809",
      "$type": "color",
      "$description": "Void — Body backdrop, outer page shell, and deepest shadow zone behind the nav"
    }
  },
