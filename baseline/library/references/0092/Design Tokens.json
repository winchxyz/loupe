      "$description": "ui-sans-serif — detected in extracted data but not described by AI"
    },
    "suisse-intl": {
      "$value": "Suisse Intl",
      "$type": "fontFamily",
      "$description": "Primary brand typeface for headlines, navigation, body, and UI. The 55px display at line-height 1.10 with -0.015em tracking is the signature voice — editorial weight, magazine-tight rhythm. Weight 500 is reserved for nav links and select emphasis."
    },
    "system-sans-serif": {
      "$value": "System Sans-Serif",
      "$type": "fontFamily",
      "$description": "Secondary UI text, system fallbacks, form labels. Used sparingly — Suisse Intl is the workhorse. System stack appears for form fields and accessibility fallbacks where neutral rendering matters."
    }
  },
