  "font": {
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "All UI chrome — nav, buttons, body copy, captions, links. The workhorse that disappears into the interface. 600 weight used for interactive emphasis, 400 for running text."
    },
    "domaine": {
      "$value": "Domaine",
      "$type": "fontFamily",
      "$description": "Display-only serif for the largest hero statements and section closers. Weight 400 at near-100px is anti-convention — most dev tools use grotesque sans at this scale, the serif creates authority through editorial restraint. Tightest tracking in the system."
    },
    "abcfavorit": {
      "$value": "ABCFavorit",
      "$type": "fontFamily",
      "$description": "Section headings and subheadings. At 56px weight 400 with -0.05em tracking, punches well above its point size. At 14-20px used for feature labels and callouts. The custom geometric grotesque gives sharper corners than Inter, distinguishing marketing headings from UI copy."
    },
    "commitmono": {
      "$value": "CommitMono",
      "$type": "fontFamily",
      "$description": "Code samples, badge labels, filename strings, and terminal-style inline snippets. Distinguishes developer content from prose at a glance — the monospace voice signals 'this is actual code', not metaphor."
    },
    "helvetica": {
      "$value": "Helvetica",
      "$type": "fontFamily",
      "$description": "Helvetica — detected in extracted data but not described by AI"
    },
    "apple-system": {
      "$value": "-apple-system",
      "$type": "fontFamily",
      "$description": "-apple-system — detected in extracted data but not described by AI"
    }
  },
