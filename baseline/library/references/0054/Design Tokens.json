      "$value": "#9281f7",
      "$type": "color",
      "$description": "Resend Violet — Code syntax highlights, email address text in product UI, decorative icon borders — the brand's signature hue, always used inside product surfaces rather than nav or shell; Email app icon gradient from violet to purple — product identity mark"
    },
    "surface-lift": {
      "$value": "#1b1b1b",
