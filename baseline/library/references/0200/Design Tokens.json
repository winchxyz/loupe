{
  "color": {
    "obsidian-canvas": {
      "$value": "#1c1d20",
      "$type": "color",
      "$description": "Obsidian Canvas — Page background, card surfaces, text on light surfaces, hairline borders — the near-black that owns 95% of the interface"
    },
    "bone-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Bone White — Primary text, inverted card surfaces, link text on violet, subtle inset borders — the only light tone in the system"
    },
    "fog": {
      "$value": "#999d9e",
      "$type": "color",
      "$description": "Fog — Muted secondary text, captions, metadata — sits between the canvas and white in the neutral scale"
    },
    "graphite": {
      "$value": "#494a4d",
      "$type": "color",
      "$description": "Graphite — Elevated surface layer above the canvas, soft card backgrounds, link hover glow — adds a half-step of depth without breaking the monochrome read"
    },
    "electric-iris": {
      "$value": "#455ce9",
      "$type": "color",
      "$description": "Electric Iris — Accent card fills, link/button backgrounds, active state highlights — the one chromatic voice; its vividness is amplified by 99% achromatic surroundings"
    },
    "deep-iris": {
      "$value": "#334bd3",
      "$type": "color",
      "$description": "Deep Iris — Secondary accent surface, deeper violet card variant — used when the primary iris needs a stepped companion for layered cards or gradient-feeling stacks"
    }
  },
  "font": {
    "dennis-sans": {
      "$value": "Dennis Sans",
      "$type": "fontFamily",
      "$description": "Single-family system. Weight 450 is non-standard — not light, not bold, sits in the medium range to feel editorial rather than corporate. Uniform 0.0500em letter-spacing across all sizes creates a distinctive mechanical rhythm. Display sizes (60–216px) use tight line-height (1.00–1.07) so headlines touch or nearly touch; body sizes (14–17px) open up to 1.40–1.66 for readability. The 216px hero name is the signature element — it dwarfs everything else and bleeds off-canvas as intent."
    }
  },
