{
  "color": {
    "void-canvas": {
      "$value": "#080808",
      "$type": "color",
      "$description": "Void Canvas — Primary page background; the base upon which all display type and floating shapes sit"
    },
    "absolute-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Absolute Black — Deepest surface, decorative fills, icon strokes — the floor beneath the void"
    },
    "charcoal-plate": {
      "$value": "#171617",
      "$type": "color",
      "$description": "Charcoal Plate — Footer and inverted section backgrounds, slightly elevated off the base void"
    },
    "smoke-plate": {
      "$value": "#262525",
      "$type": "color",
      "$description": "Smoke Plate — Secondary surface for content blocks and image treatments layered over the void"
    },
    "graphite-lift": {
      "$value": "#393939",
      "$type": "color",
      "$description": "Graphite Lift — Subtle elevation surface and card background; the only visible shadow color"
    },
    "bone-white": {
      "$value": "#fcfcfc",
      "$type": "color",
      "$description": "Bone White — Primary text, hairline borders, icon outlines — the dominant non-black color in the system"
    },
    "linen": {
      "$value": "#f3efef",
      "$type": "color",
      "$description": "Linen — Inverted body sections, off-white text on dark cards, soft warm-white content surfaces"
    },
    "ash": {
      "$value": "#d4d2d2",
      "$type": "color",
      "$description": "Ash — Muted secondary text, nav labels, subtle borders — the whispered voice between bone and graphite"
    },
    "pebble": {
      "$value": "#b5b2b2",
      "$type": "color",
      "$description": "Pebble — Disabled borders, tertiary helper text, low-priority metadata"
    },
    "iron": {
      "$value": "#525252",
      "$type": "color",
      "$description": "Iron — Link underlines, nav dividers, hairline separators on dark surfaces"
    },
    "arterial-red": {
      "$value": "#fe1e34",
      "$type": "color",
      "$description": "Arterial Red — Sole brand accent — card borders, cursor, hero dot, gradient terminator; the only saturated color and it is used like a heartbeat, not a coat of paint"
    },
    "crimson-pure": {
      "$value": "#ff0000",
      "$type": "color",
      "$description": "Crimson Pure — Heading underline accent and decorative fill — a purer red for typographic emphasis only"
    }
  },
  "font": {
    "kmr-waldenburg": {
      "$value": "Kmr Waldenburg",
      "$type": "fontFamily",
      "$description": "Primary display and UI typeface across nav, headings, body, buttons, and the full scale from 10px tracked nav labels to 160px hero display. The custom face is the system's signature — its bold caps at 64–160px carry negative tracking (-0.075em to -0.080em) that compresses the letters into architectural blocks. Substitute: Neue Haas Grotesk Display, or Inter at matching weights and tracking."
    },
    "editorialnew": {
      "$value": "Editorialnew",
      "$type": "fontFamily",
      "$description": "Serif italic companion — appears as the 'crafting' / 'for the' connective words between display caps and as refined body/heading accents. The contrast of this soft serif whisper against the 700-weight caps is the system's typographic signature. Substitute: Editorial Old, Canela, or Playfair Display Italic."
    },
    "dirtyline-36-daysoftype-2022": {
      "$value": "Dirtyline 36 Daysoftype 2022",
      "$type": "fontFamily",
      "$description": "Ornamental display face used for single-letter or short-word spectacle moments (the stylized 'a' in 'WE ARE'). Aggressive -0.100em tracking at 24px makes it a sculptural object rather than readable type. Substitute: Tobias, Rogue Serif, or any expressive display serif with calligraphic contrast."
    },
    "system-ui": {
      "$value": "system-ui",
      "$type": "fontFamily",
      "$description": "Quiet body fallback and small icon labels — only used where Kmr Waldenburg's geometric personality would overpower micro-copy. Effectively the 'muted' voice in the type system."
    }
  },
