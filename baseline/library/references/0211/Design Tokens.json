{
  "color": {
    "jade-cta": {
      "$value": "#00c27a",
      "$type": "color",
      "$description": "Jade CTA — Primary CTA buttons, active links, key interactive highlights — jade against black in the hero and against white in body sections maintains equal visual force without changing hue"
    },
    "mint-surface": {
      "$value": "#b4f5c8",
      "$type": "color",
      "$description": "Mint Surface — Card backgrounds, feature highlight areas — pastel counterpoint to jade that reads as 'selected' or 'active' without the full saturation of CTA jade"
    },
    "forest": {
      "$value": "#00843f",
      "$type": "color",
      "$description": "Forest — Card accent backgrounds, deep green surface variant"
    },
    "badge-leaf": {
      "$value": "#d5f8e0",
      "$type": "color",
      "$description": "Badge Leaf — Blog/category badge backgrounds — near-white green tint that signals categorization without demanding attention"
    },
    "badge-text": {
      "$value": "#007b3b",
      "$type": "color",
      "$description": "Badge Text — Badge text and border on leaf background — dark enough on #d5f8e0 to pass contrast without going full black"
    },
    "void": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Void — Hero background, primary text, button borders, icon fills — the dominant surface and text color simultaneously; this dual role is the system's core tension"
    },
    "paper": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper — Section backgrounds, card surfaces, nav background"
    },
