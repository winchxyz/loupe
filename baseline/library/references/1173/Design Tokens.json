  "font": {
    "hedvig-letters-serif": {
      "$value": "Hedvig Letters Serif",
      "$type": "fontFamily",
      "$description": "Display and heading serif — all hero/section headlines, used at large sizes with tight letter-spacing. The warm humanist serif is the brand's voice; it gives the compliance product a literary, trustworthy quality instead of a sterile SaaS feel. The 700 weight carries the headlines, while 400 appears in larger pull-quote contexts."
    },
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "All UI and body text — nav links, button labels, form fields, card copy, footer text, small caps labels. Inter handles the functional layer with neutral efficiency, letting the serif carry the personality. Weight 500 for nav and labels, 400 for body, 600 for emphasis."
    }
  },
