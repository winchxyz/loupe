{
  "color": {
    "ember-orange": {
      "$value": "#de4c00",
      "$type": "color",
      "$description": "Ember Orange — Primary CTAs, active nav items, icon fills, link accents — the only chromatic color in the UI, it acts as a power-switch indicator against the muted neutrals"
    },
    "soft-ember": {
      "$value": "#efa680",
      "$type": "color",
      "$description": "Soft Ember — Hover-state borders, subdued accent outlines, tag strokes — a desaturated echo of Ember Orange for quieter accents"
    },
    "bone-white": {
      "$value": "#fffefb",
