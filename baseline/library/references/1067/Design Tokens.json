  "color": {
    "indigo-pulse": {
      "$value": "#3b3996",
      "$type": "color",
      "$description": "Indigo Pulse — Supporting palette color for small decorative accents when the core palette needs contrast. Do not promote it to the primary CTA color"
    },
    "slate": {
      "$value": "#6e6d7a",
      "$type": "color",
      "$description": "Slate — Hairline borders, dividers, secondary text, list separators — the structural gray that quietly defines the page grid"
    },
    "graphite": {
      "$value": "#383938",
      "$type": "color",
      "$description": "Graphite — Navigation text, heading text, dark UI elements — the primary readable dark on white"
    },
    "ink": {
      "$value": "#111111",
      "$type": "color",
      "$description": "Ink — Headline color, strongest body emphasis, near-black for maximum contrast on light surfaces"
    },
    "paper": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper — Page background, card surfaces, text on dark/indigo fills — the dominant canvas"
    },
    "mist": {
      "$value": "#edeef3",
      "$type": "color",
      "$description": "Mist — Elevated panels, subtle background washes, light borders — the cool-tinted off-white that lifts content above the page"
