{
  "color": {
    "ink": {
      "$value": "#303336",
      "$type": "color",
      "$description": "Ink — Primary text, body copy, heading text — near-black with a faint cool cast, never pure #000, keeping the page from feeling harsh"
    },
    "paper": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper — Card surfaces, elevated product mockups, input fields — pure white against the cooler canvas reads as lifted, not flat"
    },
    "mist": {
      "$value": "#f2f5f7",
      "$type": "color",
      "$description": "Mist — Page canvas, full-width background bands — a cool-tinted off-white that feels softer than pure white but still reads as light"
    },
    "fog": {
      "$value": "#838b96",
      "$type": "color",
      "$description": "Fog — Secondary body text, helper copy, muted descriptions — the most-used neutral after Ink, creates the dominant mid-tone of the page"
    },
    "ash": {
      "$value": "#55606e",
      "$type": "color",
      "$description": "Ash — Tertiary text, icon strokes, decorative dividers — a cool gray that still carries enough chroma to read as designed, not default"
    },
    "smoke": {
      "$value": "#44474b",
      "$type": "color",
      "$description": "Smoke — Deep body text alternative, emphasized inline text — sits between Ink and Fog for mid-emphasis passages"
    },
    "silver": {
      "$value": "#9299a4",
      "$type": "color",
      "$description": "Silver — Disabled or de-emphasized text, tertiary metadata"
    },
    "pebble": {
      "$value": "#8e9196",
      "$type": "color",
      "$description": "Pebble — Muted link text, breadcrumb-style secondary navigation"
    },
    "hairline": {
      "$value": "#dfe3e8",
      "$type": "color",
      "$description": "Hairline — Input borders, subtle dividers, card edges — cool and barely-there, defines boundaries without darkening the surface"
    },
    "signal-blue": {
      "$value": "#2576eb",
      "$type": "color",
      "$description": "Signal Blue — Blue supporting accent for decorative details and low-frequency emphasis. Do not promote it to the primary CTA color"
    },
    "sky-blue": {
      "$value": "#5c9cf5",
      "$type": "color",
      "$description": "Sky Blue — Secondary blue for heading accents, lighter link states, decorative icon highlights — a softer companion to Signal Blue used when the primary blue would feel too loud"
    }
  },
  "font": {
    "ui-sans-serif-system-stack-apple-system-blinkmacsystemfont-sf-pro-text-sf-pro-display": {
      "$value": "ui-sans-serif (system stack: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'SF Pro Display')",
      "$type": "fontFamily",
      "$description": "All UI and editorial text. The system stack is deliberate — on Apple devices this resolves to SF Pro, matching the Things app itself. Weight 600-800 carries headings; weight 400 carries body. No custom or web-loaded font; the restraint IS the brand."
    }
  },
