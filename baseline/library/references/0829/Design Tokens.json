    "neue-hass-grotesk-text": {
      "$value": "Neue Hass Grotesk Text",
      "$type": "fontFamily",
      "$description": "Body, nav, buttons, badges, cards — the workhorse grotesque that carries 90% of the interface. Weights stay light-to-medium (300–500), never bold, keeping the voice conversational rather than corporate"
    },
    "neue-haas-grotesk-display-pro": {
      "$value": "Neue Haas Grotesk Display Pro",
      "$type": "fontFamily",
      "$description": "Display, nav emphasis, large UI — the 135px weight-300 headline size is the signature: an anti-convention whisper-weight display that signals premium restraint. 0.04em positive tracking on display sizes gives airy breathing room"
    },
    "sanomat": {
      "$value": "Sanomat",
      "$type": "fontFamily",
