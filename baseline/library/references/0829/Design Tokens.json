{
  "color": {
    "deep-iris": {
      "$value": "#15002c",
      "$type": "color",
      "$description": "Deep Iris — Footer background, primary text on light surfaces, heading color, dark card surfaces — the near-black violet that carries Navan's brand weight across all dark regions and high-emphasis text"
    },
    "vivid-iris": {
      "$value": "#6307f8",
      "$type": "color",
      "$description": "Vivid Iris — Violet supporting accent for decorative details and low-frequency emphasis. Do not promote it to the primary CTA color"
    },
    "iris-mist": {
      "$value": "#e1e2fe",
