      "$description": "Fog — Input field shadows, card hairline borders, the lightest visible structural line"
    },
    "onyx": {
      "$value": "#151515",
      "$type": "color",
      "$description": "Onyx — Dark supporting neutral for text, icons, and strong contrast. Do not promote it to the primary CTA color"
    },
    "steel": {
      "$value": "#7f7f7f",
