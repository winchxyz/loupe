{
  "color": {
    "obsidian": {
      "$value": "#212123",
      "$type": "color",
      "$description": "Obsidian — Primary text, headings, icon strokes — near-black with a faint cool undertone, softer than pure #000 to reduce glare on long-form copy"
    },
    "bone": {
      "$value": "#fafafa",
      "$type": "color",
      "$description": "Bone — Light supporting surface for subtle backgrounds and section separation. Do not promote it to the primary CTA color"
    },
    "graphite": {
      "$value": "#4a4a4a",
      "$type": "color",
      "$description": "Graphite — Body text, secondary copy, footer text — the mid-gray that creates the reading layer between headlines and captions"
    },
    "carbon": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Carbon — Pure black reserved for the highest-contrast elements: nav links, button labels, icon fills where absolute clarity is required"
    },
    "slate": {
      "$value": "#5c5c5c",
      "$type": "color",
      "$description": "Slate — Muted body text, secondary nav, caption-level copy"
    },
    "mist": {
      "$value": "#a7a7a7",
      "$type": "color",
      "$description": "Mist — Placeholder text, disabled states, tertiary icons, hairline strokes where subtlety is the point"
    },
    "ash": {
      "$value": "#c4c4c4",
      "$type": "color",
      "$description": "Ash — Subtle shadows under icons and buttons, ghost borders on inactive controls"
    },
    "fog": {
