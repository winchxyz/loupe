    },
    "sage-foam": {
      "$value": "#b9e9c5",
      "$type": "color",
      "$description": "Sage Foam — Section background panels — muted green used as a decorative surface, never for semantic status"
    },
    "amber-flag": {
      "$value": "#f2ba41",
      "$type": "color",
      "$description": "Amber Flag — Icon fills and inline callout elements — warm yellow used sparingly for small graphic accents, not for text or backgrounds"
    },
    "near-black": {
      "$value": "#1e1e1",
      "$type": "color",
      "$description": "Near Black — Primary text, nav text, button text, footer text, borders on dark surfaces — near-black rather than pure black softens the contrast ceiling while still reading as definitive ink"
    },
    "parchment": {
      "$value": "#f2efe9",
      "$type": "color",
      "$description": "Parchment — Page background, hero section fill, card backgrounds — the defining warm-tinted base that makes the whole site feel like a printed editorial page rather than a screen"
    },
    "chalk": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Chalk — Card interiors, form inputs, modal surfaces, footer text on dark backgrounds"
    },
    "fog": {
      "$value": "#e3e3e3",
      "$type": "color",
      "$description": "Fog — All borders, dividers, input outlines — omnipresent at freq=7844, it is the connective tissue border color across every component"
    },
    "ash": {
      "$value": "#d4d4d4",
      "$type": "color",
      "$description": "Ash — Subdued body text, placeholder text, disabled states"
    }
  },
  "font": {
    "kitsansfont": {
      "$value": "KitSansFont",
      "$type": "fontFamily",
      "$description": "Hero display headlines and large section statements only. Weight 500 is the only cut — this custom face is reserved for sizes 48px and above in practice, with 14px/18px appearing as UI labels in kit-branded contexts. At 80px with 0.95 line-height, lines stack with intentional bleed, creating visual mass. The -0.009em tracking at display sizes tightens the setting so letterforms feel cut from a single block."
    },
    "libre-franklin": {
      "$value": "Libre Franklin",
      "$type": "fontFamily",
      "$description": "Everything except display headlines — nav, body copy, buttons, links, captions, footer columns. Weight 700 for sub-headlines and emphasis within body text; 600 for button labels and nav items; 400 for running body text and secondary info. Negative tracking from -0.025em at small sizes to -0.008em at 20px gives all text a slightly condensed, editorial feel even at small scales. The 0.025em uppercase letter-spacing on small-caps labels creates a typewriter-tag contrast against the condensed body."
    }
  },
