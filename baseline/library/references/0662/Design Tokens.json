{
  "color": {
    "sky-marker": {
      "$value": "#44b1ff",
      "$type": "color",
      "$description": "Sky Marker — Primary CTA buttons, active nav states, inline keyword highlights — vivid blue on parchment or near-black backgrounds acts as the single highlighter across an otherwise neutral palette, directing attention without competing with any other chromatic element"
    },
    "dust-blue": {
      "$value": "#a2d1f1",
      "$type": "color",
      "$description": "Dust Blue — Hero and section background panels — muted blue used as an atmospheric backdrop, never for text or interaction"
    },
    "blush-mist": {
      "$value": "#e7c9f1",
      "$type": "color",
