    },
    "slate": {
      "$value": "#737373",
      "$type": "color",
      "$description": "Slate — Muted secondary text, icon strokes on light surfaces, metadata labels"
    },
    "charcoal": {
      "$value": "#5f5f5f",
      "$type": "color",
      "$description": "Charcoal — Supporting neutral for secondary UI, dividers, and muted labels. Do not promote it to the primary CTA color"
    }
