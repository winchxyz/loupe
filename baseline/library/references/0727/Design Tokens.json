  "font": {
    "aktiv-grotesk": {
      "$value": "aktiv-grotesk",
      "$type": "fontFamily",
      "$description": "Sole typeface. Body text at 400 weight 16px with 1.5 line-height. Headlines scale dramatically to 64–96px at 400 weight with line-height 1.0 for poster-like impact. Nav and buttons use 500–700 at 14–16px. The dramatic size range and tight display leading are the signature — type is the only brand voice since color is absent."
    }
  },
