    }
  },
  "font": {
    "garnett": {
      "$value": "Garnett",
      "$type": "fontFamily",
      "$description": "Display and heading font. At 64px weight 700 it carries the hero headline — a custom grotesque with editorial warmth missing from Inter or DM Sans. Weight 500 handles subheadings at 24–36px. The ss14/ss15/ss19 OpenType features are active and likely handle specific glyph alternates that distinguish it from substitutes."
    },
    "universalsans": {
      "$value": "UniversalSans",
      "$type": "fontFamily",
      "$description": "UI and body font. Handles all button labels, body copy, nav items, badges, captions. Weight 400 at 14–16px for body, 600 for button labels and emphasized UI text, 700 for numeric callouts. The custom face has more warmth than Inter — slightly wider apertures that match the cream-toned page feel."
    },
    "geist-mono": {
      "$value": "Geist Mono",
      "$type": "fontFamily",
      "$description": "Monospace face used sparingly for code snippets or technical labels. Letter-spacing at 0.117em (approximately 1.4px at 12px) — wider than default, creating a deliberate typewriter rhythm."
    }
  },
