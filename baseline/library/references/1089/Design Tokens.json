  "font": {
    "sweetsans": {
      "$value": "SweetSans",
      "$type": "fontFamily",
      "$description": "Display headlines, hero text, large category labels — used at extreme sizes (70–80px) with tight leading (0.85) that lets letterforms nearly touch; weight 400 at this size is the signature choice, creating a calm authority that doesn't shout"
    },
    "grenette": {
      "$value": "Grenette",
