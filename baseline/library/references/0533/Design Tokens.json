{
  "color": {
    "obsidian": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Obsidian — Section backgrounds for dark bands, primary body text on light surfaces, hairline borders and dividers throughout — the structural backbone of every page"
    },
    "paper-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper White — Light section backgrounds, card surfaces, product image containers, modal/overlay panels, primary text on dark backgrounds"
    },
    "ash-gray": {
      "$value": "#eeeeee",
      "$type": "color",
      "$description": "Ash Gray — Subtle surface variant for product showcase panels and soft background shifts on light sections"
    },
    "smoke": {
      "$value": "#888888",
      "$type": "color",
      "$description": "Smoke — Muted secondary text, subdued nav labels, low-emphasis borders — sits just above AA contrast for accessibility"
    },
    "bone": {
      "$value": "#cacaca",
      "$type": "color",
      "$description": "Bone — Light hairline borders on white surfaces, minimal separator lines, very low-emphasis UI strokes"
    }
  },
  "font": {
    "nb-international-web": {
      "$value": "NB International Web",
      "$type": "fontFamily",
      "$description": "Primary typeface for all UI — navigation, body copy, headings, and display film titles. Weight 400 carries body and most UI; weight 500 for emphasis. The 74px display size with tight tracking (-0.04em) and 0.92 line-height lets film titles stack in dense, almost poster-like blocks. The humanist proportions and slight warmth make it readable at 11px yet commanding at 74px — the same family spans the entire voice."
    },
    "nb-international-mono-web": {
      "$value": "NB International Mono Web",
      "$type": "fontFamily",
      "$description": "Monospaced companion for technical labels, year markers beside film titles, and code-like annotations. Used sparingly as a typographic accent that signals data/specification context."
    }
  },
