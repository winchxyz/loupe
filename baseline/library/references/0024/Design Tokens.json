{
  "color": {
    "obsidian": {
      "$value": "#070709",
      "$type": "color",
      "$description": "Obsidian — Primary text, filled CTA buttons, and dark UI surfaces — near-black chosen over pure #000 to soften contrast against white canvas"
    },
    "paper-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper White — Page background, card surfaces, and button text — the primary canvas across all sections below the hero"
    },
    "cloud-gray": {
      "$value": "#f5f5f5",
      "$type": "color",
      "$description": "Cloud Gray — Secondary card surfaces and section backgrounds — separates feature blocks from main canvas"
    },
    "sky-tint": {
      "$value": "#d7e6f5",
      "$type": "color",
      "$description": "Sky Tint — Card box-shadow tint and subtle blue-toned surface — keeps elevation feeling atmospheric rather than gray"
    },
    "charcoal": {
      "$value": "#60606c",
      "$type": "color",
      "$description": "Charcoal — Body text, secondary copy, and muted borders — the dominant neutral for non-heading content"
    },
    "slate": {
      "$value": "#8b8b8b",
      "$type": "color",
      "$description": "Slate — Tertiary text and inactive border states — used for placeholder labels and disabled affordances"
    },
    "ink": {
      "$value": "#151515",
      "$type": "color",
      "$description": "Ink — Heading color and strong dividers — slightly lighter than Obsidian for less severe emphasis"
    },
    "surgical-blue": {
      "$value": "#2597d0",
      "$type": "color",
      "$description": "Surgical Blue — Icon strokes, mic glyph, waveform player, and small functional accents — the single chromatic note across the interface"
    },
    "sky-gradient": {
      "$value": "#779bc1",
      "$type": "color",
      "$description": "Sky Gradient — Hero background — vertical wash from medium blue to near-white that establishes the medical-aspirational mood"
    }
  },
  "font": {
    "sans-serif": {
      "$value": "sans-serif",
      "$type": "fontFamily",
      "$description": "sans-serif — detected in extracted data but not described by AI"
    },
    "open-runde": {
      "$value": "Open Runde",
      "$type": "fontFamily",
      "$description": "Primary display and heading face — geometric humanist with tight tracking at large sizes; the -0.04em at 80px compresses the headline into a single confident block. Use for all headings, nav, and large text."
    },
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "Secondary body and UI text — used for small labels, nav items, and inline links where a more neutral reading rhythm is needed. Pairs with Open Runde for hierarchy contrast."
    },
    "the-doctor-freeversion": {
      "$value": "The Doctor FreeVersion",
      "$type": "fontFamily",
      "$description": "Decorative handwritten/doctor's note face — used only in the Before/After card illustrations to evoke clinical handwriting. Not for functional UI text."
    },
    "open-runde-semibold": {
      "$value": "Open Runde Semibold",
