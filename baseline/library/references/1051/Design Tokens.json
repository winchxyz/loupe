{
  "color": {
    "obsidian-canvas": {
      "$value": "#303236",
      "$type": "color",
      "$description": "Obsidian Canvas — Page background, dominant surface — near-black with a whisper of warmth, the default stage for all content"
    },
    "void": {
      "$value": "#090a0c",
      "$type": "color",
      "$description": "Void — Deepest surface layer for hero gradients, modal backdrops, and borders that need to disappear into the canvas"
    },
    "charcoal-card": {
      "$value": "#111111",
      "$type": "color",
      "$description": "Charcoal Card — Elevated card and panel surfaces sitting one step above the canvas"
    },
    "slate-edge": {
      "$value": "#4a4b50",
      "$type": "color",
      "$description": "Slate Edge — Hairline borders and dividers on dark surfaces"
    },
    "iron-veil": {
      "$value": "#6b6c6d",
      "$type": "color",
      "$description": "Iron Veil — Muted backgrounds for tags, list-item fills, and disabled state washes"
    },
    "smoke": {
      "$value": "#95979e",
      "$type": "color",
      "$description": "Smoke — Icon strokes, secondary text, and inactive controls — the workhorse mid-gray"
    },
    "ash": {
      "$value": "#a9a9aa",
      "$type": "color",
      "$description": "Ash — Tertiary text and subtle body borders in content-heavy lists"
    },
    "frost": {
      "$value": "#d1d1d1",
      "$type": "color",
      "$description": "Frost — Light-mode borders, input fields, and secondary CTA borders"
    },
    "linen": {
      "$value": "#e5e5e7",
      "$type": "color",
      "$description": "Linen — Light-mode surface tint and subtle section dividers in white backgrounds"
    },
    "snow": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Snow — Hairline borders, dividers, input outlines, and card edges on light surfaces. Do not promote it to the primary CTA color"
    },
    "electric-iris": {
      "$value": "#5683da",
      "$type": "color",
      "$description": "Electric Iris — Primary action background, active nav indicator, hero aurora cool stop — vivid violet-blue against charcoal reads as switched-on, not corporate"
    },
    "ember-pulse": {
      "$value": "#ff8964",
      "$type": "color",
      "$description": "Ember Pulse — Secondary accent, hero aurora warm stop, notification dot, illustration highlight — the amber that breaks the blue's composure and gives the beam its heat"
    },
    "molasses": {
      "$value": "#5a250a",
      "$type": "color",
      "$description": "Molasses — Deep ember tone for dark-context borders, icon strokes, and tag fills when coral would be too bright"
    }
  },
  "font": {
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "All functional UI text — body, nav, buttons, list items, captions, small headings. Used at weight 500–600 for emphasis, 400 for body, 300 sparingly for quiet metadata."
    },
    "esbuild": {
      "$value": "Esbuild",
      "$type": "fontFamily",
      "$description": "Display-only: hero headlines, section openers, MetaBrain feature titles. The condensed geometry and tight tracking make 84px feel editorial rather than SaaS. Never used below 28px."
    }
  },
