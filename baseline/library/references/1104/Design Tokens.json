{
  "color": {
    "voltage-lime": {
      "$value": "#d3fb52",
      "$type": "color",
      "$description": "Voltage Lime — Primary action fill, nav pill, active state, hero gradient endpoint — the single chromatic ignition point against an otherwise monochrome system"
    },
    "cyan-spark": {
      "$value": "#7af3ff",
      "$type": "color",
      "$description": "Cyan Spark — Hero gradient start point, secondary glow tone — pairs with Voltage Lime to create the aurora-like radial background"
    },
    "mid-abyss": {
      "$value": "#052326",
      "$type": "color",
      "$description": "Mid Abyss — Footer surface, dark section backgrounds — a near-black with a subtle teal undertone that keeps the dark mode on-brand"
    },
    "carbon-ink": {
      "$value": "#14151c",
      "$type": "color",
      "$description": "Carbon Ink — Primary text, icon strokes, input borders — the slightly cool near-black used for the majority of foreground content"
    },
    "pure-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Pure White — Page canvas, card surfaces, button text on lime fills, input interiors — the dominant surface tone (1590+ appearances)"
    },
    "true-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "True Black — Nav borders, strong text emphasis, icon fills — used sparingly where maximum contrast is needed"
    },
    "ash": {
      "$value": "#666666",
      "$type": "color",
      "$description": "Ash — Body helper text, muted body borders — the secondary text level for de-emphasized copy"
    }
