  "font": {
    "helvetica-neue": {
      "$value": "Helvetica Neue",
      "$type": "fontFamily",
      "$description": "Single-family system used for everything from 12px captions to 200px stat numerals. The extreme range (16× scale) is the signature — the same weight carries caption text and hero headlines, letting scale and tracking do the differentiation. Positive letter-spacing (+0.08em) on the smallest sizes signals uppercase labels; aggressive negative tracking (-0.05em) on display sizes tightens large type to a poster-like density."
    }
  },
