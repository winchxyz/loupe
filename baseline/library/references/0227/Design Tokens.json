  "font": {
    "fellix": {
      "$value": "Fellix",
      "$type": "fontFamily",
      "$description": "Primary interface and display typeface — geometric grotesque with unusually low contrast; weight 520 is a near-medium custom step that gives headlines substance without going bold, weight 400 handles body. Tracking sits tight at -0.025em across the scale, which is anti-convention for a sans and makes even 48px headlines feel compact and scientific rather than airy or editorial."
    },
    "pp-fraktion-mono": {
      "$value": "PP Fraktion Mono",
      "$type": "fontFamily",
      "$description": "Monospace lab-label voice — uppercase column headers, tag chips, dataset captions, metric labels. Tracking opens up to +0.025em and ligatures/contextual alternates are explicitly disabled, producing a deliberately clinical, index-card feel that contrasts the tight sans. The 'COMBINED', 'DATASET COMPOSITION', 'BLOG POST' eyebrows are the signature use."
    }
  },
