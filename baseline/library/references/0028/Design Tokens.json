{
  "color": {
    "velvet-wine": {
      "$value": "#260212",
      "$type": "color",
      "$description": "Velvet Wine — Page canvas and deepest section background — the floor everything sits on"
    },
    "burgundy-stage": {
      "$value": "#4f0423",
      "$type": "color",
      "$description": "Burgundy Stage — Section and card surfaces, slightly lifted from the canvas to separate bands of content"
    },
    "impossible-red": {
      "$value": "#e10600",
      "$type": "color",
      "$description": "Impossible Red — Primary action buttons, active toggles, headline accents, icon emphasis — the single chromatic signal that commands attention"
    },
    "blush-highlight": {
      "$value": "#ffc7c6",
      "$type": "color",
      "$description": "Blush Highlight — Soft secondary text, pill toggles in default state, link hover, tonal counterpoint to the aggressive red"
    },
    "butcher-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Butcher Black — Top navigation background, hairline borders, card outlines, deep contrast strokes"
    },
    "bone-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Bone White — Navigation and button text, body copy on dark surfaces, inverted toggle text"
    }
  },
  "font": {
    "sans-meat": {
      "$value": "sans-meat",
      "$type": "fontFamily",
      "$description": "The only typeface on the site. Carries everything from 10px micro-labels to 231px hero statements. Weight 700 dominates display and CTAs; 400 and 500 handle body, nav, and secondary UI. The display sizes are anti-convention — most brands cap hero text around 64–80px; sans-meat's display reaches viewport-filling proportions because the brand is built on the stunt of oversized declarations like 'STEAK (FROM PLANTS)' and 'THE POTLUCK'."
    }
  },
