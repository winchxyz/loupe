{
  "color": {
    "ink": {
      "$value": "#06040e",
      "$type": "color",
      "$description": "Ink — Primary text, primary CTA fill, nav background, heading copy — near-black with a violet undertone that ties dark elements back to the brand palette"
    },
    "deep-teal": {
      "$value": "#10242f",
      "$type": "color",
      "$description": "Deep Teal — Secondary headings, body emphasis, dark surface variation — co-leads with Ink for high-contrast typographic hierarchy"
    },
    "graphite": {
      "$value": "#452623",
      "$type": "color",
      "$description": "Graphite — Tertiary text and dark surface variant — warm brown-black that softens the typographic scale below the primary two"
    },
    "fog": {
      "$value": "#f5f5f5",
      "$type": "color",
      "$description": "Fog — Page canvas, section background — the warm off-white that gives the entire interface its sunlit, paper-like quality"
    },
    "paper": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper — Card surfaces, elevated panels, button text on dark fills — pure white reserved for content surfaces that sit above the Fog canvas"
    },
    "mist": {
      "$value": "#e1edf2",
      "$type": "color",
      "$description": "Mist — Soft dividers, input borders, ghost button borders, secondary surface tint — cool pale blue-gray that whispers separation without weight"
    },
    "terracotta": {
      "$value": "#e39a4d",
      "$type": "color",
      "$description": "Terracotta — Brand accent, feature card fill, decorative blob shape, warm highlight — the most saturated color in the system, used sparingly as energetic punctuation"
    },
    "lavender": {
      "$value": "#cbb0eb",
      "$type": "color",
      "$description": "Lavender — Brand accent, feature card fill, decorative blob shape, soft highlight wash — dusty pastel violet that softens the palette"
    },
    "plum": {
      "$value": "#1f1738",
      "$type": "color",
      "$description": "Plum — Dark accent surface, deep feature card variant, outlined action border — the saturated dark violet that anchors the lavender to something readable"
    },
    "sky": {
      "$value": "#a5c8d8",
      "$type": "color",
      "$description": "Sky — Gray action color for filled buttons, selected navigation states, and focused conversion moments"
    },
    "cream": {
      "$value": "#f6ddc4",
      "$type": "color",
      "$description": "Cream — Soft warm tint, outlined action border, decorative wash — peachy off-white that warms the palette without adding saturation"
    }
  },
  "font": {
    "stabilgrotesk": {
      "$value": "StabilGrotesk",
      "$type": "fontFamily",
      "$description": "Single-family type system carrying everything from micro-labels to display headlines. The custom geometric grotesque's tight apertures and compressed letterforms at 700 give the display sizes a hand-cut quality; 400 body weight is unusually readable for a display-origin face. Negative tracking (-0.03em at display, -0.02em at heading) is signature — the headlines feel cut from a single strip. Uppercase labels at 0.1em tracking create quiet eyebrow rhythm."
    }
  },
