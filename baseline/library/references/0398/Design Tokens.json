{
  "color": {
    "shop-violet": {
      "$value": "#5433eb",
      "$type": "color",
      "$description": "Shop Violet — Wordmark, search submit arrow, primary button fill, brand icon — saturated indigo-violet that reads as electric against a pure white canvas. Used sparingly so it carries signal weight"
    },
    "violet-glow": {
      "$value": "#c0b5f3",
      "$type": "color",
      "$description": "Violet Glow — Violet supporting accent for decorative details and low-frequency emphasis. Do not promote it to the primary CTA color"
    },
    "pure-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Pure White — Page canvas, card surfaces, input fields, inverse text on violet buttons"
    },
    "ink-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Ink Black — Primary text, dominant border color across cards/nav/dividers, and outline-button strokes — the structural skeleton of the whole UI"
    },
    "near-black": {
      "$value": "#121212",
      "$type": "color",
      "$description": "Near Black — Dark-mode or emphasized text surface, dark panel background where inverted hierarchy is needed"
    },
    "soft-canvas": {
      "$value": "#f2f4f5",
      "$type": "color",
      "$description": "Soft Canvas — Secondary surface band — subtle off-white that separates sections and input wells from the pure white page"
    },
    "hairline": {
      "$value": "#ebebeb",
      "$type": "color",
      "$description": "Hairline — Light borders, input outlines, card dividers — the quietest separator tone, used where pure black would be too loud"
    },
    "concrete": {
      "$value": "#c9cbcc",
      "$type": "color",
      "$description": "Concrete — Muted text, disabled icons, placeholder body copy — sits one step above the lightest borders"
    },
    "slate": {
      "$value": "#707070",
      "$type": "color",
      "$description": "Slate — Secondary navigation text, helper labels, muted metadata, and secondary icon strokes"
    },
    "ash": {
      "$value": "#7b7b7b",
      "$type": "color",
      "$description": "Ash — Tertiary body text, supporting captions"
    }
  },
  "font": {
    "gt-standard": {
      "$value": "GT Standard",
      "$type": "fontFamily",
      "$description": "Primary UI typeface — card titles, product names, nav labels, body, buttons, ratings, and footer copy all flow through this single family. The aggressive negative tracking at small sizes keeps 9-12px labels from looking loose."
    },
    "gt-standard-medium": {
      "$value": "GT Standard Medium",
      "$type": "fontFamily",
      "$description": "Emphasized inline labels, small icon-adjacent text where Regular would recede too far."
    },
    "shopify-sans": {
      "$value": "Shopify Sans",
      "$type": "fontFamily",
      "$description": "Meta copy, system/legal text, and links that originate from the Shopify ecosystem — appears sparingly."
    }
  },
