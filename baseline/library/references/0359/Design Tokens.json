{
  "color": {
    "preply-pink": {
      "$value": "#ff7aac",
      "$type": "color",
      "$description": "Preply Pink — Red supporting accent for decorative details and low-frequency emphasis. Do not promote it to the primary CTA color"
    },
    "midnight-ink": {
      "$value": "#121117",
      "$type": "color",
      "$description": "Midnight Ink — Dark supporting neutral for text, icons, and strong contrast. Do not promote it to the primary CTA color"
    },
    "soft-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Soft White — Page canvas above the pink hero, card surfaces, tutor catalog backgrounds, button text on dark fills"
    },
    "mist-gray": {
      "$value": "#f4f4f8",
      "$type": "color",
      "$description": "Mist Gray — Subtle page background for content sections that need separation from pure white"
    },
    "smoke": {
      "$value": "#dcdce5",
      "$type": "color",
      "$description": "Smoke — Card borders, input outlines, dividers — structural hairlines that define the catalog grid"
    },
    "pewter": {
      "$value": "#6a697c",
      "$type": "color",
      "$description": "Pewter — Card border accent and tertiary text, slightly cooler than Midnight Ink for layered hierarchy"
    },
    "graphite": {
      "$value": "#4d4c5c",
      "$type": "color",
      "$description": "Graphite — Body copy, icon strokes, secondary text — the readable neutral that lives between Midnight Ink headings and lighter helper text"
    },
    "pure-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Pure Black — Icon fills, decorative sticker text, and any place where the absolute black is needed for photographic overlay"
    },
    "signal-yellow": {
      "$value": "#ffdf3d",
      "$type": "color",
      "$description": "Signal Yellow — Accent highlights, announcement bar background, decorative stickers — used sparingly as a callout color over pink"
    },
    "sky-pop": {
      "$value": "#99c5ff",
      "$type": "color",
      "$description": "Sky Pop — Secondary accent, tag chips, and decorative illustration — the cool counterpoint to pink in multicolor compositions"
    }
  },
  "font": {
    "platform": {
      "$value": "Platform",
      "$type": "fontFamily",
      "$description": "All headlines, section titles, hero copy, and the largest display text. Weight 700 dominates from 32px upward, creating dense, confident type blocks. The 1.00–1.08 line-heights at 48–96px make headlines read as solid slabs. Tracking tightens with size: -0.005em at body, -0.017em at display."
    },
    "figtree": {
      "$value": "Figtree",
      "$type": "fontFamily",
      "$description": "Body copy, UI labels, button text, card content, nav, links, footer text, and form fields. Weight 400 for paragraphs, weight 600 for emphasis and button labels. Line-height 1.43–1.71 at 14–18px gives body copy comfortable air. Letter-spacing stays near zero to slightly positive (+0.01 to +0.012em) for legible small sizes."
    }
  },
