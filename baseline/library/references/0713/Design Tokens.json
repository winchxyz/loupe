{
  "color": {
    "obsidian": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Obsidian — Page background, hero canvas, navigation surface — the default darkness that lets poster art and white text feel illuminated"
    },
    "smoke": {
      "$value": "#050409",
      "$type": "color",
      "$description": "Smoke — Near-black secondary surface, subtle elevation layer above pure black for section separation"
    },
    "ash-mist": {
      "$value": "#b8b6bb",
      "$type": "color",
      "$description": "Ash Mist — Muted helper text, secondary body copy, disabled icon strokes — readable but recedes"
    },
    "iron-veil": {
      "$value": "#89868e",
      "$type": "color",
      "$description": "Iron Veil — Tertiary text, inactive border outlines on controls"
    },
    "faded-print": {
      "$value": "#999999",
      "$type": "color",
      "$description": "Faded Print — Lowest-priority metadata, footnote-level text and borders"
    },
    "snow": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Snow — Primary text, pricing card surfaces, icon fills, pill backgrounds — the dominant positive value in the system"
    },
    "eclipse-indigo": {
      "$value": "#0e0a17",
      "$type": "color",
      "$description": "Eclipse Indigo — Near-black heading accent, subtle border tint for heading underlines"
    },
    "signal-blue": {
      "$value": "#3d6a99",
      "$type": "color",
      "$description": "Signal Blue — Primary CTA fill, active link color, brand accent on icons and borders — the single chromatic note that powers all interactivity"
    },
    "glacier-beam": {
      "$value": "#71b8f2",
      "$type": "color",
      "$description": "Glacier Beam — Blue text accent for links, tags, and emphasized short phrases. Do not promote it to the primary CTA color"
    }
  },
  "font": {
    "max-sans": {
      "$value": "Max Sans",
      "$type": "fontFamily",
      "$description": "Custom sans-serif. Weights 300–400 carry the bulk of body and headline work; 600–700 reserved for prices and CTAs; 100 used for ultra-light display moments. Positive letter-spacing (0.083–0.1em) on small labels gives cinematic, marquee-poster feel."
    }
  },
