{
  "color": {
    "powder-blue": {
      "$value": "#d5e0ea",
      "$type": "color",
      "$description": "Powder Blue — Section bands, card borders, decorative dividers — the brand's secondary canvas, used to segment the page into editorial chapters without introducing contrast"
    },
    "slate-bloom": {
      "$value": "#a3bfdb",
      "$type": "color",
      "$description": "Slate Bloom — Primary action buttons, active states — the single chromatic accent; its low saturation keeps it feeling clinical rather than commercial"
    },
    "warm-ink": {
      "$value": "#231f20",
      "$type": "color",
      "$description": "Warm Ink — Primary text, hairline borders, card outlines, icon strokes — near-black with a warm undertone that softens the high-contrast text against white"
    },
    "true-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "True Black — Icon fills, occasional heavy borders — used sparingly for graphical weight when maximum contrast is needed"
    },
    "paper-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper White — Page background, card surfaces, text on dark blocks — the dominant canvas, never off-white or cream"
    },
    "mist-gray": {
      "$value": "#5f6368",
      "$type": "color",
      "$description": "Mist Gray — Muted helper text, secondary metadata, low-priority labels — only when a softer reading level is needed without leaving the achromatic palette"
    }
  },
