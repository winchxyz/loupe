{
  "color": {
    "vivid-indigo": {
      "$value": "#494bcb",
      "$type": "color",
      "$description": "Vivid Indigo — Primary action background, filled buttons, active nav, brand focal point — the one chromatic color that carries the entire brand"
    },
    "midnight-ink": {
      "$value": "#08093f",
