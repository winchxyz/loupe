{
  "color": {
    "hudson-blue": {
      "$value": "#0081c0",
      "$type": "color",
      "$description": "Hudson Blue — Blue wash for highlight backgrounds, decorative bands, and soft emphasis behind content. Do not promote it to the primary CTA color"
    },
    "slate-cyan": {
      "$value": "#41a1cf",
      "$type": "color",
      "$description": "Slate Cyan — Blue accent for outlined action borders, linked labels, and lightweight interactive emphasis. Do not promote it to the primary CTA color"
    },
    "graphite-night": {
      "$value": "#282834",
      "$type": "color",
      "$description": "Graphite Night — Floating navigation island fill and icon strokes — the dark surface that anchors the pill-shaped nav against the light canvas"
    },
    "ink": {
      "$value": "#171717",
      "$type": "color",
      "$description": "Ink — Primary text and dominant border color. Drives 619 occurrences — the structural backbone of the interface"
    },
    "carbon": {
      "$value": "#2c2c2c",
      "$type": "color",
      "$description": "Carbon — Secondary heading text and dark UI elements — slightly softer than Ink for subheadings and dense text blocks"
    },
    "iron": {
      "$value": "#444141",
      "$type": "color",
      "$description": "Iron — Button borders, icon strokes, mid-dark surface edges. Sits between Ink and Steel on the dark scale"
    },
    "steel": {
      "$value": "#646464",
      "$type": "color",
      "$description": "Steel — Muted helper text and link borders. The first step down from primary text — used for body captions and less-prominent metadata"
    },
    "fog": {
      "$value": "#b4b8b4",
      "$type": "color",
      "$description": "Fog — Light hairlines and faint surface fills — gentle dividers that separate content without drawing attention"
    },
    "ash": {
      "$value": "#a5afaf",
      "$type": "color",
      "$description": "Ash — Mid-gray for subtle background fills and muted borders on inactive elements"
    },
    "mist": {
      "$value": "#cfd3cf",
      "$type": "color",
      "$description": "Mist — Soft fill for inactive or decorative surface layers — the lightest non-white tone before borders kick in"
    },
    "sage": {
      "$value": "#dee2de",
      "$type": "color",
      "$description": "Sage — Card and button border ring — the barely-there outline that gives surfaces their edge in lieu of shadow"
    },
    "cream": {
      "$value": "#fefffc",
      "$type": "color",
      "$description": "Cream — Page canvas — a warm off-white that prevents the site from feeling clinical. The single most prominent background"
    },
    "linen": {
      "$value": "#f9faf7",
      "$type": "color",
      "$description": "Linen — Secondary surface and nav fill — one step cooler than Cream, used for floating panels and alternating bands"
    },
    "paper": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper — Card surfaces, elevated panels, and the topmost layer in the surface stack. Pure white for content blocks floating above the Cream canvas"
    },
    "obsidian": {
      "$value": "#1f1f29",
      "$type": "color",
      "$description": "Obsidian — High-contrast neutral action fill for primary buttons on light surfaces."
    }
  },
  "font": {
    "ppmondwest": {
      "$value": "ppmondwest",
      "$type": "fontFamily",
      "$description": "Display headings — the editorial serif that gives the brand its literary, almost academic register. Used at 40-54px with tight -0.02em tracking. The 'liga' 0 feature setting deliberately disables ligatures, preserving the spaced, slightly geometric character of each letterform."
    },
    "af": {
      "$value": "af",
      "$type": "fontFamily",
      "$description": "Body text, UI elements, navigation, buttons, and inline links. The functional workhorse — compact, quiet, and highly legible. Light negative tracking (-0.01 to -0.012em) tightens dense UI text without feeling stylized."
    }
  },
