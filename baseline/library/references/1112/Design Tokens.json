{
  "color": {
    "orchid-accent": {
      "$value": "#a95ef8",
      "$type": "color",
      "$description": "Orchid Accent — Highlighted word in display headlines, decorative emphasis — vivid violet that draws the eye to a single concept within a monochrome headline"
    },
    "iris-brand": {
      "$value": "#5551ff",
      "$type": "color",
      "$description": "Iris Brand — Violet supporting accent for decorative details and low-frequency emphasis. Do not promote it to the primary CTA color"
    },
