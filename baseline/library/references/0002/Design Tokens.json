  "font": {
    "nyght-serif": {
      "$value": "Nyght Serif",
      "$type": "fontFamily",
      "$description": "Reserved exclusively for display and heading levels (26-72px). Weight 300 is the signature: most systems reach for 600-700 serif, this whisper-weight creates editorial gravitas through restraint. Letter-spacing widens slightly at smaller sizes (0.03em) and tightens at display sizes (0.01em) to preserve optical balance."
    },
    "switzer": {
      "$value": "Switzer",
      "$type": "fontFamily",
      "$description": "Workhorse for nav, body, buttons, labels, card metadata, and small headings. Tracking runs consistently at 0.03em — a subtle positive letter-spacing that gives the grotesque a calm, considered cadence. Weight 500 for emphasis, 600 for button text and nav active states."
    }
  },
