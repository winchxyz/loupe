{
  "color": {
    "cobalt-current": {
      "$value": "#1658b3",
      "$type": "color",
      "$description": "Cobalt Current — Hero background, primary surface flood, outlined-link borders — the single color that defines every full-bleed section"
    },
    "deep-channel": {
      "$value": "#0d3c88",
      "$type": "color",
      "$description": "Deep Channel — Darker blue for gradient depth in decorative graphics, icon accents, footer bands"
    },
    "electric-ripple": {
      "$value": "#015fee",
      "$type": "color",
      "$description": "Electric Ripple — Violet wash for highlight backgrounds, decorative bands, and soft emphasis behind content. Do not promote it to the primary CTA color"
    },
    "abyssal-ink": {
      "$value": "#01295f",
      "$type": "color",
      "$description": "Abyssal Ink — Darkest blue used inside SVG decoration and deep gradient stops — never as text or button"
    },
    "white-canvas": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "White Canvas — Page background, body text on blue, primary pill button fill — the neutral that carries white sections and inverts on blue"
    },
    "cloud-border": {
      "$value": "#e5e7eb",
      "$type": "color",
      "$description": "Cloud Border — Hairline dividers, card borders, separator rules across all white surfaces — the structural neutral of the system"
    },
    "carbon": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Carbon — Body text on white, icon fills in black-mode illustrations"
    },
    "nude-clay": {
      "$value": "#eee1d9",
      "$type": "color",
      "$description": "Nude Clay — Warm flesh-tone accent inside decorative illustration fills and strokes — the only chromatic neutral, used to humanize blue compositions"
    }
  },
