{
  "color": {
    "safety-orange": {
      "$value": "#ff4000",
      "$type": "color",
      "$description": "Safety Orange — Brand accent — terminal periods after display headlines, thin underlines on key phrases, small icon accents, and full-bleed section bands. This is the only chromatic color in the system; it must be used sparingly, like a highlighter on a printed page"
    },
    "ink-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Ink Black — Dark borders and separators for elevated surfaces and inverted UI. Do not promote it to the primary CTA color"
    },
    "carbon": {
      "$value": "#1c1c1c",
      "$type": "color",
      "$description": "Carbon — Heading text where pure black feels too harsh; gives display type a slightly softer, warmer read without losing the editorial weight"
    },
    "graphite": {
      "$value": "#6e6e6e",
      "$type": "color",
      "$description": "Graphite — Body secondary text, nav inactive items, caption labels. The workhorse muted neutral for supporting copy and metadata"
    },
    "slate": {
      "$value": "#828282",
      "$type": "color",
      "$description": "Slate — Lighter secondary text and subdued headings — used when Graphite would compete with body copy"
    },
    "fog": {
      "$value": "#999999",
      "$type": "color",
      "$description": "Fog — Disabled state text, tertiary metadata, placeholder labels"
    },
    "paper": {
      "$value": "#fafafa",
      "$type": "color",
      "$description": "Paper — Page canvas and primary surface — the dominant background across all sections. Sits between pure white and cream to soften the high-contrast black typography"
    },
    "cream": {
      "$value": "#fdfef8",
      "$type": "color",
      "$description": "Cream — Warmest surface tint for elevated cards and feature blocks — barely a degree warmer than Paper, but enough to read as a distinct layer"
    },
    "ash": {
      "$value": "#f1f1f1",
      "$type": "color",
      "$description": "Ash — Mid-tone surface for cards that need more separation from the Paper canvas without introducing a border"
    },
    "linen": {
      "$value": "#ecebe8",
      "$type": "color",
      "$description": "Linen — Warmest card surface variant — used for product mockup containers and illustration cards that need a tactile, paper-like feel"
    }
  },
  "font": {
    "sans-serif": {
      "$value": "sans-serif",
      "$type": "fontFamily",
      "$description": "sans-serif — detected in extracted data but not described by AI"
    },
    "bricolage-grotesque": {
      "$value": "Bricolage Grotesque",
      "$type": "fontFamily",
      "$description": "Primary display and heading font. Used for all headlines, section titles, and feature headings. The variable weight range (500–600) and aggressive negative tracking on large sizes create poster-like headline blocks that read as printed editorial type rather than web text. Tighter tracking at larger sizes is a signature choice — the letters almost touch, creating compact, confident word shapes."
    },
    "geist": {
      "$value": "Geist",
      "$type": "fontFamily",
      "$description": "UI and navigation typeface. Used for nav links, button labels, form text, table-of-contents entries, and interface chrome. The tighter tracking at 24px and near-normal at 14px makes it a comfortable workhorse for dense UI contexts where Bricolage Grotesque would feel too editorial."
    },
    "geist-variable": {
      "$value": "Geist Variable",
      "$type": "fontFamily",
      "$description": "Secondary body and utility text at lighter weight. Used for fine print, metadata, timestamps, and supporting body copy where Geist 500/600 would feel too heavy."
    },
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "Fallback body and link text. Used in contexts where Inter's broader availability matches the design intent without requiring a custom font load."
    }
  },
