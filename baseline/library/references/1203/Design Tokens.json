{
  "color": {
    "brand-violet": {
      "$value": "#7b68ee",
      "$type": "color",
      "$description": "Brand Violet — Primary brand color for the logo, primary CTAs, active states, and brand accents — this single violet carries 90% of the chromatic identity"
    },
    "signal-blue": {
      "$value": "#0091ff",
      "$type": "color",
      "$description": "Signal Blue — Secondary accent for badges, icons, and the Agents/Brain feature highlights — a cool counterpoint to the violet, often appearing in conic-gradient sweeps"
    },
    "ultra-violet": {
      "$value": "#6647f0",
      "$type": "color",
      "$description": "Ultra Violet — Deeper violet variant for hover states and selected/active surfaces — gives the brand a darker dimension when needed"
    },
    "muted-violet": {
      "$value": "#514b81",
      "$type": "color",
      "$description": "Muted Violet — Desaturated violet for secondary text, subdued borders, and tonal backgrounds where brand presence is needed without full saturation"
    },
    "midnight-ink": {
      "$value": "#090c1d",
      "$type": "color",
      "$description": "Midnight Ink — Primary heading and body text — a near-black with a cool blue undertone that harmonizes with the violet palette"
    },
    "charcoal": {
      "$value": "#292d34",
      "$type": "color",
      "$description": "Charcoal — Secondary text, icon strokes, and high-frequency border color — the workhorse neutral that defines most UI chrome"
    },
    "carbon": {
      "$value": "#202023",
      "$type": "color",
      "$description": "Carbon — High-contrast neutral action fill for primary buttons on light surfaces."
    },
    "graphite": {
      "$value": "#1a202c",
      "$type": "color",
      "$description": "Graphite — Subtle heading color variant for lower-prominence headings and dark-on-dark contrast"
    },
    "slate": {
      "$value": "#646464",
      "$type": "color",
      "$description": "Slate — Muted body text, placeholder copy, and secondary navigation text"
    },
    "steel": {
      "$value": "#7c828d",
      "$type": "color",
      "$description": "Steel — Tertiary text and disabled-state labels — a cool gray that recedes without disappearing"
    },
    "fog": {
      "$value": "#b3b3b3",
      "$type": "color",
      "$description": "Fog — Light borders, inactive icons, and dividers on light surfaces"
    },
    "ash": {
      "$value": "#838383",
      "$type": "color",
      "$description": "Ash — Mid-gray for badges, secondary icons, and subtle text annotations"
    },
    "mist": {
      "$value": "#d9d9d9",
      "$type": "color",
      "$description": "Mist — Hairline dividers and table row separators"
    },
    "cloud": {
      "$value": "#e8e8e8",
      "$type": "color",
      "$description": "Cloud — Subtle card borders, ghost-button borders, and light surface tints"
    },
    "paper": {
      "$value": "#f8f9fa",
      "$type": "color",
      "$description": "Paper — Alternate surface background for striped sections and inset cards"
    },
    "frost": {
      "$value": "#edf6fd",
      "$type": "color",
      "$description": "Frost — Light neutral action fill for buttons on dark surfaces"
    },
    "linen": {
      "$value": "#e9ebf0",
      "$type": "color",
      "$description": "Linen — Section background tint for alternating bands — a barely-visible warm gray that creates subtle separation"
    },
    "pure-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Pure White — Page canvas, card surfaces, and filled button text"
    },
    "true-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "True Black — Reserved for high-contrast icon fills, SVG strokes, and rare emphasis elements"
    },
    "abyss": {
      "$value": "#090909",
      "$type": "color",
      "$description": "Abyss — Near-black card background for dark surface cards on light pages"
    },
    "violet-glow": {
      "$value": "#b38cff",
      "$type": "color",
      "$description": "Violet Glow — Light violet for decorative strokes, code highlighting, and accent washes"
    }
  },
  "font": {
    "plus-jakarta-sans": {
      "$value": "Plus Jakarta Sans",
      "$type": "fontFamily",
      "$description": "Primary typeface for all UI text — from display headlines (weight 800 at 60-76px) down to navigation and body. The weight 650 (between 600 and 700) is a custom intermediate that gives buttons and subheadings a distinctive confident density. Tight negative tracking scales with size: -0.05em at 76px compresses the headline for impact."
    },
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "Secondary typeface for supporting text, fine print, badges, and dense UI labels at 12-19px. Inter appears where information density trumps brand expression — tooltips, small captions, and form fields."
    },
    "sometype-mono": {
      "$value": "Sometype Mono",
      "$type": "fontFamily",
      "$description": "Monospaced typeface for badge labels, feature tags, and the all-caps micro-copy that marks category labels (e.g. 'Introducing ClickUp 4.0'). The 0.06em positive tracking creates a tracked-out, technical character that contrasts the geometric Plus Jakarta Sans."
    }
  },
