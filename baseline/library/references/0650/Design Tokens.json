{
  "color": {
    "espresso-ink": {
      "$value": "#1a0000",
      "$type": "color",
      "$description": "Espresso Ink — Primary text, filled CTA buttons, top navigation bar, icon strokes — warm near-black replaces pure #000 to feel like ground cocoa rather than ink"
    },
    "prism-spectrum": {
      "$value": "#a6b4f7",
      "$type": "color",
      "$description": "Prism Spectrum — Hero background gradient — sky blue to lavender to mint to emerald, used as a one-screen burst of color at the top of the page only"
    },
    "canvas-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Canvas White — Page background, product card surfaces, button text on dark fills"
    },
    "linen-mist": {
      "$value": "#f2f2f2",
      "$type": "color",
      "$description": "Linen Mist — Secondary card surface, alternating section background, subtle depth against pure white"
    },
    "bone": {
      "$value": "#ededec",
      "$type": "color",
      "$description": "Bone — Hairline borders, dividers, icon strokes, subtle surface elevation — the warm-tinted neutral that holds the system together"
    },
    "taupe-slate": {
      "$value": "#514f4c",
      "$type": "color",
      "$description": "Taupe Slate — Secondary body text, card borders, muted labels — warm gray that pairs with Espresso Ink without going cold"
    },
    "ash-gray": {
      "$value": "#aeaea6",
      "$type": "color",
      "$description": "Ash Gray — Helper text, tertiary metadata, low-emphasis borders"
    },
    "charcoal-bronze": {
