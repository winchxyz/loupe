{
  "color": {
    "midnight-harbor": {
      "$value": "#0b3658",
      "$type": "color",
      "$description": "Midnight Harbor — Primary text, headings, logo, dark CTA banner — the near-black navy that carries the entire voice of the interface"
    },
    "signal-blue": {
      "$value": "#4e9ad9",
      "$type": "color",
      "$description": "Signal Blue — Primary action background, logo wordmark, active nav and toggle states — the single bright chromatic accent against the navy/white axis"
    },
    "slate-channel": {
      "$value": "#486984",
      "$type": "color",
      "$description": "Slate Channel — Secondary text, outlined link borders, muted icon strokes — mid-tone companion to Midnight Harbor for de-emphasized copy"
    },
    "pale-steel": {
      "$value": "#688dac",
      "$type": "color",
      "$description": "Pale Steel — Tertiary text and meta labels, light borders on headings — the lightest blue-gray still reading as chromatic"
    },
    "sea-fog": {
      "$value": "#dde7ee",
      "$type": "color",
      "$description": "Sea Fog — Card borders, image borders, link underlines, hairline dividers — the dominant neutral stroke color"
    },
    "ice-tint": {
      "$value": "#e6f1fa",
      "$type": "color",
      "$description": "Ice Tint — Subtle background washes, hover surfaces, tinted input backgrounds — barely-there blue for grouping without weight"
    },
    "light-mist": {
      "$value": "#c8d8e4",
      "$type": "color",
      "$description": "Light Mist — Disabled or secondary button fill, neutral surface accent — the warm-cool border between Ice Tint and Sea Fog"
    },
    "canvas-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Canvas White — Page background, card surface, button text — the dominant canvas that every other color sits on"
    },
    "active-teal": {
      "$value": "#42b3b1",
      "$type": "color",
      "$description": "Active Teal — Teal outline accent for tags, dividers, and focused UI edges"
    }
  },
  "font": {
    "figtree": {
      "$value": "Figtree",
      "$type": "fontFamily",
      "$description": "Single-family system: weight 400 for body, 600 for emphasis, 700 for subheadings, 800 for display headlines. The heavy display weight is the signature — headlines feel stamped rather than set, a deliberate contrast to the quiet 400 body. Negative letter-spacing tightens proportionals as size grows."
    }
  },
