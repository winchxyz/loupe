{
  "color": {
    "lavender-canvas": {
      "$value": "#ebefff",
      "$type": "color",
      "$description": "Lavender Canvas — Page background, hero section wash, footer background — the base atmosphere that distinguishes Reclaim from generic white SaaS"
    },
    "white-surface": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "White Surface — Card surfaces, product mockup containers, button text on dark fills — pure white provides the resting layer above the lavender canvas"
    },
    "midnight-ink": {
      "$value": "#181d25",
      "$type": "color",
      "$description": "Midnight Ink — Supporting neutral for secondary UI, dividers, and muted labels. Do not promote it to the primary CTA color"
    },
    "pure-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Pure Black — Dark supporting neutral for text, icons, and strong contrast. Do not promote it to the primary CTA color"
    },
    "graphite": {
      "$value": "#111111",
      "$type": "color",
      "$description": "Graphite — Body copy and card text on light surfaces — sits just above pure black for slightly softer reading weight"
    },
    "slate": {
      "$value": "#474747",
      "$type": "color",
      "$description": "Slate — Muted helper text, secondary descriptions, footer text — the workhorse for non-headline copy"
    },
    "charcoal": {
      "$value": "#2b2b2b",
      "$type": "color",
      "$description": "Charcoal — Subheadings and emphasized body — bridges Midnight Ink headings and Slate body text"
    },
    "stone": {
