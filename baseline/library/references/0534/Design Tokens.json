{
  "color": {
    "espresso-ink": {
      "$value": "#482317",
      "$type": "color",
      "$description": "Espresso Ink — Primary text, headings, nav links, body copy, and outlined button borders — a warm dark brown that replaces pure black and gives the whole system a softer, editorial voice"
    },
    "fog-border": {
      "$value": "#e5e7eb",
      "$type": "color",
      "$description": "Fog Border — Hairline borders, dividers, input outlines, and icon strokes across cards, nav, and body containers"
    },
    "cream-canvas": {
      "$value": "#fafafa",
      "$type": "color",
      "$description": "Cream Canvas — Page background and card surfaces — the off-white that everything sits on, warmer than pure white"
    },
    "lime-spark": {
      "$value": "#ecf956",
      "$type": "color",
      "$description": "Lime Spark — Green action color for filled buttons, selected navigation states, and focused conversion moments."
    },
    "lilac-whisper": {
      "$value": "#efd8f0",
      "$type": "color",
      "$description": "Lilac Whisper — Decorative pastel surface used inside product mockups and gradient washes — soft lavender that recedes behind content"
    },
    "mint-tint": {
      "$value": "#c6e57d",
      "$type": "color",
      "$description": "Mint Tint — Decorative pastel surface — light green used in card backgrounds and gradient endpoints"
    },
    "lemon-cream": {
      "$value": "#f3fb9a",
