  "font": {
    "self-modern": {
      "$value": "Self Modern",
      "$type": "fontFamily",
      "$description": "Display headlines and editorial copy — used sparingly for hero statements and collection titles. The serif italic-leaning forms break the sans-serif monotony and signal 'this is the story'."
    },
    "geograph": {
      "$value": "Geograph",
      "$type": "fontFamily",
      "$description": "The workhorse UI typeface — body copy, nav labels, buttons, product titles, footers, inputs, badges. 500 for emphasized labels, 700 for product names. Wide letter-spacing (0.025em–0.10em) on uppercase nav and category labels gives the brand its editorial cadence."
    },
    "hurmegeometricsans3": {
      "$value": "HurmeGeometricSans3",
      "$type": "fontFamily",
      "$description": "Rarely used — a fallback or specialized button label variant. Geograph carries the system day-to-day."
    }
  },
