  "font": {
    "airbnb-cereal-vf": {
      "$value": "Airbnb Cereal VF",
      "$type": "fontFamily",
      "$description": "The sole typeface for every text element across the UI. Weight 400 handles body and metadata; 500 lifts labels and secondary headings; 600 marks section titles; 700 for price display and primary emphasis. The custom variable font brings tight optical metrics at display sizes that generic fonts cannot replicate — negative letter-spacing at -0.02em pulls large numerals together. The 'salt' feature set activates alternate letterforms that distinguish it from system sans-serifs."
    }
  },
