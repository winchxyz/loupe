{
  "color": {
    "ink-teal": {
      "$value": "#102126",
      "$type": "color",
      "$description": "Ink Teal — Primary text, borders, filled buttons, iconography — the structural backbone of the system. Its near-black teal reads as authoritative without the harshness of pure black"
    },
    "slate-veil": {
      "$value": "#3d5761",
      "$type": "color",
      "$description": "Slate Veil — Secondary text, subtle borders — bridges body copy and muted UI chrome without competing with the primary ink"
    },
    "fog-gray": {
      "$value": "#677b82",
      "$type": "color",
      "$description": "Fog Gray — Tertiary text, disabled states, low-emphasis labels — the quietest neutral that still maintains readability against white"
    },
    "chalk-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Chalk White — Page canvas, card surfaces, button text on dark fills — the dominant surface that lets the dark ink and accent colors carry the visual weight"
    },
    "pale-mist": {
      "$value": "#f1f7f9",
      "$type": "color",
      "$description": "Pale Mist — Card backgrounds, section washes, subtle surface elevation — a barely-tinted cool gray that lifts cards off the white canvas without warmth"
    },
    "hairline-gray": {
      "$value": "#e9eef0",
      "$type": "color",
      "$description": "Hairline Gray — Dividers, borders, input outlines — the thinnest structural line color, used where a 1px edge needs to exist without drawing attention"
    },
    "ember-orange": {
      "$value": "#fa4e1d",
      "$type": "color",
      "$description": "Ember Orange — Orange wash for highlight backgrounds, decorative bands, and soft emphasis behind content. Do not promote it to the primary CTA color"
    },
    "sunset-coral": {
      "$value": "#fb6338",
      "$type": "color",
      "$description": "Sunset Coral — Orange wash for highlight backgrounds, decorative bands, and soft emphasis behind content. Do not promote it to the primary CTA color"
    },
    "signal-blue": {
      "$value": "#0c67ff",
      "$type": "color",
      "$description": "Signal Blue — Violet wash for highlight backgrounds, decorative bands, and soft emphasis behind content. Do not promote it to the primary CTA color"
    },
    "info-indigo": {
      "$value": "#0519d5",
      "$type": "color",
      "$description": "Info Indigo — Violet state accent for badges, validation surfaces, and short status labels. Do not promote it to the primary CTA color"
    },
    "soft-sky": {
      "$value": "#e4eeff",
      "$type": "color",
      "$description": "Soft Sky — Info badge backgrounds, subtle blue washes — the pastel counterpoint to Info Indigo, used when a blue element needs a tinted surface rather than a solid fill"
    }
  },
  "font": {
    "graphik": {
      "$value": "Graphik",
      "$type": "fontFamily",
      "$description": "Single-family system. Weight 500 carries all emphasis (headings, nav, button labels, card titles) while weight 400 handles body, descriptions, and supporting text. The two-weight discipline creates a binary voice: 500 announces, 400 explains. The tight line-height ratio on display sizes (1.10 at 56px) gives headlines a compact, editorial density rather than airy marketing sprawl."
    }
  },
