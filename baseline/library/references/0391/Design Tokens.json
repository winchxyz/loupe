{
  "color": {
    "tally-magenta": {
      "$value": "#f81ce5",
      "$type": "color",
      "$description": "Tally Magenta — Pink decorative accent for icons, marks, and small graphic details. Do not promote it to the primary CTA color; Decorative focus-ring and glow tint used to draw the eye to a highlighted feature card, applied as a soft 2–4px outer ring rather than a fill"
    },
    "action-blue": {
      "$value": "#0070d7",
      "$type": "color",
      "$description": "Action Blue — Primary action buttons only — the lone chromatic fill in the system, used to mark conversion moments without competing with the magenta brand mark"
    },
    "ink": {
      "$value": "#37352f",
      "$type": "color",
      "$description": "Ink — Primary text, heading fills, and the dominant dark border color across cards, body elements, and form chrome. A warm near-black rather than pure black"
    },
    "paper": {
      "$value": "#e0e0df",
      "$type": "color",
      "$description": "Paper — Page canvas — the warm light-gray background that all white card surfaces sit on. The signature surface of the system"
    },
    "white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "White — Card surfaces, form previews, input fields, and icon fills on the canvas. Provides the only bright surface layer"
    },
    "mist": {
      "$value": "#f3f3f3",
      "$type": "color",
      "$description": "Mist — Subtle elevated or muted surface for secondary panels, code blocks, and hover washes — a half-step darker than pure white"
    },
    "graphite": {
      "$value": "#898884",
      "$type": "color",
      "$description": "Graphite — Secondary text, helper copy, and tertiary borders on icons and body elements"
    },
    "ash": {
      "$value": "#777672",
      "$type": "color",
      "$description": "Ash — Muted borders, inactive dividers, and low-emphasis strokes for icons and form elements"
    },
    "charcoal": {
      "$value": "#45433e",
      "$type": "color",
      "$description": "Charcoal — Dark borders and separators for elevated surfaces and inverted UI. Do not promote it to the primary CTA color"
    },
    "black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Black — Heading borders, the dark header CTA button fill, and the highest-contrast button text — reserved for moments that need maximum weight"
    },
    "purple-to-pink": {
      "$value": "#f81ce0",
      "$type": "color",
      "$description": "Purple-to-Pink — Underline and streak flourishes under display headlines — a short linear sweep from violet to magenta that replaces the traditional squiggle"
    }
  },
  "font": {
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "The only typeface across the entire system. Used for display headlines at 64px weight 800, section headings at 30–36px weight 700, subheadings at 22–26px weight 600, body at 16–18px weight 400–500, and caption/label at 13–14px weight 500. The tight -0.031em tracking and high x-height make it read like a serif replacement at display sizes."
    }
  },
