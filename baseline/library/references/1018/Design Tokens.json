  "font": {
    "lambotype": {
      "$value": "LamboType",
      "$type": "fontFamily",
      "$description": "Exclusive brand typeface used at all hierarchy levels. Renders always in UPPERCASE for editorial weight, with a consistent 0.0230em letter-spacing across all sizes — the spacing is wide enough to feel engineered, not cramped. Display sizes reach 120px with tight 0.92–1.00 line-height so headlines stack into monolithic typographic blocks. The single weight (400) at radically different sizes (10px labels → 120px display) is the signature: the system achieves voice through scale contrast, never weight contrast."
    },
    "open-sans": {
      "$value": "Open Sans",
      "$type": "fontFamily",
      "$description": "Rare fallback or supplementary body text at 16px, normal letter-spacing — only used in 3 occurrences, effectively vestigial; do not introduce for new pages"
    }
  },
