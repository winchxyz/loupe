    "parchment": {
      "$value": "#eee9cc",
      "$type": "color",
      "$description": "Parchment — Primary canvas and card surface — the warm bone tone that carries all body content, tables, and quiet sections"
    },
    "aged-linen": {
      "$value": "#cecab1",
      "$type": "color",
      "$description": "Aged Linen — Secondary surface and muted text — slightly deeper parchment for sub-surfaces, helper text, and table headers"
    },
    "tobacco-brown": {
      "$value": "#674825",
