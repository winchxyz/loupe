{
  "color": {
    "ink-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Ink Black — Primary headings, body text, and icon fills on light surfaces. Do not promote it to the primary CTA color"
    },
    "charcoal": {
      "$value": "#18191b",
      "$type": "color",
