{
  "color": {
    "electric-violet": {
      "$value": "#0007cb",
      "$type": "color",
      "$description": "Electric Violet — Brand accent — used sparingly for emphasis moments, selected icon strokes, and tag punctuation; the only saturated color in the system creates instant focus when it appears against the warm neutral canvas"
    },
    "pure-white": {
