  "font": {
    "saans": {
      "$value": "Saans",
      "$type": "fontFamily",
      "$description": "Primary typeface for everything — display headlines at weight 300 (80px/54px/40px), headings at 300 (32px/24px), body at 400 (16px/20px). The 300-weight display is the signature: most brands shout at 700–800, Intercom whispers at 300 and achieves authority through restraint. Use weight 400 only for body and supporting text where readability is paramount."
    },
    "saansmono": {
      "$value": "SaansMono",
      "$type": "fontFamily",
      "$description": "Monospace labeling system — nav micro-labels, tab labels, tag chips, section metadata. Always paired with wide positive tracking to function as typographic badges. The 100em spacing on 12px is a 'shout' weight for the smallest text, making it readable as a label rather than body copy."
    },
    "serrif": {
      "$value": "Serrif",
      "$type": "fontFamily",
      "$description": "Editorial counterpoint — appears in select body paragraphs and pull quotes at 16px/300 to add a humanist, almost literary quality. The contrast of serif at 300 against Saans display at 300 creates the magazine-spread rhythm that defines Intercom's voice."
    },
    "mediumll": {
      "$value": "MediumLL",
      "$type": "fontFamily",
      "$description": "Secondary utility face for small UI labels and nav micro-copy where a condensed, tight feel is needed. Used sparingly — only 15 occurrences."
    }
  },
