{
  "color": {
    "lego-yellow": {
      "$value": "#FFD502",
      "$type": "color",
      "$description": "LEGO Yellow — Logo background, badges, active nav indicators, brand accent — the single chromatic constant that appears regardless of page section, making every badge feel like a price sticker on a toy box."
    },
    "brick-orange": {
      "$value": "#F47D20",
      "$type": "color",
      "$description": "Brick Orange — Primary CTA buttons ('Buy now', 'Add to Bag', 'Become a member') — warm against white product backgrounds, the only pill button fill color for purchase actions."
    },
    "ember-dark": {
      "$value": "#E96F14",
      "$type": "color",
      "$description": "Ember Dark — Orange hover/pressed state for CTA buttons — 1 step darker than Brick Orange."
    },
    "lego-navy": {
      "$value": "#201D48",
      "$type": "color",
      "$description": "LEGO Navy — Footer background, deep brand surface — the only dark chromatic surface, anchoring the page bottom with brand identity."
    },
    "link-blue": {
      "$value": "#006DB7",
      "$type": "color",
      "$description": "Link Blue — Body copy links, inline hyperlinks within editorial text — vivid blue on white for maximum contrast."
    },
    "action-blue": {
      "$value": "#005AD2",
      "$type": "color",
      "$description": "Action Blue — Secondary action buttons ('Become a member', 'Learn more'), interactive link emphasis — the outlined pill button border and text color."
    },
    "flag-red": {
      "$value": "#D0021B",
      "$type": "color",
      "$description": "Flag Red — 'New' nav badge text — used sparingly to flag newness in navigation."
    },
    "off-black": {
      "$value": "#141414",
      "$type": "color",
      "$description": "Off Black — Primary text, card titles, prices, icon fills — the dominant foreground color across all light surfaces."
    },
    "graphite": {
      "$value": "#2C2C2C",
      "$type": "color",
      "$description": "Graphite — Secondary text, badge labels, footer body text, nav items."
    },
    "pitch": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Pitch — Button label text on orange CTAs, heavy borders on ghost buttons."
    },
    "snow": {
      "$value": "#FFFFFF",
      "$type": "color",
      "$description": "Snow — Page background, card surfaces, input backgrounds, text on dark surfaces."
    },
    "fog": {
      "$value": "#F2F2F2",
      "$type": "color",
      "$description": "Fog — Secondary button fill (icon-only circular buttons, wishlist/cart controls), subtle surface backgrounds."
    },
    "pebble": {
      "$value": "#F6F6F6",
      "$type": "color",
      "$description": "Pebble — Page section backgrounds, list row fills — one step warmer than pure white."
    },
    "steel": {
      "$value": "#757575",
      "$type": "color",
      "$description": "Steel — Disabled state text, muted borders, helper text."
    },
    "silver": {
      "$value": "#E0E0E0",
      "$type": "color",
      "$description": "Silver — Input borders in default state."
    }
