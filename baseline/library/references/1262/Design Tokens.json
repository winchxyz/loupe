{
  "color": {
    "signal-orange": {
      "$value": "#ff682c",
      "$type": "color",
      "$description": "Signal Orange — Brand accent — chart fills, logo swoosh, active indicators, small highlights; the single chromatic spark across an otherwise monochrome system"
    },
    "sienna-bronze": {
      "$value": "#816729",
      "$type": "color",
      "$description": "Sienna Bronze — Muted brand tone — icon strokes, decorative chart elements, secondary brand marks where a subtler warmth is needed than Signal Orange"
    },
    "carbon": {
      "$value": "#202020",
      "$type": "color",
      "$description": "Carbon — Neutral form states, badge text, and quiet UI feedback where color should stay understated. Do not promote it to the primary CTA color"
    },
    "graphite": {
      "$value": "#4d4d4d",
      "$type": "color",
      "$description": "Graphite — Secondary text, body emphasis, subdued borders"
    },
    "slate": {
      "$value": "#828282",
      "$type": "color",
      "$description": "Slate — Muted helper text, inactive nav, tertiary borders, placeholder copy"
    },
    "fog": {
      "$value": "#f5f5f5",
      "$type": "color",
      "$description": "Fog — Alt surface tint, subtle bands within white cards, nav hover washes"
    },
    "mist": {
