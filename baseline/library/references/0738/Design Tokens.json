{
  "color": {
    "ember-orange": {
      "$value": "#f43e01",
      "$type": "color",
      "$description": "Ember Orange — Orange supporting accent for decorative details and low-frequency emphasis. Do not promote it to the primary CTA color"
    },
    "vapor-pink": {
      "$value": "#e09afe",
      "$type": "color",
      "$description": "Vapor Pink — Secondary decorative accent — rare highlights, special-emphasis inline marks, and select graphic flourishes. Used as a cool counterpoint to Ember Orange when a second color is needed"
    },
    "parchment": {
      "$value": "#e8e8de",
      "$type": "color",
      "$description": "Parchment — Page canvas — the warm off-white that defines the site's light mode. Warmer than pure white, it gives the whole interface a paper-like quality"
    },
    "bone": {
      "$value": "#f3f3ee",
      "$type": "color",
      "$description": "Bone — Elevated surface — cards, content blocks, nav backgrounds. One step lighter than Parchment, used to lift elements off the canvas without harsh contrast"
    },
    "graphite": {
      "$value": "#2d2f33",
      "$type": "color",
      "$description": "Graphite — Primary text and dark section background — near-black with a cool cast. The workhorse color for headings, body copy, and full-bleed dark bands"
    },
    "obsidian": {
      "$value": "#2a2a25",
      "$type": "color",
      "$description": "Obsidian — Deepest dark — alt dark-panel fill, footer surfaces. Slightly warmer than Graphite for variation in dark sections"
    },
    "stone": {
      "$value": "#69695d",
      "$type": "color",
      "$description": "Stone — Secondary text — descriptions, supporting copy, muted labels. Warm olive-gray that harmonizes with Parchment rather than fighting it"
    },
    "ash": {
      "$value": "#9c9c90",
      "$type": "color",
      "$description": "Ash — Tertiary text and disabled states — nav dropdown items, fine print, inactive icons"
    },
    "khaki": {
      "$value": "#cecebf",
      "$type": "color",
      "$description": "Khaki — Hairline borders and dividers — low-contrast warm gray that defines edges without drawing attention"
    },
    "mist": {
      "$value": "#c2c2be",
      "$type": "color",
      "$description": "Mist — List separators and secondary borders — a touch cooler than Khaki for list-item dividers"
    }
  },
  "font": {
    "space-grotesk": {
      "$value": "Space Grotesk",
      "$type": "fontFamily",
      "$description": "Primary typeface — all headings and body text. Weight 300 for headlines creates a quiet, technical confidence (anti-convention; most sites shout with 700). Weight 400 for body. Tight tracking at -0.02em across all sizes keeps headlines compact even at 46px."
    },
    "ibm-plex-mono": {
      "$value": "IBM Plex Mono",
      "$type": "fontFamily",
      "$description": "Eyebrow labels, section tags, code snippets, small data. Tracking +0.1em (wide) gives it a technical-spec or serial-number quality — used sparingly above headings or as status indicators."
    }
  },
