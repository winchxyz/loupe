{
  "color": {
    "dusk-violet": {
      "$value": "#8584bd",
      "$type": "color",
      "$description": "Dusk Violet — Primary canvas and hero background — the stage that every other color performs on"
    },
    "hi-vis-yellow": {
      "$value": "#f4ed36",
      "$type": "color",
      "$description": "Hi-Vis Yellow — Yellow accent for outlined action borders, linked labels, and lightweight interactive emphasis. Do not promote it to the primary CTA color"
    },
    "buttery-yellow": {
      "$value": "#f9cc73",
      "$type": "color",
      "$description": "Buttery Yellow — Secondary display text and softer borders — a mellower sibling of Hi-Vis for when Hi-Vis would be too much"
    },
    "lilac-shadow": {
      "$value": "#61609a",
      "$type": "color",
      "$description": "Lilac Shadow — Card and block backgrounds — a deeper violet for nested surfaces on the violet stage"
    },
    "bubblegum-pink": {
      "$value": "#f8c1ba",
      "$type": "color",
      "$description": "Bubblegum Pink — Decorative borders and confetti accent — a warm pink used sparingly for pop"
    },
    "matcha-cream": {
      "$value": "#b5c995",
      "$type": "color",
      "$description": "Matcha Cream — Decorative borders and confetti accent — a dusty sage for the secondary cast of cards"
    },
    "magenta-punch": {
      "$value": "#ac4f98",
      "$type": "color",
      "$description": "Magenta Punch — Accent card surface — reserved for standout blocks that need to scream louder than the stage"
    },
    "firecracker-red": {
      "$value": "#c94245",
      "$type": "color",
      "$description": "Firecracker Red — Red wash for highlight backgrounds, decorative bands, and soft emphasis behind content"
    },
    "bone-white": {
      "$value": "#f9f5f2",
      "$type": "color",
      "$description": "Bone White — Hairline borders, dividers, input outlines, and card edges on light surfaces. Do not promote it to the primary CTA color"
    },
    "ink-black": {
      "$value": "#1a1a1a",
      "$type": "color",
      "$description": "Ink Black — Body text, primary borders, and outlined button strokes — the near-black that does typographic work on cream surfaces"
    },
    "pure-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Pure Black — Hard borders, icons, and text on yellow surfaces — pure black where maximum edge contrast is needed"
    }
  },
  "font": {
    "obviouslyvariable": {
      "$value": "ObviouslyVariable",
      "$type": "fontFamily",
      "$description": "Display and large heading family — the only font loud enough for the system. Sizes scale from 18px body uses up to 341px poster-scale display. Tight 0.80–1.00 leading makes multi-line headlines stack into solid color blocks; calt is disabled so the wide geometric forms stay unornamented. Substitute: Founders Grotesk Condensed, Knockout, or Druk Wide."
    },
    "degularvariable": {
      "$value": "DegularVariable",
      "$type": "fontFamily",
      "$description": "Ultra-small UI text — nav, footer micro-copy, and inline labels at 10px. The neutral workhorse that disappears next to the display voice. Substitute: Inter, IBM Plex Sans."
    },
    "bergenmonoregular": {
      "$value": "bergen_monoregular",
      "$type": "fontFamily",
      "$description": "Monospaced micro-type for nav, tags, and small data labels — provides a typewriter rhythm against the rounded display. The 0.80 leading on monospace is signature: mono stacked tight feels like a receipt. Substitute: JetBrains Mono, IBM Plex Mono."
    },
    "degulardisplay-bold": {
      "$value": "DegularDisplay-Bold",
      "$type": "fontFamily",
      "$description": "Small bold body text for CTAs, button labels, and emphasized micro-copy. The 0.05em tracking opens the letterforms enough to read at 16px without crowding. Substitute: Degular Bold, Söhne Bold."
    }
  },
