{
  "color": {
    "page-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Page White — Page background, card surfaces, button text on blue"
    },
    "ink-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Ink Black — Primary heading text, heavy borders, icon fills, image framing"
    },
    "charcoal": {
      "$value": "#171717",
      "$type": "color",
      "$description": "Charcoal — Body text, nav text, secondary borders — slightly softer than pure black for long-form readability"
    },
    "granite": {
      "$value": "#5e5e5e",
      "$type": "color",
      "$description": "Granite — Muted helper text, secondary descriptions"
    },
    "slate": {
      "$value": "#6e6e73",
      "$type": "color",
      "$description": "Slate — Tertiary text, disabled states, fine metadata"
    },
    "mist": {
      "$value": "#d2d2d7",
      "$type": "color",
      "$description": "Mist — Hairline dividers, nav accents, light surface variation"
    },
    "wash-blue": {
      "$value": "#e3eeff",
      "$type": "color",
      "$description": "Wash Blue — Soft blue surface wash for highlighted sections and subtle backgrounds"
    },
    "signal-blue": {
      "$value": "#3b82f6",
      "$type": "color",
      "$description": "Signal Blue — Primary CTA fills, active link borders, key accent — the only chromatic color allowed to draw the eye"
    },
    "link-blue": {
      "$value": "#6ea5ff",
      "$type": "color",
      "$description": "Link Blue — Lighter blue for link text and secondary outlined actions"
    }
  },
  "font": {
    "sans-serif": {
      "$value": "sans-serif",
      "$type": "fontFamily",
      "$description": "sans-serif — detected in extracted data but not described by AI"
    },
    "satoshi": {
      "$value": "Satoshi",
      "$type": "fontFamily",
      "$description": "Primary display and UI font — used for all headlines at extreme sizes (93–120px) with weight 700 and tight tracking; also for body at 15px weight 400. Satoshi's geometric, slightly humanist forms give the type a modern, builder-friendly character. The decision to run 93–120px display sizes is signature — most builder sites cap at 48–64px, and this scale creates editorial monumentality."
    },
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "Input field text — the only context where Inter appears, used for form input legibility where Satoshi's tighter geometry could feel cramped."
    },
    "system-ui": {
      "$value": "system-ui",
      "$type": "fontFamily",
      "$description": "System fallback and minor inline elements. Acts as the safety net for Satoshi; not visually load-bearing."
    }
  },
