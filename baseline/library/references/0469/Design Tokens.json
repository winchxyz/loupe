  "font": {
    "oldschool-grotesk": {
      "$value": "Oldschool Grotesk",
      "$type": "fontFamily",
      "$description": "Display and heading face — the signature font. Weight 900 at 66–116px for hero headlines, weight 400 for small caps and labels. This custom geometric grotesk gives Jam its voice: the 900-weight is not just bold, it is architectural, and the compressed letterforms make even short words feel like monuments. At 8–16px it functions as an uppercase micro-label for trust badges and nav accents."
    },
    "sf-pro-text": {
      "$value": "SF Pro Text",
      "$type": "fontFamily",
      "$description": "UI body and interface text — the workhorse. Sizes 14–16px at weight 400–500 for body and nav, 600–700 for button labels. The -0.025em letter-spacing tightens the default SF Pro into a denser, more deliberate reading rhythm that matches the display font's compressed character."
    },
    "sf-mono": {
      "$value": "SF Mono",
      "$type": "fontFamily",
      "$description": "Monospaced code fragments and technical micro-labels — sparingly used for inline technical annotations"
    }
  },
