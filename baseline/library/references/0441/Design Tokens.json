  "font": {
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "Single typeface across the entire system. Weight 800 at 72px for hero headlines, weight 600-700 for product card titles and section headings, weight 500 for nav and labels, weight 400 for body and descriptions. Consistent -0.025em tracking tightens the geometric forms and gives the dark UI a compressed, technical feel."
    }
