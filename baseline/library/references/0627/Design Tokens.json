{
  "color": {
    "canvas": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Canvas — Page background, card surfaces, input fields — the dominant neutral that everything else sits on"
    },
    "obsidian-ink": {
      "$value": "#010110",
      "$type": "color",
      "$description": "Obsidian Ink — Primary text, nav borders, icon strokes, filled primary buttons, input borders — the structural near-black that reads as pure black at body sizes"
    },
    "carbon": {
      "$value": "#111117",
      "$type": "color",
      "$description": "Carbon — Dark-mode card surfaces, elevated dark panels, secondary dark backgrounds"
    },
    "graphite": {
      "$value": "#22222a",
      "$type": "color",
      "$description": "Graphite — Highest elevation in dark mode — feature card backgrounds, overlaid panels"
    },
    "fog": {
      "$value": "#73737c",
      "$type": "color",
      "$description": "Fog — Muted helper text, secondary body copy, subtle borders — the only neutral that drops to medium contrast intentionally"
    },
    "ash": {
      "$value": "#d9d9d9",
      "$type": "color",
      "$description": "Ash — Decorative dot pattern, hairline dividers, inactive surface washes"
    },
    "iris-pulse": {
      "$value": "#635bff",
      "$type": "color",
      "$description": "Iris Pulse — Announcement bar fill, link hover states, the single chromatic accent — violet against monochrome creates a strobe effect that draws the eye to time-sensitive copy"
    },
    "deep-teal": {
      "$value": "#072723",
      "$type": "color",
      "$description": "Deep Teal — Decorative illustration fills, abstract graphic washes inside hero imagery — carries no UI function, lives only in artwork"
    }
  },
  "font": {
    "sans-serif": {
      "$value": "sans-serif",
      "$type": "fontFamily",
      "$description": "sans-serif — detected in extracted data but not described by AI"
    },
    "abc-favorit-variable": {
      "$value": "ABC Favorit Variable",
      "$type": "fontFamily",
      "$description": "Display and heading face — used for hero headlines (52–76px), section headings (26–28px), and the occasional large inline link. The weight-400 setting is anti-convention: most fintech sites use 600–700 for headlines, but Favorit's high-contrast serifs at regular weight deliver authority through typographic personality rather than stroke weight. Letter-spacing -0.03em at 56px gives a compressed, editorial feel — words read as dense blocks of ink."
    },
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "Body, UI, and navigation face — used for paragraphs (16–18px), nav items (14–15px), buttons (14–16px), captions (12–13px), and the occasional subheading (20–21px). Weight 500 for emphasized inline text, 700 reserved for small-caps-style labels and tag-like UI. Letter-spacing -0.02em tightens the geometric sans so it doesn't feel too generic next to Favorit."
    },
    "abc-favorit-unlicensed-trial": {
      "$value": "ABC Favorit Unlicensed Trial",
      "$type": "fontFamily",
      "$description": "ABC Favorit Unlicensed Trial — detected in extracted data but not described by AI"
    }
  },
