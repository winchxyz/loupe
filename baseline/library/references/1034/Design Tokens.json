{
  "color": {
    "void-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Void Black — Primary canvas, page background — deepest layer of the dark surface stack"
    },
    "obsidian": {
      "$value": "#121212",
      "$type": "color",
      "$description": "Obsidian — Card surfaces, raised panels, modal backgrounds — one step up from the canvas"
    },
    "graphite": {
      "$value": "#1f1f1f",
      "$type": "color",
      "$description": "Graphite — Elevated controls, hover surfaces, filled button backgrounds — the interactive surface tier"
    },
    "ash-gray": {
      "$value": "#333333",
      "$type": "color",
      "$description": "Ash Gray — Input borders, subtle dividers, inactive control outlines"
    },
    "steel-mist": {
      "$value": "#767676",
      "$type": "color",
      "$description": "Steel Mist — Muted text, secondary nav, disabled labels — text that fades into the background"
    },
    "cloud-gray": {
      "$value": "#b3b3b3",
      "$type": "color",
      "$description": "Cloud Gray — Secondary body text, metadata, timestamps — readable but never competing with content"
    },
    "pure-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Pure White — Primary text, headings, light icon fills, pill button fills — the highest-contrast element on the dark canvas"
    },
    "spotify-green": {
      "$value": "#1ed760",
      "$type": "color",
      "$description": "Spotify Green — Green wash for highlight backgrounds, decorative bands, and soft emphasis behind content. Do not promote it to the primary CTA color"
    },
    "premium-magenta": {
      "$value": "#af2896",
      "$type": "color",
      "$description": "Premium Magenta — Gradient anchor for premium promotional banners, subscription upsell surfaces"
    },
    "premium-cobalt": {
      "$value": "#509bf5",
      "$type": "color",
      "$description": "Premium Cobalt — Gradient terminus for premium promotional banners, feature callouts on subscription screens"
    },
    "amber-glow": {
      "$value": "#a16b1b",
      "$type": "color",
      "$description": "Amber Glow — Decorative warmth — album artwork occasionally carries this tonal range"
    }
  },
  "font": {
    "spotifymixui": {
      "$value": "SpotifyMixUI",
      "$type": "fontFamily",
      "$description": "Primary UI typeface — handles all body copy, navigation, buttons, metadata, and small headings. Weight 400 carries body and labels, weight 600 appears in tab headers and emphasized metadata, weight 700 anchors section titles. The 4px size range (11–16px) keeps the entire interface at conversational volume, never editorial. Substitute: Inter, IBM Plex Sans, or DM Sans as freely available alternates with similar geometric warmth."
    },
    "spotifymixuititle": {
      "$value": "SpotifyMixUITitle",
      "$type": "fontFamily",
      "$description": "Rail and section headings — the 24px bold treatment for 'Trending songs', 'Popular artists', etc. is the only typographic moment that breaks above body size. Substitutes should be a geometric grotesque with a tall x-height and even stroke contrast."
    }
  },
