{
  "color": {
    "ember-orange": {
      "$value": "#ff6c02",
      "$type": "color",
      "$description": "Ember Orange — Primary CTAs, section tags, active nav, the glowing product frame, hand-drawn annotations, and the single decorative rule on the left margin — the one warm voice in an otherwise cold palette"
    },
    "ember-glow": {
      "$value": "#ff9b51",
      "$type": "color",
      "$description": "Ember Glow — Gradient stop paired with Ember Orange for the rare gradient surface (e.g. template card accent bars)"
    },
    "glacier-blue": {
      "$value": "#55c2ff",
      "$type": "color",
      "$description": "Glacier Blue — Blue state accent for badges, validation surfaces, and short status labels."
    },
    "bone-white": {
      "$value": "#f3f3f3",
      "$type": "color",
      "$description": "Bone White — Neutral form states, badge text, and quiet UI feedback where color should stay understated. Do not promote it to the primary CTA color"
    },
    "ash-gray": {
      "$value": "#dedede",
      "$type": "color",
      "$description": "Ash Gray — Secondary text and lighter icon strokes on dark surfaces"
    },
    "fog-gray": {
      "$value": "#909090",
      "$type": "color",
      "$description": "Fog Gray — Medium-contrast borders, control outlines, and structural separators."
    },
    "slate-gray": {
      "$value": "#646464",
      "$type": "color",
      "$description": "Slate Gray — Muted metadata text, timestamp labels, tertiary icon strokes"
    },
    "iron-border": {
      "$value": "#303030",
      "$type": "color",
      "$description": "Iron Border — Hairline dividers, code block borders, subtle list separators"
    },
    "charcoal-edge": {
      "$value": "#252525",
      "$type": "color",
      "$description": "Charcoal Edge — Card borders, subtle frame edges, input field borders"
    },
    "graphite": {
      "$value": "#1b1b1b",
      "$type": "color",
      "$description": "Graphite — High-contrast neutral action fill for primary buttons on light surfaces."
    },
    "obsidian": {
      "$value": "#121212",
      "$type": "color",
      "$description": "Obsidian — Card surface — one step above canvas, used for testimonial cards and elevated blocks"
    },
    "onyx": {
      "$value": "#0c0c0c",
      "$type": "color",
      "$description": "Onyx — Quote/testimonial card surface, link button background, the most common elevated surface"
    },
    "void": {
      "$value": "#040404",
      "$type": "color",
      "$description": "Void — Page canvas — the dominant page background"
    },
    "black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Black — Deepest surface for footer and image fill where absolute black is needed"
    }
  },
  "font": {
    "geist": {
      "$value": "Geist",
      "$type": "fontFamily",
      "$description": "Primary UI and display typeface. Weight 600 for headlines, 500 for nav and sub-labels, 400 for body. The tight negative tracking (-0.05em at 60px tightening to -0.03em at 16px) gives the type a machined, geometric feel — Geist's tall x-height and open apertures keep small body text readable against #040404 without weight inflation. Display sizes use lineHeight 1.0–1.14 for editorial compression."
    },
    "geist-mono": {
      "$value": "Geist Mono",
      "$type": "fontFamily",
      "$description": "Code-adjacent micro-copy: version tags, branch labels, file paths, inline commit IDs. Only used at 13px / 400 with the same -0.03em tracking as body Geist — this consistency is what makes the mono feel native rather than a foreign insert."
    }
  },
