{
  "color": {
    "onyx": {
      "$value": "#191919",
      "$type": "color",
      "$description": "Onyx — Primary text, hairline borders, full-bleed dark surface bands — the near-black ink of the system"
    },
    "pure-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Pure Black — Secondary text fills, deepest borders, and image overlays where maximum contrast against white is required"
    },
    "paper": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper — Page canvas, surface backgrounds, inverse text on dark bands"
    },
    "concrete": {
      "$value": "#808080",
      "$type": "color",
      "$description": "Concrete — Secondary descriptive text, muted link borders, subdued meta-information — the gray of footnotes and captions"
    }
  },
  "font": {
    "twk-everett": {
      "$value": "TWK Everett",
      "$type": "fontFamily",
      "$description": "All interface and display type — a neo-grotesque with tall x-height and geometric openness. The sole weight (400) across the entire range from 11px captions to 62px display creates a monolithic typographic voice. At 62px it receives aggressive negative tracking (-0.05em) that pulls the letterforms into a continuous architectural band; at 11px it switches to slight positive tracking (+0.04em) for utilitarian legibility in timestamps and labels."
    },
    "twk-everett-mono": {
      "$value": "TWK Everett Mono",
      "$type": "fontFamily",
      "$description": "Monospaced companion for data and technical annotations — used sparingly in body contexts where tabular alignment or code-like precision is needed. Single size at 21px with -0.01em tracking."
    }
  },
