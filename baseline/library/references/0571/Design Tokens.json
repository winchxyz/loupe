    "affinity-serif-variable": {
      "$value": "Affinity Serif Variable",
      "$type": "fontFamily",
      "$description": "Display headlines only. The signature element — tight 0.96–1.10 line-height lets descenders nearly touch the line below, creating an editorial poster feel. The italic 'all' in headlines is the brand's voice. At 112px with weight 400 it whispers authority; the type is the artwork."
    },
