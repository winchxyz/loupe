      "$description": "Cloud — Soft alternate surface — sits beneath white cards for subtle banding between content sections"
    },
    "mist": {
      "$value": "#ebedef",
      "$type": "color",
      "$description": "Mist — Hairline card and stroke surface, secondary card backgrounds in quiet zones"
    },
    "graphite": {
      "$value": "#8d8e8f",
      "$type": "color",
      "$description": "Graphite — Medium-contrast borders, control outlines, and structural separators."
    },
    "iron": {
      "$value": "#5f6162",
      "$type": "color",
      "$description": "Iron — Secondary text and secondary borders — one step stronger than Graphite for body sub-copy that still needs to recede"
    },
    "noir": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Noir — Highest-contrast text and the dominant border color across all surfaces. Used where maximum legibility or definition is needed"
    },
    "cobalt-pop": {
      "$value": "#1d58c0",
      "$type": "color",
      "$description": "Cobalt Pop — Carousel testimonial card accent background — appears as a solid color block beside the violet and green variants, not used in chrome"
    },
    "fern-pop": {
      "$value": "#009639",
      "$type": "color",
      "$description": "Fern Pop — Carousel testimonial card accent background — third slot in the rotating brand color trio. Decorative only"
    },
    "lilac-wash": {
      "$value": "#f1eefe",
      "$type": "color",
      "$description": "Lilac Wash — Soft purple-tinted card surface used in the testimonial carousel — echoes the brand violet at 8% saturation"
