{
  "color": {
    "iris": {
      "$value": "#624de3",
      "$type": "color",
      "$description": "Iris — Primary brand color — gradient headline text, icon strokes, accent borders, focal links. The only chromatic voice in the system; appears sparingly to make accents feel like punctuation rather than decoration"
    },
    "soft-iris": {
      "$value": "#8d4af7",
      "$type": "color",
      "$description": "Soft Iris — Gradient tail for the brand violet — the lighter stop in hero headline gradients. Paired with #1d58c0 and #009639 only inside the carousel card color-blocks, not in chrome"
    },
    "studio-slate": {
      "$value": "#1a1d1e",
      "$type": "color",
      "$description": "Studio Slate — Primary text, dark filled buttons, body borders, heading strokes. The working near-black that carries 90% of the interface's weight"
    },
    "obsidian": {
      "$value": "#151718",
      "$type": "color",
      "$description": "Obsidian — Hero and section background fill — the deep dark behind the gradient headline and 3D illustration. Slightly cooler/lighter than pure black to keep the violet legible"
    },
    "pure-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Pure White — Light-theme canvas, card surfaces, button text on dark fills, hero overlay text"
    },
    "cloud": {
