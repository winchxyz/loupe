      "$description": "Paper — Page background, card surfaces, image holders — the dominant canvas; everything sits on this"
    },
    "ink": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Ink — Primary text, link text, icon strokes, thin section dividers — the only mark-making color"
    },
    "graphite": {
      "$value": "#858585",
      "$type": "color",
