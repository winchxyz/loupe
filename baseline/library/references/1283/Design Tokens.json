{
  "color": {
    "concrete-canvas": {
      "$value": "#e2e2df",
      "$type": "color",
      "$description": "Concrete Canvas — Page background — warm light-gray stone, the dominant surface the whole site sits on"
    },
    "cream-card": {
      "$value": "#f7f6f2",
      "$type": "color",
      "$description": "Cream Card — Card surfaces, stat panels, elevated content blocks — sits one step brighter than the canvas"
    },
    "ink": {
      "$value": "#070607",
      "$type": "color",
      "$description": "Ink — Headlines, body text, hairline borders, and the structural outlines that give the layout its editorial frame"
    },
    "pure-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Pure Black — Icon strokes, dense border work, and the deepest text where Ink isn't dark enough"
    },
    "paper-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper White — White text on orange/dark surfaces and SVG mask fills — not a background"
    },
    "citra-orange": {
      "$value": "#fc5000",
      "$type": "color",
      "$description": "Citra Orange — Primary action — filled buttons, the CTA pill, active links, stat-card fills, and brand accents; the only saturated warm in the system"
    },
    "ion-violet": {
      "$value": "#524ae9",
      "$type": "color",
      "$description": "Ion Violet — Decorative surface accent — appears in halftone gradient art and one hero card, never as a button or text"
    },
    "hazard-yellow": {
      "$value": "#f5f28e",
      "$type": "color",
      "$description": "Hazard Yellow — Rare highlight surface for emphasis blocks and tag backgrounds — high contrast against both Ink and Citra Orange"
    }
  },
  "font": {
    "sans-serif": {
      "$value": "sans-serif",
      "$type": "fontFamily",
      "$description": "sans-serif — detected in extracted data but not described by AI"
    },
    "pp-neue-corp-compact": {
      "$value": "PP Neue Corp Compact",
      "$type": "fontFamily",
      "$description": "Display and headline — the entire brand voice. Used for hero, section titles, stat numbers, and blog post titles. The extreme condensed ultrabold cut, running up to 189px on the hero with line-height under 1.0, is the signature: a single headline takes the full width and reads like a magazine cover rather than a SaaS hero."
    },
    "dm-sans": {
      "$value": "DM Sans",
      "$type": "fontFamily",
      "$description": "Body, subheadings, nav, buttons, and form labels. Medium weight (not regular) is deliberate — it matches the visual density of the ultrabold headlines and prevents body copy from looking anaemic next to them. Pairs with the display face as the quieter half of the system."
    }
  },
