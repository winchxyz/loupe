{
  "color": {
    "ember-signal": {
      "$value": "#ff4d00",
      "$type": "color",
      "$description": "Ember Signal — Active nav state only — appears on a single interactive element as a hot indicator, never used for buttons or CTAs; its rarity is the feature"
    },
    "void": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Void — Page background, button fill, SVG fills — absolute black, not near-black"
    },
