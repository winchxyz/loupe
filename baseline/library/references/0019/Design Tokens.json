{
  "color": {
    "electric-violet": {
      "$value": "#8169ff",
      "$type": "color",
      "$description": "Electric Violet — Violet supporting accent for decorative details and low-frequency emphasis. Do not promote it to the primary CTA color"
    },
    "deep-iris": {
      "$value": "#6d4ff0",
      "$type": "color",
      "$description": "Deep Iris — Pressed and hover state of Electric Violet — used for filled-element interaction feedback and slightly deeper icon strokes"
    },
    "soft-lilac": {
      "$value": "#c9bfff",
      "$type": "color",
      "$description": "Soft Lilac — Light accent wash — decorative gradient stops, soft tag backgrounds, muted selected states, and atmospheric color bleeds at section edges"
    },
    "ink-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Ink Black — Primary text, hero headlines, high-contrast icons. The strongest typographic color, reserved for content the eye should land on first"
    },
    "carbon": {
      "$value": "#181818",
      "$type": "color",
      "$description": "Carbon — Navigation text, input borders, near-black UI surfaces, button labels. Softer than pure black so it reads as interface, not print"
    },
    "graphite": {
      "$value": "#555555",
      "$type": "color",
      "$description": "Graphite — Body text, supporting copy, secondary labels, paragraph running text under headlines"
    },
    "silver": {
      "$value": "#999999",
      "$type": "color",
      "$description": "Silver — Muted text, placeholders, disabled labels, captions, subtitle hierarchy. The quietest text tier, used only for de-emphasized content"
    },
    "paper-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper White — Page canvas, card surfaces, button text on filled violet, elevated panel backgrounds"
    },
    "aqua-wash": {
      "$value": "#81dbdb",
      "$type": "color",
      "$description": "Aqua Wash — Decorative gradient stop — pastel teal radial wash on hero left side, atmospheric background tint that never fills a UI element"
    },
    "lilac-bleed": {
      "$value": "#e3deff",
      "$type": "color",
      "$description": "Lilac Bleed — Decorative gradient stop — pastel lavender radial wash on hero right side and section-edge color bleeds, creating depth at zero contrast cost"
    }
  },
  "font": {
    "gilroy": {
      "$value": "Gilroy",
      "$type": "fontFamily",
      "$description": "Primary display and brand typeface — headlines, hero copy, nav, button labels. Custom geometric sans with a friendly, designer-made personality; weight 700 at 48–62px defines the brand voice. Weight 400 is used for body and nav."
    },
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "Secondary UI and body typeface — input text, form labels, small captions, inline metadata, and any context where Gilroy would feel too display-heavy. Reads as a neutral workhorse underneath the brand voice."
    },
    "palmer-lake-print": {
      "$value": "Palmer Lake Print",
      "$type": "fontFamily",
      "$description": "Decorative script accent — used once per page for hand-drawn section annotations (e.g. \"TRY DEMO BELOW\"). Carries a personal, hand-made quality that reinforces the prototyping-workshop atmosphere. Never used for functional UI."
    }
  },
