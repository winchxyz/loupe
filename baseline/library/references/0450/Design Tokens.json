{
  "color": {
    "brand-violet": {
      "$value": "#5727e7",
      "$type": "color",
      "$description": "Brand Violet — Violet supporting accent for decorative details and low-frequency emphasis. Do not promote it to the primary CTA color"
    },
    "tinted-highlight": {
      "$value": "#f2f2ff",
      "$type": "color",
      "$description": "Tinted Highlight — Light supporting surface for subtle backgrounds and section separation."
    },
    "ink-black": {
      "$value": "#030712",
      "$type": "color",
      "$description": "Ink Black — Headline text, primary copy at full weight — the deepest near-black, used wherever the system needs maximum contrast on white"
    },
    "graphite": {
      "$value": "#222222",
      "$type": "color",
      "$description": "Graphite — Secondary text, button labels on filled surfaces, dark UI chrome where pure black is too heavy"
    },
    "slate": {
      "$value": "#4b5563",
      "$type": "color",
      "$description": "Slate — Body text, paragraph copy, subheadings — the working gray for sustained reading"
    },
    "mid-gray": {
