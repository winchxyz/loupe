      "$type": "color",
      "$description": "Cloud — Page canvas, section background behind cards — the off-white that lifts content without being clinical"
    },
    "paper": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper — Card surfaces, nav bar, button text on violet, input fields — the bright top layer"
    }
  },
  "font": {
    "satoshi": {
      "$value": "Satoshi",
      "$type": "fontFamily",
      "$description": "Single-family geometric sans used for everything from 14px helper text up to 60px display headlines. Satoshi's rounded geometric forms give the violet-and-white system a friendlier edge than a neutral grotesque — the open apertures and soft terminals keep even the 700-weight display lines from feeling corporate. Weight 700 owns the hero and section headlines; 600 handles subheadings and emphasized body; 500 is reserved for button labels and badge text; 400 carries paragraphs and UI labels. Free substitute: 'Inter' or 'General Sans' (Fontshare) as the closest open-license match."
    }
  },
