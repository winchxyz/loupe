{
  "color": {
    "acid-green": {
      "$value": "#cafc00",
      "$type": "color",
      "$description": "Acid Green — Brand accent — the singular chromatic highlight. Marks the Pro Access pill in the nav, the primary upgrade button, and occasional pill highlights. The only color allowed to carry brand meaning at full saturation"
    },
    "vermillion": {
      "$value": "#f54911",
      "$type": "color",
      "$description": "Vermillion — Secondary accent — warm red-orange for emphasis text, decorative borders, and small brand moments. Never used for backgrounds at scale"
    },
    "magenta-pop": {
      "$value": "#c42df9",
      "$type": "color",
      "$description": "Magenta Pop — Tertiary accent — vivid pink for icons, decorative strokes, and illustration pops. Functions as a tertiary tag color in the brand palette"
    },
    "ink-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Ink Black — Primary text, heading strokes, and the dominant interface color. Carries body copy, icons, and high-contrast borders"
    },
    "obsidian": {
      "$value": "#0d0d0d",
      "$type": "color",
      "$description": "Obsidian — Dark surface fill for active states, dark buttons, and inverted sections"
    },
    "charcoal": {
      "$value": "#1e1e1e",
      "$type": "color",
      "$description": "Charcoal — Secondary dark surface — slightly softer than Obsidian for cards that need depth without going fully black"
    },
    "slate-ink": {
      "$value": "#14151a",
      "$type": "color",
      "$description": "Slate Ink — Near-black for specific UI borders and text where pure black reads too harsh against warm grays"
    },
    "graphite": {
      "$value": "#606060",
      "$type": "color",
      "$description": "Graphite — Secondary text, muted icons, and secondary button text. The workhorse mid-gray for body copy that should recede"
    },
    "ash-gray": {
      "$value": "#999999",
      "$type": "color",
      "$description": "Ash Gray — Tertiary text, placeholder copy, and disabled icon strokes"
    },
    "mist": {
      "$value": "#9ea0a8",
      "$type": "color",
      "$description": "Mist — Cool-leaning gray for subtle borders and muted helper text"
    },
    "paper": {
      "$value": "#f9f9f9",
      "$type": "color",
      "$description": "Paper — Page canvas — the dominant background across the entire site. Slightly warm, never pure white"
    },
    "fog": {
      "$value": "#f2f2f2",
      "$type": "color",
      "$description": "Fog — Secondary surface for inset panels, section dividers, and soft background washes"
    },
    "snow": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Snow — Light supporting surface for subtle backgrounds and section separation. Do not promote it to the primary CTA color"
    },
    "hairline": {
      "$value": "#dee0e3",
      "$type": "color",
      "$description": "Hairline — Hairline borders, dividers, and input outlines. The thinnest structural line in the system"
    }
  },
  "font": {
    "euclid-circular-a": {
      "$value": "Euclid Circular A",
      "$type": "fontFamily",
      "$description": "The single typeface across the entire system. Euclid Circular A is a geometric humanist sans with wide apertures and circular geometry — it reads modern but warm, which keeps a design-marketplace brand from feeling cold. Used for everything from 11px nav labels to 72px display headlines. The negative letter-spacing pattern (tightest at -0.069em for 72px, loosening to 0 at 11px) creates a deliberate density that defines the site's editorial rhythm."
    }
  },
