{
  "color": {
    "ink-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Ink Black — Primary text, filled action buttons, card borders, dividers — the structural spine of the entire interface"
    },
    "paper-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper White — Page canvas, card surfaces, button text on dark fills, icon fills on dark backgrounds"
    },
    "faint-slate": {
      "$value": "#f8fafc",
      "$type": "color",
      "$description": "Faint Slate — Subtle off-white for logo strip cards, secondary panel backgrounds, alternating section tint"
    },
    "lavender-mist": {
      "$value": "#e2e9f3",
      "$type": "color",
      "$description": "Lavender Mist — Feature card surfaces and section background tints — soft cool gray that groups content without weight"
    },
    "blue-gray-mist": {
      "$value": "#c5d3e8",
      "$type": "color",
      "$description": "Blue-Gray Mist — Hero background tint, code-card surfaces, soft borders — a textured atmospheric wash"
    },
    "cream-wash": {
      "$value": "#fffde6",
      "$type": "color",
      "$description": "Cream Wash — Warm pale tint for secondary card surfaces and badge backgrounds — adds warmth without chroma"
    },
    "sky-tint": {
      "$value": "#c4edff",
      "$type": "color",
      "$description": "Sky Tint — Code/terminal block backgrounds, inline highlight washes on body text, light badge fills"
    },
    "graphite": {
      "$value": "#686562",
      "$type": "color",
      "$description": "Graphite — Muted body text, secondary borders — the only step down from pure black for de-emphasized content"
    },
    "signal-orange": {
      "$value": "#ff4500",
      "$type": "color",
      "$description": "Signal Orange — Orange outline accent for tags, dividers, and focused UI edges. Do not promote it to the primary CTA color"
    }
  },
  "font": {
    "plain": {
      "$value": "plain",
      "$type": "fontFamily",
      "$description": "Body text and UI labels at 16px (lh 1.50) and subheadings at 24px (lh 1.30). Neutral grotesque with near-zero letter-spacing — invisible by design, letting the display face carry hierarchy. Substitute: Inter or Geist."
    },
    "gtplanar": {
      "$value": "gtPlanar",
      "$type": "fontFamily",
      "$description": "Display and heading face. Carries every editorial headline. Aggressive negative tracking (-0.02em to -0.05em) tightens the geometric forms; the \"ss05\" alternate glyph set is the signature — it reshapes letterforms into the brand's distinct voice. The 189px hero size is a statement, not a heading. Substitute: GT America or Söhne Breit for the geometric density."
    },
    "gtstandardmono": {
      "$value": "gtStandardMono",
      "$type": "fontFamily",
      "$description": "Metadata labels, section eyebrows, uppercase tags, code-adjacent annotations. Positive tracking (0.03–0.06em) widens the mono into a label utility, not running code. Substitute: JetBrains Mono or IBM Plex Mono."
    }
  },
