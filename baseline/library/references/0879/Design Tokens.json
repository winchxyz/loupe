{
  "color": {
    "cream-paper": {
      "$value": "#ffffeb",
      "$type": "color",
      "$description": "Cream Paper — Primary page canvas, card surfaces, light section backgrounds — the warm ivory that defines the entire light theme"
    },
    "midnight-ink": {
      "$value": "#1a1a1a",
      "$type": "color",
      "$description": "Midnight Ink — Primary text, dark section backgrounds, hairline borders, nav dividers — near-black rather than pure black for warmth"
    },
    "pure-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Pure Black — Decorative SVG fills and shadow color — not a text or surface token"
    },
    "white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "White — Text on dark surfaces, nav bar background, badge fills, inverse button text"
    },
    "stone-mist": {
      "$value": "#e4e4d0",
      "$type": "color",
      "$description": "Stone Mist — Subtle borders on the cream canvas, nav background variant, muted surface tint — barely-there warm gray that separates without shouting"
    },
    "graphite-veil": {
      "$value": "#8a8a80",
      "$type": "color",
      "$description": "Graphite Veil — Medium-contrast borders, control outlines, and structural separators."
    },
    "smoke": {
      "$value": "#5f5f59",
      "$type": "color",
      "$description": "Smoke — Tertiary text, low-emphasis captions, less prominent body copy"
    },
    "charcoal": {
      "$value": "#222222",
      "$type": "color",
      "$description": "Charcoal — Nav borders, button borders, dark UI chrome — one step lighter than Midnight Ink for layered dark elements"
    },
    "charcoal-mist": {
      "$value": "#333333",
      "$type": "color",
      "$description": "Charcoal Mist — Dark borders and separators for elevated surfaces and inverted UI. Do not promote it to the primary CTA color"
    },
    "deep-forest-teal": {
      "$value": "#034f46",
      "$type": "color",
      "$description": "Deep Forest Teal — Announcement banner background, dark testimonial band, badge fills, brand-defining accent section — rich teal that anchors visual weight"
    },
    "lavender-whisper": {
      "$value": "#f0d7ff",
      "$type": "color",
      "$description": "Lavender Whisper — Primary CTA button background, headline underline accent, highlight washes — the soft purple that signals actionable moments without aggression"
    },
    "amber-pulse": {
      "$value": "#ffa946",
      "$type": "color",
      "$description": "Amber Pulse — Decorative accent, badge highlight, illustration warm fill — small dose of warmth against the teal-and-lavender duotone"
    }
  },
  "font": {
    "figtree": {
      "$value": "Figtree",
      "$type": "fontFamily",
      "$description": "All UI text — body, navigation, buttons, labels, captions, badge text, footer. Weight 500 for nav items and labels, 600 for button text, 700 for emphasized inline text. Compact line-heights (0.95–1.00) on larger sizes give headings a tight controlled feel."
    },
    "eb-garamond": {
      "$value": "EB Garamond",
      "$type": "fontFamily",
      "$description": "Display and hero headlines — used at 64–120px for section titles ('Don't type, just speak', '4x faster than typing') and 32–48px for sub-display. The serif choice is the brand's most distinctive decision: an editorial voice inside a tech product. Negative letter-spacing tightens the classical letterforms into a modern headline block."
    },
    "apple-color-emoji": {
      "$value": "Apple Color Emoji",
      "$type": "fontFamily",
      "$description": "Apple Color Emoji — detected in extracted data but not described by AI"
    }
  },
