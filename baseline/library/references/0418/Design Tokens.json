{
  "color": {
    "electric-blue": {
      "$value": "#0000ff",
      "$type": "color",
      "$description": "Electric Blue — Violet outline accent for tags, dividers, and focused UI edges. Do not promote it to the primary CTA color"
    },
    "wireframe-green": {
      "$value": "#098551",
      "$type": "color",
      "$description": "Wireframe Green — Data point accent on the world map visualization — marks growth/gas nodes against the neutral wireframe"
    },
