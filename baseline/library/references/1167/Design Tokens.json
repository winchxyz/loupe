{
  "color": {
    "sage-canvas": {
      "$value": "#d3e4df",
      "$type": "color",
      "$description": "Sage Canvas — Page background, hero bands, section dividers — the dominant ambient color that gives the system its calming gallery atmosphere"
    },
    "pure-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Pure White — Card surfaces, image masks, icon fills, high-contrast text on dark sections"
    },
    "mint-frost": {
      "$value": "#edf4f2",
      "$type": "color",
      "$description": "Mint Frost — Badge backgrounds, subtle highlight washes, secondary card surfaces — a quieter sibling of the sage canvas"
    },
    "carbon": {
      "$value": "#0d1212",
      "$type": "color",
      "$description": "Carbon — Primary text, dark section backgrounds, heavy borders — the deepest near-black, slightly cooler than true black"
    },
    "graphite": {
      "$value": "#34484a",
      "$type": "color",
      "$description": "Graphite — Navigation borders, secondary headings, muted icon strokes — a dark desaturated teal that bridges neutrals and the accent; Dark borders and separators for elevated surfaces and inverted UI."
    },
    "slate": {
      "$value": "#565959",
      "$type": "color",
      "$description": "Slate — Body text secondary level, list dividers, footers, muted borders"
    },
    "fog": {
      "$value": "#9aa3a5",
      "$type": "color",
      "$description": "Fog — Tertiary text, placeholder labels, disabled icon strokes"
    },
    "mist": {
      "$value": "#7b8889",
      "$type": "color",
      "$description": "Mist — Eyebrow text and label color, small caps headers"
    },
    "vivid-teal": {
      "$value": "#64d5b3",
      "$type": "color",
      "$description": "Vivid Teal — Primary action button fills, accent surfaces, interactive highlights — the single chromatic color in the system, used sparingly to signal action"
    },
    "eucalyptus": {
      "$value": "#5b8279",
      "$type": "color",
      "$description": "Eucalyptus — Gray outline accent for tags, dividers, and focused UI edges. Do not promote it to the primary CTA color"
    }
  },
  "font": {
    "gt-standard-s": {
      "$value": "GT Standard S",
      "$type": "fontFamily",
      "$description": "Primary UI and body typeface — used for navigation, buttons, body copy, badges, inputs, and headings up to 50px. The 'kern' 0 feature setting deliberately disables kerning for a monospaced-mechanical feel. The 0.0500em tracking on 12-13px text gives small labels a spacious, typeset quality."
    },
    "gt-standard-l": {
      "$value": "GT Standard L",
      "$type": "fontFamily",
      "$description": "Display-only typeface reserved for hero headlines and large section titles. Used at a single weight (400) to keep the voice calm and confident — no bold shouting. The 120px size with normal letter-spacing creates wide, architectural headlines that sit centered on the sage canvas."
    }
  },
