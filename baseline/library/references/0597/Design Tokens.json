  "font": {
    "regular": {
      "$value": "Regular",
      "$type": "fontFamily",
      "$description": "Regular — detected in extracted data but not described by AI"
    },
    "a-geometric-grotesque-sans-serif-custom-marketed-as-the-site-font-inter-manrope-or-dm-sans-are-close-substitutes": {
      "$value": "A geometric grotesque sans-serif (custom-marketed as the site font — Inter, Manrope, or DM Sans are close substitutes)",
      "$type": "fontFamily",
      "$description": "All UI, body, navigation, and headings. Weight 500 carries buttons, nav links, and sub-headings; weight 400 owns body copy; weight 700 reserved for eyebrow labels with opened tracking. The full range from 11px captions to 150px display headings makes this a single-family system doing everything."
    },
    "nanum-pen-script": {
      "$value": "Nanum Pen Script",
      "$type": "fontFamily",
      "$description": "Hand-drawn personality accent — appears only under hero copy (the orange 'actually work' underline) and similar signature moments. Never used for body, UI, or navigation. This is the brand's most distinctive typographic move: a script that says 'we're human, not enterprise software'."
    },
