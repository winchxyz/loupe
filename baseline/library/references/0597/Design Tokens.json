{
  "color": {
    "indigo-bolt": {
      "$value": "#4570ff",
      "$type": "color",
      "$description": "Indigo Bolt — Violet action color for filled buttons, selected navigation states, and focused conversion moments."
    },
    "ember-orange": {
      "$value": "#ff6808",
      "$type": "color",
      "$description": "Ember Orange — Orange accent for outlined action borders, linked labels, and lightweight interactive emphasis"
    },
    "lime-highlighter": {
      "$value": "#c6ff94",
      "$type": "color",
      "$description": "Lime Highlighter — Green text accent for links, tags, and emphasized short phrases."
    },
    "lavender-mist": {
      "$value": "#ebdcff",
      "$type": "color",
      "$description": "Lavender Mist — Soft card surface, gentle section background — pastel variant for breaking up the white canvas without adding noise"
    },
    "ice-blue": {
      "$value": "#d6e0ff",
      "$type": "color",
      "$description": "Ice Blue — Cool pastel card surface, section wash — pairs with indigo to reinforce the primary brand hue at low intensity"
    },
    "lilac-bloom": {
      "$value": "#c293f1",
      "$type": "color",
      "$description": "Lilac Bloom — Saturated card background in feature card grid — bolder pastel, one of four colored card variants that rotate across feature rows"
    },
    "deep-navy": {
      "$value": "#193f78",
      "$type": "color",
      "$description": "Deep Navy — Blue wash for highlight backgrounds, decorative bands, and soft emphasis behind content. Do not promote it to the primary CTA color"
    },
    "forest-sage": {
      "$value": "#244f47",
      "$type": "color",
      "$description": "Forest Sage — Muted teal card variant — grounded, earthy counterpoint in the four-color card rotation"
    },
    "warm-bone": {
      "$value": "#f1f0ec",
      "$type": "color",
      "$description": "Warm Bone — Secondary canvas, soft section backgrounds, neutral action borders — the off-white that keeps the page from feeling sterile"
    },
    "paper-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper White — Page background, card surfaces, button fills, body text on dark sections"
    },
    "ink-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Ink Black — Primary text, dark feature sections, filled dark comparison cards — creates the dramatic black bands that make the colors pop"
    },
    "hairline": {
      "$value": "#e5e7eb",
      "$type": "color",
      "$description": "Hairline — Borders, dividers, table rules, input borders — the workhorse neutral stroke"
    },
    "stone": {
      "$value": "#d1d5db",
      "$type": "color",
