{
  "color": {
    "signal-blue": {
      "$value": "#0080ff",
      "$type": "color",
      "$description": "Signal Blue — Blue supporting accent for decorative details and low-frequency emphasis. Do not promote it to the primary CTA color"
    },
    "voltage-violet": {
      "$value": "#0050ff",
      "$type": "color",
      "$description": "Voltage Violet — Decorative card border glow, hero gradient bloom, chromatic outline accents on floating mockups — sits one notch deeper than Signal Blue for layered brand moments"
    },
    "sky-wash": {
      "$value": "#c5e0fb",
      "$type": "color",
      "$description": "Sky Wash — Gray supporting accent for decorative details and low-frequency emphasis. Do not promote it to the primary CTA color"
    },
    "pencil-gray": {
      "$value": "#8c9baa",
      "$type": "color",
      "$description": "Pencil Gray — Muted body text, hairline borders, nav dividers, step badges, tertiary metadata"
    },
    "graphite": {
      "$value": "#636f7b",
      "$type": "color",
      "$description": "Graphite — Secondary body copy, inactive nav items, supporting descriptions"
    },
    "ink": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Ink — Headlines, primary body, button text, logo wordmark — the dominant voice of the system at AAA contrast on white"
    },
    "carbon": {
      "$value": "#222222",
      "$type": "color",
      "$description": "Carbon — Navigation text, dense UI labels where pure black feels heavy"
    },
    "paper": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper — Page background, card surface, button text on Signal Blue, inverted surfaces"
    }
  },
  "font": {
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "Single-family system. Display uses 700 weight at 64–118px with tight tracking (-0.06em) and near-square line-height (0.94–1.09) so headlines stack as a compact typographic block. Body and UI use 400–500 at 14–18px with 1.4–1.67 line-height. Weights 600–700 are reserved for headings, CTAs, and section labels; weight 500 carries button text and small caps-style badges."
    }
  },
