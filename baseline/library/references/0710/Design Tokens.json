  "font": {
    "tomato-grotesk": {
      "$value": "Tomato Grotesk",
      "$type": "fontFamily",
      "$description": "The single typeface carrying the entire brand — a custom geometric grotesque deployed at extreme display sizes (up to 176px) with aggressively tight leading (0.77–0.80) that makes headlines feel like architectural cutouts rather than composed type. Weight 600 at display, 500 at body and UI. The tight line-height at hero scale is the signature: it stacks 'Take' and 'Ctrl.' into a single visual block."
    }
  },
