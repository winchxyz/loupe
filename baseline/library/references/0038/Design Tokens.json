{
  "color": {
    "ember-orange": {
      "$value": "#ff6600",
      "$type": "color",
      "$description": "Ember Orange — Primary action fill on CTA buttons, contact links, and key navigation entry points — warm saturated orange against cream and black grounds commands without feeling aggressive"
    },
    "architect-violet": {
      "$value": "#5c2999",
      "$type": "color",
      "$description": "Architect Violet — Decorative stroke and border accent for feature panels, concentric arc illustrations, and iconography — deep saturated violet that frames content without competing with orange CTAs"
    },
    "lichen-green": {
      "$value": "#00cc88",
      "$type": "color",
      "$description": "Lichen Green — Green outline accent for tags, dividers, and focused UI edges. Use as a supporting accent, not as a status color"
    },
    "sandstone": {
      "$value": "#aa8855",
      "$type": "color",
      "$description": "Sandstone — Muted warm stroke and illustration tone used in decorative arc patterns, card imagery borders, and secondary outline accents"
    },
    "bark-brown": {
      "$value": "#665233",
      "$type": "color",
      "$description": "Bark Brown — Darker warm tone for card-surface strokes, secondary illustration fills, and text-adjacent decorative borders"
    },
    "honey-bronze": {
      "$value": "#eec07a",
      "$type": "color",
      "$description": "Honey Bronze — Lighter warm fill for icon strokes and card accent borders — sits between the muted sandstone and the cream surfaces"
    },
    "obsidian": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Obsidian — Primary text, hero canvas, deep card-image borders, ghost-button outlines — the structural anchor color"
    },
    "paper-white": {
