  "font": {
    "abc-monument-grotesk": {
      "$value": "ABC Monument Grotesk",
      "$type": "fontFamily",
      "$description": "Sole typeface across every surface — a single custom grotesque that carries hierarchy through size, weight, and consistent -0.02em tracking. Weight 400 handles body, nav, and secondary text; weight 500 lifts buttons, active nav items, and key labels. The extremely tight 64px display at line-height 1.0 and the same -0.02em tracking at 14px body is signature — tracking never loosens regardless of size, which is unusual and unifies the scale."
    }
  },
