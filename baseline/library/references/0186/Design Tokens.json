    },
    "true-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "True Black — Input text, icon fills, certain border overrides at maximum contrast"
    }
  },
  "font": {
    "graphik-web": {
      "$value": "Graphik Web",
      "$type": "fontFamily",
      "$description": "All UI text: nav, buttons, body copy, captions, badges, inputs, card text. Weight 400 is default body; 500 for subheadings and emphasis; 700 sparingly for bold callouts. The tight -0.013em letter-spacing across all sizes gives even small text a compressed editorial density."
    },
    "means-web": {
      "$value": "Means Web",
      "$type": "fontFamily",
      "$description": "Display headlines and hero headings only. Weight 300 at 40-48px is the signature move — most SaaS headlines use 600-800, but this light-weight serif whispers authority at large scale. The -0.021em tracking at display sizes compresses letterforms into a tight, journalistic headline block."
    }
  },
