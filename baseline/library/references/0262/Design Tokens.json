{
  "color": {
    "obsidian": {
      "$value": "#242429",
      "$type": "color",
      "$description": "Obsidian — Primary text, icon strokes, hairline borders across the system — the workhorse dark that replaces pure black for a slightly warmer read"
    },
    "parchment": {
      "$value": "#f9f5f2",
      "$type": "color",
      "$description": "Parchment — Page canvas, hero and footer backgrounds — warm off-white that signals editorial paper rather than digital default"
    },
    "gallery-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Gallery White — Card surfaces, image borders, badge backgrounds — the brighter neutral used to lift content off the parchment"
    },
    "ink-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Ink Black — Headings, navigation borders, and high-contrast typographic moments where maximum weight is needed"
    },
    "graphite": {
      "$value": "#3e3e3e",
      "$type": "color",
      "$description": "Graphite — Body text, card metadata, and list items — softer than Obsidian for secondary reading copy"
    },
    "ash-gray": {
      "$value": "#919191",
      "$type": "color",
      "$description": "Ash Gray — Muted heading accent and de-emphasized text — the quietest neutral, used for location subtitles and tertiary labels"
    },
    "charcoal-deep": {
      "$value": "#070707",
      "$type": "color",
      "$description": "Charcoal Deep — Reserved for the heaviest display headlines where a hair more density than Ink Black is desired"
    }
  },
  "font": {
    "gill-sans": {
      "$value": "Gill Sans",
      "$type": "fontFamily",
      "$description": "Primary typeface for all editorial copy and headings. The humanist warmth of Gill Sans is the signature — its slightly organic strokes and bookish personality carry the literary travel-magazine tone. 400 handles body and nav; 500 adds weight for sub-headings and card titles. The 64px/1.00 setting powers the monumental KOBU wordmark, where line-height matches font-size to let the letters bleed."
    },
    "fira-mono": {
      "$value": "Fira Mono",
      "$type": "fontFamily",
      "$description": "Monospace for small uppercase labels — badges, navigation, and category tags. The fixed-width geometry and wide letter-spacing (0.167em–0.183em on 10–12px) read as printed museum tags, turning functional labels into typographic detail rather than UI chrome."
    },
    "gill-sans-mt-pro": {
      "$value": "Gill Sans MT Pro",
      "$type": "fontFamily",
      "$description": "Gill Sans MT Pro — detected in extracted data but not described by AI"
    }
  },
