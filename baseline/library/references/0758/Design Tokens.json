{
  "color": {
    "vermilion-flame": {
      "$value": "#fc4a2b",
      "$type": "color",
      "$description": "Vermilion Flame — Brand accent — borders, highlight strokes, icon fills, small inline emphasis marks. The only saturated color in the system; appears as punctuation, never as a wash; Brand-to-tint linear gradient — appears as a full-bleed color bar behind embedded product screenshots"
    },
    "ember-pulse": {
      "$value": "#ea3718",
      "$type": "color",
      "$description": "Ember Pulse — Deeper vermilion variant — icon glyphs and small filled marks where the primary accent needs more weight against white"
    },
    "tangerine-signal": {
      "$value": "#f97316",
      "$type": "color",
      "$description": "Tangerine Signal — Secondary warm accent — decorative strokes and illustration outlines that sit beside the primary vermilion"
    },
    "coral-blush": {
      "$value": "#ffac9e",
      "$type": "color",
      "$description": "Coral Blush — Soft warm fill — subtle wash backgrounds, shadow tints that carry the brand's warmth without screaming"
    },
    "peach-mist": {
      "$value": "#ffe5e0",
      "$type": "color",
      "$description": "Peach Mist — Tinted surface — warm-tinted card or section background, barely-there warmth to differentiate from neutral gray"
    },
    "apricot-wash": {
      "$value": "#ffedd5",
      "$type": "color",
      "$description": "Apricot Wash — Lightest warm tint — badge fills, tag backgrounds, and hover surfaces that need warmth without saturation"
    },
    "brick-alert": {
      "$value": "#dc2626",
      "$type": "color",
      "$description": "Brick Alert — Red supporting accent for decorative details and low-frequency emphasis. Use as a supporting accent, not as a status color"
    },
    "forest-confirm": {
      "$value": "#15803d",
      "$type": "color",
      "$description": "Forest Confirm — Green supporting accent for decorative details and low-frequency emphasis. Use as a supporting accent, not as a status color"
    },
    "ink-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Ink Black — Headlines, body text, filled dark buttons, the heaviest typographic weight in the system"
    },
    "slate-900": {
      "$value": "#111827",
      "$type": "color",
      "$description": "Slate 900 — Supporting neutral for secondary UI, dividers, and muted labels."
    },
    "slate-700": {
      "$value": "#374151",
      "$type": "color",
