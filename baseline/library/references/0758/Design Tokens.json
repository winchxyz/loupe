    "paper-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper White — Primary canvas, card surfaces, button text on dark fills"
    },
    "fog-whisper": {
      "$value": "#f9fafb",
      "$type": "color",
      "$description": "Fog Whisper — Section background — the quietest gray band used to separate content zones from the pure white canvas"
    },
    "mist-gray": {
      "$value": "#f2f3f5",
      "$type": "color",
      "$description": "Mist Gray — Elevated surface — card backgrounds that sit on the Fog band, subtle inputs, and table row alternation"
    },
    "ash-border": {
      "$value": "#e6e8eb",
      "$type": "color",
      "$description": "Ash Border — Hairline dividers, card borders, input outlines at rest"
    },
    "coral-wash-gradient": {
      "$value": "#ff7e67",
      "$type": "color",
      "$description": "Coral Wash Gradient — Decorative warm gradient — used behind product imagery to extend the brand's warmth into visual sections"
    }
