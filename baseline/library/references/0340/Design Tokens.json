{
  "color": {
    "paper-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper White — Page background, card surfaces, input fields"
    },
    "cloud-gray": {
      "$value": "#f3f4f6",
      "$type": "color",
      "$description": "Cloud Gray — Secondary surface, subtle card backgrounds, tag fills"
    },
    "mist-border": {
      "$value": "#e5e7eb",
      "$type": "color",
      "$description": "Mist Border — Hairline dividers, card borders, input borders, the dominant structural line color"
    },
    "fog-border": {
      "$value": "#d1d5dc",
      "$type": "color",
      "$description": "Fog Border — Slightly stronger dividers, placeholder text on inputs"
    },
    "ink-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Ink Black — Dark supporting neutral for text, icons, and strong contrast. Do not promote it to the primary CTA color"
    },
    "midnight-panel": {
      "$value": "#101828",
      "$type": "color",
      "$description": "Midnight Panel — Dark hero panel background, dark navigation wells — the high-contrast stage for the mascot"
    },
    "deep-night": {
      "$value": "#0b0f19",
      "$type": "color",
      "$description": "Deep Night — Deepest panel surface used in gradients and product UI previews; Hero panel and product preview gradient — subtle two-stop from slate to near-black"
    },
    "slate-body": {
      "$value": "#4a5565",
      "$type": "color",
      "$description": "Slate Body — Supporting neutral for secondary UI, dividers, and muted labels. Do not promote it to the primary CTA color"
    },
    "steel-caption": {
      "$value": "#6a7282",
      "$type": "color",
      "$description": "Steel Caption — Metadata, timestamps, helper text, nav links, muted icon fills"
    },
    "ash-disabled": {
      "$value": "#99a1af",
      "$type": "color",
      "$description": "Ash Disabled — Tertiary text, inactive icons, disabled controls, the quietest neutral"
    },
    "hugging-yellow": {
      "$value": "#ffd210",
      "$type": "color",
      "$description": "Hugging Yellow — The 🤗 emoji logo mark — the only warm color in the system, appears as a small brand stamp"
    },
    "link-blue": {
      "$value": "#155dfc",
      "$type": "color",
      "$description": "Link Blue — Violet supporting accent for decorative details and low-frequency emphasis. Do not promote it to the primary CTA color"
    }
  },
  "font": {
    "source-sans-pro": {
      "$value": "Source Sans Pro",
      "$type": "fontFamily",
      "$description": "The single workhorse family — handles every UI surface from 10px metadata to 96px display headlines. Weight 400 carries body and most UI; 600 takes section labels and button text; 700 is reserved for the largest headlines where the humanist letterforms need extra weight to hold the page."
    },
    "ibm-plex-mono": {
      "$value": "IBM Plex Mono",
      "$type": "fontFamily",
      "$description": "Technical identifiers — model names like moonshatai/Kimi-K2.5, dataset slugs, parameter values, repo paths. The monospace grid signals 'this is a machine-readable handle' and gives the interface a workshop feel."
    }
  },
