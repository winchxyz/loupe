{
  "color": {
    "obsidian-ink": {
      "$value": "#181f1f",
      "$type": "color",
      "$description": "Obsidian Ink — Primary text, hairline borders, filled action buttons — the dominant near-black that carries 90% of the interface"
    },
    "paper-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper White — Canvas background, inverted text on dark blocks, nav/button borders"
    },
    "fog": {
      "$value": "#d1d2d2",
      "$type": "color",
      "$description": "Fog — Subtle dividers and secondary borders where Obsidian would be too heavy"
    },
    "ash": {
      "$value": "#a3a5a5",
      "$type": "color",
      "$description": "Ash — Muted helper text, inactive button borders, secondary metadata"
    },
    "graphite": {
      "$value": "#374151",
      "$type": "color",
