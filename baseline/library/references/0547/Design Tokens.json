{
  "color": {
    "putty": {
      "$value": "#c4c3b6",
      "$type": "color",
      "$description": "Putty — Dominant page canvas — the warm gray-beige that fills hero and most light sections. The single most-used color in the system; sets the gallery-wall tone"
    },
    "ink": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Ink — Dark borders and separators for elevated surfaces and inverted UI. Do not promote it to the primary CTA color"
    },
    "bone": {
      "$value": "#e7e5e4",
      "$type": "color",
      "$description": "Bone — Elevated card surfaces and secondary canvas in light sections. Sits one step above Putty for subtle layering without breaking the monochrome warmth"
    },
    "chalk": {
      "$value": "#ebebeb",
      "$type": "color",
      "$description": "Chalk — Footers and lightest surface tier. The coolest neutral — used sparingly at section bases to signal a different page zone"
    },
    "vellum": {
      "$value": "#dfdcd5",
      "$type": "color",
      "$description": "Vellum — Hairline borders on body and icon elements. A mid-tone warm gray that reads as a printed page edge, not a UI divider"
    },
    "graphite": {
      "$value": "#595855",
      "$type": "color",
      "$description": "Graphite — Muted secondary text fills and subtle image backgrounds. The darkest warm gray — used where pure black would be too severe"
    },
    "ash": {
      "$value": "#808080",
      "$type": "color",
      "$description": "Ash — Image placeholder backgrounds and mid-neutral surfaces. The only truly cool gray in the system, reserved for image containers"
    },
    "paper": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper — Text on dark sections, white icon strokes, and the rare pure-white element. Used only as reverse type or accent fill, never as a large surface"
    }
  },
  "font": {
    "davinci": {
      "$value": "Davinci",
      "$type": "fontFamily",
      "$description": "Display and heading serif — the brand voice. Drives the 374px hero wordmark, 94px section titles, and 52px sub-headings. Weight 500 is used for emphasis; 400 for body serif moments. The extreme size range (16–374px) and tight negative tracking at large sizes make this the single most distinctive typographic choice — a wordmark that occupies half the viewport."
    },
    "helvetica-now": {
      "$value": "Helvetica Now",
      "$type": "fontFamily",
      "$description": "Utility grotesk for body copy, nav labels, button text, stats (TVL, APY), and caption micro-text. Stays at 9–26px — never takes display duty. Weight 500 is reserved for labels and small data callouts."
    }
  },
