      "$value": "#ff0169",
      "$type": "color",
      "$description": "Signal Pink — Gradient origin — Instagram brand gradient start point, the chromatic anchor in the system"
    },
    "plasma-magenta": {
      "$value": "#d300c5",
      "$type": "color",
