{
  "color": {
    "ink": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Ink — Primary text, all structural borders, hairline page frames, link underlines — the single typographic ink"
    },
    "fog": {
      "$value": "#b3b3b3",
      "$type": "color",
      "$description": "Fog — Page background, watermark-level surfaces, lightest borders"
