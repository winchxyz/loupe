{
  "color": {
    "carbon": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Carbon — Body text, structural hairlines, dark icon strokes — the universal ink that defines every other element on the page"
    },
    "paper": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper — Page canvas, card surfaces, input fields, button text on dark fills"
    },
    "fog": {
      "$value": "#f0eff0",
      "$type": "color",
      "$description": "Fog — Body background wash, second surface tier below cards"
    },
    "silver": {
      "$value": "#e0dfe1",
      "$type": "color",
      "$description": "Silver — Input borders, subtle dividers between content bands"
    },
    "mist": {
      "$value": "#c1c0c2",
      "$type": "color",
      "$description": "Mist — Card borders — a half-step lighter than the structural hairline, used to separate stacked cards from the canvas"
    },
    "ash": {
      "$value": "#a09da1",
      "$type": "color",
      "$description": "Ash — Muted icon strokes, inactive nav borders, secondary metadata"
    },
    "obsidian": {
      "$value": "#282729",
      "$type": "color",
      "$description": "Obsidian — Heavy icon borders, strong dividers, secondary structural lines that need more weight than #000 hairline"
    },
    "onyx": {
      "$value": "#141315",
      "$type": "color",
      "$description": "Onyx — Deepest text tier for high-emphasis labels over light surfaces"
    },
    "graphite": {
      "$value": "#3d3a3e",
      "$type": "color",
      "$description": "Graphite — Primary action button fill — the dark solid button (Sign in, Randomize); slightly lifted from pure black to read as a surface, not absence"
    },
    "cobalt-pulse": {
      "$value": "#338fff",
      "$type": "color",
      "$description": "Cobalt Pulse — Link text, icon dots, chromatic borders — the blue half of the system, used to mark tokens, active links, and the start of gradients"
    },
    "ultraviolet": {
      "$value": "#7a33ff",
      "$type": "color",
      "$description": "Ultraviolet — Outlined action border, secondary link accent — appears as a stroke on ghost controls and as the mid-stop in gradient transitions"
    },
    "spectrum-bridge": {
      "$value": "#0079cc",
      "$type": "color",
      "$description": "Spectrum Bridge — Blue wash for highlight backgrounds, decorative bands, and soft emphasis behind content. Do not promote it to the primary CTA color"
    },
    "aurora-wash": {
      "$value": "#ff80d7",
      "$type": "color",
      "$description": "Aurora Wash — Hero card gradient — soft translucent wash from ember through pink to cobalt, a 30% opacity field that sits behind the launch prompt"
    }
  },
  "font": {
    "neuehaasunica": {
      "$value": "NeueHaasUnica",
      "$type": "fontFamily",
      "$description": "All interface type — body, nav, buttons, cards, inputs, links, icons labels. Weight 400 for body and secondary; 500 for buttons and emphasized labels; 600 reserved for section headings. Tabular figures ('tnum', 'lnum') on all numeric displays so token counts and prices align in columns."
    },
    "silka": {
      "$value": "Silka",
      "$type": "fontFamily",
      "$description": "Supplementary display face — used sparingly for editorial moments and icon-adjacent labels where a different texture is needed from the interface default"
    }
  },
