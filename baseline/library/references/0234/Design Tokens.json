{
  "color": {
    "svelte-ember": {
      "$value": "#d43008",
      "$type": "color",
      "$description": "Svelte Ember — Orange supporting accent for decorative details and low-frequency emphasis. Do not promote it to the primary CTA color"
    },
    "ink": {
      "$value": "#262626",
      "$type": "color",
      "$description": "Ink — Primary text, nav items, body copy, button labels — soft black that avoids the harshness of #000 while preserving 15:1 contrast on white"
    },
    "carbon": {
      "$value": "#141414",
      "$type": "color",
      "$description": "Carbon — Headlines and display copy — slightly heavier than Ink to give the serif wordmarks visual weight against the white canvas"
    },
    "paper": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper — Page canvas, card surfaces, nav background — the dominant background everywhere"
    },
    "fog": {
      "$value": "#f2f2f2",
      "$type": "color",
      "$description": "Fog — Subtle surface elevation, button hover wash, search/input field background"
    },
    "slate": {
      "$value": "#666666",
      "$type": "color",
      "$description": "Slate — Muted secondary text, helper labels, breadcrumb text"
    },
    "ash": {
      "$value": "#808080",
      "$type": "color",
      "$description": "Ash — Deemphasized text, disabled labels, tertiary metadata"
    },
    "obsidian": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Obsidian — Input field borders, form focus states, text input text"
    }
  },
  "font": {
    "eb-garamond": {
      "$value": "EB Garamond",
      "$type": "fontFamily",
      "$description": "Body text and section copy — Garamond gives the framework a literary, editorial voice that no sans-serif system font can replicate; 22px at line-height 1.5 is the site's reading rhythm, uncharacteristically large and serif for a devtool site"
    },
    "fira-sans": {
      "$value": "Fira Sans",
      "$type": "fontFamily",
      "$description": "All UI chrome — nav links, search input, button labels, the ADJECTIVE tag, section eyebrows. Fira Sans is the workspace font; it keeps interactive elements quiet so the serif voice can lead"
    },
    "dm-serif-display": {
      "$value": "DM Serif Display",
      "$type": "fontFamily",
      "$description": "Hero and section display headlines — used sparingly (only 4 occurrences on the page) as a typographic exclamation point; the heavy serif slab at 54px contrasts with the lighter Garamond body to create editorial tension"
    }
  },
