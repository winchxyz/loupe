  "font": {
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "Sole typeface across the system. Display sizes (36–64px) use weight 700 with -0.020 to -0.025em tracking to optically tighten the geometric letterforms. Body and UI sizes (14–18px) sit at weight 400–500 with near-normal tracking. Weight 600 is reserved for section titles, weight 700 for the hero headline. The consistent geometric skeleton means no font-mood shift between headline and body — the system speaks in one voice at every size."
    },
    "balig-script": {
      "$value": "Balig Script",
      "$type": "fontFamily",
      "$description": "Balig Script — detected in extracted data but not described by AI"
    }
  },
