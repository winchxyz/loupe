{
  "color": {
    "paper-white": {
      "$value": "#faf9f7",
      "$type": "color",
      "$description": "Paper White — Page canvas — warm off-white that mimics uncoated paper stock; the default surface behind everything"
    },
    "ink": {
      "$value": "#242424",
      "$type": "color",
      "$description": "Ink — Primary text, icon strokes, and dominant border color. Slightly softened from pure black to sit comfortably on the warm canvas"
    },
    "felt-gray": {
      "$value": "#d3d3d3",
      "$type": "color",
      "$description": "Felt Gray — Hairline dividers, card borders, list separators — the structural neutral that holds the layout together without drawing attention"
    },
    "linen": {
      "$value": "#edecea",
      "$type": "color",
      "$description": "Linen — Subtle surface elevation for nav backgrounds and hover states; slightly cooler than Paper White to create depth without contrast"
    },
    "parchment": {
      "$value": "#e0ddd7",
      "$type": "color",
      "$description": "Parchment — Warm-toned surface for body sections and secondary cards; introduces a faint paper-fiber warmth against the cooler Linen"
    },
    "slate": {
      "$value": "#727272",
      "$type": "color",
      "$description": "Slate — Muted secondary text and subdued borders for de-emphasized content like timestamps and helper labels"
    },
    "ash": {
      "$value": "#8d9090",
      "$type": "color",
      "$description": "Ash — Tertiary text and disabled-state borders; sits between Slate and Felt Gray in the neutral ladder"
    },
    "charcoal": {
      "$value": "#585a5a",
      "$type": "color",
      "$description": "Charcoal — Navigation borders and medium-emphasis UI structure; a bridge between the near-black Ink and the mid-grays"
    },
    "pure-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Pure White — Badge fills, icon backgrounds, and the highest surface elevation — used sparingly to lift elements above Linen and Parchment"
    },
    "mustard": {
      "$value": "#f1ba35",
      "$type": "color",
      "$description": "Mustard — Primary action color — CTA buttons, nav accents, and badge highlights. A warm sunlit yellow that reads as a sticky-note moment against the monochrome layout"
    },
    "espresso": {
      "$value": "#30250b",
      "$type": "color",
      "$description": "Espresso — Dark accent paired with Mustard on badges and nav — provides a near-black complement that makes the yellow pop without using pure black"
    },
    "terracotta": {
      "$value": "#d26c46",
      "$type": "color",
      "$description": "Terracotta — Editorial accent — appears in the typographic art palette and decorative product imagery. Rust-orange warmth that belongs in illustrations, not buttons"
    },
    "sage": {
      "$value": "#458e71",
      "$type": "color",
      "$description": "Sage — Editorial accent — a muted forest green used in the typographic art palette. Decorative, not functional"
    },
    "cobalt": {
      "$value": "#3b59a3",
      "$type": "color",
      "$description": "Cobalt — Editorial accent — deep ultramarine from the typographic art palette. The strongest chromatic statement in the decorative system"
    },
    "rust": {
      "$value": "#6c3c3c",
      "$type": "color",
      "$description": "Rust — Editorial accent — dark brick red from the typographic art palette, echoing the warmth of Terracotta but grounded"
    },
    "sky-dust": {
      "$value": "#90abc8",
      "$type": "color",
      "$description": "Sky Dust — Editorial accent — a washed, chalky blue used in the typographic art palette. The lightest chromatic in the decorative system"
    }
  },
  "font": {
    "abcdiatype": {
      "$value": "ABCDiatype",
      "$type": "fontFamily",
      "$description": "The only typeface. A neo-grotesque editorial sans used at every register — 19px body copy, 25px section headings, and dramatic 71–140px display treatments with tight tracking. The wide weight range (400–500) keeps the system monovariational; hierarchy comes from size, not weight contrast."
    },
    "arial": {
