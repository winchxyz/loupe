{
  "color": {
    "pure-canvas": {
      "$value": "#f5f5f7",
      "$type": "color",
      "$description": "Pure Canvas — Page background, section bands, card surfaces — a near-white that separates structural surfaces from pure white product highlights without introducing tint"
    },
    "paper-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper White — Elevated card surfaces, icon fills, and inverted text on dark/colored backgrounds"
    },
    "obsidian": {
      "$value": "#1d1d1f",
      "$type": "color",
      "$description": "Obsidian — Primary text, headlines, card borders, nav rules — the singular dark anchor; not pure black, a graphite that softens contrast on white"
    },
    "iron-gray": {
      "$value": "#707070",
      "$type": "color",
      "$description": "Iron Gray — Secondary nav borders, list dividers, subdued UI metadata"
    },
    "slate": {
      "$value": "#474747",
      "$type": "color",
      "$description": "Slate — Nav borders, link underlines, secondary text in dense lists"
    },
    "charcoal": {
      "$value": "#333336",
      "$type": "color",
      "$description": "Charcoal — Nav text, button labels on neutral surfaces — slightly cool graphite for UI controls"
    },
    "mist": {
      "$value": "#e2e2e5",
      "$type": "color",
      "$description": "Mist — Neutral pill button fill, secondary surface tier for compact controls and list rows"
    },
    "fog": {
      "$value": "#d6d6d6",
      "$type": "color",
      "$description": "Fog — List row backgrounds, hairline separators in data-dense sections"
    },
    "void": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Void — Icon fills on light surfaces, nav logo — reserved for the most absolute contrast moments"
    },
    "signal-blue": {
      "$value": "#0071e3",
      "$type": "color",
      "$description": "Signal Blue — Blue action color for filled buttons, selected navigation states, and focused conversion moments."
    },
    "deep-link-blue": {
      "$value": "#0066cc",
      "$type": "color",
      "$description": "Deep Link Blue — Inline link text and link underlines throughout body copy — the only chromatic text color permitted in paragraph flow"
    },
    "pulse-green": {
      "$value": "#03aa49",
      "$type": "color",
      "$description": "Pulse Green — Accent word within hero headlines (e.g. the first verb of a product tagline) — used to color-code an emotional concept inside otherwise monochrome type"
    },
    "deep-green": {
      "$value": "#03873a",
      "$type": "color",
      "$description": "Deep Green — Darker green variant for text-level green accents and underlined links in sustainability/spec contexts"
    },
    "ultraviolet": {
      "$value": "#8668ff",
      "$type": "color",
      "$description": "Ultraviolet — Violet outline accent for tags, dividers, and focused UI edges."
    },
    "ember-orange": {
      "$value": "#ed6300",
      "$type": "color",
      "$description": "Ember Orange — Orange outline accent for tags, dividers, and focused UI edges."
    },
    "lagoon-teal": {
      "$value": "#00a1b3",
      "$type": "color",
      "$description": "Lagoon Teal — Teal outline accent for tags, dividers, and focused UI edges."
    }
  },
  "font": {
    "sf-pro-display": {
      "$value": "SF Pro Display",
      "$type": "fontFamily",
      "$description": "Hero headlines, section headings, and the page-level brand statement. Set in semibold at very large sizes (64–96px) with aggressive negative tracking (-0.019em to -0.005em) that tightens the headline into a single confident block. Smaller sizes (21–28px) carry section headings and card titles. The signature choice: weight 600 is the heaviest weight on the entire site — Apple trusts display weight 600 over 700+ to command the page"
    },
    "sf-pro-text": {
      "$value": "SF Pro Text",
      "$type": "fontFamily",
      "$description": "Body copy, nav labels, button text, spec text, and large display numerals (44px). Weight 400 is the paragraph default; weight 600 marks links, button labels, and emphasis within body text. The 44px instance is a display-numeral role used for prices or large data — it borrows SF Pro Text rather than Display because the data needs to feel tabular, not editorial"
    }
  },
