{
  "color": {
    "forest-ink": {
      "$value": "#009959",
      "$type": "color",
      "$description": "Forest Ink — Primary action — filled download buttons, outlined CTAs, and active nav indicators carry this deep botanical green that reads as decisive without aggression"
    },
    "vine": {
      "$value": "#00b96c",
      "$type": "color",
      "$description": "Vine — Soft surface accent and gradient wash for feature sections — the mid-tone green that fades into the white canvas as ambient atmosphere"
    },
    "neon-sprout": {
      "$value": "#00ff95",
      "$type": "color",
      "$description": "Neon Sprout — Decorative illustration fill and gradient endpoint — appears only inside brand graphics, never on UI controls"
    },
    "ice-blue": {
      "$value": "#3de1ff",
      "$type": "color",
      "$description": "Ice Blue — Decorative illustration fill for brand mark and app icon glyphs — companion to Neon Sprout in the visual identity"
    },
    "obsidian": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Obsidian — Primary text, heavy borders, and the dominant hairline divider color throughout the layout"
    },
    "graphite": {
      "$value": "#141414",
      "$type": "color",
      "$description": "Graphite — Headline text and dark surface text — near-black with slight warmth for large display type"
    },
    "carbon": {
      "$value": "#313232",
      "$type": "color",
      "$description": "Carbon — Secondary text, image overlays, and dark UI text on light backgrounds — the workhorse body tone"
    },
    "slate": {
      "$value": "#545454",
      "$type": "color",
      "$description": "Slate — Body text helper copy and tertiary borders"
    },
    "fog": {
