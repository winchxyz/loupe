{
  "color": {
    "void": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Void — Page background, primary canvas — the dark field where the constellation lives"
    },
    "bone": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Bone — Primary text, icon strokes, hairlines, card borders, nav text — the only light that reads on the void"
    },
    "ash": {
      "$value": "#bdbdbd",
      "$type": "color",
      "$description": "Ash — Secondary muted text, subtle border accents — quieter than bone, still legible on black"
    },
    "smoke": {
      "$value": "#9a9a9a",
      "$type": "color",
      "$description": "Smoke — Tertiary text, nav link resting state, low-emphasis dividers — fades into the background"
    },
    "plum-voltage": {
      "$value": "#8052ff",
      "$type": "color",
      "$description": "Plum Voltage — Primary action background, nav accents, icon highlights, decorative borders — the brand pulse, the only filled chromatic surface in the UI"
    },
    "amber-spark": {
      "$value": "#ffb829",
      "$type": "color",
      "$description": "Amber Spark — Yellow accent for outlined action borders, linked labels, and lightweight interactive emphasis. Do not promote it to the primary CTA color"
    },
    "lichen": {
      "$value": "#15846e",
      "$type": "color",
      "$description": "Lichen — Decorative icon accent, constellation node color — appears in illustration marks, not core interface chrome"
    }
  },
  "font": {
    "acronym": {
      "$value": "Acronym",
      "$type": "fontFamily",
      "$description": "Sole typeface. Weight 200 carries display headlines — its extreme thinness against 113px creates a 'etched in light' feel. Weight 600–700 for nav and buttons. Weight 400 for body. Negative tracking at large sizes (-0.04em) pulls glyphs tight; positive tracking (0.021–0.05em) opens body and nav for readability on black. The single-family approach keeps the system spare — no serifs, no display variants, only weight and tracking do the work."
    }
  },
