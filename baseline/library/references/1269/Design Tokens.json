{
  "color": {
    "electric-ink": {
      "$value": "#0000ff",
      "$type": "color",
      "$description": "Electric Ink — Primary CTA fill, active nav, product surface backgrounds, chromatic borders — the only saturated color that carries meaning"
    },
    "voltage-green": {
      "$value": "#00d37c",
      "$type": "color",
      "$description": "Voltage Green — Green wash for highlight backgrounds, decorative bands, and soft emphasis behind content"
    },
    "onyx": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Onyx — Body text, headings, hairline borders, icon strokes — the dominant ink color"
    },
    "pure": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Pure — Page canvas, card surface, button text, dark-section contrast text"
    },
    "carbon": {
      "$value": "#121212",
      "$type": "color",
      "$description": "Carbon — Dark-section background, deep UI surfaces, high-contrast text on light"
    },
    "slate": {
      "$value": "#1e1e1e",
      "$type": "color",
      "$description": "Slate — Elevated dark surface inside dark sections, card on near-black"
    },
    "fog": {
      "$value": "#bcc1c7",
      "$type": "color",
      "$description": "Fog — Quiet borders, disabled text, secondary icon strokes"
    },
    "ash": {
      "$value": "#999999",
      "$type": "color",
      "$description": "Ash — Muted helper text, low-emphasis borders, placeholder color"
    },
    "smoke": {
      "$value": "#cfcfcf",
      "$type": "color",
      "$description": "Smoke — Divider lines, subtle card borders, input resting state"
    },
    "bone": {
      "$value": "#efefef",
      "$type": "color",
      "$description": "Bone — Section band, soft surface fill behind cards"
    },
    "chalk": {
      "$value": "#f4f4f4",
      "$type": "color",
      "$description": "Chalk — Alternate section background, subtle grouping fill"
    },
    "hi-vis-yellow": {
      "$value": "#fffc52",
      "$type": "color",
      "$description": "Hi-Vis Yellow — Accent panel surface, spotlight callout, tag fill — never text or border"
    }
  },
  "font": {
    "whyte-semi-mono": {
      "$value": "Whyte Semi-Mono",
      "$type": "fontFamily",
      "$description": "UI chrome — monospace-flavored labels, nav links, small caps taglines, price text, code-adjacent captions. Its tabular geometry makes dense product UI legible without switching fonts"
    },
    "unica77": {
      "$value": "Unica77",
      "$type": "fontFamily",
      "$description": "Primary voice — headings, body, nav, buttons, cards, hero. Engages stylistic alternates ss01–ss09 and 'salt' to differentiate product screenshots from marketing type"
    },
    "pp-neue-montreal": {
      "$value": "PP Neue Montreal",
      "$type": "fontFamily",
      "$description": "Geometric headline counterpoint — used when the page needs a rounder, friendlier display than Unica77 can provide"
    },
    "fraunces-72pt-soft-supersoft": {
      "$value": "Fraunces 72pt Soft / SuperSoft",
      "$type": "fontFamily",
      "$description": "Serif accent at hairline weights — editorial pull quotes and contrast moments. Thinness creates softness that breaks the industrial rigour"
    },
    "druk-xxcondensed-super": {
      "$value": "Druk XXCondensed Super",
      "$type": "fontFamily",
      "$description": "Hero-scale display — used once, for maximum typographic spectacle. Ultra-condensed verticals fill the viewport"
    },
    "tan-buster": {
      "$value": "TAN-BUSTER",
      "$type": "fontFamily",
      "$description": "Single decorative display moment — out-of-system character that signals craft over platform"
    },
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "Inter — detected in extracted data but not described by AI"
    },
    "ui-monospace": {
