{
  "color": {
    "deep-teal": {
      "$value": "#244d54",
      "$type": "color",
      "$description": "Deep Teal — Primary structural color — dark hero background, stat block surfaces, icon strokes, navigation wordmark, secondary button borders. A near-gray teal that reads as ink rather than ocean, so it grounds the brand without going clinical-cold"
    },
    "mint-pulse": {
      "$value": "#2ecea0",
      "$type": "color",
      "$description": "Mint Pulse — Primary action color — filled CTA backgrounds, badge fills, active dots, announcement bar, review star highlights. Bright green with cyan lean, makes every interactive element feel switched on and biological"
    },
    "soft-teal": {
      "$value": "#6dddbd",
      "$type": "color",
      "$description": "Soft Teal — Teal text accent for links, tags, and emphasized short phrases. Do not promote it to the primary CTA color"
    },
    "carbon": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Carbon — Body text, hairline borders, icon strokes, input borders. The dominant structural neutral — most borders on the site are pure black, giving the UI a stark, editorial frame"
    },
    "ink": {
      "$value": "#151515",
      "$type": "color",
      "$description": "Ink — Primary heading text and secondary borders. Softer than pure black for large headlines where Carbon reads as too heavy"
    },
    "graphite": {
      "$value": "#4d4d4d",
      "$type": "color",
      "$description": "Graphite — Subhead text, button text on light surfaces, muted labels"
    },
    "slate": {
      "$value": "#858585",
      "$type": "color",
      "$description": "Slate — Muted body text, helper copy, disabled labels, secondary icon strokes. The workhorse neutral for anything that needs to recede"
    },
    "fog": {
      "$value": "#999999",
      "$type": "color",
      "$description": "Fog — Input borders, placeholder color, low-priority surface accents"
    },
    "mist": {
      "$value": "#e5e7eb",
      "$type": "color",
      "$description": "Mist — Card and section dividers, subtle borders on white surfaces, separators between review cards"
    },
    "bone": {
      "$value": "#f0f1f2",
      "$type": "color",
      "$description": "Bone — Lightest card and list surface — sits one step above pure white for subtle elevation on the page canvas"
    },
    "paper": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper — Page canvas, card surfaces, button text, input fills. The dominant light surface"
    }
  },
  "font": {
    "inter-tight": {
      "$value": "Inter Tight",
      "$type": "fontFamily",
      "$description": "Primary brand typeface across headings, body, buttons, badges, and UI. The custom tighter cut tightens headline rhythm and gives small caps a pharmaceutical, prescription-label feel."
    },
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "Secondary face used for stat block numerals and a few large product display sizes. Inter handles the very large gradient stats with clean digits that gradient-fill cleanly."
    }
  },
