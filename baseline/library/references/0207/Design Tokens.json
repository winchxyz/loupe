{
  "color": {
    "olive-ink": {
      "$value": "#393c2a",
      "$type": "color",
      "$description": "Olive Ink — Primary text, borders, and structural strokes — all type from body to display headings, all card and image borders, all interactive outlines"
    },
    "sage-type": {
      "$value": "#737955",
      "$type": "color",
      "$description": "Sage Type — Display headings and brand voice — used for the monumental SHELBY wordmark, section anchors, and selective heading accents that carry the brand's botanical identity"
    },
    "linen": {
      "$value": "#efe6d9",
      "$type": "color",
      "$description": "Linen — Primary canvas and card surfaces — page background, card fills, the base warm tone the entire system sits on"
    },
    "sienna": {
      "$value": "#d6b292",
      "$type": "color",
      "$description": "Sienna — Orange wash for highlight backgrounds, decorative bands, and soft emphasis behind content."
    },
    "driftwood": {
      "$value": "#afa199",
      "$type": "color",
      "$description": "Driftwood — Tertiary surface and muted helpers — profile-section backdrop, desaturated metadata, low-emphasis UI text and dividers"
    },
    "riverstone": {
      "$value": "#7b8785",
      "$type": "color",
      "$description": "Riverstone — Cool-toned neutral for subtle contrast shifts — secondary surface, hover or muted state for UI elements needing visual separation from the warm base"
    }
  },
  "font": {
    "ranade": {
      "$value": "Ranade",
      "$type": "fontFamily",
      "$description": "Display and editorial headlines. Used at extreme scale (83–265px) for the wordmark and section anchors, and at 24px for the CONTACT callout. The geometric, slightly condensed forms give the brand its monumental-but-restrained voice — the type fills the frame without shouting. Substitute: Boldonse or Bold Neue for display, Space Grotesk for smaller uses."
    },
    "switzer": {
      "$value": "Switzer",
      "$type": "fontFamily",
      "$description": "Everything else: body copy, nav, labels, metadata, card titles, list items. The compact grotesque reads as editorial running text. Weight 500–600 is the workhorse range; 700 is reserved for section headers and emphasized nav. Substitute: Inter, Untitled Sans, or Suisse Int'l for full weight coverage."
    }
  },
