{
  "color": {
    "ember-orange": {
      "$value": "#ff5a2f",
      "$type": "color",
      "$description": "Ember Orange — Primary action buttons, active badges, accent borders — the system's only chromatic voice, used to signal interactivity and emphasis"
    },
    "ember-orange-link-variant": {
      "$value": "#f15b2b",
      "$type": "color",
      "$description": "Ember Orange (link variant) — Orange text accent for links, tags, and emphasized short phrases. Do not promote it to the primary CTA color"
    },
    "carbon-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Carbon Black — Primary text, icons, image overlays, card headings — maximum contrast against white canvas"
    },
    "graphite": {
      "$value": "#1f1f1f",
      "$type": "color",
      "$description": "Graphite — Headings, body emphasis, dark surface alternative — slightly softened black for large display text"
    },
    "slate-dark": {
      "$value": "#333333",
      "$type": "color",
      "$description": "Slate Dark — List items, secondary body text, card content"
    },
    "stone": {
