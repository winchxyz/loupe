{
  "color": {
    "amber-curtain": {
      "$value": "#ec580a",
      "$type": "color",
      "$description": "Amber Curtain — Hero and statistics block backgrounds, brand atmospheric layer — the entire warm light system of the page, applied as full-bleed gradient with vertical streak texture. Never used for buttons, links, or inline accents"
    },
    "ember-wash": {
      "$value": "#ff683d",
      "$type": "color",
      "$description": "Ember Wash — Lighter highlight within the amber gradient — the illuminated folds of the curtain texture, appearing in hero highlights and statistic card upper regions"
    },
    "midnight-ink": {
      "$value": "#00104e",
      "$type": "color",
      "$description": "Midnight Ink — Deep navy used sparingly for outlined link borders and select link text — the only chromatic accent in the otherwise achromatic interface, and only where link affordance must be unmistakable"
    },
    "canvas-cream": {
      "$value": "#f7f6f5",
      "$type": "color",
      "$description": "Canvas Cream — Page background, the warm off-white that gives the whole system its paper-like editorial base — sits behind cards, inputs, and quiet content areas"
    },
    "paper-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper White — Card surfaces, elevated panels, button fills for ghost and light action variants — the bright top layer of the surface stack"
    },
    "charcoal-depth": {
      "$value": "#1c1c1c",
      "$type": "color",
      "$description": "Charcoal Depth — Dark section backgrounds, footer, inverse card surfaces — the counterweight to the amber hero, used when content must read against a near-black ground"
    },
    "graphite": {
      "$value": "#292929",
      "$type": "color",
      "$description": "Graphite — Filled button backgrounds, input fields, dense neutral surfaces — the primary action surface when a button must be heavy and deliberate rather than ghost"
    },
    "stone": {
      "$value": "#484848",
      "$type": "color",
      "$description": "Stone — Secondary card backgrounds and darker card variants on light sections"
    },
    "mist": {
      "$value": "#989897",
      "$type": "color",
      "$description": "Mist — Muted helper text, secondary metadata, and low-emphasis borders on light backgrounds"
    },
    "foil": {
      "$value": "#6a6a6a",
      "$type": "color",
      "$description": "Foil — Quiet border strokes and disabled text — present but unobtrusive"
    },
    "onyx": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Onyx — Primary text, hairline borders, icon strokes, the dominant border color across the entire interface"
    }
  },
  "font": {
    "sans-serif": {
      "$value": "sans-serif",
      "$type": "fontFamily",
      "$description": "sans-serif — detected in extracted data but not described by AI"
    },
    "martina-plantijn": {
      "$value": "Martina Plantijn",
      "$type": "fontFamily",
      "$description": "Display and editorial headlines — the only serif in the system, used at whisper-light weight 300 for hero statements and section titles. The choice of a 300-weight serif is anti-convention: most enterprise tools shout in 600–700 sans-serif; V7 lets the serif breathe and creates authority through typographic restraint. Letterspacing tightens as size grows (-0.02em at 40px, -0.01em at 30px) so large displays optically close into a single word-mass."
    },
    "stk-bureau": {
      "$value": "STK Bureau",
      "$type": "fontFamily",
      "$description": "Body, navigation, UI controls, and subheadings — the workhorse face. The 430 weight is unusual (a micro-step between regular and medium) and gives buttons and labels a slightly denser feel than standard 400. Letterspacing follows a consistent contraction pattern, tighter at larger sizes and approaching zero at 12px and below. Acts as the 'ink' of the system while Martina Plantijn acts as the 'voice'."
    },
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "Small inline metadata and tertiary body text — appears in badge-like annotations and compact helper labels where STK Bureau's tighter tracking would feel too dense at minimum sizes."
    },
    "inter-variable": {
      "$value": "Inter Variable",
      "$type": "fontFamily",
      "$description": "Inter Variable — detected in extracted data but not described by AI"
    }
  },
