{
  "color": {
    "void-canvas": {
      "$value": "#010314",
      "$type": "color",
      "$description": "Void Canvas — Primary page background, hero canvas — near-black with a blue-violet undertone, not a true neutral"
    },
    "obsidian-surface": {
      "$value": "#171825",
      "$type": "color",
      "$description": "Obsidian Surface — Elevated panels, nav bar, secondary cards — one step up from canvas, reads as a subtle surface tier"
    },
    "slate-layer": {
      "$value": "#2a2b3a",
      "$type": "color",
      "$description": "Slate Layer — Card backgrounds, input fields, inset panels — the main surface level for content containers"
    },
    "carbon-border": {
      "$value": "#343543",
      "$type": "color",
      "$description": "Carbon Border — Hairline borders, dividers, card edges — barely visible structural lines on dark surfaces"
    },
    "ash-text": {
      "$value": "#5e6077",
      "$type": "color",
      "$description": "Ash Text — Muted helper text, disabled labels, tertiary metadata"
    },
    "fog-text": {
      "$value": "#9fa2b9",
      "$type": "color",
      "$description": "Fog Text — Secondary body text, inactive icons, subdued UI labels"
    },
    "mist-text": {
      "$value": "#babcd2",
      "$type": "color",
      "$description": "Mist Text — Link resting state, sub-labels, low-emphasis body"
    },
    "lunar-white": {
      "$value": "#dfe1f4",
      "$type": "color",
      "$description": "Lunar White — Primary body and heading text — a cool off-white, the dominant readable surface in the system"
    },
    "frost-white": {
      "$value": "#ececfb",
      "$type": "color",
      "$description": "Frost White — High-contrast text, hover states, icon highlights — the brightest text in the hierarchy"
    },
    "pure-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Pure White — Light supporting surface for subtle backgrounds and section separation. Do not promote it to the primary CTA color"
    },
    "ultraviolet-key": {
      "$value": "#b88cff",
      "$type": "color",
      "$description": "Ultraviolet Key — Brand accent — links, highlight icons, gradient termini, the signature violet that signals encryption"
    },
    "deep-iris": {
      "$value": "#6633ee",
      "$type": "color",
      "$description": "Deep Iris — Brand gradient anchor — hero gradient origin, logo violet, saturated primary brand tone"
    },
    "amethyst-glow": {
      "$value": "#8e64ff",
      "$type": "color",
      "$description": "Amethyst Glow — Mid-gradient violet, hover states on brand elements, secondary accent fills"
    },
    "shadow-iris": {
      "$value": "#2e2a4c",
      "$type": "color",
      "$description": "Shadow Iris — Tinted shadows and border accents — gives depth a violet cast rather than pure black"
    },
    "plum-depth": {
      "$value": "#1f1d3a",
      "$type": "color",
      "$description": "Plum Depth — Deep accent backgrounds, violet-tinted shadow layers, card hover glows"
    },
    "code-rose": {
      "$value": "#f92672",
      "$type": "color",
      "$description": "Code Rose — Code syntax highlighting (Monokai-style keywords), inline emphasis in code blocks"
    }
  },
  "font": {
    "roobert": {
      "$value": "Roobert",
      "$type": "fontFamily",
      "$description": "Headlines and display text — the brand's signature face. Aggressive negative tracking at large sizes makes characters pull into each other, creating a custom-display feel no system font replicates. Use for h1–h3, hero copy, and section titles."
    },
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "Body text, navigation, buttons, UI labels, footer copy. The workhorse face for everything below the headline tier. Weight 580 is an uncommon mid-weight that fills the gap between 500 and 600 for UI emphasis."
    },
    "roboto-mono": {
      "$value": "Roboto Mono",
      "$type": "fontFamily",
      "$description": "Code snippets, terminal output, technical labels. The 0.400em tracking at small sizes is a deliberate eyebrow/label pattern for uppercase micro-copy like 'Built for Developers'."
    }
  },
