      "$type": "color",
      "$description": "Graphite — Input field text, subdued body text, card detail labels"
    },
    "iron": {
      "$value": "#5a5b5f",
      "$type": "color",
      "$description": "Iron — Mid-tone icon strokes, secondary metadata, less prominent UI labels"
    },
