  "font": {
    "proxima-nova": {
      "$value": "Proxima Nova",
      "$type": "fontFamily",
      "$description": "Single-family system. Display and headings lock to 700–800 — near-black weight gives headlines a poster-like authority. Body and nav use 400. The weight gap between body (400) and headline (800) is the hierarchy engine; no medium or semibold exists in between. Substitute: Montserrat, Gotham, or Nunito Sans."
    }
