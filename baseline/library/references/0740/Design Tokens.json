    "cobalt-signal": {
      "$value": "#2b22fa",
      "$type": "color",
      "$description": "Cobalt Signal — Promotional announcement bar, brand accent — the only chromatic moment in the system, used sparingly to signal news or offers without competing with the research content"
    }
  },
  "font": {
    "abcnormal": {
      "$value": "abcNormal",
      "$type": "fontFamily",
      "$description": "Sole typeface across the entire interface — navigation, body, buttons, and display headlines. Weight 450 (a half-step) and 500 carry most UI text; 600 is reserved for emphasis. The tight tracking on large sizes (-0.025em at 48px) prevents headlines from feeling airy, keeping them grounded as editorial statements rather than marketing shouts. The positive tracking at 11px (+0.025em) compensates for small-size readability. Weight 400 for body keeps long research paragraphs light on the eye."
    }
  },
