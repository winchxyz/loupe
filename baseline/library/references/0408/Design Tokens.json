{
  "color": {
    "ink": {
      "$value": "#1e1e1e",
      "$type": "color",
      "$description": "Ink — Body text, headings, primary borders, icon strokes — the dominant neutral that carries almost all type and structural lines"
    },
    "cream-canvas": {
      "$value": "#e3d7cd",
      "$type": "color",
      "$description": "Cream Canvas — Page background and deepest warm surface — the base tone of the entire site"
    },
    "warm-white": {
      "$value": "#f0e9e5",
      "$type": "color",
      "$description": "Warm White — Primary card and section surface, nav background, soft fills"
    },
    "paper-white": {
      "$value": "#f5f2f0",
      "$type": "color",
      "$description": "Paper White — Button hover surfaces and elevated neutral blocks, slightly cooler than Warm White"
    },
    "pure-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Pure White — Top-level product card surfaces and modal panels that need to float above cream"
    },
    "sand-border": {
      "$value": "#c9c9c7",
      "$type": "color",
      "$description": "Sand Border — Subtle warm-gray dividers and disabled controls"
    },
    "stone-text": {
      "$value": "#767676",
      "$type": "color",
      "$description": "Stone Text — Secondary and helper text, muted labels, description copy"
    },
    "charcoal": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Charcoal — Pure black for SVG icon fills in dark contexts only"
    },
    "terracotta": {
      "$value": "#ee884f",
      "$type": "color",
      "$description": "Terracotta — Primary action button fill, the one chromatic accent — warm orange against cream creates urgency without aggression"
    }
  },
  "font": {
    "archivo": {
      "$value": "Archivo",
      "$type": "fontFamily",
      "$description": "Single typeface system. Weight 400 carries body, captions, and descriptions; weight 600 is reserved for headings, nav items, and button labels. Archivo's geometric warmth matches the cream palette — its straight-sided 'A' and open apertures read as set type, not screen type."
    }
  },
