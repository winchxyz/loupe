{
  "color": {
    "parchment-cream": {
      "$value": "#f6f3f1",
      "$type": "color",
      "$description": "Parchment Cream — Page canvas, nav background, badge surfaces — the warm off-white base that makes the entire interface feel like paper rather than screen"
    },
    "ink-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Ink Black — Primary text, icon strokes, hairline borders, and the dominant outline color across nav, cards, and dividers"
    },
    "charcoal": {
      "$value": "#242424",
      "$type": "color",
      "$description": "Charcoal — Primary action button fill, badge borders, elevated surface — filled CTAs sit slightly off pure black for visual softness"
    },
    "graphite": {
      "$value": "#4e4d4d",
      "$type": "color",
      "$description": "Graphite — Body and heading text at lower contrast, secondary card borders, muted UI elements"
    },
    "slate-shadow": {
      "$value": "#3d3d3d",
      "$type": "color",
      "$description": "Slate Shadow — Tertiary borders and decorative strokes where pure black would feel too heavy"
    },
    "warm-stone": {
      "$value": "#797776",
      "$type": "color",
      "$description": "Warm Stone — Muted helper text, link underlines, and low-emphasis labels"
    },
    "lavender-mist": {
      "$value": "#cfdaf5",
      "$type": "color",
      "$description": "Lavender Mist — Card surface tint — the only non-grayscale surface color, used as a gentle wash to separate elevated content from the cream canvas"
    },
    "peach-to-periwinkle-wash": {
      "$value": "#ff9473",
      "$type": "color",
      "$description": "Peach to Periwinkle Wash — Decorative gradient endstop in the data-flow diagram — soft atmospheric color, never used as a UI accent"
    },
    "mint-to-periwinkle-wash": {
      "$value": "#a7fccd",
      "$type": "color",
      "$description": "Mint to Periwinkle Wash — Decorative gradient in the data-flow diagram aura — appears as a soft green glow around the central processing node"
    }
  },
  "font": {
    "untitled-serif": {
      "$value": "Untitled Serif",
      "$type": "fontFamily",
      "$description": "All headlines and display text. Anti-convention: weight 400 (not 600-700) lets the serif shapes whisper — authority comes from the typeface's humanist proportions and generous negative tracking, not from boldness."
    },
    "abc-diatype-mono": {
      "$value": "ABC Diatype Mono",
      "$type": "fontFamily",
      "$description": "Body text, navigation, buttons, badges, tags, and all functional UI copy. The monospaced treatment for non-code text is the system's most distinctive choice — it gives every label the visual weight of a typeset annotation, reinforcing the technical-journal metaphor."
    },
    "untitled-sans": {
      "$value": "Untitled Sans",
      "$type": "fontFamily",
      "$description": "Secondary body text fallback — appears minimally, likely for paragraphs where monospaced character widths would be distracting at length"
    }
  },
