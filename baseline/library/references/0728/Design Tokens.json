  "font": {
    "cofo-sans": {
      "$value": "Cofo Sans",
      "$type": "fontFamily",
      "$description": "Display headlines at 72px weight 700 with extremely tight tracking read like editorial poster type — the weight does the work, not the size alone. Also used for nav links, button labels, and small caps text at 18–22px weight 600/700. The 700 weight is the signature: most sites use 500–600 for heroes, this goes maximum weight to create authority through volume rather than restraint."
    },
    "arial": {
      "$value": "Arial",
      "$type": "fontFamily",
      "$description": "System fallback for body copy and secondary text at 14px — deliberately quiet, never competes with the Cofo Sans display moments"
    }
  },
