{
  "color": {
    "ember-orange": {
      "$value": "#ff4100",
      "$type": "color",
      "$description": "Ember Orange — Orange supporting accent for decorative details and low-frequency emphasis. Do not promote it to the primary CTA color"
    },
    "signal-blue": {
      "$value": "#0052ef",
      "$type": "color",
      "$description": "Signal Blue — Links, secondary highlights, focus rings, decorative code accents — cool counterpoint to the warm orange, used sparingly"
    },
    "plex-green": {
      "$value": "#19d600",
      "$type": "color",
      "$description": "Plex Green — Green supporting accent for decorative details and low-frequency emphasis. Use as a supporting accent, not as a status color"
    },
    "plasma-magenta": {
      "$value": "#f500ff",
      "$type": "color",
      "$description": "Plasma Magenta — Decorative code syntax highlight, studio editor token — appears only within code/editor contexts, not general UI"
    },
    "acid-lime": {
      "$value": "#45ff00",
      "$type": "color",
      "$description": "Acid Lime — Code syntax token — restricted to developer-facing surfaces like the terminal and JSON editor"
    },
    "electric-blue": {
      "$value": "#027fff",
      "$type": "color",
      "$description": "Electric Blue — Code syntax token, inline link variants in editorial copy — secondary to Signal Blue"
    },
    "onyx": {
      "$value": "#0b0b0b",
      "$type": "color",
      "$description": "Onyx — Primary text, dark hero backgrounds, dark product surface panels, button text on light fills"
