{
  "color": {
    "warm-cream": {
      "$value": "#f9f7f0",
      "$type": "color",
      "$description": "Warm Cream — Page canvas — the entire site rests on this off-white, never pure #ffffff. Removes clinical SaaS sterility; reads as approachable, paper-like"
    },
    "snow": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Snow — Elevated card surfaces, input fields, and light-bordered elements"
    },
    "ink": {
      "$value": "#333333",
      "$type": "color",
      "$description": "Ink — Primary body and UI text — the dominant neutral for readable copy across cards, paragraphs, and labels"
    },
    "charcoal": {
      "$value": "#212121",
      "$type": "color",
      "$description": "Charcoal — Heavier text instances, emphasis copy"
    },
    "fog": {
      "$value": "#d0d5dd",
      "$type": "color",
      "$description": "Fog — Hairline borders and dividers between sections and cards"
    },
    "slate": {
      "$value": "#616c8a",
      "$type": "color",
      "$description": "Slate — Muted secondary text, body copy in lighter contexts, de-emphasized metadata"
    },
    "slate-border": {
      "$value": "#40444e",
      "$type": "color",
      "$description": "Slate Border — Stronger borders and link outlines where extra weight is needed"
    },
    "deep-harbor": {
      "$value": "#13426f",
      "$type": "color",
      "$description": "Deep Harbor — Feature card fills, testimonial card fills, heading text — the dominant dark surface that anchors content blocks against the cream"
    },
    "sky-pop": {
      "$value": "#2e96ff",
      "$type": "color",
      "$description": "Sky Pop — Primary action buttons, active states, key emphasis text — the single chromatic accent that drives every interaction"
    },
    "deep-wave": {
      "$value": "#0254a5",
      "$type": "color",
      "$description": "Deep Wave — Outlined link and action border — a darker navy for ghost-style interactive elements that need to read on cream"
    },
    "sky-tint": {
      "$value": "#bde1f9",
      "$type": "color",
      "$description": "Sky Tint — Badge and trust-pill backgrounds, soft highlight washes behind icons and social proof"
    },
    "sky-wash": {
      "$value": "#cde7fb",
      "$type": "color",
      "$description": "Sky Wash — Button shadow tone — the same hue family used for the chunky pop shadow under sky-blue buttons"
    },
    "info-mist": {
      "$value": "#73b9ff",
      "$type": "color",
      "$description": "Info Mist — Blue decorative accent for icons, marks, and small graphic details"
    },
    "sky-mid": {
      "$value": "#50a7ff",
      "$type": "color",
      "$description": "Sky Mid — Decorative illustration fills, mid-tone in 3D hero artwork"
    }
  },
  "font": {
    "gilroy": {
      "$value": "Gilroy",
      "$type": "fontFamily",
      "$description": "Single-family type system — Gilroy runs at every size from 12px captions to 58px hero headlines. Rounded geometric forms give the brand its friendly financial tone without the stiffness of a grotesque. Weight 700 is the working default for headings and buttons; weight 500 carries UI labels."
    }
  },
