{
  "color": {
    "page-canvas": {
      "$value": "#222222",
      "$type": "color",
      "$description": "Page Canvas — Page background, full-bleed canvas behind all product imagery and content bands"
    },
    "deep-surface": {
      "$value": "#151515",
      "$type": "color",
      "$description": "Deep Surface — Dark supporting neutral for text, icons, and strong contrast. Do not promote it to the primary CTA color"
    },
    "void": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Void — Deepest layer — button cores, icon fills, the negative space inside navigation controls"
    },
    "platinum": {
      "$value": "#eeeef2",
      "$type": "color",
      "$description": "Platinum — Primary text, icons, link body, badges, footer text — the only light-on-dark workhorse"
    },
    "pure-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Pure White — Selected link states, rare icon contrast points on dark surfaces"
    },
    "iron": {
      "$value": "#333337",
      "$type": "color",
      "$description": "Iron — Input field surface — one subtle step above canvas for form wells"
    },
    "ash": {
      "$value": "#b4b4b8",
      "$type": "color",
      "$description": "Ash — Input placeholder and helper text — low-contrast gray on the dark input field"
    }
  },
  "font": {
