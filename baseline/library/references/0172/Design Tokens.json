{
  "color": {
    "abyssal-teal": {
      "$value": "#012624",
      "$type": "color",
      "$description": "Abyssal Teal — Page canvas, primary background — the dominant field the entire interface floats on"
    },
    "midnight-current": {
      "$value": "#011d1c",
      "$type": "color",
      "$description": "Midnight Current — Card surface, elevated panels — one step deeper than canvas, surfaces feel pressed into the void"
    },
    "tide-pool-teal": {
      "$value": "#003734",
      "$type": "color",
      "$description": "Tide Pool Teal — Interactive card backgrounds, subtle filled actions, secondary surface lift"
    },
    "fog-veil": {
      "$value": "#bbc7c6",
      "$type": "color",
      "$description": "Fog Veil — Body text, secondary copy, muted borders — the dim chorus against white headlines"
    },
    "ice-mist": {
      "$value": "#edfffe",
      "$type": "color",
      "$description": "Ice Mist — Highlight borders, accent strokes, light decorative edges — a breath of cool light"
    },
    "ash-gray": {
      "$value": "#333333",
      "$type": "color",
      "$description": "Ash Gray — Dark borders and separators for elevated surfaces and inverted UI."
    },
    "snow-sheet": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Snow Sheet — Primary headings, nav text, icon strokes, logo — the bright typographic surface"
    },
    "lilac-wisp": {
      "$value": "#fde9ff",
      "$type": "color",
      "$description": "Lilac Wisp — Accent border tint, warm complement to the cool teal field — used sparingly on hover and decorative edges"
    },
    "current-gradient": {
      "$value": "#00827c",
      "$type": "color",
      "$description": "Current Gradient — Supporting palette color for small decorative accents when the core palette needs contrast. Do not promote it to the primary CTA color"
    },
    "aurora-gradient": {
      "$value": "#cbfffc",
      "$type": "color",
