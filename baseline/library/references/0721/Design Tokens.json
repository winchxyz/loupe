{
  "color": {
    "forest-ink": {
      "$value": "#1a3300",
      "$type": "color",
      "$description": "Forest Ink — Primary text, filled CTA buttons, link text, nav borders, card borders — the structural backbone. This near-black green carries 90% of the interface weight"
    },
    "highlighter-yellow": {
      "$value": "#ffe95c",
      "$type": "color",
      "$description": "Highlighter Yellow — Text highlight wash (behind keywords in headlines), badge backgrounds, accent fills. Always reads as a marker stroke, never as a CTA"
    },
    "cream-paper": {
      "$value": "#fcfaf5",
      "$type": "color",
      "$description": "Cream Paper — Page canvas, card surfaces, nav background — the warm off-white everything sits on. Slightly yellow-shifted to feel like aged paper, not screen white"
    },
    "pencil-gray": {
      "$value": "#b6b6b6",
      "$type": "color",
      "$description": "Pencil Gray — Nav and divider borders — a single mid-gray for hairlines that should recede"
    },
    "whisper-gray": {
      "$value": "#f1f1f1",
      "$type": "color",
      "$description": "Whisper Gray — Muted helper text, secondary labels — disappears into the cream canvas"
    },
    "sticky-note-teal": {
      "$value": "#a8e5e5",
      "$type": "color",
      "$description": "Sticky Note Teal — Teal action color for filled buttons, selected navigation states, and focused conversion moments."
    },
    "sticky-note-mint": {
      "$value": "#d5f5c2",
      "$type": "color",
      "$description": "Sticky Note Mint — Green action color for filled buttons, selected navigation states, and focused conversion moments"
    },
    "sticky-note-blush": {
      "$value": "#f6d0ff",
      "$type": "color",
      "$description": "Sticky Note Blush — Decorative button/card fill. Sprinkle use only"
    },
    "terracotta": {
      "$value": "#cb5521",
      "$type": "color",
      "$description": "Terracotta — Decorative card accent — warm counterpoint to the green/yellow palette"
    }
  },
  "font": {
    "bricolage-grotesque": {
      "$value": "Bricolage Grotesque",
      "$type": "fontFamily",
      "$description": "Display headlines only. Custom variable font with positive tracking (0.04-0.05em) that makes characters feel chunky and sticker-like. This is the signature voice — never use for body or UI."
    },
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "Everything functional: body copy, nav, buttons, cards, subheadings. Weight 400 for body, 500-600 for labels and subheads, 700 for section headings. Clean humanist sans that lets the Bricolage display type stay loud."
    },
    "roboto-mono": {
      "$value": "Roboto Mono",
      "$type": "fontFamily",
      "$description": "Micro-labels in nav, small caps-style tags, and technical metadata. Mono signals 'tool/utility' context within the otherwise rounded typographic system."
    }
  },
