{
  "color": {
    "studio-black": {
      "$value": "#100904",
      "$type": "color",
      "$description": "Studio Black — Page canvas and primary surface. Near-black with a faint warm brown undertone — warmer than pure black, never cold"
    },
    "warm-cream": {
      "$value": "#ffedd7",
      "$type": "color",
      "$description": "Warm Cream — All text, all nav labels, all borders, all button outlines. The sole foreground color — cream rather than white keeps the contrast warm against the near-black canvas"
    },
    "cork-shadow": {
      "$value": "#40372e",
      "$type": "color",
      "$description": "Cork Shadow — Dashed divider borders and secondary structural lines. One step lighter than canvas, used for subtle spatial separation"
    },
    "dark-cork": {
      "$value": "#382416",
      "$type": "color",
      "$description": "Dark Cork — Filled button background — the only non-transparent surface in the button system, mid-dark brown that reads as a contained warm swatch against the canvas"
    },
    "burnt-sienna": {
      "$value": "#dc5000",
      "$type": "color",
      "$description": "Burnt Sienna — Accent for link underlines, icon strokes, and ghost-button outlines where a chromatic edge is needed. Vivid orange-red used as a hairline signal, never a fill"
    },
    "grey-brown": {
      "$value": "#6c5f51",
      "$type": "color",
      "$description": "Grey Brown — Mid-tone warm gray for muted text, secondary labels, and deemphasized UI elements"
    },
    "forest-grid": {
      "$value": "#445231",
      "$type": "color",
      "$description": "Forest Grid — Deep olive green used in product photography and scene surfaces — not a UI token, but defines the photographic palette"
    }
  },
  "font": {
    "halyard-display-variable": {
      "$value": "halyard-display-variable",
      "$type": "fontFamily",
      "$description": "The only typeface on the site, used at every scale from 10px utility labels to 51px cinematic headlines. Weight 400 at body and nav scale; 500 reserved for display headlines. The variable axis allows a single family to carry both whispered captions and room-filling titles. Line-height 0.90 at 51px makes headlines stack with almost no air — deliberate density at large scale."
    },
    "arial": {
      "$value": "Arial",
      "$type": "fontFamily",
      "$description": "System fallback at 8px only — appears in button letter-spaced character animations (the duplicated character reveal effect). Not a design system choice, strictly a motion/animation artifact."
    }
  },
