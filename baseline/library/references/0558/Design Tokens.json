    "midnight-ink": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Midnight Ink — Primary text, filled CTA buttons, icon fills, card borders — black on white is the entire contrast system; no blue or colored accent dilutes it"
    },
    "pure-canvas": {
      "$value": "#ffffff",
