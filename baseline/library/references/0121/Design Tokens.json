{
  "color": {
    "ink-black": {
      "$value": "#0d0e13",
      "$type": "color",
      "$description": "Ink Black — Primary text, dark UI frames, icon strokes — the deepest near-black with a barely-perceptible cool cast that keeps it from feeling warm or brown against the beige canvas"
    },
    "pure-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Pure White — Card surfaces, nav background, image bleeds — the brightest surface level that lifts content off the warm canvas"
    },
    "canvas-beige": {
      "$value": "#e4e0db",
      "$type": "color",
      "$description": "Canvas Beige — Page background, section bands — a warm light gray-beige that gives the whole site its sunlit, paper-like quality"
    },
    "steel-gray": {
      "$value": "#6e6e71",
      "$type": "color",
      "$description": "Steel Gray — Secondary body text, muted borders — the only truly achromatic neutral in the system, used sparingly to signal de-emphasis"
    },
    "footer-ink": {
      "$value": "#070707",
      "$type": "color",
      "$description": "Footer Ink — Footer background — a pure near-black that reads as the deepest possible dark without losing detail"
    },
    "sand-border": {
      "$value": "#e0ccbb",
      "$type": "color",
      "$description": "Sand Border — Default hairline borders, icon outlines, structural dividers — the warm tan that replaces cold gray chrome throughout the interface"
    },
    "warm-linen": {
      "$value": "#e6d7ca",
      "$type": "color",
      "$description": "Warm Linen — Outlined action borders, link underlines, interactive link states — the lighter, more luminous sand tone that signals interactivity without filling the shape"
    }
  },
  "font": {
    "lausanne-400": {
      "$value": "Lausanne-400",
      "$type": "fontFamily",
      "$description": "Lausanne-400 — detected in extracted data but not described by AI"
    },
    "lausanne": {
      "$value": "Lausanne",
      "$type": "fontFamily",
      "$description": "Primary typeface for everything from 14px body to 250px display. The 250px hero display with -0.046em tracking is the signature element — letters nearly collide, creating a monolithic word-as-architecture presence. The single weight 400 across the full scale (from 14px to 250px) means hierarchy comes from size and tracking alone, not from bold."
    },
    "times": {
      "$value": "Times",
      "$type": "fontFamily",
      "$description": "System serif fallback used in tertiary body contexts. Acts as a quiet typographic counterpoint to the neo-grotesque — never set in display sizes, always at 16px with generous leading."
    }
  },
