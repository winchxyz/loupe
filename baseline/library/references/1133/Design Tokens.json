{
  "color": {
    "void": {
      "$value": "#0f0f0f",
      "$type": "color",
      "$description": "Void — Page canvas and primary surface — the base layer beneath all artwork, slightly lifted from pure black to prevent OLED banding in the dark void"
    },
    "absolute": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Absolute — Hairline borders, image containers, icon strokes, footer dividers — pure black acts as the structural ink that defines edges in the absence of visible card surfaces"
    },
    "charcoal": {
      "$value": "#1a1a1a",
      "$type": "color",
      "$description": "Charcoal — Elevated footer surface and deeper UI panels — a single step up from canvas for zone separation without breaking the dark void"
    },
    "faint": {
      "$value": "#080808",
      "$type": "color",
      "$description": "Faint — Shadow base for subtle elevation effects — nearly invisible against canvas, used in box-shadow compositions for soft ambient lift"
    },
    "bone": {
      "$value": "#f0f0f0",
      "$type": "color",
      "$description": "Bone — Primary text color, nav item fills, filled button background — warm off-white replaces pure white to soften contrast against the black void and reduce eye strain"
    },
    "ash": {
      "$value": "#b8b8b8",
      "$type": "color",
      "$description": "Ash — Secondary body text, subdued helper labels, muted metadata — sits one step below Bone for non-emphasized copy without losing legibility on dark surfaces"
    },
    "graphite": {
      "$value": "#696969",
      "$type": "color",
      "$description": "Graphite — Tertiary text and border accents on headings — used sparingly for fine print and inactive labels that should recede"
    },
    "live-wire": {
      "$value": "#08ff00",
      "$type": "color",
      "$description": "Live Wire — Green wash for highlight backgrounds, decorative bands, and soft emphasis behind content"
    }
  },
  "font": {
    "inter-display": {
      "$value": "Inter Display",
      "$type": "fontFamily",
      "$description": "Primary typeface across all UI, body, navigation, and headings — used exclusively at weight 400 with no weight variation, creating a flat, even visual texture where size and spacing alone carry hierarchy. Substitute with Inter (free, near-identical metrics)."
    },
    "system-sans-serif": {
      "$value": "System sans-serif",
      "$type": "fontFamily",
      "$description": "Micro-UI labels (12px) — system stack for the smallest utility text where font loading overhead isn't justified"
    }
  },
