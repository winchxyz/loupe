{
  "color": {
    "slate-ink": {
      "$value": "#333333",
      "$type": "color",
      "$description": "Slate Ink — Primary text, dominant borders, nav links — the workhorse dark that replaces pure black everywhere a softer edge is wanted"
    },
    "pure-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Pure White — Neutral form states, badge text, and quiet UI feedback where color should stay understated. Do not promote it to the primary CTA color"
    },
    "onyx-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Onyx Black — Icon strokes, input borders, and hard-edge accents where maximum contrast is required"
    },
    "warm-bone": {
      "$value": "#faf7ef",
      "$type": "color",
      "$description": "Warm Bone — Secondary surface — a barely-warm cream that lifts cards off pure white without introducing visible color"
    },
    "ash-gray": {
      "$value": "#707070",
      "$type": "color",
      "$description": "Ash Gray — Muted helper text, secondary borders, disabled states — quieter than Slate Ink by two stops"
    },
    "cobalt-signal": {
      "$value": "#0048ff",
      "$type": "color",
      "$description": "Cobalt Signal — Primary action fill — the only chromatic color in the system, reserved for CTA buttons and live action moments"
    },
    "stone-gray": {
      "$value": "#999999",
      "$type": "color",
      "$description": "Stone Gray — Tertiary borders and inactive icon strokes — the quietest neutral, used only when Ash is still too loud"
    }
  },
