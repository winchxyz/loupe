{
  "color": {
    "midnight-plum": {
      "$value": "#0b051d",
      "$type": "color",
      "$description": "Midnight Plum — Violet supporting accent for decorative details and low-frequency emphasis."
    },
    "deep-plum": {
      "$value": "#2c2242",
      "$type": "color",
      "$description": "Deep Plum — Accent card background — a slightly lifted version of Midnight Plum, used for dark-themed product/feature cards to create tonal variation within the dark family"
    },
    "lavender-mist": {
      "$value": "#aa89f2",
      "$type": "color",
      "$description": "Lavender Mist — Violet supporting accent for decorative details and low-frequency emphasis"
    },
    "lime-sherbet": {
      "$value": "#e6ffa9",
      "$type": "color",
      "$description": "Lime Sherbet — Accent card background — high-key lime used as a rotating card surface color. High contrast against Midnight Plum text makes it ideal for dark-on-light product cards"
    },
    "bubblegum-pink": {
      "$value": "#ffa8cd",
      "$type": "color",
      "$description": "Bubblegum Pink — Red supporting accent for decorative details and low-frequency emphasis. Do not promote it to the primary CTA color"
    },
    "warm-bone": {
      "$value": "#f9f8f5",
      "$type": "color",
      "$description": "Warm Bone — Page canvas — the warm off-white that fills the body of every content section. Slightly cream-toned to feel inviting rather than clinical"
    },
    "pure-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Pure White — Card surfaces and nav background — used for elevated cards on the Warm Bone canvas, and for the sticky top navigation bar"
    },
    "silver-mist": {
      "$value": "#e2e2e7",
      "$type": "color",
      "$description": "Silver Mist — Hairline borders, input outlines, and card edge definition. Also functions as the inset shadow color on buttons (rgb(228, 227, 223) inset ring)"
    },
    "storm-gray": {
      "$value": "#615f6d",
      "$type": "color",
      "$description": "Storm Gray — Primary muted text — body copy, nav links, secondary descriptions. Near-gray with a slight cool violet undertone matching the brand"
    },
    "slate-gray": {
      "$value": "#75727f",
      "$type": "color",
      "$description": "Slate Gray — Secondary text — captions, helper text, fine print, and less prominent body copy"
    },
    "charcoal-plum": {
      "$value": "#373544",
      "$type": "color",
      "$description": "Charcoal Plum — Dark UI text and button borders — used on pill buttons and nav controls where a softer dark than Midnight Plum is needed"
    },
    "ash-gray": {
      "$value": "#999999",
      "$type": "color",
      "$description": "Ash Gray — Tertiary neutral — placeholder text, disabled states, and very low-emphasis UI elements"
    }
  },
  "font": {
    "klarna-title": {
      "$value": "Klarna Title",
      "$type": "fontFamily",
      "$description": "Custom display font used exclusively for headings and hero text. Sizes escalate dramatically (40→58→90px) with tight 1.05-1.10 line-height — the 90px hero weight is a signature: oversized geometric type that commands the viewport. Normal letter-spacing at these sizes lets the letterforms breathe at their natural width."
    },
    "klarna-text": {
      "$value": "Klarna Text",
      "$type": "fontFamily",
      "$description": "Custom UI/body font for navigation labels, input text, and smaller headings. Slight negative tracking (-0.01em) tightens display usage; -0.003em for body keeps text compact without feeling cramped. Weight 500 for nav, 700 for subheadings, 400 for body."
    },
    "apple-system": {
      "$value": "-apple-system",
      "$type": "fontFamily",
      "$description": "System font fallback for body text, links, buttons, and general UI at 12-20px. Tighter line-heights (1.14-1.20) for compact UI elements, relaxed 1.43-1.50 for readable body paragraphs."
    }
  },
