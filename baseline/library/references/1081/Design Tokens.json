{
  "color": {
    "electric-cobalt": {
      "$value": "#0700ff",
      "$type": "color",
      "$description": "Electric Cobalt — Violet wash for highlight backgrounds, decorative bands, and soft emphasis behind content. Do not promote it to the primary CTA color"
    },
    "gallery-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Gallery Black — Primary text, product titles, prices, navigation links, icon strokes, and dominant fill on collection overlay labels"
    },
    "paper-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper White — Card surfaces, product image backgrounds, and inverse text on dark imagery and the cobalt announcement bar"
    },
    "hairline-gray": {
      "$value": "#ebebeb",
      "$type": "color",
      "$description": "Hairline Gray — Primary border color, page canvas background, card dividers, list separators, input field backgrounds — the dominant structural neutral"
    },
    "fog-gray": {
      "$value": "#cecccc",
      "$type": "color",
      "$description": "Fog Gray — Secondary surface for elevated sections and secondary borders, providing one subtle step above the dominant #ebebeb"
    },
    "chalk-white": {
      "$value": "#f7f7f7",
      "$type": "color",
      "$description": "Chalk White — Soft background wash for alternating sections and subtle card lift without shadows"
    },
    "ash-gray": {
      "$value": "#b5b5b5",
      "$type": "color",
      "$description": "Ash Gray — Muted helper text, disabled icon fills, and secondary metadata"
    }
  },
  "font": {
    "ftbasicspace": {
      "$value": "FTBasicSpace",
      "$type": "fontFamily",
      "$description": "Single custom typeface used across all surfaces — UI chrome, product metadata, and section headlines. The 500/600 weights are reserved for product titles and brand labels (WAKA WAKA, RARIFY, PROSA), while 400 carries navigation, prices, and body. The signature is the tight negative tracking (-0.0220em at display sizes) which compresses the letterforms into a dense, almost monolinear rhythm — unlike typical e-commerce type that opens up, this tightens."
    }
  },
