{
  "color": {
    "mint-green": {
      "$value": "#0c8c5e",
      "$type": "color",
      "$description": "Mint Green — Brand links, active nav state, feature icons, decorative dots in eyebrow labels, the thin underline on inline code references — the only chromatic accent in a monochrome system, applied sparingly to make functional moments feel switched on"
    },
    "ink-black": {
      "$value": "#08090a",
      "$type": "color",
      "$description": "Ink Black — Dark supporting neutral for text, icons, and strong contrast. Do not promote it to the primary CTA color"
    },
    "true-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "True Black — Body text, link defaults before hover, icon strokes, and footer rules — the workhorse neutral that carries most of the typography load"
    },
    "paper-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper White — Page canvas, card surfaces, button text on dark fills, input fields — the base layer everything else sits on"
    },
    "mist-gray": {
      "$value": "#f2f2f2",
      "$type": "color",
      "$description": "Mist Gray — Subtle dividers, hairline strokes on cards, low-emphasis backgrounds, and the faintest hover wash"
    },
    "cloud-gray": {
      "$value": "#dddddd",
      "$type": "color",
      "$description": "Cloud Gray — Input borders, card outlines on hover states, secondary divider lines that need a step more visibility than Mist"
    }
  },
  "font": {
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "Universal typeface — the only family in the system. Used for headlines, body, nav, buttons, inputs, and code. No display face, no mono override visible."
    }
  },
