{
  "color": {
    "forest-ink": {
      "$value": "#003f2e",
      "$type": "color",
      "$description": "Forest Ink — Primary brand color, headlines, logo mark, body emphasis, heavy borders, dark surface blocks — deep emerald reads as ink-stamp rather than digital green, anchoring every page with editorial weight"
    },
    "vivid-emerald": {
      "$value": "#039861",
      "$type": "color",
      "$description": "Vivid Emerald — Outlined/ghost link borders, thin section rules, and occasional icon accents — the only chromatic accent in the system, used sparingly so it reads as a signal rather than decoration"
    },
    "cream-canvas": {
      "$value": "#fdf9f7",
      "$type": "color",
      "$description": "Cream Canvas — Page background, document body — warm off-white gives the entire site a paper-like, non-screen feel"
    },
    "pure-paper": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Pure Paper — Card and elevated surfaces layered above the cream canvas"
    },
    "ink-black": {
      "$value": "#333333",
      "$type": "color",
      "$description": "Ink Black — Primary body and link text on light surfaces — softened pure black to feel printed rather than digital"
    },
    "faded-pencil": {
      "$value": "#6e7673",
      "$type": "color",
      "$description": "Faded Pencil — Muted body text, secondary metadata, helper copy"
    },
    "hairline-gray": {
      "$value": "#d6d6d6",
      "$type": "color",
      "$description": "Hairline Gray — Light borders, dividers, accordion separators, subtle structural rules"
    },
    "mid-gray": {
      "$value": "#a6a6a6",
      "$type": "color",
      "$description": "Mid Gray — Medium-weight borders, icon strokes, secondary dividers"
    }
