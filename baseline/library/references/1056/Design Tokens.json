{
  "color": {
    "tile-grout": {
      "$value": "#d25a24",
      "$type": "color",
      "$description": "Tile Grout — Signature brand border and link accent — orange tile-line strokes that frame cards, links, and section edges with the warmth of fired clay against the clinical white canvas"
    },
    "cold-press-green": {
      "$value": "#113722",
      "$type": "color",
      "$description": "Cold-Press Green — Primary action fill — the dark botanical green of filled CTA buttons, footer band, and category button backgrounds, signaling the product inside without resorting to food-photo greens"
    },
    "sticker-crimson": {
      "$value": "#6b1229",
      "$type": "color",
      "$description": "Sticker Crimson — Hard-offset shadow accent — deep burgundy that throws a zero-blur 5px shadow under stickers and emphasized buttons, turning flat elements into screen-print layers peeled onto the page"
    },
    "noir": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Noir — Navigation, body text, and default border color — the unyielding black that carries every paragraph, icon stroke, and card hairline"
    },
    "glacial-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Glacial White — Page canvas, card surface, and reverse text on dark nav and green CTAs — the clinical white tile of the entire system"
    },
    "ash": {
      "$value": "#efefef",
      "$type": "color",
      "$description": "Ash — Soft card border and subtle fill — the gray grout between white surfaces, used for hairline dividers and recessed card frames"
    },
    "char": {
      "$value": "#232323",
      "$type": "color",
      "$description": "Char — Heading color and deep-surface accent — nearly-black tone for the heaviest display text and occasional dark bands"
    },
    "concrete": {
      "$value": "#cccccc",
      "$type": "color",
      "$description": "Concrete — Mid-gray utility border and muted body text — quieter dividers where full black would be too loud"
    },
    "fog": {
      "$value": "#d7d7d7",
      "$type": "color",
      "$description": "Fog — Input field border — neutral resting-state outline for form fields"
    },
    "slate": {
      "$value": "#646464",
      "$type": "color",
      "$description": "Slate — Input text and icon fill — secondary legibility gray for form labels and small icon detail"
    },
    "pewter": {
      "$value": "#808080",
      "$type": "color",
      "$description": "Pewter — Decorative low-emphasis border and text — rarely used, appears on tertiary UI marks"
    }
  },
  "font": {
    "helvetica": {
      "$value": "Helvetica",
      "$type": "fontFamily",
      "$description": "All UI and editorial text. The choice of system Helvetica is deliberate — it reads as lab-label stencil rather than fashion-serif sophistication. Weight 900 headlines shout at 40-48px in all-caps with positive tracking, weight 400-500 carries body copy at 14-18px. No custom display face: the system itself is the brand."
    }
  },
