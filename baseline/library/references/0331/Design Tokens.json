{
  "color": {
    "signal-violet": {
      "$value": "#5e51f8",
      "$type": "color",
      "$description": "Signal Violet — Primary brand color — hero backgrounds, CTAs, interactive states, logo mark. The electric quality (vivid, high-chroma) makes every surface it touches feel charged."
    },
    "deep-nebula": {
      "$value": "#251544",
      "$type": "color",
      "$description": "Deep Nebula — Hero section footer tone and gradient terminus. Paired with Signal Violet for the dark-to-darker hero gradient that creates depth within the purple field."
    },
    "iris-mid": {
      "$value": "#4b41c6",
      "$type": "color",
      "$description": "Iris Mid — Button shadow underlay and hover states on the hero. Creates tactile depth on dark surfaces via box-shadow layering."
    },
    "soft-amethyst": {
      "$value": "#cfcbfd",
      "$type": "color",
      "$description": "Soft Amethyst — Secondary headline text on dark violet backgrounds — brand color carried into typography so the hero never loses chromatic identity."
    },
    "lavender-mist": {
      "$value": "#d5a8f5",
      "$type": "color",
      "$description": "Lavender Mist — Pill button accent variant — appears as a pastel contrast button against the violet hero. Black text on this color delivers AAA contrast with brand warmth."
    },
    "powder-violet": {
      "$value": "#d7d3fd",
      "$type": "color",
      "$description": "Powder Violet — Feature card illustration tints and ghost typography in the white sections — keeps brand hue present without saturating light backgrounds."
    },
    "periwinkle-glow": {
      "$value": "#867dfa",
      "$type": "color",
      "$description": "Periwinkle Glow — Icon fills and glow halos (box-shadow on interactive elements). The lighter violet relative of Signal Violet — used for SVG fills and hover glow effects."
    },
    "celestial-cyan": {
      "$value": "#99eeff",
      "$type": "color",
      "$description": "Celestial Cyan — Decorative accent surface — appears sparingly as a cool counterpoint to the warm violet system."
    },
