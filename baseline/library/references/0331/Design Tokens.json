  "font": {
    "nan-jaune-midi-bold": {
      "$value": "NaN Jaune Midi Bold",
      "$type": "fontFamily",
      "$description": "Hero and section display headlines exclusively. The custom font's chunky stroke contrast and tight tracking at display sizes creates broadcast-title energy — unmistakable at a glance, nothing Inter could replicate. The aggressive negative tracking (-0.054em at 56px) squeezes letters into a dense typographic block that reads as a single graphic unit."
    },
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "All UI text: navigation, body copy, subheadings, card titles, buttons, captions. Weight 700 at 24-30px for section subheadings; weight 600 at 18-20px for card headers; weight 500 at 14-16px for body and UI labels. The utilitarian pairing with NaN Jaune Midi is intentional — Inter stays invisible so the display font commands full attention."
    },
    "sans-serif": {
      "$value": "sans-serif",
      "$type": "fontFamily",
      "$description": "System fallback at 12px for fine-print labels and browser-rendered micro text."
    }
  },
