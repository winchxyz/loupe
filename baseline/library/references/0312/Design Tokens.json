    "pewter": {
      "$value": "#808080",
      "$type": "color",
      "$description": "Pewter — Mid-neutral for utility backgrounds, subtle dividers between tonal sections"
    },
    "graphite": {
      "$value": "#636363",
      "$type": "color",
      "$description": "Graphite — Solid fill for compact utility buttons (cookie accept, dismiss) — the only non-black action surface"
