    "mercury-flow": {
      "$value": "#a0e0ab",
      "$type": "color",
      "$description": "Mercury Flow — Atmospheric gradient terminus — organic color appearing only in hero 3D renders and brand film stills, not a UI token"
    }
  },
  "font": {
    "roobert": {
      "$value": "Roobert",
      "$type": "fontFamily",
      "$description": "Sole display and UI typeface across every role. The 225px hero scale (weight 300) creates whisper-weight monumentality — authority through restraint, not volume. Weight 300 is the signature headline weight; weight 400 carries body and navigation; weight 600 is reserved for emphasis. Substitutes: Inter, DM Sans, or Suisse Int'l as geometric neo-grotesque alternatives."
    },
    "raleway": {
      "$value": "Raleway",
      "$type": "fontFamily",
      "$description": "Secondary display presence at the 54px tier — likely used for editorial subhead or pull-quote contrast against Roobert headlines. Substitutes: Montserrat, Poppins."
    },
    "system-ui": {
      "$value": "system-ui",
      "$type": "fontFamily",
      "$description": "Fallback for cookie banner, legal micro-copy, and system-level utility text where custom font loading is unnecessary."
    }
  },
