{
  "color": {
    "electric-blue": {
      "$value": "#5196fe",
      "$type": "color",
      "$description": "Electric Blue — Primary brand color — filled CTAs, full-bleed feature section background, icon accents, the credit card product visual's gradient. Carries 80% of brand recognition"
    },
    "ember-orange": {
      "$value": "#f9754e",
      "$type": "color",
      "$description": "Ember Orange — Orange action color for filled buttons, selected navigation states, and focused conversion moments."
    },
    "ink-black": {
      "$value": "#1b1d20",
      "$type": "color",
      "$description": "Ink Black — Primary text, dark card surfaces (the credit card mockup, the dark feature section), heavy borders. Not pure black — sits slightly warm"
    },
    "midnight": {
      "$value": "#101828",
      "$type": "color",
      "$description": "Midnight — Secondary text and dark borders when Ink Black feels too heavy in tight contexts"
    },
    "paper-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper White — Primary canvas, card surfaces, button text, input fills — the bright default that lets blue and orange speak"
    },
    "parchment": {
      "$value": "#f2f1ec",
      "$type": "color",
      "$description": "Parchment — Warm card surface alternative — used when a card needs to feel softer than pure white, typically for feature blocks or stat panels"
    },
    "sand": {
      "$value": "#e1dfd8",
      "$type": "color",
      "$description": "Sand — Warm hairline border, parchment-adjacent dividers, subtle card outlines that need warmth without darkness"
    },
    "graphite": {
      "$value": "#27272a",
      "$type": "color",
      "$description": "Graphite — Border color for dark elements, secondary dividers on dark surfaces"
    },
    "steel": {
      "$value": "#6e6e6e",
      "$type": "color",
      "$description": "Steel — Muted helper text, quiet borders, icon strokes that need to recede"
    },
    "ash": {
      "$value": "#797876",
      "$type": "color",
      "$description": "Ash — Muted text and borders on warm surfaces, slightly lighter than Steel for secondary hierarchy"
    },
    "fog": {
      "$value": "#a3a3a3",
      "$type": "color",
      "$description": "Fog — Input default border — the resting state before focus activates the Electric Blue ring"
    }
  },
  "font": {
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "Primary typeface for all functional UI: body, nav, buttons, labels, stats, card titles. Weight 600 for headings, 500 for sub-labels, 400 for body, 700 for stat numbers. The workhorse that does 95% of the work."
    },
    "gambetta": {
      "$value": "Gambetta",
      "$type": "fontFamily",
      "$description": "Italic display serif reserved for the single most important word in the hero headline — a deliberate voice break that turns a product descriptor into editorial copy. Used at most once per page."
    },
    "system-ui": {
