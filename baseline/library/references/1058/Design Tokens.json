      "$value": "#212529",
      "$type": "color",
      "$description": "Charcoal Ink — Body text, headings, nav text, footer text, most borders — the dominant text and structural color, slightly softer than pure black for warmth"
    },
    "pure-press": {
      "$value": "#000000",
