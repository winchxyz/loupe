{
  "color": {
    "signal-blue": {
      "$value": "#007bff",
      "$type": "color",
      "$description": "Signal Blue — Primary action button fill, active link states, focus indicators — the single chromatic action color in an otherwise achromatic system"
    },
    "amber-alert": {
      "$value": "#f7be00",
      "$type": "color",
      "$description": "Amber Alert — Download CTA, high-priority callouts, notification accents — warm yellow against dark surfaces for the conversion moment"
    },
    "deep-indigo": {
      "$value": "#0d0021",
      "$type": "color",
      "$description": "Deep Indigo — Dark section backgrounds, announcement bar, hero gradient base — the midnight-violet that makes screens glow"
    },
    "midnight-ink": {
      "$value": "#05010d",
      "$type": "color",
      "$description": "Midnight Ink — Dark card surfaces, deepest background layer — near-black with a violet undertone"
    },
    "pure-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Pure White — Light canvas, notification card surfaces, text on dark — the dominant surface color in the upper page"
    },
    "pure-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Pure Black — Primary text, icon strokes, hairline borders, ghost button fills — the structural ink of the system"
    },
    "carbon": {
      "$value": "#333333",
      "$type": "color",
      "$description": "Carbon — Secondary text, subdued body copy — reads softer than pure black for paragraph-length content"
    },
    "slate": {
      "$value": "#595959",
      "$type": "color",
      "$description": "Slate — Tertiary text, metadata, timestamps in notification cards"
    },
    "steel": {
      "$value": "#737373",
      "$type": "color",
      "$description": "Steel — Muted body text, disabled states, inactive nav items"
    },
    "fog": {
      "$value": "#808080",
      "$type": "color",
      "$description": "Fog — Placeholder text, dimmed labels, low-priority metadata"
    },
    "silver": {
      "$value": "#cfcfcf",
      "$type": "color",
      "$description": "Silver — Hairline borders, card outlines, subtle dividers, very light surface tint"
    },
    "linen": {
      "$value": "#faf8f7",
      "$type": "color",
      "$description": "Linen — Warm off-white surface — alternate card background, subtle tonal shift from pure white"
    },
    "ash": {
      "$value": "#89898e",
      "$type": "color",
      "$description": "Ash — Cool gray for pressed states and slightly cooler text — the only neutral with a slight blue cast"
    },
    "alert-red": {
      "$value": "#d92d20",
      "$type": "color",
      "$description": "Alert Red — Red outline accent for tags, dividers, and focused UI edges. Use as a supporting accent, not as a status color"
    }
  },
  "font": {
    "sans-serif": {
      "$value": "sans-serif",
      "$type": "fontFamily",
      "$description": "sans-serif — detected in extracted data but not described by AI"
    },
    "system-ui": {
      "$value": "system-ui",
      "$type": "fontFamily",
      "$description": "Primary typeface for the entire system — covers display headlines, navigation, body copy, and UI labels. Weight 700 dominates display sizes (56px, 32px) for the bold announcement-board voice; 500–600 for nav and emphasis; 400 for body. The choice of system-ui over a custom typeface is itself a signature: it reads native on every device and inherits the platform's voice rather than imposing a foreign one."
    },
    "eb-garamond": {
      "$value": "EB Garamond",
      "$type": "fontFamily",
      "$description": "Editorial serif accent for emphasis moments — tight line-height (0.90) and 700 weight give it a display-poster quality. Used sparingly, probably for tagline or feature emphasis where the sans-serif would feel too uniform."
    },
    "sf-pro-text-regular": {
      "$value": "SF Pro Text Regular",
      "$type": "fontFamily",
      "$description": "SF Pro Text Regular — detected in extracted data but not described by AI"
    },
