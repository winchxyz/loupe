{
  "color": {
    "forest-depths": {
      "$value": "#122314",
      "$type": "color",
      "$description": "Forest Depths — Dark elevated surface for cards, headers, and contained panels. Do not promote it to the primary CTA color"
    },
    "moss-shadow": {
      "$value": "#273f2b",
      "$type": "color",
      "$description": "Moss Shadow — Gray action color for filled buttons, selected navigation states, and focused conversion moments."
    },
    "lichen-sage": {
      "$value": "#7e8371",
      "$type": "color",
      "$description": "Lichen Sage — Secondary muted text, link underline on dark, and badge border color — sits between Moss Shadow and Pure White as the off-tone voice"
    },
    "pale-fern": {
      "$value": "#b7bda5",
      "$type": "color",
      "$description": "Pale Fern — Medium-contrast borders, control outlines, and structural separators."
    },
    "electric-sprout": {
      "$value": "#68ef3f",
      "$type": "color",
      "$description": "Electric Sprout — Green action color for filled buttons, selected navigation states, and focused conversion moments."
    },
    "deep-verdant": {
      "$value": "#26a200",
      "$type": "color",
      "$description": "Deep Verdant — Secondary accent for link borders, icon strokes, and hover-active states — a quieter green that supports Sprout without competing"
    },
    "sprout-wash": {
      "$value": "#e7f9dd",
      "$type": "color",
      "$description": "Sprout Wash — Light green badge background and success-tint surface — the diluted form of Electric Sprout for soft status chips"
    },
    "mist-green": {
      "$value": "#d9deca",
      "$type": "color",
      "$description": "Mist Green — Light sage link border and chip outline on bone surfaces — a low-contrast divider that reads as green without demanding attention"
    },
    "onyx-olive": {
      "$value": "#30322a",
      "$type": "color",
      "$description": "Onyx Olive — Primary achromatic dark — body copy on white, borders on light cards, and the dominant hairline color across the whole system"
    },
    "pure-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Pure White — Light-section page background, text on dark surfaces, and inverted badge fills — the greenhouse bench"
    },
    "bone-white": {
      "$value": "#f2f5eb",
      "$type": "color",
      "$description": "Bone White — Card surface on light sections — warm off-white that prevents the page from reading sterile, never pure #fff when elevated"
    },
    "soft-mist": {
      "$value": "#dcdfe3",
      "$type": "color",
      "$description": "Soft Mist — Cool-tinted heading rule and quiet secondary border — the only neutral that isn't green-tinted"
    },
    "cool-stone": {
      "$value": "#d6d6d6",
      "$type": "color",
      "$description": "Cool Stone — Muted UI surface for disabled controls, low-emphasis panels, and placeholder blocks."
    },
    "carbon": {
      "$value": "#222222",
      "$type": "color",
      "$description": "Carbon — Link text and border on light surfaces — darker than Onyx Olive, used only where the link must read as a typographic accent rather than a button"
    }
  },
  "font": {
    "ozik": {
      "$value": "Ozik",
      "$type": "fontFamily",
      "$description": "Hero and section display only — used for two or three words maximum per line. The ultra-tight 0.86 line-height stacks letterforms like glasshouse beams; the heavy weight on a near-black canvas is the system's signature."
    },
    "aeonik": {
      "$value": "Aeonik",
      "$type": "fontFamily",
      "$description": "Workhorse for every UI surface — nav, body, buttons, cards, inputs, headings up to 40px. 400 for body and labels, 500 for sub-labels, 600 for sub-headings, 700 for section titles and button labels. The negative letter-spacing tightens as size grows, giving headlines a compressed, technical feel without becoming a display face."
    },
    "instrument-serif": {
      "$value": "Instrument Serif",
      "$type": "fontFamily",
      "$description": "Editorial accent only — drops into badges, small pull quotes, and the occasional 32px sub-heading to break Aeonik's geometric monotony. The serif's organic stroke and slight +0.063em tracking at small sizes are the only warmth this system permits."
    }
  },
