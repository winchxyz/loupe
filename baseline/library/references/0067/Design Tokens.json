{
  "color": {
    "graphite": {
      "$value": "#0a0a0a",
      "$type": "color",
      "$description": "Graphite — Dark supporting neutral for text, icons, and strong contrast. Do not promote it to the primary CTA color"
    },
    "pure-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Pure Black — Body text, icon fills, link text, and the darkest border variant — the default ink"
    },
    "carbon": {
      "$value": "#171717",
      "$type": "color",
      "$description": "Carbon — Dark surface for inverted cards, dark-mode preview tiles, and badge backgrounds — sits one step above graphite for subtle dark layering"
    },
    "concrete": {
      "$value": "#737373",
      "$type": "color",
      "$description": "Concrete — Secondary body text, muted labels, placeholder content — the workhorse mid-gray for non-primary copy"
    },
    "ash": {
      "$value": "#a1a1a1",
      "$type": "color",
      "$description": "Ash — Disabled state borders, extremely subtle dividers"
    },
    "smoke": {
      "$value": "#b9b9b9",
      "$type": "color",
      "$description": "Smoke — Soft borders on less-emphasized containers"
    },
    "hairline": {
      "$value": "#e5e5e5",
      "$type": "color",
      "$description": "Hairline — The dominant structural color — every card border, input border, table separator, and nav divider is this exact shade. Frequency 1225 makes it the load-bearing wall of the entire system"
    },
    "mist": {
      "$value": "#f2f2f2",
      "$type": "color",
      "$description": "Mist — Subtle surface fill for tags, ghost button hover, and micro-backgrounds — the lightest gray that still registers as not-white"
    },
    "chalk": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Chalk — Page canvas, card surfaces, button text on dark fills, input backgrounds — the dominant surface at all levels"
    }
  },
  "font": {
    "geist": {
      "$value": "Geist",
      "$type": "fontFamily",
      "$description": "Every text context on the site — body, buttons, icons-as-labels, badges, nav, inputs, cards, headings. Geist is a custom Vercel geometric sans with quiet, slightly squared terminals. Its 1.43 line-height at 14-16px creates a compact utilitarian rhythm; at 48px with weight 600 and -0.05em tracking it becomes the only moment of typographic drama. The tight tracking on larger sizes (-0.05em) is signature — text feels set in concrete, not floating"
    },
    "geist-mono": {
      "$value": "Geist Mono",
      "$type": "fontFamily",
      "$description": "Monospace input fields, code-adjacent text, and technical micro-copy where character width consistency matters. Detected only in input context at 14px"
    }
  },
