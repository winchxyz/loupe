{
  "color": {
    "warm-cream": {
      "$value": "#faf6ef",
      "$type": "color",
      "$description": "Warm Cream — Primary page canvas, card surfaces — warm off-white replaces stark white to soften the photography-first layout and avoid the cold SaaS feel"
    },
    "pure-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Pure White — Image borders, elevated card surfaces, contrast panel behind embedded media"
    },
    "obsidian": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Obsidian — Primary text, hairline borders, icon strokes, navigation typography — the structural anchor of the entire system"
    },
    "pebble": {
      "$value": "#999999",
      "$type": "color",
      "$description": "Pebble — Muted body text, secondary borders, disabled states — the one step above placeholder gray"
    },
    "driftwood": {
      "$value": "#a1a1a1",
      "$type": "color",
      "$description": "Driftwood — Helper text, low-emphasis captions, subtle dividers"
    },
    "mist": {
      "$value": "#d9d9d9",
      "$type": "color",
      "$description": "Mist — Light hairline dividers, nav separators, input borders in resting state"
    },
    "ember-orange": {
      "$value": "#fa5c40",
      "$type": "color",
      "$description": "Ember Orange — Orange wash for highlight backgrounds, decorative bands, and soft emphasis behind content. Do not promote it to the primary CTA color"
    }
  },
  "font": {
    "f37bolton": {
      "$value": "F37Bolton",
      "$type": "fontFamily",
      "$description": "Sole typeface across the entire system. Custom geometric sans with tight aperture and industrial DNA. Weight 400 for body, 700 only for display headlines and the wordmark. Tracking runs -0.05em at display sizes down to -0.03em at body, giving headlines a compressed editorial feel and body text a quiet, compact rhythm"
    }
  },
