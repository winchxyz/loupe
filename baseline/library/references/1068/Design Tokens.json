{
  "color": {
    "obsidian": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Obsidian — Primary page canvas, nav background, terminal preview windows — the void that every other surface floats on"
    },
    "graphite": {
      "$value": "#121212",
      "$type": "color",
      "$description": "Graphite — Secondary page surface, body backgrounds behind hero sections, footer base"
    },
    "onyx": {
      "$value": "#1e1e1d",
      "$type": "color",
      "$description": "Onyx — Elevated card and panel surfaces — first step up from the canvas for product cards and testimonials"
    },
    "carbon": {
      "$value": "#333333",
      "$type": "color",
      "$description": "Carbon — Mid-level surface for nested UI, secondary buttons, and tag/badge backgrounds"
    },
    "slate-deep": {
      "$value": "#40403f",
      "$type": "color",
      "$description": "Slate Deep — Highest neutral surface — hover states, elevated modals, and pill chip backgrounds"
    },
    "bone": {
      "$value": "#faf9f6",
      "$type": "color",
      "$description": "Bone — Primary text and headline color — warm off-white avoids the clinical feel of pure white on black"
    },
    "paper": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper — Light supporting surface for subtle backgrounds and section separation. Do not promote it to the primary CTA color"
    },
    "ash-light": {
      "$value": "#e3e2e0",
      "$type": "color",
      "$description": "Ash Light — Secondary heading text, soft dividers, subtle borders on elevated cards"
    },
    "ash-mid": {
      "$value": "#b4b4b2",
      "$type": "color",
      "$description": "Ash Mid — Body copy, secondary text, button text on dark fills, muted descriptions"
    },
    "ash": {
      "$value": "#868684",
      "$type": "color",
      "$description": "Ash — Tertiary text, captions, nav links at rest, metadata, timestamps"
    },
    "ash-mute": {
      "$value": "#a0a0a0",
      "$type": "color",
      "$description": "Ash Mute — Sub-heading emphasis, medium-muted text where Ash feels too dim"
    },
    "iron": {
      "$value": "#666469",
      "$type": "color",
      "$description": "Iron — Lowest-priority text, disabled labels, nav metadata"
    },
    "ink": {
      "$value": "#080808",
      "$type": "color",
      "$description": "Ink — Near-black for fine borders, deep text on light fills, separator strokes"
    },
    "phosphor-violet": {
      "$value": "#cbb0f7",
      "$type": "color",
      "$description": "Phosphor Violet — The only chromatic color in the system — decorative icon strokes, code accents, product mark highlights, and subtle borders. Never used for filled CTAs; it is a whisper, not a shout"
    }
  },
  "font": {
    "matter-regular": {
      "$value": "Matter Regular",
      "$type": "fontFamily",
      "$description": "Matter Regular — detected in extracted data but not described by AI"
    },
    "matter": {
      "$value": "Matter",
      "$type": "fontFamily",
      "$description": "Primary display and UI typeface — a custom geometric sans with engineered proportions. Weight 400 carries body and nav, 600–700 escalates to subheadings and emphasis. Extreme negative tracking at large sizes (-0.04em at 56px) tightens headlines into a single visual mass. Free substitute: Inter or General Sans"
    },
    "geist-mono": {
      "$value": "Geist Mono",
      "$type": "fontFamily",
      "$description": "Monospace for code snippets, terminal output, and technical micro-copy inside buttons and tags. Free substitute: JetBrains Mono or IBM Plex Mono"
    },
    "matter-mono": {
      "$value": "Matter Mono",
      "$type": "fontFamily",
      "$description": "Companion monospace for inline code and signature terminal callouts — ties back to the primary type family visually. Free substitute: Berkeley Mono or IBM Plex Mono"
    },
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "Secondary body fallback for long-form content blocks, testimonial quotes, and support copy where Matter may not load. Tight tracking (-0.012 to -0.014em) matches Matter's geometric feel"
    },
    "system-ui-sans-serif": {
      "$value": "system-ui sans-serif",
      "$type": "fontFamily",
      "$description": "Ultra-small UI labels (icon captions, footer micro-text) where system rendering is acceptable and loading a web font is wasteful"
    }
  },
