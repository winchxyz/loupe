{
  "color": {
    "paper-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper White — Page canvas, card surfaces, image borders, nav backgrounds — the only surface tone in the system"
    },
    "ink-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Ink Black — Primary text, all border outlines on images and nav, list markers — the sole chromatic anchor"
    }
  },
  "font": {
    "title": {
      "$value": "title",
      "$type": "fontFamily",
      "$description": "Display serif used exclusively for the brand title and hero headlines. The custom serif — with its high contrast strokes and slightly condensed forms — carries all brand identity. Letter-spacing of -0.018em tightens the large caps just enough to feel deliberate without becoming stiff. A close substitute would be a transitional or didone-style serif like 'GT Sectra Display' or free options 'Playfair Display' / 'DM Serif Display'"
    },
    "neue-haas-grotesk-display": {
      "$value": "neue-haas-grotesk-display",
      "$type": "fontFamily",
      "$description": "All UI, navigation, captions, metadata, and body-adjacent text. Geometric grotesque at a single weight (400) — the system deliberately avoids bold/light contrast, using size and placement to create hierarchy instead. Use 'Inter' or 'Neue Haas Grotesk' itself (free via Adobe) as substitutes"
    }
  },
