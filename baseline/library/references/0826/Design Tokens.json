  "font": {
    "sf-pro-text": {
      "$value": "SF Pro Text",
      "$type": "fontFamily",
      "$description": "Button labels, navigation items, tab labels, in-card headings. Always semibold — Apple buttons are never bold, they are confident semibold."
    },
    "sf-pro-display": {
      "$value": "SF Pro Display",
      "$type": "fontFamily",
      "$description": "All display and heading type — product page hero headlines (80–160px), section headings (40–56px), nav labels and eyebrow text (21–28px). Weight 600 for hero and key headlines, 400 for sub-headings. Aggressive negative letter-spacing tightens the visual density even at extreme sizes: -0.040em at 160px, -0.015em at 40–48px, near-zero at 21px. The signature choice: 160px headlines at weight 600 with -6.4px tracking are architectural, not decorative."
    },
    "arial": {
