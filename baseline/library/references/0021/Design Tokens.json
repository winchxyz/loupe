{
  "color": {
    "pure-canvas": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Pure Canvas — Page background, card surface, image mask — the baseline white everything else sits on"
    },
    "bone": {
      "$value": "#f5f5f4",
      "$type": "color",
      "$description": "Bone — Alternate section background, subtle warm-off-white band between content blocks"
    },
    "mist": {
      "$value": "#edeeee",
      "$type": "color",
      "$description": "Mist — Nav and section fills that need a barely-there elevation above canvas"
    },
    "silk-border": {
      "$value": "#e5e5e5",
      "$type": "color",
      "$description": "Silk Border — Hairline card and divider borders — defines surfaces without painting them"
    },
    "quill": {
      "$value": "#d4d4d4",
      "$type": "color",
      "$description": "Quill — Link and secondary border treatment, lighter dividers inside dense blocks"
    },
    "ash": {
      "$value": "#a1a1a1",
      "$type": "color",
      "$description": "Ash — Muted helper text, disabled labels, low-emphasis icon strokes"
    },
    "pebble": {
      "$value": "#737373",
      "$type": "color",
      "$description": "Pebble — Body text and default neutral borders — the workhorse mid-gray"
    },
    "slate": {
      "$value": "#525252",
      "$type": "color",
      "$description": "Slate — Secondary text, button borders in outlined controls, sub-label icons"
    },
    "graphite": {
      "$value": "#404040",
      "$type": "color",
      "$description": "Graphite — Nav text, stronger body text for emphasis without going to black"
    },
    "iron": {
      "$value": "#333333",
      "$type": "color",
      "$description": "Iron — Link text in dark contexts, strong card borders on featured surfaces"
    },
    "charcoal": {
      "$value": "#262626",
      "$type": "color",
      "$description": "Charcoal — Primary text and dark button fills — the near-black that keeps contrast warm"
    },
    "midnight": {
      "$value": "#171717",
      "$type": "color",
      "$description": "Midnight — Display text, deepest heading weight, high-contrast inverse text"
    },
    "signal-blue": {
      "$value": "#397dff",
      "$type": "color",
      "$description": "Signal Blue — Violet action color for filled buttons, selected navigation states, and focused conversion moments."
    },
    "ember-stroke": {
      "$value": "#f55c15",
      "$type": "color",
      "$description": "Ember Stroke — Decorative borders, badge outlines, icon accents — warm orange that warms the cool white canvas without competing with Signal Blue"
    },
    "alarm-red": {
      "$value": "#ff0000",
      "$type": "color",
      "$description": "Alarm Red — Red outline accent for tags, dividers, and focused UI edges. Use as a supporting accent, not as a status color"
    }
  },
  "font": {
    "tiempos-headline": {
      "$value": "Tiempos Headline",
      "$type": "fontFamily",
      "$description": "All display and heading copy — headlines, hero statements, section titles, large numbers. The single weight 300 is a deliberate anti-convention: instead of bold, Tiempos whispers, and the editorial serif does the work of authority through restraint rather than volume."
    },
    "selecta": {
      "$value": "Selecta",
      "$type": "fontFamily",
      "$description": "All UI, body, navigation, button, badge, and caption text. Weight 400 is the body default, 500 for emphasized UI labels and nav items. The slightly open tracking (+0.025em) on small sizes gives the interface an airy, legible quality that pairs against the dense serif headlines."
    }
  },
