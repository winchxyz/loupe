{
  "color": {
    "ice-cyan": {
      "$value": "#d7f3f5",
      "$type": "color",
      "$description": "Ice Cyan — All foreground text, underlined link strokes, hairline borders, and the full-bleed inverted surface at the page foot — the only chromatic element in the system, used to make every readable word and every interactive affordance feel like it shares one voice"
    },
    "void": {
      "$value": "#020203",
      "$type": "color",
      "$description": "Void — Page background and deepest canvas layer — near-pure black with a barely-perceptible cool tint that makes Ice Cyan read slightly blue"
    },
    "carbon": {
      "$value": "#111314",
      "$type": "color",
      "$description": "Carbon — Elevated card surface, section backdrop, and subtle horizontal divider band — one step lighter than Void to lift project cards and content blocks without breaking the dark mood"
    }
  },
