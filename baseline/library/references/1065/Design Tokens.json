{
  "color": {
    "void": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Void — Page background, hero canvas, deepest surface — the default everywhere; nothing sits on top of it, everything floats within it"
    },
    "obsidian": {
      "$value": "#080808",
      "$type": "color",
      "$description": "Obsidian — Sub-surface for cards and panels directly on the canvas — barely lighter than Void, so elevation is felt rather than seen"
    },
    "graphite": {
      "$value": "#171717",
      "$type": "color",
      "$description": "Graphite — Elevated card surface, modal backgrounds, project tile frames — the most clearly distinct card layer above the canvas"
    },
    "carbon": {
      "$value": "#222222",
      "$type": "color",
      "$description": "Carbon — Higher-elevation panels, inset wells, code blocks — a step up from Graphite for content that needs to feel enclosed"
    },
    "iron": {
      "$value": "#2b2b2b",
      "$type": "color",
      "$description": "Iron — Top-tier surface for floating elements, sticky bars, or hover-states on dark cards"
    },
    "snow": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Snow — Light supporting surface for subtle backgrounds and section separation. Do not promote it to the primary CTA color"
    },
    "ash": {
      "$value": "#999999",
      "$type": "color",
      "$description": "Ash — Body text, secondary descriptions, subdued copy — the workhorse gray for everything that isn't a heading"
    },
    "smoke": {
      "$value": "#a6a6a6",
      "$type": "color",
      "$description": "Smoke — Lighter secondary text, metadata, timestamps — slightly brighter than Ash for hierarchy within muted copy"
    },
    "pearl": {
      "$value": "#cccccc",
      "$type": "color",
      "$description": "Pearl — High-emphasis muted text, captions on light surfaces, disabled labels that still need to read"
    },
    "slate": {
      "$value": "#666666",
      "$type": "color",
      "$description": "Slate — De-emphasized text, tertiary metadata, placeholder content, icon strokes on dark surfaces"
    },
    "steel": {
      "$value": "#8c8c8c",
      "$type": "color",
      "$description": "Steel — Mid-muted text and borders, divider lines on dark backgrounds where #333333 would be invisible"
    },
    "electric-signal": {
      "$value": "#0099ff",
      "$type": "color",
      "$description": "Electric Signal — Blue supporting accent for decorative details and low-frequency emphasis."
    }
  },
  "font": {
    "sans-serif": {
      "$value": "sans-serif",
      "$type": "fontFamily",
      "$description": "sans-serif — detected in extracted data but not described by AI"
    },
    "gt-walsheim-framer-medium": {
      "$value": "GT Walsheim Framer Medium",
      "$type": "fontFamily",
      "$description": "Hero display headline — used only for the single biggest statement on the page; the 0.85 line-height and -0.05em tracking make letters nearly touch, creating a block-like sculptural headline that dominates the viewport"
    },
    "gt-walsheim-medium": {
      "$value": "GT Walsheim Medium",
      "$type": "fontFamily",
      "$description": "Section display and large headings — medium weight (not bold) keeps the type feeling architectural rather than aggressive; same -0.05em tracking carries the display voice into 85px and 62px section openers"
    },
    "mona-sans": {
      "$value": "Mona Sans",
      "$type": "fontFamily",
      "$description": "Secondary headlines, subtitles, and mid-weight UI text — the bridge between monumental display and compact body; 62px use creates variety in section headers"
    },
    "inter-variable": {
      "$value": "Inter Variable",
      "$type": "fontFamily",
      "$description": "Body copy and feature descriptions — extensive character variant features (cv01–cv11) and stylistic sets (ss02, ss03, ss07) tune letterforms for the brand's geometric, slightly squared personality"
    },
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "UI chrome — nav items, button labels, tag text, form fields, meta labels; tabular numerals (tnum) enabled for numeric data consistency"
    },
    "open-runde": {
      "$value": "Open Runde",
      "$type": "fontFamily",
      "$description": "Micro labels, eyebrow text, small caps-style category tags — the only 600-weight in the system, used at 9px to create distinctive all-caps section markers above headlines"
    }
  },
