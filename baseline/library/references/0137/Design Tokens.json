{
  "color": {
    "charcoal": {
      "$value": "#080808",
      "$type": "color",
      "$description": "Charcoal — Primary headings, high-emphasis text — the deepest ink against the warm white canvas, anchoring headlines at maximum contrast"
    },
    "graphite": {
      "$value": "#222222",
      "$type": "color",
      "$description": "Graphite — Body text, icon strokes, secondary headings — slightly lighter than Charcoal for body density where pure black feels too heavy"
    },
    "mid-ink": {
      "$value": "#292929",
      "$type": "color",
      "$description": "Mid Ink — Filled button background, dark UI surfaces, strong border emphasis — the primary action surface; charcoal-darker than body text for weight contrast against pills"
    },
    "steel": {
      "$value": "#696969",
      "$type": "color",
      "$description": "Steel — Default border color, card edges, icon strokes at rest — the structural hairline that carries the entire layout; appears in 260 borderColor uses, making it the most-used stroke in the system"
    },
    "fog": {
      "$value": "#999999",
      "$type": "color",
      "$description": "Fog — Muted secondary borders, low-emphasis dividers — a lighter hairline for de-emphasized structure"
    },
    "ash": {
      "$value": "#b2b2b2",
      "$type": "color",
      "$description": "Ash — Card inner borders, subtle dividers inside containers — softer than Steel for nested elements"
    },
    "slate": {
      "$value": "#8d8d8d",
      "$type": "color",
      "$description": "Slate — Disabled or inactive border state, decorative dividers — sits between Steel and Fog for tertiary structural lines"
    },
    "mist": {
      "$value": "#cccccc",
      "$type": "color",
      "$description": "Mist — Subtle shadow contribution, light card shadow base — a desaturated mid-gray for soft elevation"
    },
    "silk": {
      "$value": "#e4e4e7",
      "$type": "color",
      "$description": "Silk — Image borders, body content dividers, light surface separators — the lightest visible structural line, near-white with just enough definition"
    },
    "bone": {
      "$value": "#fafafa",
      "$type": "color",
      "$description": "Bone — Page canvas, card surfaces, link border, light text on dark — the warm white foundation; every other neutral reads against this base"
    },
    "cream": {
      "$value": "#f4f4f5",
      "$type": "color",
      "$description": "Cream — Secondary button fill, elevated surface tone, subtle hover state — one step warmer/lighter than Bone for nested surfaces"
    }
  },
  "font": {
    "aspekta": {
      "$value": "Aspekta",
      "$type": "fontFamily",
      "$description": "All UI text — headlines at 40-56px use weight 400 with aggressive negative tracking (-0.035em to -0.020em) to create a condensed, modern feel; body text at 16-18px uses weight 400 with lighter tracking (-0.011em to -0.010em); weight 500 reserved for button labels and emphasis. The tight letter-spacing at display sizes is signature — it pulls letters together so headlines read as confident blocks rather than airy sentences."
    },
    "fasthand": {
      "$value": "Fasthand",
      "$type": "fontFamily",
      "$description": "Handwritten accent for emotional kickers and signatures — the 'Listen!' above the hero headline, the 'Open Letter' section intro. One weight, one size, used at most once per section. This is the human voice in an otherwise architectural system; it appears only where the brand needs warmth over precision."
    },
    "aspekta-500": {
      "$value": "Aspekta 500",
      "$type": "fontFamily",
      "$description": "Aspekta 500 — detected in extracted data but not described by AI"
    }
  },
