{
  "color": {
    "ember-orange": {
      "$value": "#f15730",
      "$type": "color",
      "$description": "Ember Orange — Filled CTA buttons, primary action backgrounds — deep saturated orange that reads as confident rather than playful, the only color with enough chroma to anchor a click target against the white field"
    },
    "tangerine-blaze": {
      "$value": "#f7651a",
      "$type": "color",
      "$description": "Tangerine Blaze — Promotional surface fills (email capture modal, featured product cards, stat callout backgrounds) — slightly brighter and more luminous than Ember, used where orange must own an entire region of the layout"
    },
    "apricot-whisper": {
      "$value": "#ff8562",
      "$type": "color",
      "$description": "Apricot Whisper — Borders on outlined cards, link underlines, icon strokes, accent hairlines — the lightest orange, functioning as a warm-tinted structural color rather than a fill"
    },
    "graphite-black": {
      "$value": "#111111",
      "$type": "color",
      "$description": "Graphite Black — Body text, default borders, the dominant structural color — a true near-black, not warm, used for the bulk of hairline rules and paragraph copy"
    },
    "inkwell": {
      "$value": "#0d1717",
      "$type": "color",
      "$description": "Inkwell — Heading text, navigation text, primary headings — a deep black with the faintest cool-green undertone that gives headlines a quiet cast against pure white"
    },
    "pure-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Pure White — Page canvas, card surfaces, text on dark/orange surfaces — the unchanging ground tone across every section"
    },
    "mist-gray": {
      "$value": "#eeeeee",
      "$type": "color",
      "$description": "Mist Gray — Soft card borders, hairline dividers on white surfaces where Graphite would feel too heavy"
    },
    "smoke": {
      "$value": "#818181",
      "$type": "color",
      "$description": "Smoke — Secondary captions, muted helper text, subdued icon strokes — the only mid-gray in the palette, used sparingly to fade metadata without going fully light"
    }
  },
  "font": {
    "onest": {
      "$value": "Onest",
      "$type": "fontFamily",
      "$description": "Sole brand typeface. The 200-300 weights at display sizes (48-152px) define the editorial couture voice — thin strokes hung on a white wall with aggressive negative letter-spacing. Weights 400-500 handle body and UI; 600-800 reserved for occasional emphasis. Substantial negative letter-spacing contracts large text to the width of small, producing the 'cut from a single line' effect. Substitute with Inter or General Sans if Onest is unavailable."
    },
    "times": {
      "$value": "Times",
      "$type": "fontFamily",
      "$description": "Times — detected in extracted data but not described by AI"
    },
    "arial": {
      "$value": "Arial",
      "$type": "fontFamily",
      "$description": "Arial — detected in extracted data but not described by AI"
    }
  },
