{
  "color": {
    "void": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Void — Page background, all structural borders, primary text on light surfaces — the absolute black that makes the dashed containment lines read as ink on paper"
    },
    "carbon": {
      "$value": "#1c1c1c",
      "$type": "color",
      "$description": "Carbon — Elevated surface — card backgrounds, section fills, the canvas where the hero spotlight lands; lifted one step from Void but barely"
    },
    "graphite": {
      "$value": "#4d4d4d",
      "$type": "color",
      "$description": "Graphite — Tertiary borders and disabled outlines, dividers in dense lists"
    },
    "steel": {
      "$value": "#808080",
      "$type": "color",
      "$description": "Steel — Body text secondary, metadata labels, muted borders, checkbox/divider lines on dark"
    },
    "ash": {
      "$value": "#ababab",
      "$type": "color",
      "$description": "Ash — Helper text, caption-level metadata, tertiary text on dark surfaces"
    },
    "paper": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper — Primary text, logo mark, active nav text, button borders, eyebrow chips — the one bright stroke against the void"
    },
    "periwinkle-annotation": {
      "$value": "#7089ba",
      "$type": "color",
      "$description": "Periwinkle Annotation — Decorative icon fills, data-node accents, subtle highlight washes on feature illustrations, checkmark accents — the only chromatic mark in the system, rationed to annotation roles"
    }
  },
  "font": {
    "sans-serif": {
      "$value": "sans-serif",
      "$type": "fontFamily",
      "$description": "sans-serif — detected in extracted data but not described by AI"
    },
    "raveo-variable": {
      "$value": "Raveo Variable",
      "$type": "fontFamily",
      "$description": "Primary face for all display, heading, body, and nav text. Weight 1000 at 70px is the signature display; weight 500 for subheadings; weight 400 for body. The 1000 weight is the system's defining move — a single blocky headline silhouette against the void does more work than any color or shadow could."
    },
    "geist-mono": {
      "$value": "Geist Mono",
      "$type": "fontFamily",
      "$description": "Eyebrow chips, version tags (\"NEW · INDEX 2.0 EARLY PREVIEW\"), step labels, and all-caps micro-labels. Sets a technical/code-adjacent tone that reinforces the blueprint metaphor. Tracked +0.02em for legibility at small sizes."
    }
  },
