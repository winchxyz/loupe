  "font": {
    "glyph": {
      "$value": "Glyph",
      "$type": "fontFamily",
      "$description": "Primary UI and body typeface — a custom humanist sans with wider proportions and more open apertures than matter. Weight 400 for body, nav, buttons, labels; 700 for emphasis and subheadings. The 1.45 line-height is generous for reading comfort at 16px body size."
    },
    "matter": {
      "$value": "matter",
      "$type": "fontFamily",
      "$description": "Display and heading typeface — a custom geometric grotesque with a slight humanist warmth. Weight 670 (between bold and black) gives headlines visual weight without becoming heavy; the -0.0100em tracking and tight 1.09 line-height create a compressed, editorial feel. Used for h1–h3 and large stat numbers."
    },
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "Secondary body in card contexts — appears in product UI cards and embedded components"
    },
    "arial": {
      "$value": "Arial",
      "$type": "fontFamily",
      "$description": "Arial — detected in extracted data but not described by AI"
    },
    "sans-serif": {
