{
  "color": {
    "pulse-violet": {
      "$value": "#4a53ff",
      "$type": "color",
      "$description": "Pulse Violet — Violet supporting accent for decorative details and low-frequency emphasis. Do not promote it to the primary CTA color"
    },
    "obsidian": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Obsidian — Primary text on light surfaces, dark hero/section backgrounds, filled neutral buttons, icon strokes"
    },
    "carbon": {
      "$value": "#191919",
      "$type": "color",
      "$description": "Carbon — Secondary dark surface (footer band, alternating black sections), heading text on light surfaces"
    },
    "paper-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper White — Primary page canvas, card surfaces on dark sections, text on dark backgrounds, filled white pill buttons"
    },
    "lab-mist": {
      "$value": "#f3f5f9",
      "$type": "color",
      "$description": "Lab Mist — Soft elevated surface for light cards and feature panels — a cool off-white that distinguishes cards from the page without using shadow"
    },
    "hairline": {
      "$value": "#e5e7eb",
      "$type": "color",
      "$description": "Hairline — Borders, dividers, outlined button strokes, input frames — the most-used neutral in the system (2560 occurrences)"
    },
    "fog-gray": {
      "$value": "#808080",
      "$type": "color",
      "$description": "Fog Gray — Muted body text, secondary descriptions, placeholder copy on light surfaces"
    },
    "ash": {
      "$value": "#999999",
      "$type": "color",
      "$description": "Ash — Tertiary text, inactive button labels, disabled icon strokes — sits one step below Fog Gray for de-emphasized metadata"
    }
  },
  "font": {
    "proxima-nova": {
      "$value": "Proxima Nova",
      "$type": "fontFamily",
      "$description": "Single-family system covering everything from 14px captions to 120px display headlines. The aggressive letter-spacing compression at display sizes (-4.8px at 120px) is signature — it makes oversized headlines feel carved rather than stacked. Proxima Nova's geometric warmth keeps the clinical data aesthetic from feeling cold."
    }
  },
