{
  "color": {
    "electric-violet": {
      "$value": "#8800ff",
      "$type": "color",
      "$description": "Electric Violet — Headline accents, decorative strokes, feature callouts — vivid violet against the white canvas makes typographic moments feel electric and editorial rather than corporate"
    },
    "deep-violet": {
      "$value": "#2c0fb1",
      "$type": "color",
      "$description": "Deep Violet — Secondary violet accent, decorative borders and outlines paired with the primary violet for layered brand moments"
    },
    "ember-orange": {
      "$value": "#ff5000",
      "$type": "color",
      "$description": "Ember Orange — Orange supporting accent for decorative details and low-frequency emphasis. Do not promote it to the primary CTA color"
    },
    "burnt-orange": {
      "$value": "#ec520b",
      "$type": "color",
      "$description": "Burnt Orange — Orange supporting accent for decorative details and low-frequency emphasis. Do not promote it to the primary CTA color"
    },
    "signal-yellow": {
      "$value": "#ffcc00",
      "$type": "color",
      "$description": "Signal Yellow — Decorative full-bleed accent bands and section dividers — appears in few places but dominates attention where it does"
    },
    "cobalt-blue": {
      "$value": "#1551ff",
      "$type": "color",
      "$description": "Cobalt Blue — Supporting palette color for small decorative accents when the core palette needs contrast. Do not promote it to the primary CTA color"
    },
    "ink-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Ink Black — Pure black for solid feature card backgrounds and the strongest typographic moments — makes colored cards feel printed, not screen-painted"
    },
    "graphite": {
      "$value": "#282828",
      "$type": "color",
      "$description": "Graphite — Primary text color for body copy, links, and most UI text — the workhorse near-black that keeps reading comfortable without going full contrast"
    },
    "carbon": {
      "$value": "#141414",
      "$type": "color",
      "$description": "Carbon — Slightly deeper text tone used in specific body and border contexts for a richer near-black"
    },
    "near-black": {
      "$value": "#0f0e0e",
      "$type": "color",
      "$description": "Near Black — Heading text color — pushed darker than body for stronger hierarchy against the white canvas"
    },
    "paper-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper White — Light supporting surface for subtle backgrounds and section separation. Do not promote it to the primary CTA color"
    },
    "fog-gray": {
      "$value": "#f4f4f4",
      "$type": "color",
      "$description": "Fog Gray — Subtle surface elevation for inputs, inactive controls, and the softest card backgrounds"
    },
    "mist-gray": {
      "$value": "#e7e7e7",
      "$type": "color",
      "$description": "Mist Gray — Hairline borders, dividers, placeholder fills — the minimum-contrast separator"
    },
    "steel-gray": {
      "$value": "#808080",
      "$type": "color",
      "$description": "Steel Gray — Muted helper text, icon stroke, and secondary metadata — sits between body text and true gray for ambient labels"
    }
  },
  "font": {
    "apple-system": {
      "$value": "-apple-system",
      "$type": "fontFamily",
      "$description": "-apple-system — detected in extracted data but not described by AI"
    },
    "readymag-display-custom": {
      "$value": "Readymag Display (custom)",
      "$type": "fontFamily",
      "$description": "Headlines, display copy, and large feature titles. The signature choice: a geometric sans pushed to 80px with -0.067em tracking, which makes letters visually touch and creates a tightly-set editorial title block. The 0.88 line-height on the 16px bold variant ('xgnl') is anti-conventional and creates stacked, compressed display moments in feature panels. Use for anything that needs to feel like magazine cover type."
    },
    "graphik": {
      "$value": "Graphik",
      "$type": "fontFamily",
      "$description": "Secondary body and link face for utilitarian contexts where the system stack would feel too generic but full display weight would be wasteful. Its near-zero tracking keeps body paragraphs tight and modern."
    },
    "system-ui": {
      "$value": "System UI",
      "$type": "fontFamily",
      "$description": "Default body and UI text fallback — quietly supports the custom faces rather than competing. Tiny negative tracking (-0.006em) keeps it from feeling like a default browser font."
    },
    "custom37866": {
      "$value": "custom_37866",
      "$type": "fontFamily",
      "$description": "custom_37866 — detected in extracted data but not described by AI"
    },
    "xgnl": {
