      "$value": "#d3dfeb",
      "$type": "color",
      "$description": "Glacier Tint — Hero photograph cool wash, decorative ice-blue accent — appears only as a near-gray atmospheric tint, not a saturated brand color"
    }
  },
  "font": {
    "almarai": {
      "$value": "Almarai",
      "$type": "fontFamily",
      "$description": "Display and heading — the only font that carries headlines. Weight 300 is anti-convention: most enterprise brands use 600-700 for authority, Almarai Light achieves authority through restraint. Combined with -0.02em tracking it reads like editorial print, not SaaS. Originated as an Arabic typeface, its Latin glyphs have a distinctive humanist geometry that no system font replicates exactly."
    },
    "abc-diatype": {
      "$value": "ABC Diatype",
      "$type": "fontFamily",
      "$description": "Body and running text. The workhorse — paragraphs, descriptions, card content. Neutral humanist sans that steps back to let the Almarai headlines lead."
    },
    "abc-diatype-semi-mono": {
      "$value": "ABC Diatype Semi-Mono",
      "$type": "fontFamily",
      "$description": "Technical labels, nav items, tag text, links, caption-style metadata. The monospaced variant of Diatype gives the UI a quiet engineering voice — used to mark functional elements that should read as system, not editorial."
    },
    "system-sans-serif": {
      "$value": "System sans-serif",
      "$type": "fontFamily",
      "$description": "Smallest utility text, browser-default contexts, fallback"
    }
  },
