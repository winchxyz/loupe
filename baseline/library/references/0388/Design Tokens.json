{
  "color": {
    "parchment": {
      "$value": "#faf9f7",
      "$type": "color",
      "$description": "Parchment — Page canvas — the warm off-white that defines the entire experience; never substitute pure #ffffff at the body level"
    },
    "paper": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper — Card surfaces, code blocks, and inset panels sitting on Parchment"
    },
    "mist": {
      "$value": "#f1efef",
      "$type": "color",
      "$description": "Mist — Subtle secondary surface — hover states on tag pills, tinted code snippet backgrounds, gentle section differentiation without borders"
    },
    "stone-200": {
      "$value": "#e7e5e4",
      "$type": "color",
      "$description": "Stone-200 — Default hairline border — button outlines, card edges, input borders"
    },
    "stone-300": {
      "$value": "#d6d3d1",
      "$type": "color",
      "$description": "Stone-300 — Stronger dividers and hover-borders where more separation is needed"
    },
    "stone-400": {
      "$value": "#a8a29e",
      "$type": "color",
      "$description": "Stone-400 — Muted helper text, disabled labels, icon stroke at rest"
    },
    "stone-500": {
      "$value": "#78716c",
      "$type": "color",
      "$description": "Stone-500 — Secondary text, timestamps, breadcrumb trails"
    },
    "stone-600": {
      "$value": "#57534e",
      "$type": "color",
      "$description": "Stone-600 — Link text at rest, nav labels, mid-priority body text"
    },
    "stone-700": {
      "$value": "#44403c",
      "$type": "color",
      "$description": "Stone-700 — High-emphasis body text, button text on light surfaces"
    },
    "warm-ink": {
      "$value": "#1c1917",
      "$type": "color",
      "$description": "Warm Ink — Primary headings and filled button background — the near-black with a warm cast that harmonizes with Parchment; use instead of #000 for all text and CTA fills"
    },
    "charcoal": {
      "$value": "#292524",
      "$type": "color",
      "$description": "Charcoal — Deep border tone for card hairlines and inset shadows on elevated elements"
    },
    "ember": {
      "$value": "#f97316",
      "$type": "color",
      "$description": "Ember — Orange decorative accent for icons, marks, and small graphic details"
    }
  },
  "font": {
    "sans-serif": {
      "$value": "sans-serif",
      "$type": "fontFamily",
      "$description": "sans-serif — detected in extracted data but not described by AI"
    },
    "newsreader": {
      "$value": "Newsreader",
      "$type": "fontFamily",
      "$description": "Display and headings — a transitional serif with optical sizing. At 80px it carries the hero with -0.04em tracking; at 34px it subtitles feature sections; at 28px it titles cards. This is the signature choice: an editorial serif in a product UI breaks the SaaS sans-serif monotony and signals craft."
    },
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "Body, UI controls, labels, and links. The default voice for everything that isn't a display headline. 450 is used for slightly heavier body emphasis; 500–600 for button text and nav."
    },
    "ui-monospace": {
      "$value": "ui-monospace",
      "$type": "fontFamily",
      "$description": "Code blocks, API endpoints, JSON payloads, and the inline code chip. System monospace keeps the engineering texture without importing a web font."
    },
    "ui-sans-serif": {
      "$value": "ui-sans-serif",
      "$type": "fontFamily",
      "$description": "ui-sans-serif — detected in extracted data but not described by AI"
