{
  "color": {
    "obsidian": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Obsidian — Primary page background, hero canvas, image void — the default stage everything sits on"
    },
    "midnight": {
      "$value": "#0b0f15",
      "$type": "color",
      "$description": "Midnight — Hero ambient and large image containers — a near-black with the faintest blue undertone that keeps the void from looking flat"
    },
    "charcoal": {
      "$value": "#171717",
      "$type": "color",
      "$description": "Charcoal — Elevated card surfaces, hover state for ghost buttons, secondary panels that need to lift off Obsidian"
    },
    "graphite": {
      "$value": "#262626",
      "$type": "color",
      "$description": "Graphite — Supporting neutral for secondary UI, dividers, and muted labels. Do not promote it to the primary CTA color"
    },
    "iron": {
      "$value": "#404040",
      "$type": "color",
      "$description": "Iron — Muted body text, inactive icon strokes, decorative dividers in dense blocks"
    },
    "slate": {
      "$value": "#525252",
      "$type": "color",
      "$description": "Slate — Secondary supporting text, caption-level annotations, tertiary iconography"
    },
    "ash": {
      "$value": "#737373",
      "$type": "color",
      "$description": "Ash — Tertiary text, helper copy, less-prominent metadata"
    },
    "fog": {
      "$value": "#a3a3a3",
      "$type": "color",
      "$description": "Fog — Secondary body text and sub-labels that still need readability over dark surfaces"
    },
    "pearl": {
      "$value": "#d4d4d5",
      "$type": "color",
      "$description": "Pearl — Hairline borders, subtle stroke dividers, ghost button outlines"
    },
    "mist": {
      "$value": "#e5e5e5",
      "$type": "color",
      "$description": "Mist — Light divider lines on dark surfaces where higher contrast isn't needed"
    },
    "cloud": {
      "$value": "#f5f5f5",
      "$type": "color",
      "$description": "Cloud — Light surface reserved for inverted sections or content blocks that demand brightness"
    },
    "pure-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Pure White — Light supporting surface for subtle backgrounds and section separation. Do not promote it to the primary CTA color"
    }
  },
  "font": {
    "suisse-intl": {
      "$value": "Suisse Intl",
      "$type": "fontFamily",
      "$description": "The only typeface in the system. Used for every interface element: nav, body, buttons, hero, pricing, footer. Display weights 500–600 at 48–96px with aggressive -0.025em tracking create the compressed, cinematic headline feel; the unusual 450 weight handles editorial body emphasis without crossing into semibold territory."
    }
  },
