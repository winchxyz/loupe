{
  "color": {
    "mint-canvas": {
      "$value": "#b7ffb4",
      "$type": "color",
      "$description": "Mint Canvas — Page background, card surfaces — the signature pastel that makes dark type appear sunlit rather than printed"
    },
    "lime-spark": {
      "$value": "#00ff00",
      "$type": "color",
      "$description": "Lime Spark — Decorative typographic flourishes and SVG scribble overlays — a raw signal-green that contrasts the pastel canvas without warming it"
    },
    "carbon-ink": {
      "$value": "#262626",
      "$type": "color",
      "$description": "Carbon Ink — Primary text, borders, icon strokes, button outlines — softer than pure black, sits on mint without vibrating"
    },
    "obsidian": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Obsidian — Display-type fills at the largest sizes, pure-black SVG fills for the heaviest display specimens"
    },
    "fog": {
      "$value": "#999999",
      "$type": "color",
      "$description": "Fog — Muted helper text, inactive borders, disabled controls — the quietest readable neutral on the mint canvas"
    },
    "smoke": {
      "$value": "#767676",
      "$type": "color",
      "$description": "Smoke — Input field borders in resting state — darker than fog to signal interactivity without competing with the canvas"
    },
    "bone": {
      "$value": "#efefef",
      "$type": "color",
      "$description": "Bone — Light surface for elevated UI bits (button hover, inverted controls) — provides a near-white counterpoint when the canvas needs to recede"
    },
    "paper": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper — Input field interior, pure-white text on dark inverted moments"
    },
    "aurora-gradient": {
      "$value": "#ffa3b6",
      "$type": "color",
      "$description": "Aurora Gradient — Supporting palette color for small decorative accents when the core palette needs contrast. Do not promote it to the primary CTA color"
    }
  },
  "font": {
    "nan-holo-mono": {
      "$value": "NaN Holo Mono",
      "$type": "fontFamily",
      "$description": "All interface chrome — navigation, labels, buttons, form controls, metadata, keyboard hints. Set uppercase with +0.075em tracking, the letter-spacing is the signature that makes mono read as a deliberate UI system rather than terminal output. The weight range lets it flex from thin nav links to heavy button text without leaving the family."
    },
    "nan-holo": {
      "$value": "NaN Holo",
      "$type": "fontFamily",
      "$description": "Prose body and large secondary headlines that need to sit beside display specimens without competing. The 86px weight-300 size is a typographic statement — a humanist counterweight to the blocky display faces above it."
    },
    "nan-archy-on-extrablack": {
      "$value": "NaN Archy On ExtraBlack",
      "$type": "fontFamily",
      "$description": "Hero display headline — the signature specimen face, shown at its native 228px with tight 0.90 leading so the letterforms stack into a near-monolithic mass. This is the typeface the homepage exists to sell."
    },
    "nan-superx-sans-display-black": {
      "$value": "NaN SuperX Sans Display Black",
      "$type": "fontFamily",
      "$description": "Secondary display face — ultra-tight 0.85 leading creates a dense typographic slab, the contrast to Archy's rounded forms. Used in alternate hero rotations."
    },
    "nan-superx-serif-text-thin-italic": {
      "$value": "NaN SuperX Serif Text Thin Italic",
      "$type": "fontFamily",
      "$description": "Editorial italic display — the serif counterpoint that proves the practice spans humanist letterforms, not just geometric sans. Thin weight at 216px is a tension device: fragile strokes at monumental size."
    },
    "nan-holo-gigawide-ultra1": {
      "$value": "NaN Holo Gigawide Ultra1",
      "$type": "fontFamily",
      "$description": "Ultra-condensed display at 336px — the widest single-character scale on the site, used sparingly as a one-word exclamation."
    },
    "nan-rage-family-zipp-soft-beau-sans-narrow": {
      "$value": "NaN Rage family (Zipp, Soft, Beau, Sans Narrow)",
      "$type": "fontFamily",
      "$description": "Card specimen headlines in the 'You Might Have Missed' grid — each card shows the family name rendered in that exact family at 86px, making the grid self-documenting."
    },
    "nanragezippnarrowthin": {
