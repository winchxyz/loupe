{
  "color": {
    "ember-orange": {
      "$value": "#ff692d",
      "$type": "color",
      "$description": "Ember Orange — Primary action buttons, active nav indicators, key UI accents — the only chromatic color in the system, reserved so it reads as decisive when it appears"
    },
    "linen": {
      "$value": "#efecea",
      "$type": "color",
      "$description": "Linen — Page canvas and section backgrounds — the warm cream that separates the site from sterile white SaaS"
    },
    "ink": {
      "$value": "#22201d",
      "$type": "color",
      "$description": "Ink — Primary text, icon strokes, heading color, footer text — near-black with a warm brown undertone that harmonizes with the cream canvas"
    },
    "graphite": {
      "$value": "#777573",
      "$type": "color",
      "$description": "Graphite — Muted body text, secondary helper text, captions — warm mid-gray that sits between Ink and Paper"
    },
    "stone": {
      "$value": "#dcd9d6",
      "$type": "color",
      "$description": "Stone — Hairline borders, dividers, table separators, icon outlines — the warm neutral that stitches cards and sections together"
    },
    "paper": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper — Card surfaces, elevated product panels, input fields — pure white that floats above the Linen canvas"
    },
    "smoke": {
      "$value": "#cccccc",
      "$type": "color",
      "$description": "Smoke — Light text on dark surfaces, inverse labels, and high-contrast captions. Do not promote it to the primary CTA color"
    }
  },
  "font": {
    "abc-oracle": {
      "$value": "ABC Oracle",
      "$type": "fontFamily",
      "$description": "All UI text — body, buttons, nav, links, cards, labels. The weight 350 default is unusually light; most fintech systems default to 400-500, but Monarch's lighter body weight lets the orange accent carry more visual weight. Letter-spacing sits at -0.010 to -0.012em across all sizes."
    },
    "copernicus": {
      "$value": "Copernicus",
      "$type": "fontFamily",
      "$description": "All display and section headings. The signature choice: a single weight 350 used at every heading size, paired with aggressive negative tracking (-0.050em to -0.067em). The tight tracking compresses wide headings into compact, editorial blocks rather than airy marketing copy. At 48px the -0.067em tracking is extreme — it pulls letters almost touching, creating a dense, premium feel."
    }
  },
