{
  "color": {
    "ink-black": {
      "$value": "#221f1c",
      "$type": "color",
      "$description": "Ink Black — Primary text, dark CTA backgrounds, dark icon fills — warm near-black rather than neutral black keeps the palette from feeling clinical"
    },
    "paper-white": {
      "$value": "#f5f5f5",
      "$type": "color",
      "$description": "Paper White — Page canvas, card backgrounds, subtle surface fills — the warm off-white that gives the product its paper-like base"
    },
    "pure-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Pure White — Elevated product card surfaces inside the app UI (inbox, context graph nodes) — one level above Paper White"
    },
    "stone-gray": {
      "$value": "#797267",
      "$type": "color",
      "$description": "Stone Gray — Secondary text, icon strokes, muted body copy — warm gray that stays in the same family as Ink Black"
    },
    "pebble": {
      "$value": "#8c8a88",
      "$type": "color",
      "$description": "Pebble — Tertiary text, disabled states, low-emphasis icons"
    },
    "slate-edge": {
      "$value": "#27272a",
      "$type": "color",
      "$description": "Slate Edge — Hairline borders on cards and inputs, subtle dividers"
    },
    "azure-action": {
      "$value": "#518bdb",
      "$type": "color",
      "$description": "Azure Action — Primary action background, focused links, active states, key icon accents — the one chromatic CTA color, vivid enough to register against the warm neutrals; Hero background gradient (Azure Action → Teal Pulse, left to right in oklab) — the signature opening visual"
    },
    "teal-pulse": {
      "$value": "#36bab8",
      "$type": "color",
      "$description": "Teal Pulse — Teal text accent for links, tags, and emphasized short phrases. Do not promote it to the primary CTA color"
    },
    "mint-wash": {
      "$value": "#cbfbf1",
      "$type": "color",
      "$description": "Mint Wash — Soft pastel surface tint for feature cards and highlight washes"
    },
    "peach-wash": {
      "$value": "#f8ebd8",
      "$type": "color",
      "$description": "Peach Wash — Soft pastel surface tint, warm counterpart to Mint Wash"
    },
    "lavender-wash": {
      "$value": "#ede9fe",
      "$type": "color",
      "$description": "Lavender Wash — Soft pastel surface tint for alternate feature blocks"
    },
    "teal-mist": {
      "$value": "#cff2ef",
      "$type": "color",
      "$description": "Teal Mist — Subtle teal-tinted surface, bridges brand teal and neutral canvas"
    },
    "coral-marker": {
      "$value": "#ed6d68",
      "$type": "color",
      "$description": "Coral Marker — Red text accent for links, tags, and emphasized short phrases"
    },
    "amber-marker": {
      "$value": "#e5a057",
      "$type": "color",
      "$description": "Amber Marker — Warm icon accent, category color in the multicolor icon palette"
    },
    "orchid-marker": {
      "$value": "#bf89cd",
      "$type": "color",
      "$description": "Orchid Marker — Purple-toned icon accent, category color, decorative node edges in the context graph"
    },
    "forest-edge": {
      "$value": "#1a3a12",
      "$type": "color",
      "$description": "Forest Edge — Dark green border for the live-product mockup's edge treatment, deep botanical accent"
    },
    "signal-green": {
      "$value": "#3a6b2a",
      "$type": "color",
      "$description": "Signal Green — Green wash for highlight backgrounds, decorative bands, and soft emphasis behind content. Use as a supporting accent, not as a status color"
    },
    "live-lime": {
      "$value": "#7efa55",
      "$type": "color",
      "$description": "Live Lime — Green wash for highlight backgrounds, decorative bands, and soft emphasis behind content. Use as a supporting accent, not as a status color"
    }
  },
  "font": {
    "perfectlynineties": {
      "$value": "perfectlyNineties",
      "$type": "fontFamily",
      "$description": "Display and editorial headlines (hero, section H1/H2, large marketing statements) — a chunky 70s/80s display face that gives the page magazine-cover weight. The 0.02em positive tracking at large sizes is a deliberate anti-trend: most modern display faces go tight, this one breathes open."
    },
    "haffer": {
      "$value": "haffer",
      "$type": "fontFamily",
      "$description": "Primary workhorse for body, UI labels, buttons, nav, product chrome, card content, and the 96px hero brand mark. The tight -0.025em tracking at 24px+ creates compact, confident headings; the 0.10em tracking on 8-10px eyebrow/uppercase labels adds editorial rhythm."
    },
    "ui-monospace": {
      "$value": "ui-monospace",
      "$type": "fontFamily",
      "$description": "Monospace for timestamps, email addresses, technical metadata in inbox rows, and AI prompt placeholder text. The system-stack choice signals these are data, not prose."
    }
  },
