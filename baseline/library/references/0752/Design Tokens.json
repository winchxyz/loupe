{
  "color": {
    "signal-yellow": {
      "$value": "#ffc500",
      "$type": "color",
      "$description": "Signal Yellow — Yellow supporting accent for decorative details and low-frequency emphasis. Do not promote it to the primary CTA color"
    },
    "folio-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Folio Black — Primary text, headlines, nav items, icons, and 1px hairline rules — the ink of the page"
    },
    "newsprint-cream": {
      "$value": "#fdfcf3",
      "$type": "color",
      "$description": "Newsprint Cream — Page canvas — the warm off-white that keeps the interface from feeling clinical and signals print provenance"
    },
    "broadsheet-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Broadsheet White — Card surfaces, feature panels, and inverted text on dark or yellow blocks"
    },
    "margin-white": {
      "$value": "#fdfbe4",
      "$type": "color",
      "$description": "Margin White — Subtle secondary surface — a slightly warmer yellow-tinted off-white used for featured/elevated blocks like the radio card"
    },
    "pull-quote-gray": {
      "$value": "#e7e7e7",
      "$type": "color",
      "$description": "Pull Quote Gray — Card backgrounds and muted panel fills where content needs to recede from the page cream"
    },
    "rule-gray": {
      "$value": "#d9d9d9",
      "$type": "color",
      "$description": "Rule Gray — Borders, dividers between columns and sections, input outlines — the structural skeleton of the layout"
    },
    "caption-gray": {
      "$value": "#6e6e6e",
      "$type": "color",
      "$description": "Caption Gray — Secondary text, metadata, read-time labels, byline captions, and muted UI labels"
    },
    "mute-gray": {
      "$value": "#b3b3b3",
      "$type": "color",
      "$description": "Mute Gray — Tertiary text, disabled UI states, and low-emphasis nav accents"
    },
    "charcoal": {
      "$value": "#211d1c",
      "$type": "color",
      "$description": "Charcoal — Near-black warm border for buttons and decorative outlines where pure black feels too cold"
    },
    "desk-blue": {
      "$value": "#64d5ff",
      "$type": "color",
      "$description": "Desk Blue — Decorative illustration accent — appears inside editorial artwork, not in interface controls"
    }
  },
  "font": {
    "plantin": {
      "$value": "Plantin",
      "$type": "fontFamily",
      "$description": "Brand serif used for the MONOCLE wordmark, all article headlines, body copy, card titles, and bylines. The only typeface that carries editorial voice. Subtle negative tracking at 32–40px pulls headlines tight like a magazine title, while 0.05–0.075em positive tracking on 13–16px sizes creates the tracked uppercase eyebrow labels (POLITICS, OPINION, AFFAIRS)."
    },
    "helvetica-neue": {
      "$value": "Helvetica Neue",
      "$type": "fontFamily",
      "$description": "Utility sans for UI chrome: top utility bar (MAGAZINE / RADIO / SHOP), the SUBSCRIBE button label, small icons-adjacent labels, and the primary nav row (AFFAIRS | BUSINESS | CULTURE | DESIGN | FASHION | TRAVEL | CITY GUIDES). Kept narrow and functional — never used for editorial content."
    },
    "chanel": {
      "$value": "Chanel",
      "$type": "fontFamily",
      "$description": "Chanel — detected in extracted data but not described by AI"
    }
  },
