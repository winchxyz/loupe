    },
    "mist": {
      "$value": "#e5e7eb",
      "$type": "color",
      "$description": "Mist — Card surfaces, placeholder image wells, subtle inset zones"
    },
    "chalk": {
      "$value": "#ffffff",
      "$type": "color",
