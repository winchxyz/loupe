  "font": {
    "wf-visual-sans-variable": {
      "$value": "WF Visual Sans Variable",
      "$type": "fontFamily",
      "$description": "The sole sans family for the entire interface — navigation, body, headings, buttons, cards. A custom geometric variable typeface with widths that compress at display sizes. Weight 400 covers body and UI; 500–550 for subheads and labels; 600 reserved for the boldest display headlines. The variable axis enables optical sizing so display weights (56–80px) feel chiseled with tight tracking while body weights (14–16px) remain open and readable."
    },
    "wf-visual-sans-mono": {
      "$value": "WF Visual Sans Mono",
      "$type": "fontFamily",
      "$description": "Monospaced companion for code snippets, terminal outputs, keyboard shortcuts, and developer-facing micro-copy. Rare on the marketing site but present in product demos."
    }
  },
