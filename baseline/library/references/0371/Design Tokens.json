{
  "color": {
    "electric-iris": {
      "$value": "#533afd",
      "$type": "color",
      "$description": "Electric Iris — Primary action fill, active nav, brand focal point — the only saturated color allowed to carry weight against the white canvas"
    },
    "lumen-violet": {
      "$value": "#8087ff",
      "$type": "color",
      "$description": "Lumen Violet — Hover/active washes, secondary link state, icon accents, soft brand halos"
    },
    "midnight-ink": {
      "$value": "#061b31",
      "$type": "color",
      "$description": "Midnight Ink — Primary text, nav ink, dark CTA text — deep near-black blue, never pure black"
    },
    "steel": {
      "$value": "#50617a",
      "$type": "color",
      "$description": "Steel — Body text, secondary headings, default link color — the workhorse neutral that reads as typography, not decoration"
    },
    "slate": {
      "$value": "#64748d",
      "$type": "color",
      "$description": "Slate — Muted helper text, captions, de-emphasized labels, iconography at rest"
    },
    "pewter": {
      "$value": "#7d8ba4",
      "$type": "color",
      "$description": "Pewter — Tertiary text, placeholder content, supporting metadata"
    },
    "fog": {
      "$value": "#3c4f69",
      "$type": "color",
      "$description": "Fog — Stronger secondary text where Steel feels too light, card subtitle ink"
    },
    "mist": {
      "$value": "#e5edf5",
      "$type": "color",
      "$description": "Mist — Page background, hairline borders, card borders — the cool off-white that keeps the canvas from feeling sterile"
    },
    "snow": {
      "$value": "#f8fafd",
      "$type": "color",
      "$description": "Snow — Card surface, raised panels, subtle elevation base — one step warmer than Mist"
    },
    "paper": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper — Pure white reserved for elevated cards, button text on dark fills, and nav surfaces"
    },
    "ember": {
      "$value": "#ff6118",
      "$type": "color",
      "$description": "Ember — Decorative warm accent inside gradient artwork and product illustrations — never used as a functional UI color"
    },
    "solar": {
      "$value": "#ffbb00",
      "$type": "color",
      "$description": "Solar — Highlight wash inside decorative gradient blooms, warm counterweight to violet"
    },
    "periwinkle-tint": {
      "$value": "#e2e4ff",
      "$type": "color",
      "$description": "Periwinkle Tint — Soft violet wash for inactive chip backgrounds, ghost button hover, tag fills"
    },
    "iris-glow": {
      "$value": "#d6d9fc",
      "$type": "color",
      "$description": "Iris Glow — Lighter violet tint for selected states, secondary fills, soft brand surfaces"
    },
    "verdant": {
      "$value": "#81b81a",
      "$type": "color",
      "$description": "Verdant — Green outline accent for tags, dividers, and focused UI edges. Use as a supporting accent, not as a status color"
    },
    "dawn-bloom": {
      "$value": "#f72df3",
      "$type": "color",
      "$description": "Dawn Bloom — Gradient endpoint for hero gradient washes — magenta counterpoint to Electric Iris"
    },
    "spectrum-veil": {
      "$value": "#7232f1",
      "$type": "color",
      "$description": "Spectrum Veil — Gradient origin for tri-color violet→pink→amber spectrum washes behind hero and feature sections"
    }
  },
  "font": {
    "sohne-var": {
      "$value": "sohne-var",
      "$type": "fontFamily",
      "$description": "The single typeface for everything. Weight 300 carries all display and headline work — an anti-convention choice that whispers authority instead of shouting it. Weight 400 handles body, UI labels, and button text. The variable axis allows precise weight tuning for gradient text transitions."
    }
  },
