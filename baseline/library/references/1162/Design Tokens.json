{
  "color": {
    "midnight-ink": {
      "$value": "#05060f",
      "$type": "color",
      "$description": "Midnight Ink — Page canvas and primary surface — the near-black ground everything else is drawn onto. Slight cool tint keeps it from feeling truly black, giving a blueprint-paper quality"
    },
    "graphite-plate": {
      "$value": "#2f343e",
      "$type": "color",
      "$description": "Graphite Plate — Elevated card and panel surface — one step above canvas, used for previewed UI mockups and form containers. Matte, never glossy"
    },
    "steel-border": {
      "$value": "#3f4959",
      "$type": "color",
      "$description": "Steel Border — Hairline borders, dividers, and muted structural lines between UI elements"
    },
    "fog": {
      "$value": "#81899b",
      "$type": "color",
      "$description": "Fog — De-emphasized helper text and secondary metadata that should recede behind primary content"
    },
    "pebble": {
      "$value": "#9da7ba",
      "$type": "color",
      "$description": "Pebble — Muted body text and disabled-state labels — readable but clearly secondary"
    },
    "moonlight": {
      "$value": "#c7d3ea",
      "$type": "color",
      "$description": "Moonlight — Primary body and icon color — cool off-white that carries the interface's default voice"
    },
    "ice": {
      "$value": "#d1e4fa",
      "$type": "color",
      "$description": "Ice — Highlighted body text, strong secondary labels, and badge content where extra presence is needed without going full white"
    },
    "glacier": {
      "$value": "#d8ecf8",
      "$type": "color",
      "$description": "Glacier — Headings, link text, and section titles — the brightest readable text, used to anchor the eye on the most important strings"
    },
    "frost-link": {
      "$value": "#b6d9fc",
      "$type": "color",
      "$description": "Frost Link — Active link states and glow-infused accent text where a clear blue signal is required"
    },
    "electric-iris": {
      "$value": "#663af3",
      "$type": "color",
      "$description": "Electric Iris — Violet supporting accent for decorative details and low-frequency emphasis. Do not promote it to the primary CTA color"
    },
    "ember": {
      "$value": "#e46d4c",
      "$type": "color",
      "$description": "Ember — Alternative brand accent for live-preview or demo CTAs where a warm contrast is needed against the cool palette"
    },
    "azure": {
      "$value": "#027dea",
      "$type": "color",
      "$description": "Azure — Blue supporting accent for decorative details and low-frequency emphasis. Do not promote it to the primary CTA color"
    },
    "cipher-mint": {
      "$value": "#269684",
      "$type": "color",
      "$description": "Cipher Mint — Teal supporting accent for decorative details and low-frequency emphasis. Do not promote it to the primary CTA color"
    },
    "blueprint-glow": {
      "$value": "#bacff7",
      "$type": "color",
      "$description": "Blueprint Glow — Soft highlight gradient endpoint — appears in the vertical text gradient (Glacier → Frost Link) and as the top stop in hero light gradients"
    }
  },
  "font": {
    "untitled-sans": {
      "$value": "Untitled Sans",
      "$type": "fontFamily",
      "$description": "Workhorse UI and body face. Carries everything from 12px captions to 24px section titles; weight 400 is default body, 500 for emphasis, 600–700 for button labels and form controls. Slight negative tracking (-0.01em) tightens the dark-mode rhythm."
    },
    "aeonikpro": {
      "$value": "aeonikPro",
      "$type": "fontFamily",
      "$description": "Display and hero-only face. Used for the 'AuthKit' wordmark and large section headlines at 44–48px. Wider proportions and a cleaner geometric skeleton give the brand a distinctive presence that Untitled Sans cannot supply at scale. Normal tracking."
    },
    "dotdigital": {
      "$value": "dotDigital",
      "$type": "fontFamily",
      "$description": "Eyebrow and label-only face at 15px. The wide 0.1em tracking and tabular numerals ('tnum') mark these as quiet structural markers — 'Introducing', 'Shine bright', 'Extensible by design' — that precede headlines. Never used for body copy."
    }
  },
