{
  "color": {
    "midnight-navy": {
      "$value": "#000f2e",
      "$type": "color",
      "$description": "Midnight Navy — Primary text, headings, dark surface cards, logo wordmark — the dominant ink of the system. Deep enough to anchor the cream canvas without going pure black"
    },
    "warm-cream": {
      "$value": "#f6ecc8",
      "$type": "color",
      "$description": "Warm Cream — Hero band background, alternating section backdrop — sets the warm, sunlit atmosphere of the brand"
    },
    "soft-off-white": {
      "$value": "#fcfaf2",
      "$type": "color",
      "$description": "Soft Off-White — Page canvas, card surfaces, button text on filled blue — the base layer everything sits on"
    },
    "electric-blue": {
      "$value": "#0067e5",
      "$type": "color",
      "$description": "Electric Blue — Blue supporting accent for decorative details and low-frequency emphasis. Do not promote it to the primary CTA color"
    },
    "heather-violet": {
      "$value": "#515a8a",
      "$type": "color",
      "$description": "Heather Violet — Muted secondary text, supporting body copy — keeps longer passages from competing with the Midnight Navy headings"
    },
    "signal-yellow": {
      "$value": "#fed200",
      "$type": "color",
      "$description": "Signal Yellow — Solution card fill, decorative high-energy accent — one of the candy-bright poster colors for the product grid"
    },
    "deep-teal": {
      "$value": "#116973",
      "$type": "color",
      "$description": "Deep Teal — Solution card fill, decorative oceanic accent — reinforces the water brand narrative in the product grid"
    },
    "sky-wash": {
      "$value": "#8ab1e6",
      "$type": "color",
      "$description": "Sky Wash — Solution card fill, soft brand-blue companion — a lighter blue tone for visual variety in card blocks"
    },
    "black-ink": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Black Ink — Outlined button stroke, icon strokes, text in solid dark contexts — used sparingly for maximum contrast outlines"
    },
    "brand-blue-drift": {
      "$value": "#4183d9",
      "$type": "color",
      "$description": "Brand Blue Drift — Gradient terminus paired with Electric Blue — used in the subtle horizontal brand gradient for decorative washes"
    }
  },
  "font": {
    "dopper": {
      "$value": "Dopper",
      "$type": "fontFamily",
      "$description": "Display hero headlines ('Hot, cold, or fizzy.') — a custom quirky face with tight line-height that sits like a poster cut-out. Substitute with Fraunces or a chunky display serif for close fidelity."
    },
    "gilroy": {
      "$value": "Gilroy",
      "$type": "fontFamily",
      "$description": "Headlines, subheadings, card titles, body emphasis — the structural workhorse. Weight 600 for section headings ('Explore our solutions'), 700 for card titles, 400 for body. Substitute with Manrope or Outfit."
    },
    "apple-system": {
      "$value": "-apple-system",
      "$type": "fontFamily",
      "$description": "System fallback for utility text and small body — inherits platform-native rhythm."
    }
  },
