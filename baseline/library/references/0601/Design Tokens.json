  "font": {
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "Sole brand typeface — handles everything from 12px micro-labels to 80px display headlines. Weight 500/600 for headlines keeps the voice confident without shouting; weight 400 carries body text. The tight letter-spacing on large sizes (-0.025em at 80px, -0.019em at 40–48px) makes display lines feel set, not stacked."
    },
    "ui-monospace": {
      "$value": "ui-monospace",
      "$type": "fontFamily",
      "$description": "Inline code, keyboard shortcuts, technical tokens — appears sparingly, never as a headline face"
    }
  },
