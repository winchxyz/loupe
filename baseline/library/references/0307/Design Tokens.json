{
  "color": {
    "deep-ink": {
      "$value": "#192830",
      "$type": "color",
      "$description": "Deep Ink — Primary CTA button fill, nav border, interactive controls — this single dark-teal anchor is the only departure from the black/cream palette, creating a subtle aquatic undertone that reads health-adjacent without being clinical"
    },
    "parchment": {
      "$value": "#f5f5ee",
      "$type": "color",
      "$description": "Parchment — Page background, section fills — the slight warm-green cast separates this from pure white and prevents sterility"
    },
    "linen": {
      "$value": "#e4e7da",
      "$type": "color",
      "$description": "Linen — Subtle section dividers, secondary surface tinting"
    },
    "pressed-cotton": {
      "$value": "#d7d7cb",
      "$type": "color",
      "$description": "Pressed Cotton — Tertiary surface, card backgrounds in feature sections"
    },
    "graphite": {
      "$value": "#2f3136",
      "$type": "color",
      "$description": "Graphite — Body text, headings, primary readable content"
    },
    "slate": {
      "$value": "#535557",
      "$type": "color",
      "$description": "Slate — Secondary body text, captions, supporting copy"
    },
    "dusk": {
      "$value": "#424e52",
      "$type": "color",
      "$description": "Dusk — Tertiary text, footer links, subdued labels"
    },
    "white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "White — Button text on dark fills, icon fills, overlay text on photography"
    },
    "ink": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Ink — Maximum contrast text, SVG fills"
    }
  },
  "font": {
    "abc-arizona-sans": {
      "$value": "ABC Arizona Sans",
      "$type": "fontFamily",
      "$description": "Navigation links, body copy, buttons, captions, footer text. Single weight used across all UI text — no bold weight anywhere forces hierarchy through size alone. The tight letter-spacing (-0.016em at 20px, -0.020em at 16px, -0.025em at 14px) gives a condensed editorial feel at every size."
    },
    "abc-arizona-flare": {
      "$value": "ABC Arizona Flare",
      "$type": "fontFamily",
      "$description": "Display headings and the oversized brand wordmark. The flare-serif construction (hairline terminal spurs) at very tight -0.05em spacing at 64px collapses letterforms together like editorial magazine typography — the 'Luffu' logotype treatment at display scale is the signature visual moment of this system."
    }
  },
