    },
    "pewter-caption": {
      "$value": "#666666",
      "$type": "color",
      "$description": "Pewter Caption — Badge and tag text — the only readable gray for small uppercase labels"
    },
    "terracotta-alert": {
      "$value": "#9b1b01",
      "$type": "color",
      "$description": "Terracotta Alert — Input validation error borders, error state signals — the single chromatic UI color, echoing the product terracotta"
