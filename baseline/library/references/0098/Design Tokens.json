{
  "color": {
    "ink-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Ink Black — Primary text, all structural borders, logo wordmark, button outlines — the load-bearing color of the entire system"
    },
    "gallery-white": {
      "$value": "#fefefe",
      "$type": "color",
      "$description": "Gallery White — Card surfaces, product photography backgrounds, badge fills, hero overlay text color"
    },
    "concrete-canvas": {
      "$value": "#e3e2e2",
      "$type": "color",
      "$description": "Concrete Canvas — Dominant page background — the warm-tinted gray that sets the gallery-like stage for every section"
    },
    "ash-border": {
      "$value": "#c3c3c3",
      "$type": "color",
