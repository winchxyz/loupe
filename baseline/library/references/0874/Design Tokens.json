{
  "color": {
    "cherry-marquee": {
      "$value": "#b00e2f",
      "$type": "color",
      "$description": "Cherry Marquee — Brand accent, heading text, link color, icon stroke, outlined button border, footer headline — vivid warm red used as the single chromatic signal across an otherwise cream-and-white interface"
    },
    "cream-bisque": {
      "$value": "#fee5ca",
      "$type": "color",
      "$description": "Cream Bisque — Secondary surface for cards, callout panels, and the cart/bag detail button — warm near-white that reads as paper, not gray"
    },
    "canvas-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Canvas White — Page background, card surface, input fill, button text on dark"
    },
    "ink-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Ink Black — Primary body text, icon fills, heavy borders, SVG fill — the only true dark"
    },
    "slate-mid": {
      "$value": "#aaaaaa",
      "$type": "color",
      "$description": "Slate Mid — Muted secondary text, disabled placeholders, low-emphasis dividers"
    }
  },
  "font": {
    "cervo": {
      "$value": "Cervo",
      "$type": "fontFamily",
      "$description": "Display and headings only. Set extremely tight (line-height 0.75 on the 144px hero, 0.9 on 64-72px) and tracked slightly outward at 0.05em — the condensed letterforms and compressed leading make the headline read as a hand-painted sign rather than a web type block. Weight 400 carries the body, weight 500 amplifies emphasis within the display."
    },
    "helveticaneuecyr": {
      "$value": "HelveticaNeueCyr",
      "$type": "fontFamily",
      "$description": "Body, UI, navigation, footer, input, captions. Light 400 weight throughout with generous 1.3-1.4 leading on running text — the whisper-weight keeps chrome from competing with the Cervo display, so the marquee headline always wins the eye."
    }
  },
