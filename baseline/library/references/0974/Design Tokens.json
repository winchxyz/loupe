{
  "color": {
    "parchment-cream": {
      "$value": "#f5f4df",
      "$type": "color",
      "$description": "Parchment Cream — Page canvas, card surfaces, text color on dark imagery — the warm off-white that keeps photography from feeling cold"
    },
    "carbon-ink": {
      "$value": "#0e1620",
      "$type": "color",
      "$description": "Carbon Ink — Body text, headings, hairline borders, icon strokes — near-black with a cool blue undertone that pairs with the cream"
    },
    "pale-sky": {
      "$value": "#c1dfef",
      "$type": "color",
      "$description": "Pale Sky — Soft secondary surface wash, subtle section backgrounds when cream needs contrast"
    },
    "shadow-khaki": {
      "$value": "#abab9c",
      "$type": "color",
      "$description": "Shadow Khaki — Warm gray used in card box-shadow tinting — gives elevation a warm cast rather than a cold blue"
    },
    "electric-blue": {
      "$value": "#007ae5",
      "$type": "color",
      "$description": "Electric Blue — Blue wash for highlight backgrounds, decorative bands, and soft emphasis behind content. Do not promote it to the primary CTA color"
    },
    "deep-cobalt": {
      "$value": "#1c3f99",
      "$type": "color",
      "$description": "Deep Cobalt — Secondary brand surface for navigation bars and accent fills — darker register of the blue for layering"
    },
    "outlined-action": {
      "$value": "#083e6f",
      "$type": "color",
      "$description": "Outlined Action — Blue accent for outlined action borders, linked labels, and lightweight interactive emphasis. Do not promote it to the primary CTA color"
    },
    "sunset-orange": {
      "$value": "#eb6110",
      "$type": "color",
      "$description": "Sunset Orange — Warm accent fill for decorative highlights and select illustration elements — echoes the golden-hour photography palette"
    },
    "peach-glow": {
      "$value": "#ffd9c9",
      "$type": "color",
      "$description": "Peach Glow — Soft warm surface accent, peachy wash that harmonizes with the sunset photography"
    },
    "signal-blue": {
      "$value": "#319fff",
      "$type": "color",
      "$description": "Signal Blue — Brighter blue accent for small icon and illustration highlights — lighter pop than the primary Electric Blue"
    }
  },
  "font": {
    "jobydisplay": {
      "$value": "jobyDisplay",
      "$type": "fontFamily",
      "$description": "Display headlines and hero text. Sizes scale dramatically from 40px to 207px with tight tracking (-0.03em at the largest sizes) — the near-200px display weight is the signature: whisper-light at colossal scale, the opposite of typical bold-hero convention. Used for hero copy ('Skip traffic. Time to fly.') and section display headlines."
    },
    "jobytext": {
      "$value": "jobyText",
      "$type": "fontFamily",
      "$description": "All body copy, navigation, badges, footer, and inline links. The 450 weight is distinctive — a custom intermediate weight between Regular and Medium that gives body text a subtly heavier presence than a standard 400. Tight letter-spacing (-0.01 to -0.02em) even at body sizes reinforces the display font's compressed character."
    },
    "joby-sans-display": {
      "$value": "Joby Sans Display",
      "$type": "fontFamily",
      "$description": "Micro-display usage at 12px for labels and tags that need display-type personality at small scale — -0.03em tracking gives these tiny labels the same compressed character as the 200px headlines"
    },
    "arial": {
      "$value": "Arial",
      "$type": "fontFamily",
      "$description": "System fallback for button text and icon-adjacent micro-copy where system font rendering is preferred"
    }
  },
