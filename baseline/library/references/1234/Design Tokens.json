{
  "color": {
    "pitch-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Pitch Black — Primary text, filled pill buttons, full-bleed dark section backgrounds, icon strokes, hairline borders — the structural backbone of every page"
    },
    "paper-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper White — Page canvas, card surfaces, text on dark sections, button text on filled black buttons, search field fill"
    },
    "ash-gray": {
      "$value": "#eeeeee",
      "$type": "color",
      "$description": "Ash Gray — Soft image backgrounds, secondary surface tint, subtle card/poster fill behind event artwork"
    },
    "concrete": {
      "$value": "#d9d9d9",
