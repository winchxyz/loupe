{
  "color": {
    "obsidian": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Obsidian — Primary text, filled dark CTAs, high-contrast borders. Sets the typographic anchor against the cream canvas"
    },
    "graphite": {
      "$value": "#333333",
      "$type": "color",
      "$description": "Graphite — Secondary text and the dominant hairline border color (336 uses). Carries the structural edge system"
    },
    "slate": {
      "$value": "#7b7b7b",
      "$type": "color",
      "$description": "Slate — Muted helper text and inactive link text. Used wherever secondary information must recede"
    },
    "mist": {
      "$value": "#bcbcbc",
      "$type": "color",
      "$description": "Mist — Subtle badge borders and soft body borders. Sits between structural Graphite and canvas in the border hierarchy"
    },
    "silver": {
      "$value": "#d6d6d6",
      "$type": "color",
      "$description": "Silver — Light dividers, input borders, and inactive link borders. The quietest structural neutral"
    },
    "bone": {
      "$value": "#f5f2f0",
      "$type": "color",
      "$description": "Bone — Warm cream surface — badge backgrounds and off-white secondary surfaces. Distinct from pure white, gives the system a paper-like warmth"
    },
    "paper": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper — Page canvas and card surfaces. The default ground everything sits on"
    },
    "lilac-bloom": {
      "$value": "#f1ccff",
      "$type": "color",
      "$description": "Lilac Bloom — Pink action color for filled buttons, selected navigation states, and focused conversion moments."
    },
    "sky-veil": {
      "$value": "#91e0ff",
      "$type": "color",
      "$description": "Sky Veil — Secondary accent — used sparingly for icon accents, illustration details, and alternate highlight surfaces. The cool counterpart to Lilac Bloom"
    }
  },
  "font": {
    "switzer": {
      "$value": "Switzer",
      "$type": "fontFamily",
      "$description": "All functional UI, body copy, subheadings, nav, buttons, badges. Weight 400 for body, 500 for subheadings, 600 for emphasized UI labels. Letter-spacing tightens at larger sizes (-0.025em at 32px, -0.01em at 20px). Substitute: 'Inter' or 'General Sans'."
    },
    "pp-editorial-new": {
      "$value": "PP Editorial New",
      "$type": "fontFamily",
      "$description": "Hero and section headlines. A high-contrast editorial serif used at display sizes only — the deliberate contrast with the geometric Switzer body is the system's signature typographic move, making the brand read like a magazine rather than a product page. Substitute: 'Playfair Display' or 'DM Serif Display'."
    },
    "arial": {
      "$value": "Arial",
      "$type": "fontFamily",
      "$description": "Arial — detected in extracted data but not described by AI"
    },
    "system-ui": {
      "$value": "system-ui",
      "$type": "fontFamily",
      "$description": "system-ui — detected in extracted data but not described by AI"
    }
  },
