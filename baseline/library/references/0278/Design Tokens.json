  "font": {
    "britti-sans": {
      "$value": "Britti Sans",
      "$type": "fontFamily",
      "$description": "Display and heading typeface used exclusively at 24–64px, always weight 500. The 1.0 line-height is distinctive — headings sit tight with no leading slack, creating geometric, almost architectural presence. Substitute with Plus Jakarta Sans (500) or General Sans (500) for closest geometric match."
    },
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "Workhorse UI and body typeface. Weight 400 for body, 500 for buttons/nav/table headers, 700 for emphasized labels. The tight size range (12–16px) and compact line-heights signal a data-dense product, not a marketing site. Substitute with Inter directly or IBM Plex Sans."
    }
  },
