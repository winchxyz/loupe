  "font": {
    "gelica": {
      "$value": "Gelica",
      "$type": "fontFamily",
      "$description": "Display and heading face — a custom chunky serif used exclusively for h1/h2 moments. Tight line-heights (1.0–1.11) make stacked headlines feel dense and editorial. Normal letter-spacing."
    },
    "articulat-cf": {
      "$value": "Articulat CF",
      "$type": "fontFamily",
      "$description": "Body, UI, and small-label face. The defining quirk: 0.28em letter-spacing on this family creates the system's signature airy, architectural feel — almost certainly applied to small/uppercase labels and meta text where the wide tracking reads as deliberate typesetting rather than gap. Generous line-heights (up to 1.78) keep body copy breathing."
    }
  },
