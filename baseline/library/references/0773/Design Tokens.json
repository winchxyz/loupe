    },
    "ash": {
      "$value": "#d2cec6",
      "$type": "color",
      "$description": "Ash — Hairline dividers, footer borders, low-contrast separators"
    },
    "chartreuse": {
      "$value": "#dbf570",
      "$type": "color",
      "$description": "Chartreuse — Highlight badges, study tags, the globe motif, card accent fills — the only chromatic note in the system, used sparingly to draw the eye to research signals"
    },
    "olive": {
      "$value": "#4b5b0a",
      "$type": "color",
      "$description": "Olive — Decorative border accent, chromatic link underline — the only deep color, appears in the olive outline treatments and the heading underline on the hero"
    }
  },
  "font": {
    "ui-sans-serif": {
      "$value": "ui-sans-serif",
      "$type": "fontFamily",
      "$description": "ui-sans-serif — detected in extracted data but not described by AI"
    },
    "phonic": {
      "$value": "Phonic",
      "$type": "fontFamily",
      "$description": "Display, headings, body — the brand's signature humanist serif set aggressively tight at large sizes (–0.09em at 130px down to +0.03em at 12px). Weight 300 dominates for display, 400 for body. The custom typeface carries the editorial voice; weight 300 at 130px is the signature move — most brands use 600–700 here, Maze whispers in a light serif to claim authority through restraint."
    },
    "system-ui-sans": {
      "$value": "System UI Sans",
      "$type": "fontFamily",
      "$description": "Secondary UI text, fallback for browser contexts — only used sparingly; Phonic carries the brand"
    }
  },
