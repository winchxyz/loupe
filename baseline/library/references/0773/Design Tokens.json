{
  "color": {
    "bone": {
      "$value": "#f5f4f0",
      "$type": "color",
      "$description": "Bone — Page canvas, footer, secondary button fills — warm off-white replaces cold digital white, giving every screen a paper-like base"
    },
    "paper": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper — Card surfaces, elevated panels, input fields — the bright layer above bone"
    },
    "ink": {
      "$value": "#1c1c1c",
      "$type": "color",
      "$description": "Ink — Primary text, dark filled buttons, heading color — the default ink, warm near-black rather than #000"
    },
    "charcoal": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Charcoal — Hairline borders, icon strokes, the announcement bar — the thinnest line work"
    },
    "fossil": {
      "$value": "#706f6c",
      "$type": "color",
      "$description": "Fossil — Secondary text, muted borders, body annotations"
    },
    "pebble": {
