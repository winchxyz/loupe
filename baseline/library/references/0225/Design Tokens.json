{
  "color": {
    "cobalt-spark": {
      "$value": "#298ef5",
      "$type": "color",
      "$description": "Cobalt Spark — Primary filled action, active states, brand accent — the sole chromatic voice in an otherwise monochrome system, so it must appear sparingly to retain its charge"
    },
    "obsidian-bar": {
      "$value": "#333333",
      "$type": "color",
      "$description": "Obsidian Bar — Navigation background — dark anchor that frames the light canvas below"
    },
    "ink": {
      "$value": "#171718",
      "$type": "color",
      "$description": "Ink — Primary headings and body text — near-black with a barely-warm cast that softens against pure #000"
    },
    "carbon": {
      "$value": "#25282b",
      "$type": "color",
      "$description": "Carbon — Icon strokes, secondary text, UI graphics — a touch cooler than Ink for icon differentiation"
    },
    "smoke": {
      "$value": "#7c7e83",
      "$type": "color",
      "$description": "Smoke — Muted helper text, secondary nav, inactive labels"
    },
    "ash": {
      "$value": "#a3a7ad",
      "$type": "color",
      "$description": "Ash — Tertiary icon fills, disabled-state text, low-priority metadata"
    },
    "frost": {
      "$value": "#e5e7eb",
      "$type": "color",
      "$description": "Frost — Hairline borders, card outlines, divider lines — the structural backbone of the grayscale system"
    },
    "bone": {
      "$value": "#f5f5f7",
      "$type": "color",
      "$description": "Bone — Card surfaces, section backgrounds, subtle elevation — the off-white between pure white and Frost"
    },
    "porcelain": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Porcelain — Page canvas, button fills, card base — the default surface everything sits on"
    },
    "shadow-veil": {
      "$value": "#bfbfbf",
      "$type": "color",
      "$description": "Shadow Veil — Soft shadow tint used in card and button drop-shadows to imply elevation without color"
    },
    "lavender-wash": {
      "$value": "#b1b3cc",
      "$type": "color",
      "$description": "Lavender Wash — Hero background atmospheric tint — a radial gradient that briefly warms the monochrome with a cool violet glow"
    }
  },
  "font": {
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "All interface text — nav, buttons, body, subheads, and most headings; the 600 weight is reserved for emphasis, never used decoratively, and the tight -0.025em tracking on 48–72px display sizes is what makes headlines feel engineered rather than typed"
    },
    "rogan": {
      "$value": "Rogan",
      "$type": "fontFamily",
      "$description": "Wide-tracked label/eyebrow text — its defining move is the 0.05em positive tracking at modest sizes, which forces the type to read as caption-or-category rather than heading; appears as uppercase or small-caps markers above content blocks"
    }
  },
