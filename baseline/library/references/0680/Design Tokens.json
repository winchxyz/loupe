  "font": {
    "mediumllweb": {
      "$value": "MediumLLWeb",
      "$type": "fontFamily",
      "$description": "All text across the site — UI, body, and display. A single neo-grotesque custom face from Production Type carrying every typographic role. Weight 400 is the default for body and navigation; weight 500 is reserved for artist names, prices, and emphasis in card metadata. Display sizes (48–72px) use the same 400 weight with tight line-height (1.00–1.15) to create the measured, catalog-page cadence."
    }
  },
