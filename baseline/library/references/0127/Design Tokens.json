{
  "color": {
    "sst-ink": {
      "$value": "#303055",
      "$type": "color",
      "$description": "SST Ink — Headings, body text, links, primary text color — dark indigo-violet replaces the conventional near-black, giving every word a faint cool cast that signals developer-tool seriousness without feeling heavy"
    },
    "code-plum": {
      "$value": "#8844ae",
      "$type": "color",
      "$description": "Code Plum — Code syntax highlighting for strings, property names, and keywords — the most vivid color in the system, reserved exclusively for inside code blocks"
    },
    "code-cobalt": {
      "$value": "#3b61b0",
      "$type": "color",
      "$description": "Code Cobalt — Code syntax for method names, object keys, and function calls — paired with Code Plum to create the two-color syntax core"
    },
    "code-teal": {
      "$value": "#096e72",
      "$type": "color",
      "$description": "Code Teal — Code syntax for type annotations, decorators, and select tokens — deeper teal that reads as technical rather than decorative"
    },
    "code-rust": {
      "$value": "#984e4d",
      "$type": "color",
      "$description": "Code Rust — Red supporting accent for decorative details and low-frequency emphasis"
    },
    "slate": {
      "$value": "#403f53",
      "$type": "color",
      "$description": "Slate — Secondary body text, descriptions, paragraph copy — sits one step lighter than SST Ink for prose that shouldn't compete with headings"
    },
    "fog": {
      "$value": "#767682",
      "$type": "color",
      "$description": "Fog — Muted helper text, icon fills, secondary button text, navigation metadata — the mid-gray that makes UI chrome recede"
    },
    "mist": {
      "$value": "#a8a8b0",
      "$type": "color",
      "$description": "Mist — Lightest text, disabled states, subtle icon outlines, and hairlines — the floor of the gray scale"
    },
    "obsidian": {
      "$value": "#111111",
      "$type": "color",
      "$description": "Obsidian — Occasional maximum-contrast text and borders where absolute black is required"
    },
    "lavender-mist": {
      "$value": "#e8e8f2",
      "$type": "color",
      "$description": "Lavender Mist — Subtle surface tint for code-block backgrounds, tag pills, and soft card fills — a whisper of violet that ties back to SST Ink"
    },
    "paper": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper — Light supporting surface for subtle backgrounds and section separation. Do not promote it to the primary CTA color"
    }
  },
  "font": {
    "ibm-plex-mono": {
      "$value": "IBM Plex Mono",
      "$type": "fontFamily",
      "$description": "The code and technical voice — used for all code blocks, terminal output, inline code, API identifiers, and the 48px hero command line. Weight 600 highlights the shell prompt, file names, and key tokens inside code. The negative tracking tightens monospaced characters into dense, readable blocks."
    },
    "rubik-variable": {
      "$value": "Rubik Variable",
      "$type": "fontFamily",
      "$description": "The product and prose voice — all navigation, headings, body copy, button labels, footer text, and UI metadata. Weight 400 is the default body, 500 for nav and button emphasis, 600 for headings. Positive tracking (0.016–0.056em) appears on uppercase eyebrows and small labels, giving them a controlled, technical stamp rather than decorative flair."
    }
  },
