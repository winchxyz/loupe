{
  "color": {
    "midnight-navy": {
      "$value": "#142978",
      "$type": "color",
      "$description": "Midnight Navy — Violet text accent for links, tags, and emphasized short phrases. Do not promote it to the primary CTA color"
    },
    "flame-orange": {
      "$value": "#fe5000",
      "$type": "color",
      "$description": "Flame Orange — Filled CTA buttons, icon strokes, decorative accents — the single chromatic action color that commands every screen it touches"
    },
    "wine-burgundy": {
      "$value": "#82163f",
      "$type": "color",
      "$description": "Wine Burgundy — Secondary section background, hero display text, promotional bands — adds warmth and depth against the navy"
    },
    "deep-ink": {
      "$value": "#001233",
      "$type": "color",
      "$description": "Deep Ink — Outlined/ghost button borders, dark text on light surfaces, deep button variant background"
    },
    "abyss-navy": {
      "$value": "#0a153c",
      "$type": "color",
      "$description": "Abyss Navy — Pressed/secondary button fill — a near-black navy for dark button variants on the navy canvas"
    },
    "powder-blue": {
      "$value": "#dbebf5",
      "$type": "color",
      "$description": "Powder Blue — Card surfaces and light-blue panel backgrounds within dark sections — breaks up the navy with breathing room"
    },
    "warm-cream": {
      "$value": "#f3e0c8",
      "$type": "color",
      "$description": "Warm Cream — Hero left-panel background, soft warm neutral — used in only the highest-impact first-screen block"
    },
    "snow-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Snow White — Primary text on dark surfaces, button borders, input fills, card text — the dominant foreground color"
    },
