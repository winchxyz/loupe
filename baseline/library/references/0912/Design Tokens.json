{
  "color": {
    "lime-signal": {
      "$value": "#e4f222",
      "$type": "color",
      "$description": "Lime Signal — Green supporting accent for decorative details and low-frequency emphasis. Do not promote it to the primary CTA color"
    },
    "cobalt-glow": {
      "$value": "#5683d2",
      "$type": "color",
      "$description": "Cobalt Glow — Hero gradient midpoint, decorative accents, link hover washes. Provides the atmospheric blue that carries the dawn-sky hero treatment"
    },
    "obsidian": {
      "$value": "#0c0a08",
      "$type": "color",
      "$description": "Obsidian — Primary text color, dark canvas surfaces, navigation bar, footer. The near-black that grounds the system with 19.8:1 contrast against white"
    },
    "paper": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper — Page background in light sections, text on dark surfaces, input fills. The clean canvas that lets product imagery and the lime accent command attention"
    },
    "limestone": {
      "$value": "#f4f2f0",
      "$type": "color",
      "$description": "Limestone — Card surfaces, elevated panels, warm neutral fills. Replaces drop shadows as the separation mechanism in light-mode layouts"
    },
    "charcoal": {
      "$value": "#1a1919",
      "$type": "color",
      "$description": "Charcoal — Elevated dark surfaces, filled dark buttons, card overlays. One step lifted from Obsidian for subtle depth without true black"
    },
    "slate": {
      "$value": "#4d505d",
      "$type": "color",
      "$description": "Slate — Borders, dividers, muted structural elements. Carries a cool undertone that keeps it from competing with the warm Limestone surfaces"
    },
    "fog": {
      "$value": "#999ba3",
      "$type": "color",
      "$description": "Fog — Secondary text, helper copy, muted labels, icon strokes. The 50% gray that handles all de-emphasized content"
    },
    "bone": {
      "$value": "#d2cecb",
      "$type": "color",
      "$description": "Bone — Hairline borders on light surfaces, subtle dividers, card outlines. Warmer than Slate, used where Slate would feel cold against Limestone"
    }
  },
  "font": {
    "lausanne": {
      "$value": "Lausanne",
      "$type": "fontFamily",
      "$description": "Primary typeface for all UI, headings, body, nav, buttons, and display. Lausanne is a custom commissioned sans-serif with optical sizing across 11 steps — its compressed line-height at 64px (0.74-1.05) gives hero headlines an editorial slab feel without switching to a serif. Weight 400 carries everything; 500 is reserved for nav and emphasis."
    },
    "arial": {
      "$value": "Arial",
      "$type": "fontFamily",
      "$description": "Arial — detected in extracted data but not described by AI"
    }
  },
