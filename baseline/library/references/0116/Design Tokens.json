{
  "color": {
    "ink": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Ink — Primary text, icon strokes, hairline borders, Log in button — the structural black that carries almost all interface weight"
    },
    "paper": {
      "$value": "#fafafa",
      "$type": "color",
      "$description": "Paper — Page canvas, card surface background — the off-white that makes the whole feed feel like printed paper"
    },
    "concrete": {
      "$value": "#d5d5d5",
      "$type": "color",
      "$description": "Concrete — Dividers and separator borders between feed sections"
    },
    "graphite": {
      "$value": "#969696",
      "$type": "color",
      "$description": "Graphite — Muted helper text, inactive icons, disabled state borders, timestamp labels"
    },
    "charcoal": {
      "$value": "#424242",
      "$type": "color",
      "$description": "Charcoal — Secondary body text, icon detail strokes, post metadata"
    },
    "hover-mist": {
      "$value": "#efefef",
      "$type": "color",
      "$description": "Hover Mist — Soft section background, alternate surface, and quiet card fill. Do not promote it to the primary CTA color"
    },
    "verified-indigo": {
      "$value": "#385898",
      "$type": "color",
      "$description": "Verified Indigo — Verified badges, inline links, outlined hover state on action buttons — the only chromatic brand color, used as a quiet signature rather than a loud accent"
    },
    "signal-blue": {
      "$value": "#0095f6",
      "$type": "color",
      "$description": "Signal Blue — Follow button, primary outlined action color, clickable link emphasis — vivid blue reserved for moments that must demand a tap"
    }
  },
  "font": {
    "system-ui": {
      "$value": "system-ui",
      "$type": "fontFamily",
      "$description": "All text rendering — post bodies at 15px/400, usernames and timestamps at 13px/600, caption-sized metadata at 12px/700. System font stack keeps the feed platform-native and weight-driven hierarchy rather than size-driven hierarchy."
    }
  },
  "typography": {
    "xs": {
      "$value": {
        "fontFamily": "system-ui",
        "fontSize": "12px",
        "fontWeight": 700,
        "lineHeight": 1.4
      },
      "$type": "typography",
      "$description": "Typography step xs at 12px"
    },
    "xs-2": {
      "$value": {
