      "$value": "#32c5ff",
      "$type": "color",
      "$description": "Aurora Wash — Subtle multi-hue gradient wash on feature sections — used at 0.08 opacity for atmospheric backgrounds"
    }
  },
  "font": {
    "p22-mackinac-pro": {
      "$value": "p22-mackinac-pro",
      "$type": "fontFamily",
      "$description": "Display headlines and editorial accents. Weight 300-400 at 60-96px creates the signature warm, literary feel — the serif whispers rather than commands. Italic variant used for emphasis words in headlines ('actually', 'Statamic')."
    },
    "lexend": {
      "$value": "Lexend",
      "$type": "fontFamily",
      "$description": "Primary UI and body typeface. Nav, buttons, body text, card titles, footer. Weight 300 for nav and secondary text keeps the interface light; 500-600 for buttons and labels. The wide weight range lets it carry both quiet metadata and confident CTAs."
    },
    "code-saver": {
      "$value": "code-saver",
      "$type": "fontFamily",
      "$description": "Monospace for code blocks, file tree, technical content, input fields. Weight 700 for syntax emphasis, 300 for ambient code display."
    },
    "lore": {
