{
  "color": {
    "periwinkle-signal": {
      "$value": "#576cdb",
      "$type": "color",
      "$description": "Periwinkle Signal — Violet supporting accent for decorative details and low-frequency emphasis. Do not promote it to the primary CTA color"
    },
    "deep-indigo": {
      "$value": "#1f1f47",
      "$type": "color",
      "$description": "Deep Indigo — Primary heading text, nav links, high-emphasis body — anchors the palette with near-black authority carrying a faint cool tint"
    },
    "storm-violet": {
      "$value": "#3d3d5c",
      "$type": "color",
      "$description": "Storm Violet — Secondary text, input values, subdued body copy — sits between indigo and gray for medium-emphasis reading"
    },
    "slate": {
      "$value": "#575775",
      "$type": "color",
      "$description": "Slate — Muted inline links, secondary metadata, caption-level annotations"
    },
    "fog": {
      "$value": "#6c7693",
      "$type": "color",
      "$description": "Fog — Helper text, placeholder copy, low-emphasis labels in form and card contexts"
    },
    "ash": {
