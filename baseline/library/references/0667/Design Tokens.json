      "$value": "#321e1e",
      "$type": "color",
      "$description": "Walnut — Primary text color, filled action buttons, dark hero sections, footer wordmark. Deep warm brown that reads as near-black while carrying the brand's earthy warmth — used as both foreground and background surface"
    },
    "linen": {
      "$value": "#f4f1e0",
      "$type": "color",
