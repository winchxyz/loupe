  "font": {
    "sans-serif": {
      "$value": "sans-serif",
      "$type": "fontFamily",
      "$description": "sans-serif — detected in extracted data but not described by AI"
    },
    "general-sans-variable": {
      "$value": "General Sans Variable",
      "$type": "fontFamily",
      "$description": "All display headlines, section headings, card titles, button labels, and emphasis text. Weight 700 is the single weight used — GitBook leans into geometric bold for its editorial authority. Negative tracking tightens at scale: -0.04em at 55px, -0.03em at 45px, -0.02em at 32px. This is the primary visual identity font."
    },
    "general-sans": {
      "$value": "General Sans",
      "$type": "fontFamily",
      "$description": "Lead paragraph and subheading body copy. Weight 500 (medium) is heavier than typical body text — this is the descriptive copy directly under headlines, giving it subtle emphasis without crossing into heading territory."
    },
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "Body text, paragraph copy, table data, dense information areas, and any secondary UI text. Inter is the workhorse — used wherever content density matters. Open-source, system-fallback friendly."
    },
    "geist-mono": {
      "$value": "Geist Mono",
      "$type": "fontFamily",
      "$description": "Code snippets, technical labels, keyboard shortcuts, and monospaced data. Weight 600 gives code blocks presence against the Inter body."
    },
    "general-sans-variable-variable-bold": {
      "$value": "General Sans Variable Variable Bold",
      "$type": "fontFamily",
      "$description": "General Sans Variable Variable Bold — detected in extracted data but not described by AI"
    },
    "space-mono": {
