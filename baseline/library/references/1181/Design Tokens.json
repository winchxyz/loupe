{
  "color": {
    "flame-orange": {
      "$value": "#fe551b",
      "$type": "color",
      "$description": "Flame Orange — Orange outline accent for tags, dividers, and focused UI edges."
    },
    "ink": {
      "$value": "#1c1917",
      "$type": "color",
      "$description": "Ink — Primary action buttons, headlines, body text, primary borders — warm near-black replaces pure black for a softer, editorial feel"
    },
    "paper": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper — Page canvas, button text on dark fills, card surfaces — the dominant background"
    },
    "bone": {
      "$value": "#fafaf9",
      "$type": "color",
      "$description": "Bone — Card backgrounds, subtle surface elevation above the white canvas, link/button ghost states"
    },
    "pebble": {
      "$value": "#efeeed",
      "$type": "color",
      "$description": "Pebble — Nested surface backgrounds, secondary card layers, muted button backgrounds"
    },
    "charcoal": {
      "$value": "#57534d",
      "$type": "color",
      "$description": "Charcoal — Secondary body text, muted borders, description copy — warm gray for paragraph content"
    },
    "stone": {
      "$value": "#79716b",
      "$type": "color",
      "$description": "Stone — Tertiary text, placeholder text, inactive labels, subtle borders"
    },
    "ash": {
      "$value": "#948d89",
      "$type": "color",
      "$description": "Ash — Disabled states, very muted helper text, subtle dividers"
    },
    "true-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "True Black — SVG icon fills, sharp borders where maximum contrast is needed, logo marks"
    }
