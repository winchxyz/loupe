{
  "color": {
    "obsidian": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Obsidian — Primary text, hairlines, icon strokes, borders on light surfaces — the dominant structural color"
    },
    "paper": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper — Page backgrounds, card surfaces, text on dark sections"
    },
    "carbon": {
      "$value": "#161717",
      "$type": "color",
      "$description": "Carbon — Dark surface panels, filled button backgrounds — warm-tinted near-black, not pure black"
    },
    "ember": {
      "$value": "#fe2c02",
      "$type": "color",
      "$description": "Ember — Primary accent — link/CTA emphasis, the one chromatic moment in the system, warm orange-red against the monochrome field"
    },
    "sprout": {
      "$value": "#49de80",
      "$type": "color",
      "$description": "Sprout — Green outline accent for tags, dividers, and focused UI edges"
    },
    "slate": {
      "$value": "#8a8f98",
      "$type": "color",
      "$description": "Slate — Muted helper text, secondary borders, disabled state strokes"
    },
    "iron": {
      "$value": "#202020",
      "$type": "color",
      "$description": "Iron — Secondary text on light surfaces, dark-mode body text"
    },
    "fog": {
      "$value": "#b3b3b3",
      "$type": "color",
      "$description": "Fog — Light borders, placeholder text, subtle dividers"
    },
    "ash": {
      "$value": "#969696",
      "$type": "color",
      "$description": "Ash — Tertiary text, low-emphasis labels"
    },
    "smoke": {
      "$value": "#808080",
      "$type": "color",
      "$description": "Smoke — Muted borders, low-priority separators"
    },
    "stone": {
      "$value": "#666666",
      "$type": "color",
      "$description": "Stone — Tertiary text, metadata"
    },
    "ink": {
      "$value": "#050505",
      "$type": "color",
      "$description": "Ink — Dark borders and separators for elevated surfaces and inverted UI. Do not promote it to the primary CTA color"
    },
    "dusk-fade": {
      "$value": "#0f0e0d",
      "$type": "color",
      "$description": "Dusk Fade — Hero overlay gradient endpoint — top-of-photo darkening for text legibility"
    }
  },
  "font": {
    "sans-serif": {
      "$value": "sans-serif",
      "$type": "fontFamily",
      "$description": "sans-serif — detected in extracted data but not described by AI"
    },
    "emilio-light": {
      "$value": "Emilio Light",
      "$type": "fontFamily",
      "$description": "Display and section headlines — the signature choice. A humanist serif at light weight used at 41-48px creates an editorial, literary voice that contrasts with the AI-tech convention of geometric sans-serif. Letter-spacing tightens to -0.03em at display sizes. Substitute: Cormorant Garamond Light or Libre Caslon Text Light for similar warmth without licensing the custom face."
    },
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "Body text, UI labels, secondary headings, navigation. The workhorse — appears at every size from 8px micro-labels to 44px section headers. Weight 400 is the default, 500 for emphasis."
    },
    "geist-mono": {
      "$value": "Geist Mono",
      "$type": "fontFamily",
      "$description": "Code-adjacent labels, monospace badges, small-caps-style indicators. The slight positive tracking (0.009em) gives it a technical, label-like quality that contrasts with the serif headlines."
    },
    "giga-sans-display": {
      "$value": "Giga Sans Display",
      "$type": "fontFamily",
      "$description": "Custom display sans for sub-headings and card titles. The tight 0.86 line-height at 22px gives a dense, stacked feel. Substitute: Inter at equivalent weight and tracking since the Giga Sans faces are licensed."
    },
    "giga-sans-text": {
      "$value": "Giga Sans Text",
      "$type": "fontFamily",
      "$description": "Custom body sans — essentially an Inter variant. Used for link text and dense body content. Substitute: Inter at 14px/400."
    },
    "inter-display": {
      "$value": "Inter Display",
      "$type": "fontFamily",
      "$description": "Optically-adjusted variant for body display sizes — slightly wider apertures than standard Inter. Substitute: standard Inter."
    },
    "giga-sans-display-trial-400": {
      "$value": "Giga Sans Display Trial 400",
      "$type": "fontFamily",
      "$description": "Giga Sans Display Trial 400 — detected in extracted data but not described by AI"
    },
    "giga-sans-text-trial-400": {
      "$value": "Giga Sans Text Trial 400",
      "$type": "fontFamily",
      "$description": "Giga Sans Text Trial 400 — detected in extracted data but not described by AI"
    }
  },
