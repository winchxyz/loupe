    "plum-deep": {
      "$value": "#481a54",
      "$type": "color",
      "$description": "Plum Deep — Darkest brand surface for full-bleed storytelling sections, header bars — the near-black purple that creates the page's dramatic contrast moments"
    },
    "cream-canvas": {
      "$value": "#fefbff",
      "$type": "color",
      "$description": "Cream Canvas — Page background, dominant canvas — the warm off-white with the faintest purple warmth that distinguishes it from clinical pure white"
