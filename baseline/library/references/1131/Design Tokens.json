    },
    "iris-edge": {
      "$value": "#eac8fe",
      "$type": "color",
      "$description": "Iris Edge — Hairline borders, card outlines, decorative dividers — the lavender 1px line that separates content while staying within the brand family"
    },
    "violet-glow": {
      "$value": "#d17dfe",
