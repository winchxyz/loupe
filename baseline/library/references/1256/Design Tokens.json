{
  "color": {
    "parchment": {
      "$value": "#fefefc",
      "$type": "color",
      "$description": "Parchment — Page canvas, card surfaces, light-section backgrounds — a warm ivory that reads as paper, not screen"
    },
    "ink": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Ink — Dark borders and separators for elevated surfaces and inverted UI. Do not promote it to the primary CTA color"
    },
    "graphite": {
      "$value": "#0a0a0a",
      "$type": "color",
      "$description": "Graphite — Body text, heading strokes, dark surface accents — near-black used wherever ink is too harsh"
    },
    "smoke": {
      "$value": "#6b6b6b",
      "$type": "color",
      "$description": "Smoke — Secondary body copy, subdued borders, caption-level metadata"
    },
    "iron": {
      "$value": "#444444",
      "$type": "color",
      "$description": "Iron — Tertiary text and dividers between smoke and graphite"
    },
    "verdigris-wash": {
      "$value": "#ebf5ed",
      "$type": "color",
      "$description": "Verdigris Wash — Light neutral action fill for buttons on dark surfaces."
    },
    "slate-mist": {
      "$value": "#bdd4f0",
      "$type": "color",
      "$description": "Slate Mist — Soft card surface tint for product preview panels and link highlights — a desaturated cool blue that lives in the background, never the foreground"
    },
    "pewter-haze": {
      "$value": "#98a7aa",
      "$type": "color",
      "$description": "Pewter Haze — Muted placeholder tint on empty illustration frames and disabled control fills"
    }
  },
  "font": {
    "sans-serif": {
      "$value": "sans-serif",
      "$type": "fontFamily",
      "$description": "sans-serif — detected in extracted data but not described by AI"
    },
    "rhymes-display": {
      "$value": "Rhymes Display",
      "$type": "fontFamily",
      "$description": "Display headlines and hero serif. The whisper-weight 300 cut at 88px is the signature move — most legal-tech sites shout in bold sans, Legora murmurs in light serif. The tight -0.02em tracking pulls letters together so the display reads as one continuous voice, not as individual glyphs."
    },
    "suisse-intl": {
      "$value": "Suisse Int'l",
      "$type": "fontFamily",
      "$description": "Primary body and UI text. The 450-book weight at 16px with -0.01em tracking is the workhorse — a humanist sans tuned for long-form legal copy. The 500-medium cut at 13px is reserved for input values and small emphasis labels. The negative leading (0.80) on small sizes tightens tight UI like eyebrow labels and tags."
    },
    "aktiv-grotesk-vf": {
      "$value": "Aktiv Grotesk VF",
      "$type": "fontFamily",
      "$description": "Section subheads and longer body paragraphs where a slightly more neutral grotesk reads cleaner than Suisse Int'l's warmth"
    },
    "suisse-intl-book": {
      "$value": "Suisse Intl Book",
