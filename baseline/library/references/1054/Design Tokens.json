{
  "color": {
    "canvas-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Canvas White — Page background, card surface, image plate — the entire site sits on pure white"
    },
    "ink-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Ink Black — All text, hairline borders, navigation, link underlines, image frames — the sole structural color"
    },
    "terminal-lime": {
      "$value": "#d7ff66",
      "$type": "color",
      "$description": "Terminal Lime — Footer band, surface highlight wash, terminal accent — high-chroma green that signals a page boundary the way a colored edge stops a gallery wall"
    },
    "signal-red": {
      "$value": "#ff1313",
      "$type": "color",
      "$description": "Signal Red — Decorative border strokes, icon outlines, hairline rules in editorial layouts — used at sub-readable contrast as graphic punctuation, never as body text"
    }
  },
  "font": {
    "helveticaneuepro": {
      "$value": "HelveticaNeuePro",
      "$type": "fontFamily",
      "$description": "Universal type family for navigation, body, headings, inputs, and footer — the only weight on the site (400), set in all-caps across the nav and footer, with positive tracking 0.0140em–0.0240em that gives the single weight a mechanical, catalog-like cadence"
    }
  },
