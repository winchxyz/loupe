{
  "color": {
    "bone": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Bone — Primary canvas, card surfaces, button text on dark bands — the dominant air of the system"
    },
    "ash-mist": {
      "$value": "#efefef",
      "$type": "color",
      "$description": "Ash Mist — Light supporting surface for subtle backgrounds and section separation. Do not promote it to the primary CTA color"
    },
    "vault-ink": {
      "$value": "#0f111a",
      "$type": "color",
      "$description": "Vault Ink — Primary heading text, dark band backgrounds, footer surface — the near-black that carries all authority and seals dark chambers"
    },
    "absolute": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Absolute — Deepest dark band background, high-contrast text on light surfaces — used where absolute weight is required"
    },
    "carbon": {
      "$value": "#141414",
      "$type": "color",
      "$description": "Carbon — Secondary dark surface, border on dark sections — one shade lighter than Absolute for layered darkness"
    },
    "charcoal": {
      "$value": "#2a2a2a",
      "$type": "color",
      "$description": "Charcoal — Supporting neutral for secondary UI, dividers, and muted labels. Do not promote it to the primary CTA color"
    },
    "graphite": {
      "$value": "#222222",
      "$type": "color",
      "$description": "Graphite — Dark border, secondary text on dark surfaces, image overlay tones"
    },
    "silver-veil": {
      "$value": "#aeaeae",
      "$type": "color",
      "$description": "Silver Veil — Muted card text, disabled states, secondary metadata — the quietest readable neutral"
    },
    "frost": {
      "$value": "#a6b8d1",
      "$type": "color",
      "$description": "Frost — Decorative border, link accent on dark, subtle cool-tinted hairline — the only chromatic whisper in the neutral stack"
    },
    "cobalt-signal": {
      "$value": "#1c53bd",
      "$type": "color",
      "$description": "Cobalt Signal — Gradient origin — small icon accents, arrow markers, chromatic punctuation on otherwise monochrome controls"
    },
    "electric-sky": {
      "$value": "#53adfe",
      "$type": "color",
      "$description": "Electric Sky — Gradient terminus — the bright terminal of the blue mark, always paired with Cobalt Signal as a gradient pair"
    }
  },
  "font": {
    "interdisplay": {
      "$value": "Interdisplay",
      "$type": "fontFamily",
      "$description": "Primary workhorse — body copy, UI controls, nav, and most headings. Carries the system's voice at 400 weight only; variation comes from size and tracking, not weight. Single-weight usage is a signature choice: the system never bolds, only scales."
    },
    "roobert": {
      "$value": "Roobert",
      "$type": "fontFamily",
      "$description": "Display and feature headings, hero typography, emphasis text. Used at the top of the hierarchy where 90–96px sizes demand a typeface with more open counters and personality. Also appears in nav and inputs for tactile warmth against Interdisplay's neutrality."
    },
    "inter-24-pt": {
      "$value": "Inter 24 Pt",
      "$type": "fontFamily",
      "$description": "Secondary body, card copy, link text, image captions — a quieter Inter variant for less prominent content areas where Interdisplay would feel too dominant"
    },
    "fragmentmono": {
      "$value": "Fragmentmono",
      "$type": "fontFamily",
      "$description": "Monospaced accent for nav labels, link IDs, technical metadata, heading eyebrows — a typewriter whisper that signals precision and protocol"
    },
    "aeonik-mono": {
      "$value": "Aeonik Mono",
      "$type": "fontFamily",
      "$description": "Rare monospaced flourish for signature inline moments — used as the tiniest typographic exclamation in the system"
    }
  },
