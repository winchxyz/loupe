{
  "color": {
    "void-base": {
      "$value": "#0e0918",
      "$type": "color",
      "$description": "Void Base — Primary page background and hero section — the near-black violet creates depth without being neutral charcoal"
    },
    "elevated-surface": {
      "$value": "#1a1624",
      "$type": "color",
      "$description": "Elevated Surface — Card backgrounds (rgb(26,22,36)) — one step above void, visible as panels"
    },
    "deep-panel": {
      "$value": "#1b1728",
      "$type": "color",
      "$description": "Deep Panel — Secondary card surface (rgb(27,23,40)) — close to Elevated Surface, used for 24px-radius feature cards"
    },
    "muted-shell": {
      "$value": "#2c2834",
      "$type": "color",
      "$description": "Muted Shell — Ghost button backgrounds — semi-transparent frosted layer over dark surfaces"
    },
    "border-smoke": {
      "$value": "#3e3a46",
      "$type": "color",
      "$description": "Border Smoke — Nav and container borders — low-contrast edge definition on dark surfaces"
    },
    "ash-text": {
      "$value": "#d1cece",
      "$type": "color",
      "$description": "Ash Text — Primary body and UI text — warm-gray rather than pure white, reducing harshness against dark bg"
    },
    "fog-text": {
      "$value": "#9d9797",
      "$type": "color",
      "$description": "Fog Text — Secondary body text, captions, de-emphasized labels"
    },
    "silver-rail": {
      "$value": "#e5e7eb",
      "$type": "color",
      "$description": "Silver Rail — Border lines across components and nav — light border on dark background creates fine hairline edges"
    },
    "cloud-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Cloud White — High-emphasis headings, icon fills, badge text, active nav items"
    },
    "steel-muted": {
      "$value": "#48556a",
      "$type": "color",
      "$description": "Steel Muted — Badge text on light badge backgrounds"
    },
    "ember-cta": {
      "$value": "#fd8925",
      "$type": "color",
      "$description": "Ember CTA — Primary CTA buttons — orange-to-red gradient (rgb(253,137,37) → rgb(255,12,0)) burns against the dark void; the only warm-chromatic element above the fold, creating immediate focal pull"
    },
    "electric-current": {
      "$value": "#077ac7",
      "$type": "color",
      "$description": "Electric Current — Link underline glow, active focus rings, node connection lines in workflow canvas — blue-to-violet gradient (rgb(7,122,199) → rgb(107,33,239)) signals data flow and connectivity"
    },
    "ember-scorch": {
      "$value": "#ff492c",
      "$type": "color",
      "$description": "Ember Scorch — Icon fills and secondary highlight accents — pure saturated red-orange for SVG emphasis marks"
    },
    "crimson-glow": {
      "$value": "#56312d",
      "$type": "color",
      "$description": "Crimson Glow — Card box-shadow tint — dark muted red used in shadow layers beneath cards, creating a heat-haze underneath panels"
    }
  },
  "font": {
    "geomanist": {
      "$value": "geomanist",
      "$type": "fontFamily",
      "$description": "The sole display and body typeface. Weight 300 at 48–54px is the defining choice — headlines whisper against the dark background rather than asserting. Weight 400 handles body copy at 15–18px with 1.5–1.7 line-height for comfortable reading in dark contexts. The compressed line-height of 0.88 at 54px stacks headline lines into a dense visual block."
    },
    "geomanist-book": {
      "$value": "geomanist-book",
      "$type": "fontFamily",
      "$description": "Medium-emphasis subheadings and section labels. The 'book' variant sits optically between 300 and regular 400, used for callout text in feature cards and section introductions at 20–24px."
    }
  },
