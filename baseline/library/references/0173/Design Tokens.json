{
  "color": {
    "butter-highlight": {
      "$value": "#fbda5f",
      "$type": "color",
      "$description": "Butter Highlight — Yellow accent for outlined action borders, linked labels, and lightweight interactive emphasis. Do not promote it to the primary CTA color"
    },
    "signal-blue": {
      "$value": "#006aff",
      "$type": "color",
      "$description": "Signal Blue — Link and icon accent for secondary navigation and store-badge fills — cool counterpoint to the warm yellow, never used for primary CTAs"
    },
    "ink": {
      "$value": "#0d0d0d",
      "$type": "color",
      "$description": "Ink — Body text, heading text, card borders, hairline dividers — the dominant near-black that carries almost all typography and outlines"
    },
    "pure-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Pure Black — Hard-edge borders on feature band cards, icon fills, and the inverted footer band where it provides maximum contrast against yellow text"
    },
    "paper": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper — Page canvas, card backgrounds, and the negative space inside inverted black bands — the surface everything else sits on"
    },
    "fog": {
      "$value": "#edeef0",
      "$type": "color",
      "$description": "Fog — Soft feature-band surface (alternates with Butter Highlight and Pure Black), subtle card backgrounds, neutral pill borders and text"
    },
    "stone": {
      "$value": "#e5e4e3",
      "$type": "color",
      "$description": "Stone — Warm-leaning neutral for card surfaces and background variation where Fog feels too cool"
    },
    "charcoal": {
      "$value": "#333333",
      "$type": "color",
      "$description": "Charcoal — Deep surface fill used inside the dark footer band and as an elevated neutral surface"
    },
    "mist": {
      "$value": "#999999",
      "$type": "color",
      "$description": "Mist — Muted helper text, list dividers, and secondary metadata where Ink would carry too much weight"
    },
    "silver": {
      "$value": "#cccccc",
      "$type": "color",
      "$description": "Silver — Hairline borders, low-emphasis dividers, and the single drop shadow tint used on elevated cards"
    }
  },
  "font": {
    "phudu": {
      "$value": "Phudu",
      "$type": "fontFamily",
      "$description": "Display and heading typeface — used for every oversized headline, feature-band title, and section header. The extreme weight contrast (400 vs 700) and ultra-tight 0.90 line-height give SaveDay its poster identity. Letterspacing runs from -0.04em at 112px down to -0.02em at 24px, pulling glyphs into a dense, almost monoline block."
    },
    "interdisplay": {
      "$value": "InterDisplay",
      "$type": "fontFamily",
      "$description": "UI, body, and small-heading workhorse — paragraphs, button labels, nav links, FAQ text, badge text, card subtext. The slight negative tracking (-0.018em to -0.024em) keeps the grotesque crisp at small sizes without feeling mechanical. Always paired with a relaxed 1.50 line-height for body and 1.20 for UI labels."
    }
  },
