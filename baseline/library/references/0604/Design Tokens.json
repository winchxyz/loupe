      "$value": "#fafafb",
      "$type": "color",
      "$description": "Bone White — Primary canvas, card surfaces, button text, input fills"
    },
    "graphite-ink": {
      "$value": "#2c2c2b",
      "$type": "color",
      "$description": "Graphite Ink — Primary borders, hairline dividers, link underlines, heading accents"
    },
    "deep-coal": {
      "$value": "#1f1f1f",
      "$type": "color",
      "$description": "Deep Coal — High-contrast neutral action fill for primary buttons on light surfaces."
    },
    "obsidian": {
      "$value": "#111111",
      "$type": "color",
      "$description": "Obsidian — Body and heading text at maximum weight, dark hero overlays, icon strokes"
    },
    "press-black": {
      "$value": "#080808",
      "$type": "color",
      "$description": "Press Black — Hardest text and button fills where pure black is needed for contrast over warm photography"
    },
    "stone": {
      "$value": "#70706f",
      "$type": "color",
      "$description": "Stone — Secondary body text, helper copy, muted icon strokes"
    },
    "fog": {
      "$value": "#cbcbcb",
      "$type": "color",
      "$description": "Fog — Disabled button borders, low-emphasis outlines, decorative hairlines"
    },
    "ash-gray": {
      "$value": "#e3e3e3",
      "$type": "color",
      "$description": "Ash Gray — Badge fills, input borders, tag backgrounds — the lightest non-canvas neutral"
    },
    "cloud": {
      "$value": "#ededed",
      "$type": "color",
      "$description": "Cloud — Elevated card backgrounds, subtle surface lift above the canvas"
    },
    "slate": {
      "$value": "#444444",
      "$type": "color",
      "$description": "Slate — Mid-weight button borders, heavy outlines on dark surfaces"
    }
  },
  "font": {
    "gestura-custom-serif": {
      "$value": "Gestura (custom serif)",
      "$type": "fontFamily",
      "$description": "Display and editorial headlines. The serif is the brand's single most recognizable choice — it converts what would be a standard AI-tool landing into a financial-broadsheet feel. Used at 36-66px for hero/section headlines and at 20-30px for subheadings."
    },
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "All functional UI: body, nav, buttons, inputs, badges, footers. Carries the system's information while the serif does the emotional work. Uppercase eyebrows at 12-14px with +0.14em tracking are the consistent section-opener pattern."
    }
  },
