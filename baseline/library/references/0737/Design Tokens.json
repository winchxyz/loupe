      "$description": "Ash — Muted UI chrome, disabled states, tertiary borders"
    },
    "frost-text": {
      "$value": "#f3f3f3",
      "$type": "color",
      "$description": "Frost Text — Primary text, headings, body copy — slightly off-white so it sits softer than pure #fff against the dark canvas"
    },
    "silver": {
      "$value": "#c1c1c1",
