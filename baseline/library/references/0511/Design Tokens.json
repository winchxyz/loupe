    "fira-code": {
      "$value": "Fira Code",
      "$type": "fontFamily",
      "$description": "Reserved for code-as-heading treatments and developer-facing copy blocks — the monospace signal tells the reader 'this is code or technical content' even when displayed at heading size. Tracking is widened to 0.08em to keep monospace headings legible"
    }
  },
