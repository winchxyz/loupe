{
  "color": {
    "ink-navy": {
      "$value": "#0c1754",
      "$type": "color",
      "$description": "Ink Navy — Display headings, dark feature cards, footer background, body text on light canvas — the editorial weight color, used wherever the page needs to feel considered rather than decorative"
    },
    "electric-cobalt": {
      "$value": "#2545ff",
      "$type": "color",
      "$description": "Electric Cobalt — Violet supporting accent for decorative details and low-frequency emphasis. Do not promote it to the primary CTA color"
    },
    "charcoal": {
      "$value": "#171417",
      "$type": "color",
      "$description": "Charcoal — Primary body and heading text, nav text, icon strokes on light surfaces"
    },
    "warm-canvas": {
      "$value": "#f9f8f6",
      "$type": "color",
      "$description": "Warm Canvas — Page background, footer surface, soft card fills, input backgrounds — the unifying warm off-white"
    },
    "paper-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper White — Elevated card surfaces, button text, nav background, input fields, icon fills on dark"
    },
    "cream-border": {
      "$value": "#f0e9e1",
      "$type": "color",
      "$description": "Cream Border — Hairline dividers, card borders, subtle section separators — replaces the typical cool gray to keep the page warm"
    },
    "graphite": {
      "$value": "#222222",
      "$type": "color",
      "$description": "Graphite — Secondary text, button text in outlined/ghost states, nav inactive labels"
    },
    "stone": {
      "$value": "#969696",
      "$type": "color",
      "$description": "Stone — Muted helper text, placeholder content, tertiary metadata"
    },
    "smoke": {
      "$value": "#cccccc",
      "$type": "color",
      "$description": "Smoke — Input borders, disabled form states, neutral dividers on white"
    },
    "lavender-mist": {
      "$value": "#eaebf8",
      "$type": "color",
      "$description": "Lavender Mist — Tinted badge backgrounds, soft highlight washes on white surfaces — a whisper of the electric blue"
    }
  },
  "font": {
    "martinaplantijn": {
      "$value": "Martinaplantijn",
      "$type": "fontFamily",
      "$description": "Display serif reserved for the largest hero and section headlines (40-64px). Its italic cuts carry the brand voice — the words that bend feel personal and editorial, breaking the SaaS monotone. Substitute: a humanist serif like GT Super or Tiempos Text."
    },
    "abcfavoritvariable": {
      "$value": "Abcfavoritvariable",
      "$type": "fontFamily",
      "$description": "Geometric sans for sub-headings, step labels, and eyebrow text (16-40px). Tight tracking at large sizes (-0.05em) is the signature — it makes the type feel modern and compressed against the serif display. The ss01/ss04 alternates likely swap in single-story 'a' and more open terminals. Substitute: ABC Diatype Mono or Inter Tight."
    },
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "Workhorse for body copy, button labels, nav items, form fields, captions, and footer text. Stays neutral so the serif display and Abcfavorit can carry personality. The ss01/ss04 features are inherited to keep the typographic family consistent across all three faces."
    }
  },
