{
  "color": {
    "obsidian": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Obsidian — Neutral form states, badge text, and quiet UI feedback where color should stay understated. Do not promote it to the primary CTA color"
    },
    "bone-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Bone White — Page canvas, product card backgrounds, modal surfaces — the base everything sits on"
    },
    "vellum-cream": {
      "$value": "#f7f5e8",
      "$type": "color",
      "$description": "Vellum Cream — Warm off-white used for color-block hero panels, editorial sections, and the newsletter module background — the only chromatic surface in the system"
    },
    "charcoal": {
      "$value": "#231f20",
      "$type": "color",
      "$description": "Charcoal — Near-black for body copy on white and cream surfaces — slightly softer than pure obsidian, preserving AAA contrast on the warm cream"
    },
    "pewter": {
      "$value": "#888888",
      "$type": "color",
      "$description": "Pewter — Muted icon strokes, separators, and secondary graphic details."
    },
    "dahlen-rust": {
      "$value": "#b94e3a",
      "$type": "color",
      "$description": "Dahlen Rust — Supporting palette color for small decorative accents when the core palette needs contrast."
    }
  },
