    },
    "ash": {
      "$value": "#8e8e93",
      "$type": "color",
      "$description": "Ash — Pill-shaped navigation markers, muted icon strokes, secondary UI chrome"
    },
    "slate": {
      "$value": "#1a1a1a",
      "$type": "color",
      "$description": "Slate — Dark card tile background variant (near-black) — deeper than Ink, used when a tile needs a subtly softer dark than pure black"
    }
  },
  "font": {
    "graphik-custom": {
      "$value": "Graphik (custom)",
      "$type": "fontFamily",
      "$description": "Display and heading family. 24px/600 for section openers like 'iconwerk,' 21–22px/400 for larger body passages, 16px/400 for standard body. The 1.18–1.21 line-height range is tight — heading text feels compact and confident rather than airy."
    },
    "arial": {
      "$value": "Arial",
      "$type": "fontFamily",
      "$description": "System fallback / dense utility text at 14px. Used at small sizes throughout — link labels, helper copy. Its system-font nature keeps it invisible; it never carries brand weight, only function."
    }
  },
