{
  "color": {
    "ink": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Ink — Primary headings, body text, and icon fills on light surfaces. Do not promote it to the primary CTA color"
    },
    "paper": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper — Page background, text on dark tiles, inverse surfaces — the canvas everything sits on"
    },
    "fog": {
