{
  "color": {
    "cream-paper": {
      "$value": "#f5f4f0",
      "$type": "color",
      "$description": "Cream Paper — Page background, canvas — warm off-white that softens the overall feel and keeps the pastel accents from vibrating against pure white"
    },
    "pure-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Pure White — Card and button surfaces — sits one elevation above the cream canvas"
    },
    "ink-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Ink Black — Primary text, hairline borders, icon strokes, card outlines — the dominant structural color, 3625 occurrences make it the spine of every layout"
    },
    "charcoal": {
      "$value": "#222222",
      "$type": "color",
