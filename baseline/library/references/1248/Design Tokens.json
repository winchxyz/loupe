{
  "color": {
    "forest-ink": {
      "$value": "#09352e",
      "$type": "color",
      "$description": "Forest Ink — Primary text, icons, and chart strokes — the load-bearing dark color. Reads near-black but carries a cool green undertone that ties the monochrome system together"
    },
    "bone-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Bone White — Card surfaces, data point fills, and reverse text on dark blocks"
    },
    "sage-paper": {
      "$value": "#e0e0e0",
      "$type": "color",
      "$description": "Sage Paper — Page canvas and large background fields. A green-tinted light gray that gives the whole surface its herbarium character"
    },
    "ash-gray": {
      "$value": "#e5e5e5",
      "$type": "color",
      "$description": "Ash Gray — Alternate surface tone for nested blocks, inset panels, and subtle differentiation beneath cards"
    },
    "muted-sage": {
      "$value": "#77aa83",
      "$type": "color",
      "$description": "Muted Sage — Soft fill washes, scatter plot halos, and decorative surface tints that sit behind darker data marks"
    },
    "lichen": {
      "$value": "#cad3d2",
      "$type": "color",
      "$description": "Lichen — Hairline borders, dotted gridlines, and chart axes. The structural line color when a neutral needs to be present without competing with text"
    },
    "slate-smoke": {
      "$value": "#6c7a79",
      "$type": "color",
      "$description": "Slate Smoke — Secondary metadata, icon strokes, and caption text where the body tone is too heavy"
    },
    "charcoal-bark": {
      "$value": "#29211e",
      "$type": "color",
      "$description": "Charcoal Bark — Deep text, heavy borders, and dark surface blocks. Slightly warm-neutral, used for the rare dark panel and strong dividers"
    },
    "moss": {
      "$value": "#85c093",
      "$type": "color",
      "$description": "Moss — The single filled action color — primary buttons, active state fills, and the rare chromatic surface. A soft, slightly desaturated mint that does not shout against the sage canvas"
    },
    "deep-fern": {
      "$value": "#007010",
      "$type": "color",
      "$description": "Deep Fern — Green text accent for links, tags, and emphasized short phrases. Do not promote it to the primary CTA color"
    },
    "pine": {
      "$value": "#117025",
      "$type": "color",
      "$description": "Pine — Green text accent for links, tags, and emphasized short phrases. Do not promote it to the primary CTA color"
    },
    "emerald": {
      "$value": "#008023",
      "$type": "color",
      "$description": "Emerald — Alternate data-mark fill and emphasis backgrounds, used on scatter plot points and callout chips"
    },
    "indigo-accent": {
      "$value": "#433787",
      "$type": "color",
      "$description": "Indigo Accent — A single chromatic exception — used on one special link or annotation to break the green-only system. Employ rarely; treat as a punctuation mark, not a palette member"
    }
  },
  "font": {
    "denim": {
      "$value": "denim",
      "$type": "fontFamily",
      "$description": "Primary workhorse — body copy, headings, and UI text. Weight 500 is used for headings and emphasis; weight 400 carries all body. Tracking sits at a slightly open +0.012em at body sizes, making the face feel like a working tool rather than a display face."
    },
    "muoto": {
      "$value": "muoto",
      "$type": "fontFamily",
      "$description": "Compact UI sans for tags, labels, captions, axis tick text, and micro-copy. Tight negative tracking (-0.009 to -0.012em) at 11–13px makes it dense and instrument-like rather than friendly. Weight 500 is reserved for uppercase labels."
    },
    "cinetype": {
      "$value": "cinetype",
      "$type": "fontFamily",
      "$description": "Decorative tracking-heavy display face used only on ALL-CAPS labels, axis titles, and stamp-like badges. Tracking swings from a tight -0.008em to an extreme +0.30em, which is the visual signature of the system — it produces the 'specimen label' feel on tags and section markers."
    }
  },
