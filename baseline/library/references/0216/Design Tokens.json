  "font": {
    "neue-haas-grotesk-display": {
      "$value": "Neue Haas Grotesk Display",
      "$type": "fontFamily",
      "$description": "Body, subheads, small labels, button text, nav, form copy — the workhorse neo-grot at 12–72px. Weight 450 is the signature mid-weight for body copy; 500 for nav and labels; 400 for de-emphasized body. Letter-spacing tightens from 0.0200em at 12px to -0.0200em at 72px. Substitute: Inter, Söhne, or Neue Haas Grotesk Text Pro."
    },
    "national-2-compressed": {
      "$value": "National 2 Compressed",
      "$type": "fontFamily",
      "$description": "Display headlines only — used at 56–147px with line-height 0.80–0.95, the ultra-condensed proportions make type behave as a graphic block; weight 450 for default, 700 for maximum-impact stat callouts. Substitute: Oswald (700/600) or Antonio Bold. Letter-spacing: -0.0100em across the scale."
    },
