{
  "color": {
    "plaster-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Plaster White — Primary canvas for the light sections; text color on the dark sections; hairline dividers on the dark sections"
    },
    "carbon": {
      "$value": "#111111",
      "$type": "color",
      "$description": "Carbon — Page background for the dark/film section; primary body text on light sections; structural fill for project name typography"
    },
    "ink-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Ink Black — Secondary text and fill on light sections; used where maximum contrast is needed against the white canvas"
    },
    "graphite": {
      "$value": "#2b2b2b",
      "$type": "color",
      "$description": "Graphite — Subtle darker border for low-emphasis rules on light surfaces"
    }
  },
  "font": {
    "teg": {
      "$value": "Teg",
      "$type": "fontFamily",
      "$description": "Display — reserved for the largest project names and the hero text. The aggressive -0.033em tracking at 86px tightens the letters into a near-monolithic block; this is the font that creates the 'stacked concrete' reading. Substitute: Migra, Editorial New, or Canela Display."
    },
    "beatrice-display": {
      "$value": "Beatrice Display",
      "$type": "fontFamily",
      "$description": "Mid-scale editorial type — appears as secondary project list text alongside the larger Teg names, providing typographic counterpoint at a calmer scale. Substitute: Tiempos Headline, Canela, or Reckless."
    },
    "beatrice": {
      "$value": "Beatrice",
      "$type": "fontFamily",
      "$description": "Body-weight Beatrice variant for the same 26px role but with the text-figure character set. Substitute: same as Beatrice Display."
    },
    "diatype": {
      "$value": "Diatype",
      "$type": "fontFamily",
      "$description": "Workhorse sans for body copy, nav items, and supporting text. Weight 500 is the default; 700 is reserved for the nav name 'Ben Powell' to give it anchor weight in the distributed nav. Substitute: Söhne, Inter, or ABC Diatype."
    },
    "new-grotesk": {
      "$value": "New Grotesk",
      "$type": "fontFamily",
      "$description": "Wide-tracked all-caps label face for section markers ('Design', 'Film'). The extreme +0.069em tracking turns short words into spaced-out type-art — this is the system's only 'decorative' choice. Substitute: ABC Diatype Mono Upper, Space Grotesk, or Neue Haas Grotesk Display."
    }
  },
