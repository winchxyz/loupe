{
  "color": {
    "apple-blue": {
      "$value": "#0071e3",
      "$type": "color",
      "$description": "Apple Blue — Filled action buttons, selected states — the only chromatic interactive color, used sparingly so each appearance carries weight"
    },
    "link-blue": {
      "$value": "#0066cc",
      "$type": "color",
      "$description": "Link Blue — Outlined action borders, inline links — deeper saturation than Apple Blue, used where a filled pill would be too loud"
    },
    "signal-blue": {
      "$value": "#2997ff",
      "$type": "color",
      "$description": "Signal Blue — Decorative borders, image outlines, icon strokes — the lightest blue in the system, used for atmospheric emphasis rather than interaction"
    },
    "carbon": {
      "$value": "#1d1d1f",
      "$type": "color",
      "$description": "Carbon — Primary text, heading borders, nav rules, card borders — the dominant ink color, near-black with a whisper of warmth"
    },
    "frost": {
      "$value": "#f5f5f7",
      "$type": "color",
      "$description": "Frost — Page canvas, body backgrounds, footer surface — the signature Apple light gray, slightly cooler than pure white"
    },
    "ice": {
      "$value": "#f4f8fb",
      "$type": "color",
      "$description": "Ice — Elevated surface washes, subtle fills, button text on dark backgrounds — barely-blue tint that lifts a section without declaring it"
    },
    "smoke": {
      "$value": "#333333",
      "$type": "color",
      "$description": "Smoke — Secondary text, nav fills, button borders — the workhorse neutral for borders and icons that need more presence than mid-gray"
    },
    "graphite": {
      "$value": "#474747",
      "$type": "color",
      "$description": "Graphite — Nav text, nav borders, link borders — sits between Carbon and Smoke for tertiary hierarchy"
    },
    "ash": {
      "$value": "#707070",
      "$type": "color",
      "$description": "Ash — Footer text, list borders, nav borders, muted body text — the mid-gray for content that should be present but quiet"
    },
    "mist": {
      "$value": "#858585",
      "$type": "color",
      "$description": "Mist — Body borders, icon strokes, button borders — the lightest functional gray, for hairline rules on light surfaces"
    },
    "onyx": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Onyx — Heading borders, nav borders, dark image backgrounds — true black for maximum contrast in promotional and heading contexts"
    },
    "pebble": {
      "$value": "#e2e2e5",
      "$type": "color",
      "$description": "Pebble — Button background fills, disabled surfaces — the only near-white surface that is deliberately grayer than the canvas"
    }
  },
  "font": {
    "sf-pro-display": {
      "$value": "SF Pro Display",
      "$type": "fontFamily",
      "$description": "Display headlines and large feature text — sizes 40px+ use the display cut for tighter aperture and stronger negative tracking; 700 reserved for promotional lockups, 400 for editorial product names"
    },
    "sf-pro-text": {
      "$value": "SF Pro Text",
      "$type": "fontFamily",
      "$description": "Body, navigation, buttons, subheads — the working typeface; 400 for body copy, 300 for subheads and refined labels, 600 for nav items and button text; negative tracking tightens proportionally with size (-0.022em at 12px down to -0.01em at 44px)"
    }
  },
