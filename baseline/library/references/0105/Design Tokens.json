{
  "color": {
    "ink": {
      "$value": "#14171f",
      "$type": "color",
      "$description": "Ink — Primary text, headings, icon strokes, hairline borders, deep surfaces — the near-black backbone that makes white space read as gallery rather than form"
    },
    "paper": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper — Primary canvas and card surface — the default ground for the entire directory"
    },
    "mist": {
      "$value": "#f5f6f9",
      "$type": "color",
      "$description": "Mist — Secondary surface for subtle bands, input fills, and tag/chip backgrounds that need to sit just behind Paper"
    },
    "hairline": {
      "$value": "#e5e7eb",
      "$type": "color",
      "$description": "Hairline — Borders, dividers, and outlined-button strokes — the thinnest visible structural line"
    },
    "slate": {
      "$value": "#677084",
      "$type": "color",
      "$description": "Slate — Secondary body text and muted nav labels — never used as a primary heading color"
    },
    "fog": {
      "$value": "#9ba2b0",
      "$type": "color",
      "$description": "Fog — Tertiary text, placeholder text, disabled labels"
    },
    "graphite": {
      "$value": "#373f51",
      "$type": "color",
      "$description": "Graphite — Dark borders and separators for elevated surfaces and inverted UI."
    },
    "charcoal": {
      "$value": "#222834",
      "$type": "color",
      "$description": "Charcoal — Primary filled button background, elevated card surface, and tag pill fill — the single non-neutral action color"
    },
    "deep-ink": {
      "$value": "#050505",
      "$type": "color",
      "$description": "Deep Ink — Heaviest text weight and maximum-contrast border accents on dark cards"
    },
    "pearl": {
      "$value": "#d0d4dc",
      "$type": "color",
      "$description": "Pearl — Icon strokes on white surfaces and faint structural outlines"
    },
    "iris": {
      "$value": "#6a57e3",
      "$type": "color",
      "$description": "Iris — Category/challenge card background — vivid violet used as one of the rotating card-fill colors"
    },
    "lilac": {
      "$value": "#ddd8ff",
      "$type": "color",
      "$description": "Lilac — Soft violet wash for decorative surfaces and pale category cards"
    },
    "orchid": {
      "$value": "#cd74dd",
      "$type": "color",
