    "hero-wash": {
      "$value": "#9ddef9",
      "$type": "color",
      "$description": "Hero Wash — Hero background gradient running from icy cyan through sky blue into soft violet — the only multi-color wash on the page"
    }
  },
  "font": {
    "gt-standard-m": {
      "$value": "GT Standard M",
      "$type": "fontFamily",
      "$description": "Workhorse for body text, navigation, buttons, labels, input fields, and most headings up to 24px. The 15–16px body with tight -0.01em tracking and generous 1.50 line-height is what gives Contra its editorial-density feel without sacrificing legibility."
    },
    "gt-standard-l": {
      "$value": "GT Standard L",
      "$type": "fontFamily",
      "$description": "Reserved for the largest display moments (the 58px hero headline) and small uppercase eyebrows (8px at 0.15em tracking). The 0.88–1.05 line-heights at display sizes let the headline 'Get more creative' sit on a single tight block — a magazine-cover move, not a UI move."
    }
  },
