      "$value": "#594ff4",
      "$type": "color",
      "$description": "Signal Violet — Primary action fill, active links, brand iconography — the only chromatic color in the system, creating high-contrast urgency against the monochrome canvas"
    },
    "inkstone": {
      "$value": "#1f1f1f",
      "$type": "color",
