  "font": {
    "aeonik": {
      "$value": "Aeonik",
      "$type": "fontFamily",
      "$description": "Primary brand typeface for all text — geometric sans with weights 500 (medium) for body/UI and 700 (bold) for headlines. The 72px/56px display sizes paired with tight 1.05–1.10 line-heights create architectural headlines that feel constructed rather than editorial. Tracking of 0.075em applies to uppercase eyebrows and headings, giving them a premium, slightly-spaced cadence."
    },
    "rubik": {
      "$value": "Rubik",
      "$type": "fontFamily",
      "$description": "Minor inline use only — appears in small widget contexts, not the primary system font"
    }
  },
