  "font": {
    "shne-custom": {
      "$value": "Söhne (custom)",
      "$type": "fontFamily",
      "$description": "Söhne is the only typeface across the system. Weight 100 is used at display scale (60px) to make the hero whisper rather than shout — most brands push 700 at this size; Söhne 100 inverts the convention and creates editorial weight through restraint. Weight 400 handles body and UI text, 600 covers subheadings and emphasis, 700 reserves itself for button labels and strong CTAs. The wide 100–700 range means the same family can do both ethereal display and utilitarian UI without switching typefaces."
    }
  },
