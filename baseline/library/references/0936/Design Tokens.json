{
  "color": {
    "dribbble-pink": {
      "$value": "#ea4c89",
      "$type": "color",
      "$description": "Dribbble Pink — Brand signature accent — search submit button, PRO badge, logo mark, active heart, hover pulses — one vivid magenta against the monochrome canvas makes the brand unmistakable at any size"
    },
    "midnight-ink": {
      "$value": "#0d0c22",
      "$type": "color",
      "$description": "Midnight Ink — Primary text, filled primary buttons, dark surface fills, icon strokes — a near-black with a cool blue undertone that reads warmer than pure black against white"
    },
    "deep-plum": {
      "$value": "#060318",
      "$type": "color",
      "$description": "Deep Plum — Navigation bar fill, darkest text tokens, logo wordmark — slightly cooler and deeper than Midnight Ink for the fixed header band"
    },
    "charcoal-plum": {
      "$value": "#3d3d4e",
      "$type": "color",
      "$description": "Charcoal Plum — Supporting neutral for secondary UI, dividers, and muted labels. Do not promote it to the primary CTA color"
    },
    "smoke": {
      "$value": "#6e6d7a",
      "$type": "color",
      "$description": "Smoke — Secondary/muted body text, helper labels, view-count and heart-count numbers — carries the dense meta layer beneath thumbnails"
    },
    "fog": {
      "$value": "#9e9ea7",
      "$type": "color",
      "$description": "Fog — Tertiary text, placeholder text, disabled icons, checkbox idle state — the lightest readable neutral"
    },
    "mist": {
      "$value": "#f3f3f6",
      "$type": "color",
      "$description": "Mist — Soft surface fill, input field backgrounds, hover wells, secondary panels — the only off-white surface that sits above the page canvas"
    },
    "frost-border": {
      "$value": "#e2e8f2",
      "$type": "color",
      "$description": "Frost Border — Hairline borders, divider lines, input outlines, card edges on hover — a cool-tinted off-white that reads as a boundary, not a fill"
    },
    "muted-plum": {
      "$value": "#524b63",
      "$type": "color",
      "$description": "Muted Plum — Lower-emphasis dark text, link hover in dense lists, designer name secondary line — a washed dark for tertiary copy on white"
    },
    "slate-edge": {
      "$value": "#3a3546",
      "$type": "color",
      "$description": "Slate Edge — Faint dark surfaces, tag backgrounds, low-key dark UI wells — bridges the gap between the deep nav black and the lighter grays"
    },
    "paper": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper — Page canvas, card surfaces, button text on dark fills, input text — the dominant surface of the entire product"
    }
  },
  "font": {
    "mona-sans": {
      "$value": "Mona Sans",
      "$type": "fontFamily",
      "$description": "Sole typeface across the product — Mona Sans is a custom geometric humanist sans drawn by GitHub, used for everything from 9px meta labels to 48px hero headlines. Its openness keeps dense 4-column grids readable, and the 450/500 mid-weights carry the designer's brand without shouting"
    }
  },
