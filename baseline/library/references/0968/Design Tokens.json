    "gt-planar": {
      "$value": "GT-Planar",
      "$type": "fontFamily",
      "$description": "Primary display and body typeface. Weight 300 is reserved for the 95px display headlines, weight 700 drives 42-59px section headings, weight 400 carries 16-22px body. Tight negative tracking at -0.04em on display and -0.02em on sub-display is a signature choice — the letters compress into each other for a sculptural, almost condensed feel"
    },
    "abcrepromono": {
      "$value": "ABCReproMono",
      "$type": "fontFamily",
      "$description": "Monospaced micro-labels for uppercase eyebrow text above headlines, badge tags, and section markers. Line-height 0.79 is aggressive — these labels sit tight and act as typographic punctuation"
    },
    "suisseintl": {
      "$value": "SuisseIntl",
      "$type": "fontFamily",
      "$description": "UI micro-text for nav links, icon-adjacent labels, and small interactive elements. Acts as a secondary voice to GT-Planar for interface chrome"
    }
