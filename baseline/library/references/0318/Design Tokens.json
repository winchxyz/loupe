{
  "color": {
    "bone": {
      "$value": "#fafaf9",
      "$type": "color",
      "$description": "Bone — Page canvas, primary card surface — the off-white paper tone the entire interface sits on, warm enough to feel linen, not bright enough to feel clinical"
    },
    "ink": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Ink — All body type, primary action border, all interactive strokes — the only dark in the system, pure black rather than warm charcoal to create maximum contrast against the cream canvas"
    },
    "stone": {
      "$value": "#e5e2dc",
      "$type": "color",
      "$description": "Stone — Card borders, hairline dividers, subtle section breaks — the warm gray-beige that separates elements without drawing attention"
    },
    "linen": {
      "$value": "#edede7",
      "$type": "color",
      "$description": "Linen — Hairline borders, dividers, input outlines, and card edges on light surfaces. Do not promote it to the primary CTA color"
    },
    "graphite": {
      "$value": "#595959",
      "$type": "color",
      "$description": "Graphite — Card secondary text, muted metadata, price-adjacent labels — the mid-gray that recedes behind the primary ink-black headlines"
    },
    "silt": {
      "$value": "#d6d1c7",
      "$type": "color",
      "$description": "Silt — Neutral form states, badge text, and quiet UI feedback where color should stay understated. Do not promote it to the primary CTA color"
    },
    "blush": {
      "$value": "#ead1d0",
      "$type": "color",
      "$description": "Blush — Decorative accent surface, soft wash behind editorial text blocks, occasional section tints — the dusty rose that nods to botanical petals without becoming saccharine"
    },
    "citron": {
      "$value": "#f3ffa9",
      "$type": "color",
      "$description": "Citron — Promotional highlight surface — used sparingly as a wash behind sale tags, value bundle badges, or limited-edition callouts; pale enough to never compete with product photography"
    }
  },
  "font": {
    "pp-right-grotesk": {
      "$value": "PP Right Grotesk",
      "$type": "fontFamily",
      "$description": "Display headlines and section titles — weight 200 is anti-convention for commerce; the ultra-thin strokes create a calligraphic, editorial whisper that treats product names as poetry rather than slogans. Tight tracking (-0.015em) pulls the delicate strokes into a cohesive block."
    },
    "shne": {
      "$value": "Söhne",
      "$type": "fontFamily",
      "$description": "Primary body, UI, navigation, product names, buttons — the workhorse neutral grotesque. Weight 400 for body copy keeps a quiet editorial feel; weight 500 for navigation and product names adds enough presence to guide the eye. Slight positive tracking on uppercase labels opens them up to read as proper editorial tags."
    },
    "shne-mono": {
      "$value": "Söhne Mono",
      "$type": "fontFamily",
      "$description": "Micro-labels and scent-family tags — used for 'SMOKY & MEDITATIVE', 'BUTTERY & SOFT', 'VALUE BUNDLE' type annotations. The monospace width and widened tracking (0.05em) give these labels a scientific, museum-catalog quality that contrasts with the organic display type."
    }
  },
