{
  "color": {
    "void-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Void Black — Page canvas, all section backgrounds, negative space — the floor everything sits on"
    },
    "spotlight-blue": {
      "$value": "#4490ff",
      "$type": "color",
      "$description": "Spotlight Blue — Primary action, interactive links, roster name listings, focal dot indicator, highlighted borders — the only chromatic voice in an otherwise monochrome system"
    },
    "carbon-slate": {
      "$value": "#1f2937",
      "$type": "color",
      "$description": "Carbon Slate — Headings, heavy borders, structural borders on dark surfaces — near-black with a slight cool cast for separation from the pure black canvas"
    },
    "bone-white": {
      "$value": "#f4efe9",
      "$type": "color",
      "$description": "Bone White — Warm off-white for text and subtle borders — softer than pure white, evoking film stock and gallery walls against the black canvas"
    },
    "pure-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Pure White — Maximum-contrast text and dividers when absolute clarity is needed over photography or dark media"
    },
    "ash-gray": {
      "$value": "#e5e7eb",
      "$type": "color",
      "$description": "Ash Gray — Light-mode surfaces, neutral borders on cards or panels, secondary dividers — provides a paper-like counterpoint when a section lifts off the black canvas"
    }
  },
