{
  "color": {
    "parchment-cream": {
      "$value": "#eeede5",
      "$type": "color",
      "$description": "Parchment Cream — Page canvas, footer surface, and dominant background — the warm off-white that gives the entire site its editorial, paper-like feel"
    },
    "ink-black": {
      "$value": "#232323",
      "$type": "color",
      "$description": "Ink Black — Primary text, all hairline borders, footer ink, and the near-black that forms every structural line on the page"
    },
    "pure-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Pure White — Product card surfaces, alternating section backgrounds, and high-contrast text on dark or photographic surfaces"
    },
    "iron-gray": {
      "$value": "#4a4a4a",
      "$type": "color",
      "$description": "Iron Gray — Secondary body text, subdued borders, and the muted text layer that sits between primary ink and background"
    },
    "soft-stone": {
      "$value": "#ddddda",
      "$type": "color",
      "$description": "Soft Stone — Subtle surface differentiation beneath cards and secondary panels — barely warmer than the cream canvas"
    }
  },
  "font": {
    "spezia-semi-mono": {
      "$value": "Spezia Semi-Mono",
      "$type": "fontFamily",
      "$description": "The workhorse typeface for body copy, navigation links, card text, list items, and most UI labels. Semi-mono construction gives it a precise, typeset quality that reinforces the editorial identity. 700 weight is used sparingly for emphasis within mono-spaced blocks."
    },
    "spezia-medium": {
      "$value": "Spezia Medium",
      "$type": "fontFamily",
      "$description": "Headline and display font — the proportional companion to the Semi-Mono, used for the hero wordmark 'WOVEN' and section titles. Single weight keeps the type system disciplined; contrast comes from size and tracking, not weight."
    },
    "figtree": {
      "$value": "Figtree",
      "$type": "fontFamily",
      "$description": "Small UI utility font for buttons, icon labels, and tight navigation tags. Rounds out the system where a humanist sans feels warmer than the mono family."
    },
    "spezia-semi-mono-light": {
      "$value": "Spezia Semi-Mono Light",
      "$type": "fontFamily",
      "$description": "Lighter voice for inputs, helper text, and link descriptions — a whisper-weight variation that creates hierarchy without bold."
    }
  },
