{
  "color": {
    "ink": {
      "$value": "#241f20",
      "$type": "color",
      "$description": "Ink — Neutral form states, badge text, and quiet UI feedback where color should stay understated. Do not promote it to the primary CTA color"
    },
    "raw-linen": {
      "$value": "#f5f4ee",
      "$type": "color",
      "$description": "Raw Linen — Page canvas and card backgrounds — warm off-white, the signature surface that distinguishes this system from generic white SaaS"
    },
    "white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "White — Elevated card surfaces, badge fills, inverse text on dark buttons"
    },
    "fog": {
      "$value": "#808080",
      "$type": "color",
      "$description": "Fog — Muted helper text, secondary dividers, disabled labels"
    },
    "blush": {
      "$value": "#edcdc2",
      "$type": "color",
      "$description": "Blush — Accent surface wash — hero image tint, product photo backdrop, soft highlight zones"
    },
    "charcoal": {
      "$value": "#26262a",
      "$type": "color",
      "$description": "Charcoal — Darkest UI surface — footer dark bands, chat widget shell, overlaid panels"
    },
    "sage-leaf": {
      "$value": "#8bbd78",
      "$type": "color",
      "$description": "Sage Leaf — Signature accent — top announcement bar, hairline decorative borders, icon strokes, functional green; the brand's quiet living color"
    },
    "heritage-blue": {
      "$value": "#6487ba",
      "$type": "color",
      "$description": "Heritage Blue — Primary action — filled buttons, link underlines, selected states; dusty mid-blue carries trust without corporate coldness"
    },
    "midnight-forest": {
      "$value": "#233735",
      "$type": "color",
      "$description": "Midnight Forest — Dark filled buttons (hero CTA), deep green-black for high-emphasis actions; warmer than charcoal, more sophisticated than black"
    },
    "ember": {
      "$value": "#ff965b",
      "$type": "color",
      "$description": "Ember — NEW badges, notification dots, star ratings, cart count bubble — vivid warm orange used sparingly as functional punctuation"
    }
  },
  "font": {
    "foundersgrotesk": {
      "$value": "FoundersGrotesk",
      "$type": "fontFamily",
      "$description": "Workhorse sans for navigation, product cards, badges, body text, buttons, inputs, icons. The 0.1–0.15em letter-spacing on 13–15px sizes is the signature tracking pattern for uppercase labels (NEW, ORGANIC COTTON, Shop Underwear)."
    },
    "ttramillaslight": {
      "$value": "TTRamillas_Light",
      "$type": "fontFamily",
      "$description": "Editorial serif for hero headline, subhead, and body excerpts. Tight -0.01em tracking and low contrast strokes create a quiet, literary feel that contrasts the geometric sans."
    },
    "gtstandard-m": {
      "$value": "GTStandard-M",
      "$type": "fontFamily",
      "$description": "Specialty text at 17px with 0.025em tracking — used for minimal secondary copy, not a primary face"
    }
  },
