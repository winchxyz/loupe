{
  "color": {
    "obsidian": {
      "$value": "#09090b",
      "$type": "color",
      "$description": "Obsidian — Primary filled button backgrounds, display heading text on white surfaces — the system's anchor dark, nearly true black"
    },
    "ink": {
      "$value": "#18181b",
      "$type": "color",
      "$description": "Ink — Body text, nav text, badge text on light surfaces — one shade lighter than Obsidian, used for reading-weight text"
    },
    "graphite": {
      "$value": "#3f3f46",
      "$type": "color",
      "$description": "Graphite — Button borders, badge backgrounds (dark variant), border strokes across components — the dominant UI border tone"
    },
    "slate": {
      "$value": "#52525b",
      "$type": "color",
      "$description": "Slate — Mid-dark card backgrounds in dark sections, subtle icon fills"
    },
    "steel": {
      "$value": "#71717a",
      "$type": "color",
      "$description": "Steel — Muted body copy, helper text labels such as stat captions"
    },
    "ash": {
      "$value": "#a1a1aa",
      "$type": "color",
      "$description": "Ash — Subdued heading variants, placeholder text, decorative rule strokes"
    },
    "pebble": {
      "$value": "#d4d4d8",
      "$type": "color",
      "$description": "Pebble — Hairline dividers, inactive link backgrounds, lightest visible border on white cards"
    },
    "fog": {
      "$value": "#ececee",
      "$type": "color",
      "$description": "Fog — Card backgrounds (mid variant), badge borders, section dividers — the second surface step above the canvas"
    },
    "mist": {
      "$value": "#f4f4f5",
      "$type": "color",
      "$description": "Mist — Page canvas, light card backgrounds, tag/link hover surface — the dominant background tone"
    },
    "snow": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Snow — White card surfaces, input backgrounds, button fill for outlined variant — the brightest surface in the stack"
    },
    "ember": {
      "$value": "#ff5a00",
      "$type": "color",
      "$description": "Ember — YC batch badge backgrounds — vivid orange signals startup-ecosystem provenance, appears only on badge-sized labels"
    },
    "orchid-flash": {
      "$value": "#fe45e2",
      "$type": "color",
      "$description": "Orchid Flash — Decorative card wash accent — single-use vivid pink on a large card background to punctuate the portfolio grid"
    }
  },
  "font": {
    "cosmica": {
      "$value": "Cosmica",
      "$type": "fontFamily",
      "$description": "The sole typeface across the entire system — every badge, button, nav link, heading, and body copy uses Cosmica. Its wide weight range means all typographic hierarchy is weight-driven rather than family-switching. At 56–64px the light-to-medium weights feel assertive without shouting; at 10–14px the medium-to-semibold weights keep small labels legible at compact density."
    }
  },
