  "font": {
    "suisseintltrial": {
      "$value": "Suisseintltrial",
      "$type": "fontFamily",
      "$description": "Suisseintltrial — detected in extracted data but not described by AI"
    },
    "lyon-display": {
      "$value": "Lyon Display",
      "$type": "fontFamily",
      "$description": "Display serif for editorial headlines — the signature voice. 96px weight 300 for hero ('Own your wealth.'), 80px weight 300 for section openers, 38px weight 400 for medium headings. The italic-leaning weight 300 whispers authority where most fintech sites shout it."
    },
    "suisse-intl": {
      "$value": "Suisse Int'l",
      "$type": "fontFamily",
      "$description": "Sans-serif workhorse for body, subheadings, and UI copy. 18px weight 300 for subheadings, 16px weight 400 for body, 14px for nav and small copy, 12px for micro labels. Geometric humanist proportions give it a neutral-but-warm voice that doesn't compete with the serif."
    },
    "suisse-intl-trial": {
      "$value": "Suisse Int'l Trial",
      "$type": "fontFamily",
      "$description": "Wide-tracked variant for stamped UI labels — nav items, small buttons, card tags. The dramatic 0.182em letter-spacing makes these elements feel pressed, not typed, creating a distinct register between the editorial serif headlines and the quiet body text."
    },
    "roboto-mono": {
      "$value": "Roboto Mono",
      "$type": "fontFamily",
      "$description": "Monospace for chart axes, data values, timestamps, and micro-captions. The 0.182em tracked variant at 11px stamps technical labels (e.g. 'SPEND THIS MONTH'). The 0.016-0.021em variants at 12-16px handle inline data display."
    },
    "suisseintl": {
      "$value": "Suisseintl",
      "$type": "fontFamily",
      "$description": "Suisseintl — detected in extracted data but not described by AI"
    }
  },
