      "$description": "Slate Violet — Muted text on dark sections, secondary borders and dividers — a desaturated companion to the primary navy"
    },
    "warm-cream": {
      "$value": "#fcf6ea",
      "$type": "color",
      "$description": "Warm Cream — Hairline borders, dividers, input outlines, and card edges on light surfaces. Do not promote it to the primary CTA color"
