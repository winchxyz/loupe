      "$description": "Midnight Sapphire — Primary canvas for hero and feature bands, body text on cream surfaces, outlined action borders — the void that everything floats on"
    },
    "bright-violet": {
      "$value": "#9c8bf9",
      "$type": "color",
      "$description": "Bright Violet — Rare accent fill for highlight buttons and emphasis moments — a vivid punctuation against the matte navy canvas"
    },
    "deep-indigo": {
      "$value": "#162d67",
      "$type": "color",
