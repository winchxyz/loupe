{
  "color": {
    "lime-voltage": {
      "$value": "#c9fe6e",
      "$type": "color",
      "$description": "Lime Voltage — Primary CTA fill, active border accent, highlight tags — the only chromatic note in an otherwise monochrome system, used at 1-2 instances per viewport to make actions feel switched on"
    },
    "concrete": {
      "$value": "#f1f1f1",
      "$type": "color",
      "$description": "Concrete — Page canvas, card surfaces, light borders, inverted text on dark — the base background layer every other element sits on"
    },
    "ink": {
      "$value": "#121212",
      "$type": "color",
      "$description": "Ink — Primary text, heading borders, nav borders, dark demo-card surfaces, icon strokes — the dominant structural color across the system"
    },
    "charcoal-edge": {
      "$value": "#252525",
      "$type": "color",
      "$description": "Charcoal Edge — Card borders, elevated surface edges — one step lighter than Ink for layered card frames"
    },
    "fog": {
      "$value": "#777777",
      "$type": "color",
      "$description": "Fog — Muted body copy, secondary metadata, inactive borders"
    },
    "graphite": {
      "$value": "#1a1a1a",
      "$type": "color",
      "$description": "Graphite — Deep SVG fills, dark interior backgrounds for inverted panels"
    },
    "paper": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper — Inverted text on dark cards, light link borders, occasional white surfaces"
    }
  },
  "font": {
    "laygrotesk": {
      "$value": "LayGrotesk",
      "$type": "fontFamily",
      "$description": "Single-family display + body system. Weight 700 carries all display sizes (65-250px) and nav headings; weight 500 handles body, labels, and captions. The aggressive line-height compression (0.80-0.90) on display sizes lets massive headlines stack tightly without breathing room, creating an editorial-poster density. Negative letter-spacing scales with size — -0.04em at display, -0.01em at subheading — so large type tightens optically."
    }
  },
