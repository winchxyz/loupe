{
  "color": {
    "parchment": {
      "$value": "#f7f6f2",
      "$type": "color",
      "$description": "Parchment — Page background — the warm off-white canvas that gives the entire system its paper-like, non-clinical feel. Never use pure white for the body background"
    },
    "paper-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper White — Card surfaces, product UI mockups, and embedded media containers — pure white lifted above the parchment canvas to create subtle elevation without shadows"
    },
    "forest-ink": {
      "$value": "#001f1f",
      "$type": "color",
      "$description": "Forest Ink — Neutral form states, badge text, and quiet UI feedback where color should stay understated. Do not promote it to the primary CTA color"
    },
    "lichen-gray": {
      "$value": "#5c7070",
      "$type": "color",
      "$description": "Lichen Gray — Secondary text and medium-emphasis borders. Sits between Forest Ink and the lighter grays — use for body descriptions, supporting copy, and subtle dividers"
    },
    "stone": {
      "$value": "#6a7878",
      "$type": "color",
      "$description": "Stone — Muted body text, nav borders, and tertiary UI elements. The readable-but-quiet gray for descriptions and helper text"
    },
    "slate": {
      "$value": "#455252",
      "$type": "color",
      "$description": "Slate — Dark borders and separators for elevated surfaces and inverted UI. Do not promote it to the primary CTA color"
    },
    "mist": {
      "$value": "#889494",
      "$type": "color",
      "$description": "Mist — Lightest text tier — captions, metadata, tertiary labels. Use for timestamps, footnotes, and non-essential annotations"
    },
    "meadow": {
      "$value": "#cdface",
      "$type": "color",
      "$description": "Meadow — Pill badge fills, success highlights, and light accent surfaces. The signature light green for category tags, status indicators, and soft highlight washes"
    },
    "deep-forest": {
      "$value": "#2a4e1c",
      "$type": "color",
      "$description": "Deep Forest — Dark green accent for data visualization, illustration strokes, and secondary green elements. Distinct from Forest Ink in that it reads clearly as green, not near-black"
    },
    "deep-teal": {
      "$value": "#003d3d",
      "$type": "color",
      "$description": "Deep Teal — Secondary brand accent — teal-toned borders, illustration fills, and data visualization. Used alongside Deep Forest for multi-color charts and decorative elements"
    },
    "olive": {
      "$value": "#515c0b",
      "$type": "color",
      "$description": "Olive — Chart and illustration accent — the yellow-green in the multi-color palette system. Used in data bars, category indicators, and decorative strokes"
    },
    "plum": {
      "$value": "#7a2251",
      "$type": "color",
      "$description": "Plum — Magenta-pink accent for data visualization and illustration. The warm-cool counterpoint in the multi-color palette system"
    },
    "saffron": {
      "$value": "#a36a14",
      "$type": "color",
      "$description": "Saffron — Amber-gold accent for data visualization and illustration. The warm yellow in the multi-color palette system, used in charts and decorative strokes"
    },
    "iris": {
      "$value": "#652ea3",
      "$type": "color",
      "$description": "Iris — Violet accent for data visualization, illustration strokes, and the integrations section gradient. The cool counterpoint in the multi-color palette"
    },
    "mint-surface": {
      "$value": "#e4f7f9",
      "$type": "color",
      "$description": "Mint Surface — Pastel feature card background — the pale aqua tint assigned to product modules like Performance. Each product area gets its own pastel home"
    },
    "lime-surface": {
      "$value": "#f8fbe7",
      "$type": "color",
      "$description": "Lime Surface — Pastel feature card background — the pale yellow-green tint for modules like Goals & OKRs. The warmest pastel in the system"
    },
    "lavender-surface": {
      "$value": "#e1e1fa",
      "$type": "color",
      "$description": "Lavender Surface — Pastel card background — pale violet for testimonial cards, secondary feature blocks, and the cool side of the pastel system"
    },
    "blush-surface": {
      "$value": "#fcf2fe",
      "$type": "color",
      "$description": "Blush Surface — Pastel card background — near-white pink for subtle surface differentiation. The quietest of the pastel tints"
    },
    "buttercream": {
      "$value": "#fff3c2",
      "$type": "color",
      "$description": "Buttercream — Warm pastel accent surface — soft yellow for tag backgrounds and light highlight zones"
    },
    "sage-glow": {
      "$value": "#eff5ce",
      "$type": "color",
      "$description": "Sage Glow — Green pastel accent for tag backgrounds and soft category highlights. A more saturated green than Lime Surface"
    },
    "petal": {
      "$value": "#fde5ff",
      "$type": "color",
      "$description": "Petal — Pink pastel accent for tag backgrounds and soft category highlights"
    },
    "lilac-stroke": {
      "$value": "#dcc2eb",
      "$type": "color",
      "$description": "Lilac Stroke — Muted violet for illustration strokes and decorative outlines"
    },
    "halo-gradient": {
      "$value": "#a9eba9",
      "$type": "color",
      "$description": "Halo Gradient — Hero radial gradient — the lime-to-teal aurora behind the product device frame. Evokes a natural, organic light source rather than a tech glow"
    }
