    "azure": {
      "$value": "#1f86ff",
      "$type": "color",
      "$description": "Azure — Lighter blue border — paired with Deep Iris in decorative border compositions"
    },
    "alert-red": {
      "$value": "#c60808",
      "$type": "color",
      "$description": "Alert Red — Red action color for filled buttons, selected navigation states, and focused conversion moments. Use as a supporting accent, not as a status color"
    },
    "deep-moss": {
      "$value": "#1c372a",
      "$type": "color",
      "$description": "Deep Moss — Dark text/footer — near-black with a green undertone, used for footer backgrounds and deep heading text"
    },
    "concrete": {
      "$value": "#e5e7eb",
      "$type": "color",
      "$description": "Concrete — Hairline border — the dominant neutral border color, appearing on virtually every element"
    },
    "obsidian": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Obsidian — Primary text and filled CTA — all body and heading text, plus filled button backgrounds"
    },
    "paper": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper — Card and nav surface — opaque white for cards, navigation bar, and button text"
    },
    "carbon": {
      "$value": "#101516",
      "$type": "color",
