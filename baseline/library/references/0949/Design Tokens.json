{
  "color": {
    "ink": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Ink — Primary text, navigation labels, logo, link borders, footer type — the single graphic ink of the system. Every stroke, border, and character mark across the site"
    },
    "bone": {
      "$value": "#e7e7e7",
      "$type": "color",
      "$description": "Bone — Page canvas, card surface, elevated surface — the warm near-white that holds all imagery and text"
    },
    "charcoal": {
      "$value": "#121212",
      "$type": "color",
      "$description": "Charcoal — Secondary text and deep surface tone where slightly softer black is needed against bone"
    }
  },
  "font": {
    "adobe-garamond": {
      "$value": "Adobe Garamond",
      "$type": "fontFamily",
      "$description": "Editorial display and body serif. The single weight (400) does all the talking — no bold, no italic reliance. Used at 56px for display headlines (artwork titles, hero captions) with tight tracking -0.018em and 1.10 line-height, at 20px for introductory text and at 16px for body. The restraint of a single weight Garamond at display sizes creates an old-master gravitas: authority through historical type, not weight."
    },
    "akzidenz-grotesk": {
      "$value": "Akzidenz Grotesk",
      "$type": "fontFamily",
      "$description": "Functional sans-serif for all UI, navigation, labels, and metadata. Rendered almost exclusively in uppercase at 8-10px with aggressive positive tracking (+0.027 to +0.038em) — the effect is that of gallery wall labels, museum credits, and colophon text. Weight 500 highlights active nav, 700 for emphasis labels, 400 default. The grotesk never competes with Garamond for the reader's attention; it serves."
    }
  },
