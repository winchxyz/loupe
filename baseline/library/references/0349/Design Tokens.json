{
  "color": {
    "lavender-canvas": {
      "$value": "#f3f5ff",
      "$type": "color",
      "$description": "Lavender Canvas — Page background — the entire site sits on this faint blue-lavender wash instead of pure white, which warms the space and lets white cards lift visibly"
    },
    "card-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Card White — Card surfaces, modal panels, nav bar, elevated UI blocks"
    },
    "ink": {
      "$value": "#181c31",
      "$type": "color",
      "$description": "Ink — Primary text, headings, button labels — a near-black with a blue undertone, not pure #000"
    },
    "muted-iris": {
      "$value": "#757693",
      "$type": "color",
      "$description": "Muted Iris — Body text, nav links, secondary copy, helper text, footer links — a desaturated violet-gray that keeps the type hierarchy warm without competing with the brand accent"
    },
    "border-mist": {
      "$value": "#e5e7eb",
      "$type": "color",
      "$description": "Border Mist — Hairline dividers, input borders, card outlines, table rules"
    },
    "hover-iris": {
      "$value": "#6b7280",
      "$type": "color",
      "$description": "Hover Iris — Slightly deeper secondary text for hover/active metadata"
    },
    "soft-blue-wash": {
      "$value": "#dbeafe",
      "$type": "color",
      "$description": "Soft Blue Wash — Highlighted surface tint, selected row state, subtle feature-panel background — the lightest visible blue in the palette"
    },
    "brand-violet": {
      "$value": "#4457ff",
      "$type": "color",
      "$description": "Brand Violet — Violet supporting accent for decorative details and low-frequency emphasis. Do not promote it to the primary CTA color"
    },
    "brand-violet-light": {
      "$value": "#7583fd",
      "$type": "color",
      "$description": "Brand Violet Light — Supporting palette color for small decorative accents when the core palette needs contrast. Do not promote it to the primary CTA color"
    },
    "shadow-violet": {
      "$value": "#c7c8e2",
      "$type": "color",
      "$description": "Shadow Violet — Reference color for the signature blue-tinted product mockup glow — shadows are cast in violet, never gray"
    }
  },
  "font": {
    "thicccboi": {
      "$value": "Thicccboi",
      "$type": "fontFamily",
      "$description": "The only typeface in the system. Display headlines at 60px weight 700, hero sublines at 44px weight 700, section headings at 34–36px weight 600, body at 16px weight 400, and labels at 12–14px weight 500. The geometric, slightly rounded sans gives the brand a friendly-but-technical voice — closer to a productivity tool than a marketing site."
    }
  },
