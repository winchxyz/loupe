{
  "color": {
    "warm-bone": {
      "$value": "#fafaf9",
      "$type": "color",
      "$description": "Warm Bone — Page canvas, button secondary fills, section backgrounds — the warm off-white that prevents the page from feeling clinical"
    },
    "paper-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper White — Card surfaces, elevated panels, primary button text, input fills — layered above Warm Bone for subtle separation"
    },
    "stone-mist": {
      "$value": "#e7e5e4",
      "$type": "color",
      "$description": "Stone Mist — Hairline borders, dividers, button outlines, list separators — the structural linework that holds the layout together"
    },
    "bark-grey": {
      "$value": "#79716b",
      "$type": "color",
      "$description": "Bark Grey — Muted body text, secondary labels, icon strokes, placeholder copy — warm rather than cool grey"
    },
    "charcoal": {
      "$value": "#292524",
      "$type": "color",
      "$description": "Charcoal — Primary text, headings, active nav, dominant border color — the near-black that carries every important word"
    },
    "obsidian": {
      "$value": "#0c0a09",
      "$type": "color",
      "$description": "Obsidian — Deepest text and edge cases requiring maximum contrast"
    },
    "pebble": {
      "$value": "#a6a09b",
      "$type": "color",
      "$description": "Pebble — Tertiary text, disabled states, subtle icon tints"
    },
    "electric-indigo": {
      "$value": "#615fff",
      "$type": "color",
      "$description": "Electric Indigo — Primary CTA fill, active links, brand marks — the singular chromatic accent that makes the sign-up button feel switched on"
    },
    "deep-violet": {
      "$value": "#4f39f6",
      "$type": "color",
      "$description": "Deep Violet — Hover and pressed states for Electric Indigo, decorative borders, illustration strokes"
    },
    "terracotta": {
      "$value": "#d97757",
      "$type": "color",
      "$description": "Terracotta — Secondary accent — warm orange used sparingly on card borders, decorative icons, and highlight strokes to soften the indigo/grey palette"
    },
    "lichen-green": {
      "$value": "#5ea500",
      "$type": "color",
      "$description": "Lichen Green — Green outline accent for tags, dividers, and focused UI edges. Use as a supporting accent, not as a status color"
    },
    "tide-teal": {
      "$value": "#22b8cd",
      "$type": "color",
      "$description": "Tide Teal — Teal decorative accent for icons, marks, and small graphic details. Use as a supporting accent, not as a status color"
    },
    "alarm-red": {
      "$value": "#ff0000",
      "$type": "color",
      "$description": "Alarm Red — Red accent for outlined action borders, linked labels, and lightweight interactive emphasis. Use as a supporting accent, not as a status color"
    },
    "sapphire-link": {
      "$value": "#007ebb",
      "$type": "color",
      "$description": "Sapphire Link — Standard text links within body copy — the one blue that behaves like a link"
    }
  },
  "font": {
    "geist": {
      "$value": "Geist",
      "$type": "fontFamily",
      "$description": "Primary UI and body font — nav items, buttons, card copy, subheadings; weight 400 for body, 600 for emphasis and button labels; the 40px weight 600 carries the largest non-display heading tier"
    },
    "cooper-ltbt": {
      "$value": "Cooper LtBT",
      "$type": "fontFamily",
      "$description": "Display headlines and hero copy only — the warm book-weight serif with italic for emphasis words is the signature voice of the brand; substitutes for body would dilute the effect"
    },
    "geist-mono": {
      "$value": "Geist Mono",
      "$type": "fontFamily",
      "$description": "Code, API labels, uppercase section tags (e.g. 'EMAILS SENT BY BIG AND SMALL COMPANIES ALIKE!'), button micro-labels — tracked out at 0.04–0.10em to read as tag/label type rather than body"
    },
    "datatype": {
      "$value": "dataType",
      "$type": "fontFamily",
      "$description": "Numeric stat values in the metrics bar (755,470 / 96.82% / 1.87s / 3.10%) — a dedicated monospaced-figure family so digits align"
