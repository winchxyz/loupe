  "font": {
    "booton": {
      "$value": "Booton",
      "$type": "fontFamily",
      "$description": "Primary workhorse across UI — nav, body copy, buttons, captions, and feature labels. Weight 600 for subheadings and card titles; weight 400 for body and nav. The custom design gives it a warmth that distinguishes it from commodity grotesques like Inter."
    },
    "gamuth-display": {
      "$value": "Gamuth Display",
      "$type": "fontFamily",
      "$description": "Hero and section headings only. A custom editorial serif — the signature choice that marks Descript as a content creation tool, not enterprise SaaS. Weight 400 at 88px is confident restraint; most SaaS hero fonts lean heavy."
    },
    "brett": {
      "$value": "Brett",
      "$type": "fontFamily",
      "$description": "Section eyebrow labels only (e.g. 'AI VIDEO EDITOR', 'AI VIDEO AGENT'). Wide 0.04em tracking mimics broadcast chyron or print section slugs — the only place positive letter-spacing appears in the system."
    }
  },
