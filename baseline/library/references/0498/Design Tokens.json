{
  "color": {
    "phosphor-green": {
      "$value": "#3ecf8e",
      "$type": "color",
      "$description": "Phosphor Green — Green supporting accent for decorative details and low-frequency emphasis. Do not promote it to the primary CTA color"
    },
    "mint-pulse": {
      "$value": "#00c573",
      "$type": "color",
      "$description": "Mint Pulse — Link text and inline accent — a slightly cooler green variant for textual references that shouldn't compete with primary CTAs"
    },
    "forest-depth": {
      "$value": "#1f4b37",
      "$type": "color",
      "$description": "Forest Depth — Hover and pressed borders on green CTAs — keeps the button identifiable when the fill darkens on interaction"
    },
    "midnight-emerald": {
      "$value": "#006239",
      "$type": "color",
      "$description": "Midnight Emerald — Deepest green surface — for low-key brand-tinted backgrounds, subtle section washes, and disabled-brand states"
    },
    "snow": {
      "$value": "#fafafa",
      "$type": "color",
      "$description": "Snow — Primary text, icon strokes, button labels — the dominant foreground across the entire interface"
    },
    "silver-mist": {
      "$value": "#b4b4b4",
      "$type": "color",
      "$description": "Silver Mist — Secondary headings, nav items, body emphasis — readable but never competing with Snow"
    },
    "smoke": {
      "$value": "#898989",
      "$type": "color",
      "$description": "Smoke — Tertiary text, captions, helper text, muted icon fills — the voice of metadata and annotations"
    },
    "graphite": {
      "$value": "#4d4d4d",
      "$type": "color",
      "$description": "Graphite — Icon outlines, low-emphasis borders, divider lines, and stroke color for illustrative line work"
    },
    "slate": {
      "$value": "#393939",
      "$type": "color",
      "$description": "Slate — Input borders, subtle dividers, hairline separators between nav and content"
    },
    "charcoal": {
      "$value": "#2e2e2e",
      "$type": "color",
      "$description": "Charcoal — Card and component borders — the most-used border color, giving surfaces their defined edge without a visible shadow"
    },
    "ash": {
      "$value": "#242424",
      "$type": "color",
      "$description": "Ash — Elevated surface tier for nested cards, hover states, and popover backgrounds"
    },
    "obsidian": {
      "$value": "#121212",
      "$type": "color",
      "$description": "Obsidian — Page canvas — the deep near-black foundation behind every section and card"
    }
  },
  "font": {
    "circular": {
      "$value": "Circular",
      "$type": "fontFamily",
      "$description": "All UI typography — nav, body, buttons, headings, display. Circular is a geometric humanist sans with rounded terminals; its regular 400 weight carries headlines (a deliberate anti-bold choice) and the 500 weight is reserved for emphasis and button labels."
