{
  "color": {
    "netflix-red": {
      "$value": "#e50914",
      "$type": "color",
      "$description": "Netflix Red — Primary CTAs, brand logo, active states, and the single chromatic accent in the entire system — the only warm color allowed to break the black void"
    },
    "pure-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Pure Black — Dominant page canvas and deepest surface — the cinematic background that swallows everything non-essential"
    },
    "obsidian": {
      "$value": "#0f0f0f",
      "$type": "color",
      "$description": "Obsidian — Elevated surface tone, barely distinguishable from black — used for subtle layering and section dividers"
    },
    "carbon": {
      "$value": "#232323",
      "$type": "color",
      "$description": "Carbon — Card and button surface background — the primary elevated layer above pure black"
    },
    "charcoal": {
      "$value": "#2d2d2d",
      "$type": "color",
      "$description": "Charcoal — Deeper card surface and input field background — secondary surface level for nested elements"
    },
    "graphite": {
      "$value": "#323232",
      "$type": "color",
      "$description": "Graphite — Rounded card backgrounds and tertiary surface treatment"
    },
    "slate": {
      "$value": "#393939",
      "$type": "color",
      "$description": "Slate — Hover states and pressed button backgrounds — a step lighter than carbon for interaction feedback"
    },
    "ash": {
      "$value": "#5a5a5a",
      "$type": "color",
      "$description": "Ash — Hairline borders and subtle dividers on dark surfaces"
    },
    "steel": {
      "$value": "#808080",
      "$type": "color",
      "$description": "Steel — Muted body text and inactive helper copy"
    },
    "fog": {
      "$value": "#b3b3b3",
      "$type": "color",
      "$description": "Fog — Secondary body text, metadata, footer links, and de-emphasized descriptions"
