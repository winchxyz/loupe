{
  "color": {
    "electric-iris": {
      "$value": "#6c00f6",
      "$type": "color",
      "$description": "Electric Iris — Violet text accent for links, tags, and emphasized short phrases. Do not promote it to the primary CTA color"
    },
    "bright-violet": {
      "$value": "#7f22fe",
      "$type": "color",
      "$description": "Bright Violet — Violet text accent for links, tags, and emphasized short phrases. Do not promote it to the primary CTA color"
    },
    "indigo-drift": {
      "$value": "#4f46e5",
      "$type": "color",
      "$description": "Indigo Drift — Gradient terminus — pairs with Electric Iris to create the right-leaning purple-to-indigo gradient on CTAs and hero accents"
    },
    "midnight-slate": {
      "$value": "#0f172b",
      "$type": "color",
      "$description": "Midnight Slate — Primary text, dark surface fills, logo mark, and icon strokes — the heaviest neutral in the system"
    },
    "graphite": {
      "$value": "#1d293d",
      "$type": "color",
      "$description": "Graphite — Dark UI borders, secondary dark surfaces, and high-contrast dividers where a softer gray reads too faint"
    },
    "ash": {
      "$value": "#020618",
      "$type": "color",
      "$description": "Ash — Near-black button text and icon glyphs — used as the foreground on filled purple CTAs to maximize contrast without true black"
    },
    "fog": {
      "$value": "#90a1b9",
      "$type": "color",
      "$description": "Fog — Muted helper text, nav icons, and low-emphasis stroke work — the bridge between white canvas and primary text"
    },
    "silver": {
      "$value": "#e5e7eb",
      "$type": "color",
      "$description": "Silver — Default hairline border, card dividers, and the most common neutral surface tone — carries the structural skeleton of every layout"
    },
    "mist": {
      "$value": "#f1f5f9",
      "$type": "color",
      "$description": "Mist — Subtle surface tint for alt-row cards, input backgrounds, and section bands that need a whisper of separation from the white canvas"
    },
    "white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "White — Page canvas, card surface, and button text on purple fills — the bright base everything floats on"
    },
    "spearmint": {
      "$value": "#00d492",
      "$type": "color",
      "$description": "Spearmint — Decorative product-mockup accent — used in illustrations, code editor UI, and inline highlights inside screenshots, not in chrome"
    },
    "sky-pop": {
      "$value": "#51a2ff",
      "$type": "color",
      "$description": "Sky Pop — Decorative product-mockup accent — appears in wallet/payment UI illustrations to signal connected or live data states"
    },
    "bubblegum": {
      "$value": "#fb64b6",
      "$type": "color",
      "$description": "Bubblegum — Decorative product-mockup accent — pink wash on feature-card backgrounds and illustration shadows to add warmth to the otherwise cool palette"
    }
  },
  "font": {
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "Single-family type system. Weight 700 carries hero and section headlines at 32–52px, weight 600 handles subheadings and card titles at 18–20px, weight 500–600 sets buttons and nav links, and weight 400 runs body and helper copy at 14–16px. Inter is chosen for its developer-tools neutrality — humanist but precise — letting the purple brand color do the expressive work instead of the typeface."
    }
  },
