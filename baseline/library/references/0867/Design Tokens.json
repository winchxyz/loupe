{
  "color": {
    "sky-signal": {
      "$value": "#006aff",
      "$type": "color",
      "$description": "Sky Signal — Brand accent — the single chromatic punctuation in a monochrome interface. Active nav items, inline links, hashtag chips, and filled primary buttons"
    },
    "slate-type": {
      "$value": "#405168",
      "$type": "color",
      "$description": "Slate Type — Primary text and nav labels — a cool, slightly desaturated near-black that reads softer than pure ink on the warm-white canvas"
    },
    "hazy-steel": {
      "$value": "#8798b0",
      "$type": "color",
      "$description": "Hazy Steel — Secondary icons, metadata, timestamps, and muted helper text. The cool tint keeps it visually adjacent to Sky Signal without competing"
    },
    "whisper-border": {
      "$value": "#dce2ea",
      "$type": "color",
      "$description": "Whisper Border — Hairline dividers and card borders. The only structural line work in the system — it defines edges without adding weight"
    },
    "fog-surface": {
      "$value": "#eff2f6",
      "$type": "color",
      "$description": "Fog Surface — Subtle fill for hover states, secondary buttons, and search input backgrounds. Sits one step above the canvas without creating contrast drama"
    },
    "mist-canvas": {
      "$value": "#f9fafb",
      "$type": "color",
      "$description": "Mist Canvas — Page background — a barely-warm off-white that prevents the harshness of pure white during long reading sessions"
    },
    "paper": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper — Card and surface background. The single step up from the canvas that gives post cards their boundary via border, not shadow"
    },
    "ink": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Ink — Body text on cards and highest-contrast foreground. Used sparingly where maximum legibility is required"
    }
  },
  "font": {
    "intervariable": {
      "$value": "InterVariable",
      "$type": "fontFamily",
      "$description": "Sole typeface for all UI — navigation, post bodies, metadata, buttons, inputs. The variable axis is critical: the scale ranges from 8px timestamps to 24px tab headers, so the weight axis must flex smoothly across that range without optical hiccups. No display sizes exist — this is a feed UI, not a landing page."
    }
  },
