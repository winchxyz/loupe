{
  "color": {
    "eucalyptus": {
      "$value": "#778643",
      "$type": "color",
      "$description": "Eucalyptus — Headline accents, body text emphasis, hairline borders, single filled CTA — the only chromatic voice in the entire system. Muted enough to never shout, present enough to carry the brand; Full-bleed background gradient behind hero and section text. The green is a breath, not a wall — it fades to white at the edges so text remains the focus"
    },
    "ink-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Ink Black — Primary text, dividers, image borders, icon strokes. Used at 1px hairline weight almost exclusively — never as a fill"
    },
    "pure-canvas": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Pure Canvas — Page background, card surfaces, button text on filled green CTAs. The dominant surface color across the entire site"
    },
    "graphite": {
      "$value": "#4e4e4e",
      "$type": "color",
      "$description": "Graphite — Secondary body text, muted link borders, helper copy, footer text. Quieter than black but still AA-readable on white"
    },
    "mist": {
      "$value": "#c8c8c8",
      "$type": "color",
      "$description": "Mist — Subtle surface wash for elevated panels, image placeholder backgrounds, very faint dividers. Used sparingly to add depth without darkening the page"
    }
  },
  "font": {
