      "$value": "Suisse Int'l",
      "$type": "fontFamily",
      "$description": "Secondary body and footer text. Regular weight adds density to descriptions and supporting paragraphs beneath light-weight headlines."
    },
    "space-grotesk": {
      "$value": "Space Grotesk",
      "$type": "fontFamily",
      "$description": "Primary body, UI labels, buttons, and navigation text. The geometric counter-forms pair with Suisse to give dense text a different texture from the display headlines."
    },
    "system-sans": {
      "$value": "System Sans",
