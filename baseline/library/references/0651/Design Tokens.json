{
  "color": {
    "carbon-ink": {
      "$value": "#0a0d0f",
      "$type": "color",
      "$description": "Carbon Ink — Primary text, product page borders, body type — the near-black that carries the entire brand voice in type"
    },
    "pure-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Pure White — Page canvas, product card surface, button text on dark — the base everything sits on"
    },
    "slate-veil": {
      "$value": "#2e3438",
      "$type": "color",
      "$description": "Slate Veil — Secondary text and icon strokes — slightly cooler than Carbon Ink, used where pure black would feel too heavy"
    },
    "onyx": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Onyx — Body borders, heading text — the hardest black in the system, used sparingly for maximum edge definition"
    },
    "bone": {
      "$value": "#f7f7f7",
      "$type": "color",
      "$description": "Bone — Alternate section background, subtle card wash, press-logo band — the warm off-white that breaks up white-on-white without introducing a color"
    },
    "footer-ash": {
      "$value": "#efefef",
      "$type": "color",
      "$description": "Footer Ash — Footer surface only — one step deeper than Bone to separate the footer from the body"
    },
    "silver-mist": {
      "$value": "#d5d6d7",
      "$type": "color",
      "$description": "Silver Mist — Input borders, subtle dividers — hairline neutral that only shows on form elements"
    },
    "graphite-tag": {
      "$value": "#656565",
      "$type": "color",
      "$description": "Graphite Tag — Neutral form states, badge text, and quiet UI feedback where color should stay understated."
    },
    "signal-teal": {
      "$value": "#1dd8e1",
      "$type": "color",
      "$description": "Signal Teal — Primary action buttons, link text, product dial accents, active tab indicators — the only chromatic color in the entire system, carrying every interactive moment on its own"
    }
  },
  "font": {
    "poppins": {
      "$value": "Poppins",
      "$type": "fontFamily",
      "$description": "Body copy, product titles, button text, UI chrome — the rounded geometry contrasts with Jost's squared display weight, keeping the system from feeling monotone"
    },
    "jost": {
      "$value": "Jost",
      "$type": "fontFamily",
      "$description": "Display and section headlines — the wide 0.09em tracking turns bold weight into something architectural rather than shouty; treat as the only voice for H1/H2/page titles"
    },
    "cabin": {
      "$value": "Cabin",
      "$type": "fontFamily",
      "$description": "Eyebrow labels, nav tabs, small section captions, badge text — the 0.064em-0.09em tracking at small sizes creates a 'label-grade' voice that sits above Poppins without dominating it"
    },
    "gtstandard-m": {
      "$value": "GTStandard-M",
      "$type": "fontFamily",
      "$description": "GTStandard-M — detected in extracted data but not described by AI"
    }
  },
