{
  "color": {
    "royal-violet": {
      "$value": "#2f115b",
      "$type": "color",
      "$description": "Royal Violet — Violet accent for outlined action borders, linked labels, and lightweight interactive emphasis. Do not promote it to the primary CTA color; Deeper atmospheric gradient — a 90° wash from Iris into Midnight Plum used on dark feature panels"
    },
    "midnight-plum": {
      "$value": "#1a0d3f",
      "$type": "color",
      "$description": "Midnight Plum — Primary body and heading text, outlined action borders — near-black violet that reads as ink rather than as color"
    },
    "iris": {
      "$value": "#3b1572",
      "$type": "color",
      "$description": "Iris — Hovered action state, gradient anchor — sits one step brighter than Royal Violet for interaction feedback"
    },
    "slate-mute": {
      "$value": "#5e5777",
      "$type": "color",
      "$description": "Slate Mute — Secondary text, hairline borders, icon stroke — the desaturated violet that forms the neutral system backbone"
    },
    "ember-orange": {
      "$value": "#ff4b11",
      "$type": "color",
      "$description": "Ember Orange — Orange accent for outlined action borders, linked labels, and lightweight interactive emphasis"
    },
    "white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "White — Page canvas, card surfaces, button text on dark fills, nav background"
    },
    "cream-wash": {
      "$value": "#fff2e8",
      "$type": "color",
      "$description": "Cream Wash — Softest tier of the warm gradient — the first stop in hero and testimonial backgrounds"
    },
    "peach-blush": {
      "$value": "#ffdacf",
      "$type": "color",
      "$description": "Peach Blush — Mid-stop in warm gradient washes, ghost button fill, soft surface tint"
    }
  },
  "font": {
    "dm-serif-display": {
      "$value": "DM Serif Display",
      "$type": "fontFamily",
      "$description": "Editorial headline face — used at 40–66px for section titles, never below 24px. Its single weight 400 carries the brand's serif authority without shouting; the contrast with the geometric sans body is the system's signature move"
    },
    "manrope": {
      "$value": "Manrope",
      "$type": "fontFamily",
      "$description": "All UI and body copy — 16px/400 for body, 14px/500 for nav and metadata, 600–700 for metric numbers and card labels. The 0.375em letter-spacing on small uppercase eyebrows ('15 FIVE', 'YOU'RE IN GOOD COMPANY') is a distinctive tracking choice that creates breathing room around tiny all-caps labels"
    }
  },
