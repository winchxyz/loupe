      "$type": "color",
      "$description": "Hairline — Primary border color for cards, dividers, and input fields — the most-used neutral in the system"
    },
    "bone": {
      "$value": "#cbcac7",
      "$type": "color",
      "$description": "Bone — Secondary borders, card outlines in dense grids, subtle structural dividers"
    },
    "ash": {
      "$value": "#717171",
      "$type": "color",
      "$description": "Ash — Muted body text, helper copy, secondary metadata, timestamps, and icon fills at rest"
    },
