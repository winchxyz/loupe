    },
    "charcoal": {
      "$value": "#222222",
      "$type": "color",
      "$description": "Charcoal — Headline text, SVG illustration fills, logo lockup — the warm-tinted near-black for editorial type"
    },
    "ink": {
      "$value": "#0d0d0d",
      "$type": "color",
      "$description": "Ink — Primary action button background, primary navigation text, high-emphasis links — the only dark fill used for interactive elements"
    },
    "jet": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Jet — Body text color, icon strokes, high-contrast outlines — the sharpest dark in the system"
    },
    "confirm-green": {
      "$value": "#34c759",
      "$type": "color",
      "$description": "Confirm Green — Green wash for highlight backgrounds, decorative bands, and soft emphasis behind content. Use as a supporting accent, not as a status color"
    }
  },
  "font": {
    "ui-sans-serif": {
      "$value": "ui-sans-serif",
      "$type": "fontFamily",
      "$description": "ui-sans-serif — detected in extracted data but not described by AI"
    },
    "instrumentserif-regular": {
      "$value": "InstrumentSerif-Regular",
      "$type": "fontFamily",
      "$description": "Display and heading serif — used exclusively for editorial section headlines and hero copy. At 60-80px with -0.02em tracking, it creates a magazine-cover presence that contrasts against Inter's utility. The single weight (400) and high contrast strokes give headlines an unhurried, confident voice that would feel overwrought in any bolder weight."
    },
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "Universal UI and body sans — Inter handles all interface text from 10px micro-labels up to 20px subheadings. The 400 weight is the workhorse for body, 500 for buttons and labels, 600 for emphasis, and 700 reserved for the smallest badge text. Tight letter-spacing (-0.009em at 14-18px) gives dense UI text a modern, engineered feel."
    }
  },
