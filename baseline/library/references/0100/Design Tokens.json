    },
    "bone": {
      "$value": "#f9f9fa",
      "$type": "color",
      "$description": "Bone — Card surfaces, secondary panels, subtle raised containers"
    },
    "mist": {
      "$value": "#eaebee",
      "$type": "color",
      "$description": "Mist — Hairline borders, divider rules, button outlines, input borders"
    },
    "ice-wash": {
      "$value": "#cfe7ed",
      "$type": "color",
      "$description": "Ice Wash — Pale cool-blue background tint for highlighted cards and feature panels"
    },
    "iris-sweep": {
      "$value": "#4e6fff",
      "$type": "color",
