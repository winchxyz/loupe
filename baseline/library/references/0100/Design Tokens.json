  "font": {
    "figtree": {
      "$value": "Figtree",
      "$type": "fontFamily",
      "$description": "Single-family system: 700 carries the hero and section headlines at 48–60px with tight tracking, 600 handles subheadings and prominent labels at 24–34px, 500 covers button labels and emphasized body at 16–18px, 400 runs body and caption copy at 13–16px. The geometric, low-contrast character of Figtree keeps the all-black type from feeling oppressive."
    }
  },
