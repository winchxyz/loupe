{
  "color": {
    "obsidian": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Obsidian — Primary text, heading type, dark icons, and the strongest foreground layer"
    },
    "carbon": {
      "$value": "#121212",
      "$type": "color",
      "$description": "Carbon — Filled primary buttons, active nav state, dark surface fill"
    },
    "graphite": {
      "$value": "#333333",
      "$type": "color",
      "$description": "Graphite — Secondary headings, button labels on light surfaces, heavy icon strokes"
    },
    "slate": {
      "$value": "#666666",
      "$type": "color",
      "$description": "Slate — Body secondary text, helper copy, muted metadata"
    },
    "ash": {
      "$value": "#808080",
      "$type": "color",
      "$description": "Ash — Tertiary text, disabled states, placeholder copy, subtle borders"
    },
    "fog": {
      "$value": "#999999",
      "$type": "color",
      "$description": "Fog — Inactive icons, low-emphasis dividers, shadow tinting"
    },
    "pebble": {
      "$value": "#8b8c8f",
      "$type": "color",
      "$description": "Pebble — Icon strokes on neutral surfaces, muted glyph color"
    },
    "smoke": {
      "$value": "#4d4d4d",
      "$type": "color",
      "$description": "Smoke — Heavy body text where Obsidian feels too sharp, small caption emphasis"
    },
    "charcoal-veil": {
      "$value": "#3d3d3d",
      "$type": "color",
      "$description": "Charcoal Veil — Navigation bar text and borders — the dark nav strip registers as a separate layer"
    },
    "dusk": {
      "$value": "#292929",
      "$type": "color",
      "$description": "Dusk — Deep surface fill for elevated dark blocks and image overlays"
    },
    "paper": {
      "$value": "#faf8fd",
