    },
    "orchid-edge": {
      "$value": "#ee7cff",
      "$type": "color",
      "$description": "Orchid Edge — Brand logo gradient start — warm violet anchor of the wordmark sweep"
    },
    "sky-drift": {
      "$value": "#559cff",
      "$type": "color",
      "$description": "Sky Drift — Brand logo gradient end — cool blue terminus of the wordmark sweep"
    }
