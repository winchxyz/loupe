{
  "color": {
    "crimson-seal": {
      "$value": "#e4263d",
      "$type": "color",
      "$description": "Crimson Seal — Primary action — filled add-to-cart buttons, CTA borders, section eyebrows, price accents, link underlines, and all brand punctuation against the cream canvas. The red carries the entire chromatic load; it must read as deliberate and small, never as decoration"
    },
    "vermillion-mark": {
      "$value": "#e4002b",
      "$type": "color",
      "$description": "Vermillion Mark — Secondary red accent — link borders, icon strokes, and outline-only controls. Slightly deeper than Crimson Seal; use when a quieter red moment is needed alongside the primary"
    },
    "ink-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Ink Black — Primary text, primary borders, navigation rules, body hairlines. The structural anchor of the entire interface"
    },
    "soft-coal": {
      "$value": "#1a1a1a",
      "$type": "color",
      "$description": "Soft Coal — Badge borders, heading text, list markers, card text on cream — a near-black used where pure black would feel clinical against the warm canvas"
    },
    "slate-drift": {
      "$value": "#2e2e2e",
      "$type": "color",
      "$description": "Slate Drift — Navigation borders, secondary structural lines — sits between Ink Black and the warm cream as a third depth"
    },
    "graphite": {
      "$value": "#3a3a3a",
      "$type": "color",
      "$description": "Graphite — Body text and borders for muted but still-readable paragraphs"
    },
    "pewter": {
      "$value": "#6f6f6f",
      "$type": "color",
      "$description": "Pewter — Badge borders, helper text, muted body copy — the first true mid-gray in the scale"
    },
    "stone": {
      "$value": "#8a8580",
      "$type": "color",
      "$description": "Stone — Warm-leaning gray for tags, secondary body text, and quiet fills where neutrality needs to harmonize with the cream"
    },
    "sand-border": {
      "$value": "#e4dfd9",
      "$type": "color",
      "$description": "Sand Border — Warm button borders, subtle section dividers — the border color that ties the warm palette together instead of fighting it with cool gray"
    },
    "cream-paper": {
      "$value": "#f8f6f3",
      "$type": "color",
      "$description": "Cream Paper — Page canvas, badge fills, soft card surfaces — the dominant background. Slightly warm to harmonize with product photography of amber liquids"
    },
    "pure-linen": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Pure Linen — Card surfaces, button text on red, elevated product panels — the brightest surface that sits one step above the cream canvas"
    },
    "blush-wash": {
      "$value": "#f5e7df",
      "$type": "color",
      "$description": "Blush Wash — Soft accent badge fills, warm callout backgrounds — a desaturated peach that gives badge states a skin-like warmth"
    }
  },
  "font": {
    "soehne-buch": {
      "$value": "Soehne Buch",
      "$type": "fontFamily",
      "$description": "Primary body face at comfortable reading sizes (13–16px). Cleaner, more humanist than Nimbus; used for longer paragraphs and form input text."
    },
    "nimbus-sans": {
      "$value": "Nimbus Sans",
      "$type": "fontFamily",
      "$description": "Workhorse sans for UI: button labels, body copy, price text, nav links, and all utility surfaces. Carries lnum/tnum features for tabular alignment of prices."
    },
    "soehne-kraftig": {
      "$value": "Soehne Kraftig",
      "$type": "fontFamily",
      "$description": "Display and small-bold sans for headlines (60px), navigation, and tracked uppercase labels (11–12px with 0.07–0.10em tracking). The Kraftig cut adds authority without geometric coldness."
    },
    "agaramondpro": {
      "$value": "AGaramondPro",
      "$type": "fontFamily",
      "$description": "Editorial serif for major section headlines (54px) and subheadings (17–26px). The Garamond weight gives the brand its apothecary/editorial voice; pairs with italic for emotional accents."
    },
    "garamond-italic": {
      "$value": "Garamond Italic",
      "$type": "fontFamily",
      "$description": "Signature italic for emotional phrases, pull quotes, and editorial interjections mid-paragraph. Used sparingly — it is a whisper, not a shout."
    },
    "eb-garamond": {
      "$value": "EB Garamond",
      "$type": "fontFamily",
      "$description": "EB Garamond — detected in extracted data but not described by AI"
    }
  },
