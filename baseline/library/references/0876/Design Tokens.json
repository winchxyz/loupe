  "font": {
    "saans-custom": {
      "$value": "Saans (custom)",
      "$type": "fontFamily",
      "$description": "Single typeface drives the entire system from 12px captions to 96px display. Unusual 475 weight sits between regular and medium — the brand's chosen voice weight. Positive letter-spacing across the scale (0.002–0.017em) is anti-convention: most sites tighten headlines; Customer.io opens them up, giving the type a slightly wide, editorial cadence reminiscent of old grotesques. The geometric humanist construction carries teal-dark ink with calm authority."
    }
  },
