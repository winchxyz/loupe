  "font": {
    "pp-neue-montreal": {
      "$value": "PP Neue Montreal",
      "$type": "fontFamily",
      "$description": "Single typeface carrying the entire brand voice — body, headings, and oversized display (up to 220px). The aggressive negative tracking (-0.0360em at display, -0.0320em at subhead) is the signature: letters lock together tightly even at 110px+, making the type read as a solid mass rather than individual glyphs. Weight 700 reserved for the largest display moments, weight 500 for subheadings, weight 400 for body and UI text."
    }
  },
