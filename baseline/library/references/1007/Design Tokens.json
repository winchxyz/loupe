      "$value": "#0067b8",
      "$type": "color",
      "$description": "Microsoft Blue — Primary action background, link text, navigation accents, icon strokes — the single chromatic authority in the system, used for all filled CTAs and interactive highlights"
    },
    "pure-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Pure White — Page background, card surfaces, button text on blue, surface elevation"
    },
