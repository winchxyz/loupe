    "segoe-ui": {
      "$value": "Segoe UI",
      "$type": "fontFamily",
      "$description": "Sole typeface across the entire system — navigation, body, headings, buttons, footer. Weight 400 is the workhorse; weight 600 is reserved for headings and button labels to create section-level contrast without switching families. Segoe UI's humanist proportions and open apertures give the system its calm, enterprise-confident voice — the type does not perform, it informs."
    }
