{
  "color": {
    "bone-canvas": {
      "$value": "#efefe4",
      "$type": "color",
      "$description": "Bone Canvas — Page background — warm cream instead of white, the signature surface that makes the whole site feel like a notebook page"
    },
    "paper-white": {
      "$value": "#fcfcf9",
      "$type": "color",
      "$description": "Paper White — Primary page canvas and white card surfaces. Do not promote it to the primary CTA color"
    },
    "bright-card": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Bright Card — Pure white card surface for highest elevation, code panels, product chrome"
    },
    "mist": {
      "$value": "#f3f3f4",
      "$type": "color",
      "$description": "Mist — Subtle alternate band background, soft dividers in long pages"
    },
    "ash-gray": {
      "$value": "#e3e3e3",
      "$type": "color",
      "$description": "Ash Gray — Card backgrounds in denser sections, soft grouping surface"
    },
    "stone": {
      "$value": "#d7d7d6",
      "$type": "color",
      "$description": "Stone — Hairline borders, card outlines, surface separators"
    },
    "smoke": {
      "$value": "#c1c1c0",
      "$type": "color",
      "$description": "Smoke — Secondary borders, diagram strokes, muted dividers"
    },
    "pewter": {
      "$value": "#a8a8a8",
      "$type": "color",
      "$description": "Pewter — Icon strokes, low-priority borders, decorative vector fills"
    },
    "graphite": {
      "$value": "#909090",
      "$type": "color",
      "$description": "Graphite — Secondary body text, the lighter half of the two-tone headline, heading accents"
    },
    "slate": {
      "$value": "#83837e",
      "$type": "color",
      "$description": "Slate — Subdued heading and link text, warm-gray captions"
    },
    "iron": {
      "$value": "#666666",
      "$type": "color",
      "$description": "Iron — Helper text, metadata, tertiary copy"
    },
    "lava": {
      "$value": "#434341",
      "$type": "color",
      "$description": "Lava — Near-black emphasis text, slightly softer than full ink for long reads"
    },
    "carbon": {
      "$value": "#222222",
      "$type": "color",
      "$description": "Carbon — Near-black used in nav chrome and high-contrast text"
    },
    "ink": {
      "$value": "#181818",
      "$type": "color",
      "$description": "Ink — Primary text, nav active state, filled button background — neutral dark, not chromatic"
    },
    "studio-blue": {
      "$value": "#5d8cd7",
      "$type": "color",
      "$description": "Studio Blue — Brand icon mark, decorative vector accent — cool blue against warm cream is the only chromatic tension in the marketing surface"
    },
    "wash-blue": {
      "$value": "#81adec",
      "$type": "color",
      "$description": "Wash Blue — Lighter blue used for soft body accents and nav underlines"
    }
  },
  "font": {
    "matter": {
      "$value": "Matter",
      "$type": "fontFamily",
      "$description": "Display and headline face — custom, wide stance, unusual light-to-medium weights (360 is whisper-thin). Carries the hero, the two-tone headline split, and large pull quotes. Tight tracking on display (-0.0200em at 64px) gives the type a composed, editorial feel"
    },
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "UI and body face — captions, button labels, nav, metadata, product chrome. Tight negative tracking on small sizes (-0.0100em at 12–14px) keeps dense UI legible"
    },
    "paper-mono": {
      "$value": "Paper Mono",
      "$type": "fontFamily",
      "$description": "Code, file paths, version labels, tiny metadata. Loose positive tracking (+0.0150em to +0.0160em) at small sizes gives the mono a calm, terminal-like cadence"
    }
  },
