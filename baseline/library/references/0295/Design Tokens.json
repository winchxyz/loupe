{
  "color": {
    "ink": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Ink — Neutral form states, badge text, and quiet UI feedback where color should stay understated."
    },
    "paper": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper — Page background, card surfaces, reversed text on dark — the default canvas. Never tinted, never warmed; warmth arrives only through photography"
    },
    "mist": {
      "$value": "#f7f7f7",
      "$type": "color",
      "$description": "Mist — Alternate canvas band, subtle section wash — used to separate content blocks without introducing a visible border line"
    },
    "ash": {
      "$value": "#e8e8e8",
      "$type": "color",
      "$description": "Ash — Footer and secondary dividers — the lightest perceptible rule, reserved for structural seams that must recede"
    },
    "graphite": {
      "$value": "#808080",
      "$type": "color",
      "$description": "Graphite — Muted secondary text, low-emphasis borders, tertiary metadata. Pairs with body and link borders at lower visual weight than Ink"
    },
    "warm-sand": {
      "$value": "#dec39d",
      "$type": "color",
      "$description": "Warm Sand — Yellow wash for highlight backgrounds, decorative bands, and soft emphasis behind content. Do not promote it to the primary CTA color"
    }
  },
  "font": {
    "gestura-text-extra-light": {
      "$value": "Gestura Text Extra Light",
      "$type": "fontFamily",
      "$description": "Gestura Text Extra Light — detected in extracted data but not described by AI"
    },
    "gestura-text": {
      "$value": "Gestura Text",
      "$type": "fontFamily",
      "$description": "Primary editorial face for body copy, links, nav, cards, and the 35px display overlay heading. The use of Extra Light (100) and Thin (200) weights throughout is a signature anti-convention — most luxury e-commerce uses 300–400 minimum. Here the type is intentionally thin enough to feel like it could disappear, forcing the photography to lead."
    },
    "untitled-sans": {
      "$value": "Untitled Sans",
      "$type": "fontFamily",
      "$description": "Workhorse sans for buttons, inputs, list items, and supporting UI chrome. The generous tracking (up to 0.056em) transforms a clean geometric sans into something that reads as typeset and intentional — labels feel engraved rather than typed. The 0.78 line-height at 9px is display micro-copy collapsed to its tightest possible rhythm."
    },
    "gestura-text-light": {
      "$value": "Gestura Text Light",
      "$type": "fontFamily",
      "$description": "Gestura Text Light — detected in extracted data but not described by AI"
    }
  },
