{
  "color": {
    "electric-lime": {
      "$value": "#beff50",
      "$type": "color",
      "$description": "Electric Lime — Primary CTA buttons, active UI chips, icon accent fills — the single chromatic accent that detonates against every surface (near-black, white, and cream alike), creating urgency without red-coded alarm"
    },
    "near-black": {
      "$value": "#14140f",
      "$type": "color",
      "$description": "Near Black — Primary text color, dark card backgrounds, nav borders — a warmed black (not pure #000000) that pairs with cream for a slightly analog feeling"
    },
    "pure-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Pure Black — High-contrast text, icon fills, button borders at max contrast"
    },
    "pure-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Pure White — Card backgrounds, overlay surfaces, inverted button text"
    },
    "warm-cream": {
      "$value": "#f5f5eb",
      "$type": "color",
      "$description": "Warm Cream — Page hero background, section fills — the warm off-white that makes Electric Lime feel naturalistic rather than neon"
    },
    "parchment-card": {
      "$value": "#fafaf5",
