      "$description": "Stone — Borders, disabled states, circular icon-only buttons in inactive state"
    },
    "graphite": {
      "$value": "#6e6e64",
      "$type": "color",
      "$description": "Graphite — Body text, supporting labels, card subtext — warm mid-gray that keeps warmth consistent across the achromatic scale"
    },
    "charcoal": {
      "$value": "#30302a",
      "$type": "color",
      "$description": "Charcoal — Dark surface card backgrounds, secondary dark mode elements"
    },
    "slate-border": {
      "$value": "#919183",
