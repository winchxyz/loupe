      "$type": "color",
      "$description": "Spectrum Gradient — The signature chromatic moment — ambient hero glow and decorative accent strip; this gradient IS the brand color, appearing where a logo mark would in other systems; Gradient stop — the red accent, available as --red token for error or emphasis states"
    },
    "rose-quartz": {
