  },
  "font": {
    "neuemontreal": {
      "$value": "NeueMontreal",
      "$type": "fontFamily",
      "$description": "Single typeface powers the entire system. Weight 300 at 56–115px for hero display creates whispered authority — an anti-convention choice that earns scale through restraint rather than volume. Weight 400 handles body, 500 for subheadings, 700 reserved for micro-labels and nav. Line-height collapses to 0.94 at 115px display, opening to 1.5–1.7 at body sizes."
    }
  },
