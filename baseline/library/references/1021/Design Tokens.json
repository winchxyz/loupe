{
  "color": {
    "espresso": {
      "$value": "#522c25",
      "$type": "color",
      "$description": "Espresso — Primary text, icons, card borders, nav, footer, input fields — the structural dark that holds every screen together, warm rather than black to stay on-brand with roasted coffee"
    },
    "burnt-orange": {
      "$value": "#c03001",
      "$type": "color",
      "$description": "Burnt Orange — Filled action buttons, active links, key highlights, badge fills — the single vivid accent that makes interactive elements feel switched on against the cream canvas"
    },
    "amber-ink": {
      "$value": "#c46500",
      "$type": "color",
      "$description": "Amber Ink — Secondary accent for emphasized text, hover states, and warm callouts — a slightly darker orange that pairs with Burnt Orange for tonal depth"
    },
    "marigold-wash": {
      "$value": "#febf6f",
      "$type": "color",
      "$description": "Marigold Wash — Soft highlight backgrounds, tag fills, and decorative washes — used sparingly to add warm sunlight moments inside otherwise neutral layouts"
    },
    "dusty-blue": {
      "$value": "#89b4ca",
      "$type": "color",
      "$description": "Dusty Blue — Cool counter-accent for secondary buttons, link backgrounds, and color variety — the only blue in the system, it reads as a quiet companion to the warm palette"
    },
    "cream-paper": {
      "$value": "#fff9f2",
      "$type": "color",
      "$description": "Cream Paper — Page canvas, card surfaces, button fills, input backgrounds — the base layer of every screen, warm off-white that replaces pure white"
    },
    "linen-beige": {
      "$value": "#f6ede3",
      "$type": "color",
      "$description": "Linen Beige — Card backgrounds, section surfaces, image borders, body borders — one step deeper than canvas, creates gentle layered surfaces without elevation"
    },
    "taupe-hairline": {
      "$value": "#e6dad4",
      "$type": "color",
      "$description": "Taupe Hairline — Hairline dividers, card borders, nav separators, subtle structural lines — the only border color most components need"
    },
    "sandstone": {
      "$value": "#cbbbb4",
      "$type": "color",
      "$description": "Sandstone — Muted card backgrounds, soft surface fills, disabled surface states — a warm gray-taupe for low-emphasis panels"
    },
    "coffee-dust": {
      "$value": "#977e77",
      "$type": "color",
      "$description": "Coffee Dust — Muted body text, helper text, low-emphasis copy — warm brown-gray that fades into the cream without disappearing"
    }
  },
  "font": {
    "little-amps": {
      "$value": "Little Amps",
      "$type": "fontFamily",
      "$description": "Custom display serif for brand wordmark, section headlines, and large editorial titles. Heavy negative tracking (-0.10em) at 41–51px creates a tight, chunky retro-poster feel. The heaviest typographic element on every page and the signature voice of the brand."
    },
    "inclusive-sans": {
      "$value": "Inclusive Sans",
      "$type": "fontFamily",
      "$description": "Primary body and UI text. Used for descriptions, paragraphs, and most readable content. Consistent 0.05em positive tracking gives a slightly looser, zine-like feel. The workhorse — appears in nearly every context."
    },
    "necto-mono": {
      "$value": "Necto Mono",
      "$type": "fontFamily",
      "$description": "Labels, buttons, navigation, dates, prices, and all structural metadata. Tighter line-heights (0.80–1.20) and monospaced forms make it feel like stamped or typewriter-set type. 0.05em tracking is the system-wide small-caps standard."
    },
    "roboto-mono": {
      "$value": "Roboto Mono",
      "$type": "fontFamily",
      "$description": "Secondary monospaced text for code-like or technical labels, supplementing Necto Mono in body and data contexts."
    },
    "gtstandard-m": {
      "$value": "GTStandard-M",
      "$type": "fontFamily",
      "$description": "Rare body fallback — appears in minimal contexts."
    }
  },
