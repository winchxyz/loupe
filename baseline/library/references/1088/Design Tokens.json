{
  "color": {
    "ember-gradient": {
      "$value": "#f42919",
      "$type": "color",
      "$description": "Ember Gradient — Brand mark, Poly logo, the sole chromatic accent — warm orange fading to signal red, used only on identity, never on body UI"
    },
    "porcelain": {
      "$value": "#f4f4f4",
      "$type": "color",
      "$description": "Porcelain — Page canvas, card surfaces, inverted text on dark photo backgrounds"
    },
    "onyx": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Onyx — Dark borders and separators for elevated surfaces and inverted UI. Do not promote it to the primary CTA color"
    },
    "graphite": {
      "$value": "#292930",
      "$type": "color",
      "$description": "Graphite — Secondary text, hairline borders, icon fills, the slight warmth that keeps near-black from feeling clinical"
    },
    "ash": {
      "$value": "#cccccc",
      "$type": "color",
      "$description": "Ash — Shadow tone used in the soft-etched link treatment, muted dividers"
    }
  },
  "font": {
    "haffer-variable": {
      "$value": "Haffer Variable",
      "$type": "fontFamily",
      "$description": "Primary display serif for headlines at 30–53px. Weight 450 is anti-convention — most product sites push display to 600–700, but Haffer at 450 keeps headlines warm and editorial rather than commanding. Activating liga and ss04 unlocks the alternative g and stylised letterforms that give the wordmark its personality."
    },
    "bogue": {
      "$value": "Bogue",
      "$type": "fontFamily",
      "$description": "Companion serif at regular weight, used for badge labels and secondary serif moments where Haffer 450 would feel too heavy. Tighter tracking at -0.03em distinguishes it from Haffer."
    },
    "haffer": {
      "$value": "Haffer",
      "$type": "fontFamily",
      "$description": "Static fallback for small serif text — 15px badges, 24px sub-serial moments"
    },
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "All UI, body, nav, button labels, helper text. Inter at 400 handles body, 600 carries subheadings and button text. The -0.02em tracking matches the serif family, keeping the type system visually unified."
    }
  },
