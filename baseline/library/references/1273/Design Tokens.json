{
  "color": {
    "electric-violet": {
      "$value": "#1009f6",
      "$type": "color",
      "$description": "Electric Violet — Primary brand color — hero backgrounds, geometric panels, primary action buttons, active nav — vivid blue-violet that reads as both trustworthy and unconventional against the warm cream canvas"
    },
    "solar-yellow": {
      "$value": "#ffba09",
      "$type": "color",
      "$description": "Solar Yellow — Yellow action color for filled buttons, selected navigation states, and focused conversion moments."
    },
    "ink-black": {
      "$value": "#1a1a1a",
      "$type": "color",
      "$description": "Ink Black — Primary text, icon strokes, dark buttons, default borders — near-black with a whisper of warmth to harmonize with the cream surface"
    },
    "pure-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Pure White — Card surfaces, input fills, button text on dark fills — the elevated layer floating above the cream base"
    },
    "linen-cream": {
      "$value": "#f0f0ec",
      "$type": "color",
