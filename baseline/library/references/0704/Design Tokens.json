{
  "color": {
    "forest-ink": {
      "$value": "#122315",
      "$type": "color",
      "$description": "Forest Ink — Hero canvas, primary heading text, nav bar surface, footer — the dominant dark that anchors every green-on-green moment"
    },
    "meadow": {
      "$value": "#55dd4a",
      "$type": "color",
      "$description": "Meadow — Primary action fill (GET FUNDING), accent headline words, tag fills — one switch-on green against both dark and cream surfaces"
    },
    "sage-border": {
      "$value": "#566053",
      "$type": "color",
      "$description": "Sage Border — Muted green-gray for secondary borders, dividers on cream, subhead accents — lets Meadow read as the only chromatic action"
    },
    "lichen": {
      "$value": "#77e46e",
      "$type": "color",
      "$description": "Lichen — Outlined/ghost action border, hover-state ring — a softer Meadow for non-filled interactive states"
    },
    "paper-cream": {
      "$value": "#f3ede4",
      "$type": "color",
      "$description": "Paper Cream — Main content canvas after the hero, card surface on dark hero, ghost-button fill — warm off-white that replaces typical SaaS white"
    },
    "charcoal": {
      "$value": "#333333",
      "$type": "color",
      "$description": "Charcoal — Body text on cream, hairline borders, image overlays — the workhorse neutral that keeps #122315 reserved for display moments"
    },
    "slate": {
      "$value": "#141414",
      "$type": "color",
      "$description": "Slate — Icon strokes, near-black text, very dark UI fills when Forest Ink would be too green"
    },
    "frost": {
      "$value": "#e5e7eb",
      "$type": "color",
      "$description": "Frost — Subtle dividers on cream, secondary card edges — quieter than Sage Border"
    },
    "moss-gray": {
      "$value": "#999c91",
      "$type": "color",
      "$description": "Moss Gray — Helper text, metadata, low-emphasis captions on cream"
    },
    "driftwood": {
      "$value": "#626d66",
      "$type": "color",
      "$description": "Driftwood — Dark borders and separators for elevated surfaces and inverted UI. Do not promote it to the primary CTA color"
    },
    "river-blue": {
      "$value": "#73d3eb",
      "$type": "color",
      "$description": "River Blue — Illustration accent for water and sky in the hero artwork and badge illustrations, small data-viz highlight"
    },
    "sun-yellow": {
      "$value": "#ffed52",
      "$type": "color",
      "$description": "Sun Yellow — Illustration accent for suns and warm callouts in the patch artwork, limited to decorative moments"
    },
    "deep-navy": {
      "$value": "#0a071b",
      "$type": "color",
      "$description": "Deep Navy — Illustration dark fills, badge backgrounds where Forest Ink would blend with the canvas"
    }
  },
  "font": {
    "deacon": {
      "$value": "Deacon",
      "$type": "fontFamily",
      "$description": "Display and headline family. The signature choice: an ultra-condensed sans scaled from 58px subheads up to 259px hero lines, with line-height compressed to 0.8 so two-line headlines read as a single block. Weight 900 for hero and section openers, 700 for mid-page headings, 400 for badge labels and small caps callouts. This is the only voice allowed to be loud."
    },
    "graphik": {
      "$value": "Graphik",
      "$type": "fontFamily",
      "$description": "Body, UI, and small-text family. Weight 400 for paragraphs, captions, and nav; weight 500 for button labels, tag text, and emphasized subheads. The geometric humanist sans provides the quiet counterweight to Deacon's shouting display — every sentence is calm, every headline is compressed. Use at -0.4px tracking at 24px and above."
    },
    "arial": {
      "$value": "Arial",
      "$type": "fontFamily",
      "$description": "System fallback and chart/dashboard data labels where a neutral numeric voice is needed; 40px reserved for stat readouts in the dashboard preview"
    }
  },
