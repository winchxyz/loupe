{
  "color": {
    "cream-paper": {
      "$value": "#f4efea",
      "$type": "color",
      "$description": "Cream Paper — Page canvas and section backgrounds — the entire site sits on this warm off-white like a notebook page"
    },
    "frost-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Frost White — Card surfaces, nav bar, input fields, and overlay panels — clean white layered on the cream canvas"
    },
    "chalk-gray": {
      "$value": "#f8f8f7",
      "$type": "color",
      "$description": "Chalk Gray — Secondary surface for body backgrounds and subtle borders — barely-there differentiation from white"
    },
    "ice-wash": {
      "$value": "#ebf9ff",
      "$type": "color",
      "$description": "Ice Wash — Tinted blue-white for soft button hovers and highlight washes adjacent to the primary blue"
    },
    "notebook-pale": {
      "$value": "#f9fbe7",
      "$type": "color",
      "$description": "Notebook Pale — Faint yellow-green tint used on selected/tagged surfaces for the play accent"
    },
    "charcoal-ink": {
      "$value": "#383838",
      "$type": "color",
      "$description": "Charcoal Ink — Primary text, all borders, icon strokes, and the offset shadow color — the universal line color, never pure black"
    },
