{
  "color": {
    "carbon-black": {
      "$value": "#2a2a2a",
      "$type": "color",
      "$description": "Carbon Black — Primary text, nav links, body copy, badge text, footer copy — the near-black that carries every word on the site"
    },
    "bone": {
      "$value": "#f0f0f0",
      "$type": "color",
      "$description": "Bone — Page canvas and primary surface — the warm off-white that fills every section background"
    },
    "ink": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Ink — Maximum-contrast text and hard borders, reserved for the strongest emphasis moments"
    },
    "linen": {
      "$value": "#fafafa",
      "$type": "color",
      "$description": "Linen — Subtle elevated surface and section dividers — one step lighter than the canvas for soft separation"
    },
    "ash": {
      "$value": "#d6d6d6",
      "$type": "color",
      "$description": "Ash — Muted fills, hairline borders, and disabled/inactive surface treatments"
    },
    "parchment": {
      "$value": "#f0edea",
      "$type": "color",
      "$description": "Parchment — Alternate warm section background — introduces a barely-perceptible cream tint to break the neutral flow"
    },
    "stone": {
      "$value": "#bcbcb4",
      "$type": "color",
      "$description": "Stone — Deepest mid-gray — used for low-emphasis supporting text and the dimmest UI separators"
    },
    "clay": {
      "$value": "#ccc4b9",
      "$type": "color",
      "$description": "Clay — Warm mid-gray for transitional surfaces between bone and parchment"
    }
  },
  "font": {
    "founders-grotesk": {
      "$value": "Founders Grotesk",
      "$type": "fontFamily",
      "$description": "Sole brand typeface. Weight 300 at 70–101px for the monumental editorial hero and section titles; weight 400 at 12–22px for body, nav, meta labels, and case study descriptions. The extreme weight contrast (300 vs 400) and the 5× size jump from body to display are the core typographic moves — no other type system in the palette."
    },
    "editorial-neue": {
      "$value": "Editorial Neue",
      "$type": "fontFamily",
      "$description": "Secondary editorial serif used sparingly as an accent counterpoint to Founders Grotesk — appears in specific body or pull-text moments to break the grotesque monotony with a classical note. Tight -0.0600em tracking and 0.90 line-height match the display discipline."
    }
  },
