{
  "color": {
    "onyx": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Onyx — Primary text, icons, dark hero backgrounds, footer — the dominant ink color across all UI"
    },
    "paper": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper — Card surfaces, nav bar, product detail panels, input fields — the lightest surface in the stack"
    },
    "fog": {
      "$value": "#ededed",
      "$type": "color",
      "$description": "Fog — Page canvas behind card grids and product sections — slightly cool, lower than pure white so product imagery pops"
    },
    "slate": {
      "$value": "#6c7073",
      "$type": "color",
      "$description": "Slate — Muted helper text, disabled states, secondary button borders, input placeholder"
    },
    "graphite": {
      "$value": "#595959",
      "$type": "color",
      "$description": "Graphite — Body copy, secondary nav text, descriptions — the workhorse text gray that sits between headlines and helper text"
    },
    "iron": {
      "$value": "#303233",
      "$type": "color",
      "$description": "Iron — Primary nav item text, section headings on light backgrounds — darker than body to anchor hierarchy"
    },
    "ash": {
      "$value": "#8c8c8c",
      "$type": "color",
      "$description": "Ash — Tertiary captions, meta text, fine print"
    },
    "carbon": {
      "$value": "#272727",
      "$type": "color",
      "$description": "Carbon — Footer background, dark panels — deep neutral for terminal/closing sections"
    },
    "signal-blue": {
      "$value": "#0070d5",
      "$type": "color",
      "$description": "Signal Blue — Blue supporting accent for decorative details and low-frequency emphasis."
    },
    "indigo-steel": {
      "$value": "#3b63a9",
      "$type": "color",
      "$description": "Indigo Steel — Secondary link state, hover or visited variant of Signal Blue — a muted counterpart that reads as the same brand without competing for attention"
    }
  },
