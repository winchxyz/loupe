{
  "color": {
    "graphite": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Graphite — Primary text, filled action buttons, and dominant borders — near-black provides maximum contrast against the warm cream canvas"
    },
    "cream": {
      "$value": "#f7f4f2",
      "$type": "color",
      "$description": "Cream — Page canvas and soft surface washes — the warm off-white foundation of every section"
    },
    "paper-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper White — Card surfaces, button text, and inverted text on black — the cleanest layer above cream"
    },
    "lavender-mist": {
      "$value": "#eeeafa",
      "$type": "color",
      "$description": "Lavender Mist — Shadow tint and near-white lavender surface — appears as the soft drop-shadow color (rgba 0.3) that makes cards feel like they hover"
    },
    "ash": {
      "$value": "#cdcbd0",
      "$type": "color",
      "$description": "Ash — Hairline borders, link underlines, and light dividers"
    },
    "slate": {
      "$value": "#4d4c51",
      "$type": "color",
      "$description": "Slate — Dark borders and separators for elevated surfaces and inverted UI. Do not promote it to the primary CTA color"
    },
    "fog": {
      "$value": "#767481",
      "$type": "color",
      "$description": "Fog — Body text secondary level and subdued border color"
    },
    "mist": {
      "$value": "#9a98a1",
      "$type": "color",
      "$description": "Mist — Nav inactive text and lightest nav border"
    },
    "wisteria": {
      "$value": "#d8d1ff",
      "$type": "color",
      "$description": "Wisteria — Primary lavender card surfaces, badge backgrounds, and brand-accent fills — the soft purple room tone"
    },
    "periwinkle": {
      "$value": "#b7b2ff",
      "$type": "color",
      "$description": "Periwinkle — Mid-violet badge fills and icon highlights — deeper brand accent used sparingly inside lavender contexts"
    },
    "lime-voltage": {
      "$value": "#d2e534",
      "$type": "color",
      "$description": "Lime Voltage — High-energy accent card surface and highlight badge — the vivid chartreuse that creates urgency and visual stop"
    },
    "sky-signal": {
      "$value": "#89cdf3",
      "$type": "color",
      "$description": "Sky Signal — Info badge background and location-tag accent — cool blue for map/location context"
    }
  },
