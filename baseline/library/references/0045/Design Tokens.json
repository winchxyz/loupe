{
  "color": {
    "hims-violet": {
      "$value": "#5d48db",
      "$type": "color",
      "$description": "Hims Violet — Headline text, display borders, brand accent — the single chromatic voice in an otherwise monochrome system"
    },
    "carbon-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Carbon Black — Primary text, hairline borders, icon fills, nav dividers — the structural ink of the interface"
    },
    "paper-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper White — Page canvas, card surfaces, nav background, image backgrounds — the base surface at every elevation level"
    },
    "vellum-gray": {
      "$value": "#f0f0f0",
      "$type": "color",
      "$description": "Vellum Gray — List dividers, subtle row separators, muted list text — the quietest structural neutral"
    },
    "graphite": {
      "$value": "#2e2e2e",
      "$type": "color",
      "$description": "Graphite — Secondary heading text, heading borders — slightly softer than pure black for non-display headings"
    },
    "linen": {
      "$value": "#e0e0e0",
      "$type": "color",
      "$description": "Linen — Hairline borders, list separators, thin structural strokes"
    },
    "stone": {
      "$value": "#8f8f8f",
      "$type": "color",
      "$description": "Stone — Muted body copy, subdued links, secondary metadata text"
    },
    "soft-mint": {
      "$value": "#3fd194",
      "$type": "color",
      "$description": "Soft Mint — Decorative product accent — appears inside app screenshot tiles (e.g. Acne Program card), not a UI token"
    },
    "iris": {
      "$value": "#9685ff",
      "$type": "color",
      "$description": "Iris — Decorative product accent — appears in product gradient washes inside phone mockup content"
    }
  },
  "font": {
    "sofia": {
      "$value": "sofia",
      "$type": "fontFamily",
      "$description": "Sofia is the sole typeface. Its geometric, low-contrast letterforms carry everything from 14px nav labels to 280px display heroes. Weight 400 is the default at all sizes; weight 500 is reserved for emphasis. The extreme size range (14→280px) with consistent tight tracking (-0.012em to -0.057em) creates a system that scales smoothly from caption to billboard. Signature choice: the ultra-tight tracking even at body sizes (-0.012em at 14px) gives body text a compressed, editorial density unusual for a consumer health app."
    }
  },
