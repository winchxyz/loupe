  "font": {
    "clashgrotesk": {
      "$value": "Clashgrotesk",
      "$type": "fontFamily",
      "$description": "Display and heading font — used for all headings, navigation, buttons, and links. The geometric, angular character of Clashgrotesk gives the interface an engineering/infrastructure feel; medium weight (500) carries most headings while 600 anchors the largest display sizes. Tight tracking at 0.033em tightens the geometric forms into a confident block."
    },
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "Body and hero paragraph text — used for descriptive copy, card body content, footer text. Inter's neutral clarity provides a calm counterpoint to Clashgrotesk's angular voice; 400 for body, 600 for emphasis within body contexts."
    },
    "dm-mono": {
      "$value": "DM Mono",
      "$type": "fontFamily",
      "$description": "Monospaced technical labels, metadata, category tags, badge text, and inline code-like elements — stamps a developer/infrastructure credibility onto the interface. Used in nav badges, card category headers, and small status indicators."
    },
    "f77-minecraft": {
      "$value": "F77 Minecraft",
      "$type": "fontFamily",
      "$description": "F77 Minecraft — detected in extracted data but not described by AI"
    }
  },
