{
  "color": {
    "ink-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Ink Black — Primary text, nav links, icons, body copy — near-absolute dominance means the system runs on contrast, not on color"
    },
    "paper-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper White — Page background and card surfaces; the default canvas everything sits on"
    },
    "mist-gray": {
      "$value": "#f4f4f4",
      "$type": "color",
      "$description": "Mist Gray — Soft surface for secondary cards and section bands; lifts content off the white canvas without introducing a new hue"
    },
    "pale-blush": {
      "$value": "#f8dbd5",
      "$type": "color",
      "$description": "Pale Blush — Warm section background (hero, accent bands) — the signature warmth of the brand, not a tint of any other color"
    },
    "faded-lilac": {
      "$value": "#cccccc",
      "$type": "color",
      "$description": "Faded Lilac — Disabled or muted control surface — barely visible, intentionally recessive"
    },
    "iris-violet": {
      "$value": "#2b189b",
      "$type": "color",
      "$description": "Iris Violet — Violet supporting accent for decorative details and low-frequency emphasis. Do not promote it to the primary CTA color"
    },
    "indigo-depth": {
      "$value": "#211375",
      "$type": "color",
      "$description": "Indigo Depth — Hover and pressed state of the Iris Violet button; deeper shift of the same hue for state feedback"
    },
    "forest-teal": {
      "$value": "#006654",
      "$type": "color",
      "$description": "Forest Teal — Teal supporting accent for decorative details and low-frequency emphasis. Do not promote it to the primary CTA color"
    }
  },
  "font": {
    "sans-serif": {
      "$value": "sans-serif",
      "$type": "fontFamily",
      "$description": "sans-serif — detected in extracted data but not described by AI"
    },
    "whereby-roslindale-display-condensed": {
      "$value": "Whereby Roslindale Display Condensed",
      "$type": "fontFamily",
      "$description": "Display headlines (hero, section titles). Custom condensed serif used at 80–120px is a signature choice — most SaaS brands default to sans-serif display; this serif elevates copy to editorial weight"
    },
    "whereby-roslindale-text": {
      "$value": "Whereby Roslindale Text",
      "$type": "fontFamily",
      "$description": "Card titles and mid-size headings; same family as display but in a text cut with more comfortable proportions for shorter lines"
    },
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "Body copy, navigation, button labels, tags. Weight 500 for nav and labels, 600 for emphasized UI text. Negative tracking tightens Inter at 18px to match the editorial density of the serif"
    },
    "system-sans": {
      "$value": "System Sans",
      "$type": "fontFamily",
      "$description": "Fallback rendering layer; not used in primary composition but extracted as the underlying stack"
    },
