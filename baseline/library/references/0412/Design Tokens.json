{
  "color": {
    "indigo-ink": {
      "$value": "#151581",
      "$type": "color",
      "$description": "Indigo Ink — Primary headlines, body emphasis, and brand voice — this is the only color that carries the brand identity. All top-level headings and primary body text are set in this violet rather than black, giving every screen a tinted authority without ever feeling decorative"
    },
    "electric-violet": {
      "$value": "#5465ff",
      "$type": "color",
      "$description": "Electric Violet — Violet supporting accent for decorative details and low-frequency emphasis. Do not promote it to the primary CTA color; Voice-bar and scan-overlay gradient sweeping Electric Violet → Lilac → Petal Blush — the signature visual of the AI interaction moment"
    },
    "lavender-mist": {
      "$value": "#a1a1cd",
      "$type": "color",
      "$description": "Lavender Mist — Secondary body text, muted links, and sub-labels — sits one step down from Indigo Ink on the same hue, creating a tonal ladder without introducing a different color family"
    },
    "lilac-accent": {
      "$value": "#9f73e6",
      "$type": "color",
      "$description": "Lilac Accent — Decorative and illustrative accent — used in iconography, gradient midpoints, and the scan/voice visual treatment rather than for UI controls"
    },
    "petal-blush": {
      "$value": "#de62de",
      "$type": "color",
      "$description": "Petal Blush — Decorative accent in illustrations and the brand gradient — supports the scan/face-overlay visual treatment, not part of the UI palette"
    },
    "verified-green": {
      "$value": "#00bb76",
      "$type": "color",
      "$description": "Verified Green — Green supporting accent for decorative details and low-frequency emphasis. Use as a supporting accent, not as a status color"
    },
    "alert-rose": {
      "$value": "#f25c75",
      "$type": "color",
      "$description": "Alert Rose — Red supporting accent for decorative details and low-frequency emphasis. Use as a supporting accent, not as a status color"
    },
    "info-blue": {
      "$value": "#20a2e3",
      "$type": "color",
      "$description": "Info Blue — Blue supporting accent for decorative details and low-frequency emphasis. Use as a supporting accent, not as a status color"
    },
    "porcelain": {
      "$value": "#f6f6fa",
      "$type": "color",
      "$description": "Porcelain — Dominant page canvas — every section breathes on this near-white, slightly cool surface"
    },
    "paper-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper White — Card surfaces, phone mockup screen, and elevated content blocks — sits one step above Porcelain for subtle layering"
    },
    "bone": {
      "$value": "#f6f5f4",
      "$type": "color",
      "$description": "Bone — Warm surface for review cards and section blocks that need tonal separation from the cool Porcelain canvas"
    },
    "fog": {
      "$value": "#d6d6d6",
      "$type": "color",
      "$description": "Fog — Hairline borders, divider lines, and the ambient shadow tint source — the only structural gray in the system"
    },
    "pebble": {
      "$value": "#bfbfbd",
      "$type": "color",
      "$description": "Pebble — Inactive controls, placeholder fills, and tertiary borders — warm gray that recedes"
    },
    "graphite": {
      "$value": "#292824",
      "$type": "color",
      "$description": "Graphite — Dark mode text and icon fills — near-black with a faint warm cast, used when maximum contrast is needed against light surfaces"
    },
    "ash": {
      "$value": "#949392",
      "$type": "color",
      "$description": "Ash — Secondary metadata, timestamps, and de-emphasized body text — sits between Graphite and Pebble in the neutral scale"
    }
  },
  "font": {
    "sans-serif": {
      "$value": "sans-serif",
      "$type": "fontFamily",
      "$description": "sans-serif — detected in extracted data but not described by AI"
    },
    "es-rebond-grotesque": {
      "$value": "ES Rebond Grotesque",
      "$type": "fontFamily",
      "$description": "Display and heading face — used at 28–48px weight 400 for hero headlines, section titles, and brand statements. The geometric construction and uniform weight (no bold) create an anti-convention restraint: authority through proportions, not stroke thickness. The 'ss02' feature setting activates a specific alternate glyph set that gives the headlines their slightly architectural feel. Substitute: Inter Tight or Manrope as a free alternative, though the exact geometric warmth will differ."
    },
    "es-rebond-grotesque-medium": {
      "$value": "ES Rebond Grotesque Medium",
      "$type": "fontFamily",
      "$description": "Sub-heading and emphasis face — used for 14–22px text that needs a touch more presence than Inter body, like card titles and emphasized inline text within body copy."
    },
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "Primary body and UI face — covers all functional text from 9px metadata to 24px subheadings. Weight 400 for body, 500 for labels and emphasis, 600 for strong UI elements. Substitute: keep Inter — it's already free and ubiquitous."
    },
    "geist": {
      "$value": "Geist",
      "$type": "fontFamily",
      "$description": "Secondary body face for specific content blocks — used where a slightly different rhythm is desired. The 'dlig', 'ss01', 'ss02', 'ss06' features activate Geist's discretionary ligatures and alternate sets for a more refined reading experience. Substitute: Inter (close enough) or Geist Sans (free)."
    },
    "inter-medium": {
      "$value": "Inter-Medium",
      "$type": "fontFamily",
      "$description": "Inter-Medium — detected in extracted data but not described by AI"
    }
  },
