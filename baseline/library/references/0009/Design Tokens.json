  "font": {
    "twklausanne-250": {
      "$value": "TWKLausanne-250",
      "$type": "fontFamily",
      "$description": "Body, UI, and mid-tier headings — the workhorse family. 400 for paragraphs and descriptions, 700 for sub-headings and emphasized labels. The tight 1.13 line-height at 40px gives mid-headings a compressed, architectural feel"
    },
    "twklausanne-200": {
      "$value": "TWKLausanne-200",
      "$type": "fontFamily",
      "$description": "Display and hero headlines — the lightest cut of TWKLausanne acts as an anti-convention choice: most brands shout at 80px with bold weights, this one whispers at 400 and achieves presence through restraint and aggressive negative tracking"
    },
    "neosanspro-medium": {
      "$value": "NeoSansPro-Medium",
      "$type": "fontFamily",
      "$description": "Architectural all-caps labels — nav links, scroll cues, section markers, brand wordmark. The 2.0–3.0 line-height at 10px creates dramatic vertical breathing room, and the extreme +0.32em tracking turns tiny text into spatial markers rather than readable labels"
    },
    "arial": {
      "$value": "Arial",
      "$type": "fontFamily",
      "$description": "Arial — detected in extracted data but not described by AI"
    }
  },
