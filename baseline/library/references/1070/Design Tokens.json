{
  "color": {
    "void": {
      "$value": "#0b0c0e",
      "$type": "color",
      "$description": "Void — Deepest surface layer, page base under hero — the floor of the dark stack"
    },
    "abyss": {
      "$value": "#0e111b",
      "$type": "color",
      "$description": "Abyss — Primary page canvas and most card backgrounds; cool blue-black anchors the whole system"
    },
    "deep-sea": {
      "$value": "#0d172b",
      "$type": "color",
      "$description": "Deep Sea — Elevated card surface — sits one step above the canvas, used for feature and pricing cards"
    },
    "cobalt-panel": {
      "$value": "#12244f",
      "$type": "color",
      "$description": "Cobalt Panel — Highlighted card surface for feature spotlights; a violet-tinted lift that breaks the monochrome rhythm without becoming decorative"
    },
    "frosted-lilac": {
      "$value": "#85a6e9",
      "$type": "color",
      "$description": "Frosted Lilac — Violet wash for highlight backgrounds, decorative bands, and soft emphasis behind content. Do not promote it to the primary CTA color"
    },
    "signal-blue": {
      "$value": "#2862d7",
      "$type": "color",
      "$description": "Signal Blue — Vivid blue link and accent text — the sharp chromatic punctuation against all the dark navy"
    },
    "pulse-violet": {
      "$value": "#305fbd",
      "$type": "color",
      "$description": "Pulse Violet — Mid-saturation violet-blue used in code-syntax blocks and gradient stops"
    },
    "aurora-purple": {
      "$value": "#625fff",
      "$type": "color",
      "$description": "Aurora Purple — Supporting palette color for small decorative accents when the core palette needs contrast. Do not promote it to the primary CTA color"
    },
    "plasma-pink": {
      "$value": "#ff7dda",
      "$type": "color",
      "$description": "Plasma Pink — Secondary hero glow bleeding from bottom-right — warm counterpoint to the aurora purple"
    },
    "quartz": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Quartz — Primary text and primary CTA fill — high-contrast white against the dark canvas"
    },
    "ash": {
      "$value": "#abaebb",
      "$type": "color",
      "$description": "Ash — Secondary text and subtle hairline borders — the most-used neutral after white"
    },
    "mist": {
      "$value": "#c7c9d1",
      "$type": "color",
      "$description": "Mist — Tertiary text, muted descriptions, helper copy"
    },
    "slate": {
      "$value": "#3c3f44",
      "$type": "color",
      "$description": "Slate — Muted borders and disabled state outlines"
    },
    "obsidian-edge": {
      "$value": "#172540",
      "$type": "color",
      "$description": "Obsidian Edge — Primary border color on cards and buttons — defines component outlines against the dark canvas"
    },
    "inkline": {
      "$value": "#151e32",
      "$type": "color",
      "$description": "Inkline — Subtle card borders, slightly lighter than Obsidian Edge for inner nesting"
    },
    "sapphire-hairline": {
      "$value": "#24375a",
      "$type": "color",
      "$description": "Sapphire Hairline — Lighter violet-tinted border for dividers and section separators"
    }
  },
  "font": {
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "Workhorse UI font — body copy, nav, buttons, labels, and subheadings. Weight 300 is the secret weapon: low-weight body text against a dark canvas reads as precision, not weakness."
    },
    "ibm-plex-mono": {
      "$value": "IBM Plex Mono",
      "$type": "fontFamily",
      "$description": "Code blocks and inline code only — reinforces the developer-tool identity. Sits at 13px with normal tracking."
    },
    "figtree": {
      "$value": "Figtree",
      "$type": "fontFamily",
      "$description": "Display and heading font — geometric, slightly rounded sans used at 32–64px with -0.02em tracking. The rounded counters and tall x-height distinguish it from Inter's functional neutrality, giving headlines a warm confidence."
    }
  },
