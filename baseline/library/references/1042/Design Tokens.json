{
  "color": {
    "bone-canvas": {
      "$value": "#fefcf8",
      "$type": "color",
      "$description": "Bone Canvas — Primary page background — warm off-white, the entire site sits on this paper-like canvas rather than pure white"
    },
    "press-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Press White — Alternate surface for product cards, input fields, and crisp overlays that need to separate from Bone Canvas"
    },
    "onyx-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Onyx Black — Primary text, hairline rules, filled action buttons, icon strokes, and nav borders. The structural ink of the system"
    },
    "graphite": {
      "$value": "#403f3e",
      "$type": "color",
      "$description": "Graphite — Secondary text and icon color — a softened black for less critical copy and outline button borders"
    },
    "carbon": {
      "$value": "#121212",
      "$type": "color",
      "$description": "Carbon — Deep alt-black for button borders, dark badges, and high-contrast text on white surfaces where pure black feels too harsh"
    },
    "iron": {
      "$value": "#1d1d1d",
      "$type": "color",
      "$description": "Iron — Button border accent — a near-black used for refined button outlines"
    },
    "slate": {
      "$value": "#2f2f2f",
      "$type": "color",
      "$description": "Slate — Badge and secondary text — sits between Graphite and Carbon for mid-emphasis labels"
    },
    "stone": {
      "$value": "#4c4c4a",
      "$type": "color",
      "$description": "Stone — Body text secondary and subtle borders — warm-leaning gray that pairs with the cream canvas without going cold"
    },
    "ash": {
      "$value": "#b2b0ae",
      "$type": "color",
      "$description": "Ash — Light neutral action fill for buttons on dark surfaces."
    }
  },
  "font": {
    "optima": {
      "$value": "Optima",
      "$type": "fontFamily",
      "$description": "Primary typeface across all UI — nav, buttons, body, headings. Optima's humanist flares and geometric curves carry the brand's editorial luxury; its narrow proportions let dense 5-column product grids breathe without feeling cramped. Nav and button text is uppercase at 11–12px with wide tracking (0.0640em); body sits at 14px, larger body/links at 16px, subheadings at 24px."
    },
    "arial": {
      "$value": "Arial",
      "$type": "fontFamily",
      "$description": "System fallback used sparingly for button and icon labels when Optima is unavailable — do not introduce as a primary face."
    },
    "gtstandard-m": {
      "$value": "GTStandard-M",
      "$type": "fontFamily",
      "$description": "GTStandard-M — detected in extracted data but not described by AI"
    }
  },
